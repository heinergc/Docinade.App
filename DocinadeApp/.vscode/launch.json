                "uriFormat": "%s"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Production",
                "ASPNETCORE_URLS": "https://localhost:5000;http://localhost:5001",
                "ConnectionStrings__ProductionConnection": "Server=localhost\\SQLEXPRESS;Database=RubricasDb;User Id=sa;Password=LKSA2014.01.05.14;TrustServerCertificate=true;MultipleActiveResultSets=true;"
            },
            "sourceFileMap": {

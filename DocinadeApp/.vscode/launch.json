{
    "version": "0.2.0",
    "configurations": [
        {
            "name": ".NET Core Launch (web) - Development",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "Build ASP.NET Core Project",
            "program": "${workspaceFolder}/bin/Debug/net8.0/DocinadeApp.dll",
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
                "uriFormat": "%s"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "https://localhost:18163;http://localhost:18164"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}/Views"
            },
            "logging": {
                "moduleLoad": false
            }
        },
        {
            "name": ".NET Core Launch (web) - Production Local",
            "type": "coreclr",

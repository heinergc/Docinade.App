<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet" arguments=".\DocinadeApp.dll" stdoutLogEnabled="true" stdoutLogFile=".\logs\stdout" hostingModel="inprocess">
        <environmentVariables>
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
        </environmentVariables>
      </aspNetCore>
      <httpErrors errorMode="Detailed" />
      
      <!-- Configuración para servir archivos estáticos desde wwwroot -->
      <staticContent>
        <mimeMap fileExtension=".webp" mimeType="image/webp" />
      </staticContent>
      
      <!-- Habilitar DirectoryBrowse solo para debugging (eliminar en producción) -->
      <directoryBrowse enabled="false" />
    </system.webServer>
  </location>
  
  <!-- Permitir acceso a la carpeta uploads -->
  <location path="uploads">
    <system.webServer>
      <handlers>
        <clear />
        <add name="StaticFile" path="*" verb="*" modules="StaticFileModule,DefaultDocumentModule,DirectoryListingModule" resourceType="Either" requireAccess="Read" />
      </handlers>
    </system.webServer>
  </location>
  
  <appSettings>
    <add key="ASPNETCORE_ENVIRONMENT" value="Development" />
  </appSettings>
</configuration>
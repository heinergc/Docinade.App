@model RubricasApp.Web.Models.Rubrica

@{
    ViewData["Title"] = "Nueva Rúbrica";
}

@* Token CSRF para peticiones AJAX *@
@Html.AntiForgeryToken()

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-success text-white">
                <h4 class="mb-0">
                    <i class="fas fa-plus"></i> Nueva Rúbrica
                </h4>
            </div>
            <div class="card-body">
                <form asp-controller="Rubricas" asp-action="Create" method="post" id="rubricaForm">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    
                    <div class="mb-3">
                        <label asp-for="NombreRubrica" class="form-label"></label>
                        <input asp-for="NombreRubrica" class="form-control" />
                        <span asp-validation-for="NombreRubrica" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Descripcion" class="form-label"></label>
                        <textarea asp-for="Descripcion" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Descripcion" class="text-danger"></span>
                    </div>

                    <!-- Sección de Gestión de Grupos de Calificación -->
                    <div class="card mb-3 border-info">
                        <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                            <h6 class="mb-0">
                                <i class="fas fa-layer-group"></i> Gestión de Grupos de Calificación
                            </h6>
                            <button type="button" class="btn btn-sm btn-light" data-bs-toggle="modal" data-bs-target="#modalCrearGrupoRapido">
                                <i class="fas fa-plus-circle"></i> Crear Nuevo Grupo
                            </button>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-6">
                                    <h6 class="text-info">
                                        <i class="fas fa-folder-open"></i> Asignar Grupo Existente
                                    </h6>
                                    <div class="form-group mb-3">
                                        <label for="grupoExistente">Seleccionar Grupo:</label>
                                        <div class="input-group">
                                            <select id="grupoExistente" class="form-control">
                                                <option value="">-- Seleccionar Grupo --</option>
                                                @if (ViewBag.GruposDisponibles != null)
                                                {
                                                    @foreach (var grupo in ViewBag.GruposDisponibles)
                                                    {
                                                        <option value="@grupo.IdGrupo" data-niveles="@grupo.CantidadNiveles">
                                                            @grupo.NombreGrupo (@grupo.CantidadNiveles niveles)
                                                        </option>
                                                    }
                                                }
                                            </select>
                                            <a href="@Url.Action("Index", "GruposCalificacion")" class="btn btn-outline-secondary" target="_blank" title="Administrar grupos">
                                                <i class="fas fa-cog"></i>
                                            </a>
                                        </div>
                                    </div>
                                    <button type="button" class="btn btn-info" onclick="seleccionarGrupoExistente()">
                                        <i class="fas fa-link"></i> Seleccionar Grupo
                                    </button>
                                </div>
                                <div class="col-md-6">
                                    <h6 class="text-primary">Crear Grupo Dinámico</h6>
                                    <div class="form-group mb-3">
                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                            <label>Seleccionar Niveles para el Grupo:</label>
                                            <button type="button" class="btn btn-sm btn-outline-secondary" onclick="toggleTodosNiveles()">
                                                <i class="fas fa-check-double"></i> Alternar Todos
                                            </button>
                                        </div>
                                        <div class="niveles-checkbox-container" style="max-height: 200px; overflow-y: auto; border: 1px solid #ddd; padding: 10px; border-radius: 4px;">
                                            @if (ViewBag.NivelesDisponibles != null)
                                            {
                                                @foreach (var nivel in ViewBag.NivelesDisponibles)
                                                {
                                                    <div class="form-check">
                                                        <input class="form-check-input nivel-checkbox" type="checkbox" value="@nivel.IdNivel" id="nivel_@nivel.IdNivel">
                                                        <label class="form-check-label" for="nivel_@nivel.IdNivel">
                                                            @nivel.NombreNivel
                                                            @if (!string.IsNullOrEmpty(nivel.Descripcion))
                                                            {
                                                                <small class="text-muted">- @nivel.Descripcion</small>
                                                            }
                                                        </label>
                                                    </div>
                                                }
                                            }
                                        </div>
                                    </div>
                                    <button type="button" class="btn btn-primary" onclick="prepararGrupoDinamico()">
                                        <i class="fas fa-plus"></i> Preparar Grupo Dinámico
                                    </button>
                                </div>
                            </div>
                            
                            <!-- Información del grupo seleccionado -->
                            <div id="grupoSeleccionadoInfo" class="alert alert-success d-none mt-3">
                                <h6><i class="fas fa-check-circle"></i> Grupo Seleccionado</h6>
                                <div id="infoGrupoSeleccionado"></div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Estado" class="form-label"></label>
                        <select asp-for="Estado" class="form-select">
                            <option value="ACTIVO">Activo</option>
                            <option value="INACTIVO">Inactivo</option>
                        </select>
                        <span asp-validation-for="Estado" class="text-danger"></span>
                    </div>

                    <!-- Hidden fields para el grupo seleccionado -->
                    <input type="hidden" id="grupoSeleccionadoId" name="IdGrupo" value="" />
                    <input type="hidden" id="nivelesSeleccionados" name="NivelesSeleccionados" value="" />
                    <input type="hidden" id="tipoGrupo" name="TipoGrupo" value="" />

                    <div class="mb-3">
                        <button type="submit" class="btn btn-success">
                            <i class="fas fa-save"></i> Guardar
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="fas fa-arrow-left"></i> Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
    
    <!-- Panel de ayuda -->
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h6 class="card-title mb-0">
                    <i class="fas fa-question-circle"></i> Ayuda
                </h6>
            </div>
            <div class="card-body">
                <h6>Grupos de Calificación:</h6>
                <ul class="mb-3">
                    <li><strong>Grupo Existente:</strong> Selecciona un grupo ya creado con niveles predefinidos.</li>
                    <li><strong>Grupo Dinámico:</strong> Crea un grupo personalizado seleccionando niveles específicos.</li>
                </ul>
                
                <div class="alert alert-info">
                    <small>
                        <i class="fas fa-info-circle"></i>
                        Al seleccionar un grupo, los niveles se asignarán automáticamente a la rúbrica.
                    </small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        let grupoSeleccionado = null;
        
        // Función para seleccionar grupo existente
        function seleccionarGrupoExistente() {
            const select = document.getElementById('grupoExistente');
            const grupoId = select.value;
            const grupoNombre = select.options[select.selectedIndex].text;
            
            if (!grupoId) {
                alert('Por favor seleccione un grupo.');
                return;
            }
            
            // Limpiar selección de niveles dinámicos
            document.querySelectorAll('.nivel-checkbox').forEach(cb => cb.checked = false);
            
            // Configurar grupo seleccionado
            grupoSeleccionado = {
                tipo: 'existente',
                id: grupoId,
                nombre: grupoNombre
            };
            
            // Actualizar campos hidden
            document.getElementById('grupoSeleccionadoId').value = grupoId;
            document.getElementById('tipoGrupo').value = 'existente';
            document.getElementById('nivelesSeleccionados').value = '';
            
            // Mostrar información
            mostrarInfoGrupoSeleccionado();
        }
        
        // Función para preparar grupo dinámico
        function prepararGrupoDinamico() {
            const checkboxes = document.querySelectorAll('.nivel-checkbox:checked');
            const nivelesSeleccionados = Array.from(checkboxes).map(cb => parseInt(cb.value));
            
            if (nivelesSeleccionados.length === 0) {
                alert('Por favor seleccione al menos un nivel para el grupo dinámico.');
                return;
            }
            
            // Limpiar selección de grupo existente
            document.getElementById('grupoExistente').value = '';
            
            // Configurar grupo seleccionado
            grupoSeleccionado = {
                tipo: 'dinamico',
                niveles: nivelesSeleccionados,
                cantidadNiveles: nivelesSeleccionados.length
            };
            
            // Actualizar campos hidden
            document.getElementById('grupoSeleccionadoId').value = '';
            document.getElementById('tipoGrupo').value = 'dinamico';
            document.getElementById('nivelesSeleccionados').value = nivelesSeleccionados.join(',');
            
            // Mostrar información
            mostrarInfoGrupoSeleccionado();
        }
        
        // Función para alternar todos los niveles
        function toggleTodosNiveles() {
            const checkboxes = document.querySelectorAll('.nivel-checkbox');
            const allChecked = Array.from(checkboxes).every(cb => cb.checked);
            
            checkboxes.forEach(cb => {
                cb.checked = !allChecked;
            });
        }
        
        // Función para mostrar información del grupo seleccionado
        function mostrarInfoGrupoSeleccionado() {
            const infoDiv = document.getElementById('infoGrupoSeleccionado');
            const containerDiv = document.getElementById('grupoSeleccionadoInfo');
            
            if (!grupoSeleccionado) {
                containerDiv.classList.add('d-none');
                return;
            }
            
            let infoHtml = '';
            
            if (grupoSeleccionado.tipo === 'existente') {
                infoHtml = `
                    <strong>Tipo:</strong> Grupo Existente<br>
                    <strong>Nombre:</strong> ${grupoSeleccionado.nombre}<br>
                    <small class="text-muted">Los niveles del grupo se asignarán automáticamente a la rúbrica.</small>
                `;
            } else if (grupoSeleccionado.tipo === 'dinamico') {
                infoHtml = `
                    <strong>Tipo:</strong> Grupo Dinámico<br>
                    <strong>Niveles Seleccionados:</strong> ${grupoSeleccionado.cantidadNiveles}<br>
                    <small class="text-muted">Se creará un nuevo grupo con los niveles seleccionados.</small>
                `;
            }
            
            infoDiv.innerHTML = infoHtml;
            containerDiv.classList.remove('d-none');
        }
        
        // Limpiar selección cuando se cambia entre opciones
        document.getElementById('grupoExistente').addEventListener('change', function() {
            if (this.value && grupoSeleccionado && grupoSeleccionado.tipo === 'dinamico') {
                document.querySelectorAll('.nivel-checkbox').forEach(cb => cb.checked = false);
                grupoSeleccionado = null;
                document.getElementById('grupoSeleccionadoInfo').classList.add('d-none');
            }
        });
        
        document.querySelectorAll('.nivel-checkbox').forEach(checkbox => {
            checkbox.addEventListener('change', function() {
                if (this.checked && grupoSeleccionado && grupoSeleccionado.tipo === 'existente') {
                    document.getElementById('grupoExistente').value = '';
                    grupoSeleccionado = null;
                    document.getElementById('grupoSeleccionadoInfo').classList.add('d-none');
                }
            });
        });
        
        // Manejar el envío del formulario con comportamiento estándar
        document.getElementById('rubricaForm').addEventListener('submit', function(e) {
            // Permitir el envío normal del formulario
            return true;
        });

        // Preparar niveles para el modal (variable global)
        var nivelesDisponiblesGlobal = [
            @if (ViewBag.NivelesDisponibles != null)
            {
                @foreach (var nivel in ViewBag.NivelesDisponibles)
                {
                    @:{idNivel: @nivel.IdNivel, nombreNivel: '@Html.Raw(Json.Serialize(nivel.NombreNivel))', descripcion: '@Html.Raw(Json.Serialize(nivel.Descripcion ?? ""))'},
                }
            }
        ];
    </script>
}

@* Incluir el modal de creación rápida *@
@await Html.PartialAsync("_ModalCrearGrupoRapido")
@model RubricasApp.Web.ViewModels.RubricasIndexViewModel

@{
    ViewData["Title"] = "Gestión de Rúbricas";
}

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">
                    <i class="fas fa-list"></i> Gestión de Rúbricas
                </h4>
                <small class="text-white-50">
                    Rol actual: @Model.CurrentUserRole | 
                    Total: @Model.TotalRubricas | 
                    Mis rúbricas: @Model.MisRubricas | 
                    Públicas: @Model.RubricasPublicas
                </small>
            </div>
            <div class="card-body">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                <div class="mb-3">
                    <div class="btn-group" role="group">
                        @if (Model.CanCreateNew)
                        {
                            <a asp-action="Create" class="btn btn-success">
                                <i class="fas fa-plus"></i> Nueva Rúbrica
                            </a>
                            <a asp-controller="ImportarRubrica" asp-action="Index" class="btn btn-outline-success">
                                <i class="fas fa-file-excel"></i> Importar desde Excel
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">
                                <i class="fas fa-info-circle"></i> No tienes permisos para crear nuevas rúbricas
                            </span>
                        }
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Nombre de la Rúbrica</th>
                                <th>Descripción</th>
                                <th>Creador</th>
                                <th>Fecha Creación</th>
                                <th>Estado</th>
                                <th>Permisos</th>
                                <th width="200">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Rubricas)
                            {
                                <tr class="@(item.IsOwner ? "table-success" : "")">
                                    <td>
                                        <strong>@Html.DisplayFor(modelItem => item.Rubrica.NombreRubrica)</strong>
                                        @if (item.IsOwner)
                                        {
                                            <span class="badge bg-success ms-2">Mía</span>
                                        }
                                        @if (item.Rubrica.EsPublica == 1)
                                        {
                                            <span class="badge bg-info ms-2">Pública</span>
                                        }
                                    </td>
                                    <td>@Html.DisplayFor(modelItem => item.Rubrica.Descripcion)</td>
                                    <td>
                                        <small class="text-muted">
                                            @(item.CreatedByName ?? "Sistema")
                                        </small>
                                    </td>
                                    <td>@item.Rubrica.FechaCreacion.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        @if (item.Rubrica.Estado == "ACTIVO")
                                        {
                                            <span class="badge bg-success">Activo</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Inactivo</span>
                                        }
                                    </td>
                                    <td>
                                        <small>
                                            @if (item.CanView) { <span class="badge bg-primary">Ver</span> }
                                            @if (item.CanEdit) { <span class="badge bg-warning">Editar</span> }
                                            @if (item.CanDelete) { <span class="badge bg-danger">Eliminar</span> }
                                        </small>
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm" role="group">
                                            @if (item.CanView)
                                            {
                                                <a asp-action="Details" asp-route-id="@item.Rubrica.IdRubrica" 
                                                   class="btn btn-outline-info" title="Ver detalles">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                            }
                                            @if (item.CanEdit)
                                            {
                                                <a asp-action="Edit" asp-route-id="@item.Rubrica.IdRubrica" 
                                                   class="btn btn-outline-warning" title="Editar">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <a asp-action="GestionarValoresItems" asp-route-id="@item.Rubrica.IdRubrica" 
                                                   class="btn btn-outline-primary" title="Gestionar valores">
                                                    <i class="fas fa-cogs"></i>
                                                </a>
                                            }
                                            @if (item.CanDelete)
                                            {
                                                <a asp-action="Delete" asp-route-id="@item.Rubrica.IdRubrica" 
                                                   class="btn btn-outline-danger" title="Eliminar">
                                                    <i class="fas fa-trash"></i>
                                                </a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if (!Model.Rubricas.Any())
                {
                    <div class="text-center py-4">
                        <i class="fas fa-clipboard-list fa-3x text-muted mb-3"></i>
                        <h5 class="text-muted">No hay rúbricas disponibles</h5>
                        @if (Model.CanCreateNew)
                        {
                            <p class="text-muted">Comience creando una nueva rúbrica.</p>
                            <a asp-action="Create" class="btn btn-primary">
                                <i class="fas fa-plus"></i> Crear mi primera rúbrica
                            </a>
                        }
                        else
                        {
                            <p class="text-muted">Contacte al administrador para obtener acceso a rúbricas.</p>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Tooltips para mostrar información adicional
            $('[data-bs-toggle="tooltip"]').tooltip();
            
            // Destacar las rúbricas propias
            $('.table-success').hover(
                function() { $(this).addClass('table-warning'); },
                function() { $(this).removeClass('table-warning'); }
            );
        });
    </script>
}

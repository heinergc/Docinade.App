@model RubricasApp.Web.ViewModels.RubricaConfiguracionViewModel

@{
    ViewData["Title"] = "Configurar Niveles de Calificación";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <div class="d-flex justify-content-between align-items-center">
                        <h3 class="card-title mb-0">
                            <i class="fas fa-cogs me-2"></i>
                            Configurar Niveles para: @Model.Rubrica.NombreRubrica
                        </h3>
                        <a asp-action="Details" asp-route-id="@Model.Rubrica.IdRubrica" class="btn btn-secondary">
                            <i class="fas fa-arrow-left me-1"></i>
                            Volver
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="fas fa-check-circle me-2"></i>
                            @TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="fas fa-exclamation-circle me-2"></i>
                            @TempData["ErrorMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form asp-action="ConfigureQualificationLevels" method="post">
                        <input type="hidden" asp-for="Rubrica.IdRubrica" />
                        
                        <div class="row">
                            <div class="col-md-8">
                                <div class="card">
                                    <div class="card-header">
                                        <h5><i class="fas fa-list me-2"></i>Seleccionar Niveles de Calificación</h5>
                                    </div>
                                    <div class="card-body">
                                        <p class="text-muted mb-3">
                                            Seleccione los niveles de calificación que desea usar para esta rúbrica:
                                        </p>
                                        
                                        @if (Model.TodosLosNiveles.Any())
                                        {
                                            <div class="row">
                                                @foreach (var nivel in Model.TodosLosNiveles)
                                                {
                                                    <div class="col-md-6 mb-3">
                                                        <div class="form-check">
                                                            <input class="form-check-input" type="checkbox" 
                                                                   name="selectedLevels" value="@nivel.IdNivel"
                                                                   id="nivel_@nivel.IdNivel"
                                                                   @(Model.NivelesSeleccionados.Contains(nivel.IdNivel) ? "checked" : "") />
                                                            <label class="form-check-label" for="nivel_@nivel.IdNivel">
                                                                <strong>@nivel.NombreNivel</strong>
                                                                @if (!string.IsNullOrEmpty(nivel.Descripcion))
                                                                {
                                                                    <br><small class="text-muted">@nivel.Descripcion</small>
                                                                }
                                                                @if (nivel.OrdenNivel.HasValue)
                                                                {
                                                                    <span class="badge bg-info ms-1">Orden: @nivel.OrdenNivel</span>
                                                                }
                                                                @if (nivel.IdGrupo.HasValue)
                                                                {
                                                                    <span class="badge bg-warning text-dark ms-1">Agrupado</span>
                                                                }
                                                            </label>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="alert alert-warning">
                                                <i class="fas fa-exclamation-triangle me-2"></i>
                                                No hay niveles de calificación disponibles. 
                                                <a asp-controller="NivelesCalificacion" asp-action="Create" class="alert-link">
                                                    Crear niveles primero
                                                </a>.
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                            
                            <div class="col-md-4">
                                <div class="card">
                                    <div class="card-header">
                                        <h5><i class="fas fa-layer-group me-2"></i>Opciones de Agrupación</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="form-check mb-3">
                                            <input class="form-check-input" type="checkbox" 
                                                   name="createDynamicGroup" value="true" id="createDynamicGroup" />
                                            <label class="form-check-label" for="createDynamicGroup">
                                                <strong>Crear grupo dinámico</strong>
                                            </label>
                                        </div>
                                        
                                        <div class="alert alert-info">
                                            <i class="fas fa-info-circle me-2"></i>
                                            <strong>Grupo Dinámico:</strong><br>
                                            Si activa esta opción, el sistema creará automáticamente un nuevo grupo 
                                            con copias de los niveles seleccionados, exclusivos para esta rúbrica.
                                            <br><br>
                                            <strong>Ventajas:</strong>
                                            <ul class="mb-0">
                                                <li>Niveles exclusivos para esta rúbrica</li>
                                                <li>No afecta otras rúbricas</li>
                                                <li>Permite personalización específica</li>
                                            </ul>
                                        </div>

                                        @if (Model.Rubrica.GrupoCalificacion != null)
                                        {
                                            <div class="alert alert-success">
                                                <i class="fas fa-check-circle me-2"></i>
                                                <strong>Grupo Actual:</strong><br>
                                                @Model.Rubrica.GrupoCalificacion.NombreGrupo
                                                <br><small class="text-muted">@Model.Rubrica.GrupoCalificacion.Descripcion</small>
                                            </div>
                                        }
                                    </div>
                                </div>
                                
                                <div class="card mt-3">
                                    <div class="card-body text-center">
                                        <button type="submit" class="btn btn-primary btn-lg">
                                            <i class="fas fa-save me-2"></i>
                                            Guardar Configuración
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const checkboxes = document.querySelectorAll('input[name="selectedLevels"]');
            const createGroupCheckbox = document.getElementById('createDynamicGroup');
            const form = document.querySelector('form');
            
            // Función para contar checkboxes seleccionados
            function updateUI() {
                const selectedCount = Array.from(checkboxes).filter(cb => cb.checked).length;
                
                if (selectedCount === 0) {
                    createGroupCheckbox.disabled = true;
                    createGroupCheckbox.checked = false;
                } else {
                    createGroupCheckbox.disabled = false;
                }
            }
            
            // Agregar event listeners a todos los checkboxes
            checkboxes.forEach(checkbox => {
                checkbox.addEventListener('change', updateUI);
            });
            
            // Validación del formulario
            form.addEventListener('submit', function(e) {
                const selectedCount = Array.from(checkboxes).filter(cb => cb.checked).length;
                
                if (selectedCount === 0) {
                    e.preventDefault();
                    alert('Debe seleccionar al menos un nivel de calificación.');
                    return false;
                }
            });
            
            // Inicializar UI
            updateUI();
        });
    </script>
}
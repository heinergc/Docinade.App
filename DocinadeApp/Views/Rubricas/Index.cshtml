@model IEnumerable<DocinadeApp.Models.Rubrica>

@{
    ViewData["Title"] = "Gestión de Rúbricas";
}

@section Styles {
    <style>
        .rubricas-header {
            background: linear-gradient(135deg, #2b3e5e 0%, #1e293b 30%, #334155 60%, #475569 100%);
            border-radius: 12px 12px 0 0;
            padding: 1.25rem 1.5rem;
            margin: 0.5rem 0 1.5rem 0;
            position: relative;
            overflow: hidden;
        }

        .rubricas-header::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><defs><pattern id="grid" width="10" height="10" patternUnits="userSpaceOnUse"><path d="M 10 0 L 0 0 0 10" fill="none" stroke="rgba(255,255,255,0.1)" stroke-width="0.5"/></pattern></defs><rect width="100" height="100" fill="url(%23grid)"/></svg>');
            opacity: 0.1;
        }

        .rubricas-title {
            color: white;
            font-size: 1.95rem;
            font-weight: 700;
            margin-bottom: 0.35rem;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
            position: relative;
            z-index: 2;
        }

        .rubricas-subtitle {
            color: rgba(255,255,255,0.9);
            font-size: 0.95rem;
            margin-bottom: 1rem;
            position: relative;
            z-index: 2;
        }

        .rubricas-stats {
            display: flex;
            gap: 1.5rem;
            margin-bottom: 1rem;
            position: relative;
            z-index: 2;
        }

        .stat-item {
            background: rgba(255,255,255,0.1);
            backdrop-filter: blur(10px);
            border-radius: 12px;
            padding: 1rem;
            text-align: center;
            border: 1px solid rgba(255,255,255,0.2);
            min-width: 120px;
        }

        .stat-number {
            font-size: 2rem;
            font-weight: 700;
            color: white;
            display: block;
        }

        .stat-label {
            font-size: 0.9rem;
            color: rgba(255,255,255,0.8);
            margin-top: 0.25rem;
        }

        .rubricas-actions {
            display: flex;
            gap: 1rem;
            flex-wrap: wrap;
            position: relative;
            z-index: 2;
        }

        .btn-rubricas {
            padding: 0.75rem 1.5rem;
            border-radius: 10px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            transition: all 0.3s ease;
            border: 2px solid transparent;
            position: relative;
            overflow: hidden;
        }

        .btn-rubricas::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
            transition: left 0.5s;
        }

        .btn-rubricas:hover::before {
            left: 100%;
        }

        .btn-rubricas:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.3);
        }

        .btn-primary-rubricas {
            background: linear-gradient(135deg, #ff8c00, #ff6b00);
            color: white;
            border-color: #ff8c00;
        }

        .btn-success-rubricas {
            background: linear-gradient(135deg, #28a745, #20c997);
            color: white;
            border-color: #28a745;
        }

        .btn-outline-rubricas {
            background: rgba(255,255,255,0.1);
            color: white;
            border-color: rgba(255,255,255,0.3);
        }

        .btn-outline-rubricas:hover {
            background: rgba(255,255,255,0.2);
            color: white;
            border-color: rgba(255,255,255,0.5);
        }

        /* Mejoras para la tabla */
        .table-rubricas {
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 8px 32px rgba(0,0,0,0.1);
        }

        .table-rubricas thead th {
            background: linear-gradient(135deg, #2b3e5e, #1e293b);
            color: white;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            font-size: 0.85rem;
            padding: 1rem;
            border: none;
            position: sticky;
            top: 0;
            z-index: 10;
        }

        .table-rubricas tbody tr {
            transition: all 0.2s ease;
        }

        .table-rubricas tbody tr:hover {
            background-color: rgba(43, 62, 94, 0.05);
            transform: translateX(2px);
        }

        .table-rubricas td {
            padding: 1rem;
            vertical-align: middle;
            border-bottom: 1px solid #f1f3f4;
        }

        /* Responsive */
        @@media (max-width: 768px) {
            .rubricas-header {
                padding: 1rem 1.25rem;
                margin: 0.5rem 0 1rem 0;
            }

            .rubricas-title {
                font-size: 1.65rem;
            }

            .rubricas-stats {
                flex-direction: column;
                gap: 1rem;
            }

            .stat-item {
                min-width: auto;
            }

            .rubricas-actions {
                flex-direction: column;
            }

            .btn-rubricas {
                width: 100%;
                text-align: center;
            }
        }
    </style>
}

<div class="rubricas-header">
    <h1 class="rubricas-title">
        <i class="fas fa-list me-3"></i>
        Gestión de Rúbricas
    </h1>
    <p class="rubricas-subtitle">
        Administra y organiza todas las rúbricas de evaluación del sistema
    </p>

    <!-- Estadísticas rápidas -->
    <div class="rubricas-stats">
        <div class="stat-item">
            <span class="stat-number">@Model.Count()</span>
            <div class="stat-label">Total Rúbricas</div>
        </div>
        <div class="stat-item">
            <span class="stat-number">@Model.Count(r => r.Estado == "ACTIVO")</span>
            <div class="stat-label">Activas</div>
        </div>
        <div class="stat-item">
            <span class="stat-number">@Model.Count(r => r.Estado != "ACTIVO")</span>
            <div class="stat-label">Inactivas</div>
        </div>
    </div>

    <!-- Acciones principales -->
    <div class="rubricas-actions">
        <a asp-action="Create" class="btn btn-rubricas btn-primary-rubricas">
            <i class="fas fa-plus me-2"></i>
            Nueva Rúbrica
        </a>
        <a asp-controller="ImportarRubrica" asp-action="Index" class="btn btn-rubricas btn-success-rubricas">
            <i class="fas fa-file-excel me-2"></i>
            Importar desde Excel
        </a>
        <button class="btn btn-rubricas btn-outline-rubricas" onclick="exportarRubricas()">
            <i class="fas fa-download me-2"></i>
            Exportar
        </button>
    </div>
</div>

<div class="row">
    <div class="col-md-12">
        <div class="card shadow-sm">
            <div class="card-body p-0">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show m-3" role="alert">
                        <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show m-3" role="alert">
                        <i class="fas fa-exclamation-circle me-2"></i> @TempData["ErrorMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                <div class="table-responsive">
                    <table class="table table-rubricas mb-0">
                        <thead>
                            <tr>
                                <th><i class="fas fa-tag me-2"></i>@Html.DisplayNameFor(model => model.NombreRubrica)</th>
                                <th><i class="fas fa-align-left me-2"></i>@Html.DisplayNameFor(model => model.Descripcion)</th>
                                <th><i class="fas fa-calendar me-2"></i>@Html.DisplayNameFor(model => model.FechaCreacion)</th>
                                <th><i class="fas fa-toggle-on me-2"></i>@Html.DisplayNameFor(model => model.Estado)</th>
                                <th width="200"><i class="fas fa-cogs me-2"></i>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Any())
                            {
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>
                                            <strong>@Html.DisplayFor(modelItem => item.NombreRubrica)</strong>
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(item.Descripcion))
                                            {
                                                <span title="@item.Descripcion">@(item.Descripcion.Length > 50 ? item.Descripcion.Substring(0, 50) + "..." : item.Descripcion)</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">Sin descripción</span>
                                            }
                                        </td>
                                        <td>
                                            <span class="badge bg-light text-dark">
                                                @item.FechaCreacion.ToString("dd/MM/yyyy")
                                            </span>
                                            <small class="text-muted d-block">@item.FechaCreacion.ToString("HH:mm")</small>
                                        </td>
                                        <td>
                                            @if (item.Estado == "ACTIVO")
                                            {
                                                <span class="badge bg-success">
                                                    <i class="fas fa-check-circle me-1"></i>@item.Estado
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">
                                                    <i class="fas fa-times-circle me-1"></i>@item.Estado
                                                </span>
                                            }
                                        </td>
                                        <td>
                                            <div class="btn-group btn-group-sm" role="group">
                                                <a asp-action="Details" asp-route-id="@item.IdRubrica" class="btn btn-outline-info" title="Ver detalles">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                                <a asp-action="Edit" asp-route-id="@item.IdRubrica" class="btn btn-outline-warning" title="Editar">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <a asp-action="Delete" asp-route-id="@item.IdRubrica" class="btn btn-outline-danger" title="Eliminar">
                                                    <i class="fas fa-trash"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-5">
                                        <div class="empty-state">
                                            <i class="fas fa-list fa-3x text-muted mb-3"></i>
                                            <h5 class="text-muted">No hay rúbricas registradas</h5>
                                            <p class="text-muted mb-3">
                                                Comienza creando tu primera rúbrica para organizar las evaluaciones.
                                            </p>
                                            <a asp-action="Create" class="btn btn-primary">
                                                <i class="fas fa-plus me-2"></i>Crear Primera Rúbrica
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function exportarRubricas() {
            // Implementar funcionalidad de exportación
            alert('Funcionalidad de exportación próximamente disponible');
        }
    </script>
}
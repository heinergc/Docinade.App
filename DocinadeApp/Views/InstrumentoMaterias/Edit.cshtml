@model DocinadeApp.ViewModels.InstrumentoMateriaViewModel

@{
    ViewData["Title"] = "Editar Relación Instrumento-Materia";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-warning text-dark">
                    <h4 class="card-title mb-0">
                        <i class="fas fa-edit"></i> @ViewData["Title"]
                    </h4>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                        
                        <!-- Campos ocultos para la clave compuesta -->
                        <input type="hidden" asp-for="InstrumentoId" />
                        <input type="hidden" asp-for="MateriaId" />
                        
                        <!-- Información de la relación (solo lectura) -->
                        <div class="row mb-4">
                            <div class="col-md-6">
                                <div class="card bg-light">
                                    <div class="card-body">
                                        <h6 class="card-title">
                                            <i class="fas fa-clipboard-list text-primary"></i> 
                                            Instrumento de Evaluación
                                        </h6>
                                        <p class="card-text">
                                            <strong>@Model.InstrumentoNombre</strong>
                                        </p>
                                        <small class="text-muted">ID: @Model.InstrumentoId</small>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="col-md-6">
                                <div class="card bg-light">
                                    <div class="card-body">
                                        <h6 class="card-title">
                                            <i class="fas fa-book text-info"></i> 
                                            Materia
                                        </h6>
                                        <p class="card-text">
                                            <strong>@Model.MateriaNombre</strong>
                                        </p>
                                        <small class="text-muted">ID: @Model.MateriaId</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Campo editable -->
                        <div class="mb-4">
                            <label asp-for="PeriodoAcademicoId" class="form-label">
                                <i class="fas fa-calendar-alt"></i> Período Académico
                            </label>
                            <select asp-for="PeriodoAcademicoId" class="form-select" asp-items="ViewBag.PeriodoAcademicoId">
                                <option value="">-- Seleccione un período académico --</option>
                            </select>
                            <div class="form-text">
                                Seleccione el período académico correspondiente
                            </div>
                            <span asp-validation-for="PeriodoAcademicoId" class="text-danger"></span>
                        </div>

                        <!-- Información de ayuda -->
                        <div class="alert alert-info">
                            <i class="fas fa-info-circle"></i>
                            <strong>Nota:</strong>
                            Solo se puede modificar el período académico. 
                            Para cambiar el instrumento o la materia, debe eliminar esta relación y crear una nueva.
                        </div>

                        <div class="d-flex justify-content-between">
                            <div>
                                <a asp-action="Index" class="btn btn-secondary">
                                    <i class="fas fa-arrow-left"></i> Volver a la Lista
                                </a>
                                <a asp-action="Details" 
                                   asp-route-instrumentoId="@Model.InstrumentoId" 
                                   asp-route-materiaId="@Model.MateriaId" 
                                   class="btn btn-info">
                                    <i class="fas fa-eye"></i> Ver Detalles
                                </a>
                            </div>
                            <button type="submit" class="btn btn-warning">
                                <i class="fas fa-save"></i> Guardar Cambios
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        $(document).ready(function() {
            // Validación en tiempo real
            $('form').on('submit', function(e) {
                var periodoAcademicoId = $('#PeriodoAcademicoId').val();

                if (!periodoAcademicoId) {
                    e.preventDefault();
                    $('#PeriodoAcademicoId').focus();
                    alert('El período académico es obligatorio.');
                    return false;
                }

                // Confirmar la actualización
                return confirm('¿Está seguro de que desea guardar los cambios en esta relación?');
            });

            // Resaltar el campo que se puede editar
            $('#PeriodoAcademicoId').on('focus', function() {
                $(this).addClass('border-warning');
            }).on('blur', function() {
                $(this).removeClass('border-warning');
            });
        });
    </script>
}
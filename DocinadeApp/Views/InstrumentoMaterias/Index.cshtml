@model IEnumerable<RubricasApp.Web.Models.InstrumentoMateria>

@{
    ViewData["Title"] = "Gestión de Instrumentos por Materia";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4 class="card-title mb-0">
                        <i class="fas fa-link"></i> @ViewData["Title"]
                    </h4>
                </div>
                <div class="card-body">
                    <!-- Botón para crear nueva relación -->
                    <div class="mb-3">
                        <a asp-action="Create" class="btn btn-success">
                            <i class="fas fa-plus"></i> Crear Nueva Relación
                        </a>
                    </div>

                    <!-- Filtros -->
                    <div class="card mb-3">
                        <div class="card-header">
                            <h6 class="mb-0">
                                <i class="fas fa-filter"></i> Filtros
                            </h6>
                        </div>
                        <div class="card-body">
                            <form method="get" class="row g-3">
                                <div class="col-md-4">
                                    <label for="instrumentoId" class="form-label">Instrumento:</label>
                                    <select name="instrumentoId" id="instrumentoId" class="form-select">
                                        <option value="">-- Todos los instrumentos --</option>
                                        @if (ViewBag.InstrumentoId != null)
                                        {
                                            @foreach (SelectListItem item in ViewBag.InstrumentoId)
                                            {
                                                <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                                            }
                                        }
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label for="materiaId" class="form-label">Materia:</label>
                                    <select name="materiaId" id="materiaId" class="form-select">
                                        <option value="">-- Todas las materias --</option>
                                        @if (ViewBag.MateriaId != null)
                                        {
                                            @foreach (SelectListItem item in ViewBag.MateriaId)
                                            {
                                                <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                                            }
                                        }
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <label for="periodoAcademicoId" class="form-label">Período Académico:</label>
                                    <select name="periodoAcademicoId" id="periodoAcademicoId" class="form-select">
                                        <option value="">-- Todos los períodos --</option>
                                        @if (ViewBag.PeriodoAcademicoId != null)
                                        {
                                            @foreach (SelectListItem item in ViewBag.PeriodoAcademicoId)
                                            {
                                                <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                                            }
                                        }
                                    </select>
                                </div>
                                <div class="col-md-1 d-flex align-items-end">
                                    <button type="submit" class="btn btn-primary w-100">
                                        <i class="fas fa-search"></i>
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <!-- Tabla de relaciones -->
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th>Instrumento de Evaluación</th>
                                    <th>Materia</th>
                                    <th>Período Académico</th>
                                    <th>Estado Instrumento</th>
                                    <th>Estado Materia</th>
                                    <th class="text-center">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Any())
                                {
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>
                                                <strong>@Html.DisplayFor(modelItem => item.InstrumentoEvaluacion.Nombre)</strong>
                                                @if (!string.IsNullOrEmpty(item.InstrumentoEvaluacion.Descripcion))
                                                {
                                                    <br><small class="text-muted">@item.InstrumentoEvaluacion.Descripcion</small>
                                                }
                                            </td>
                                            <td>
                                                <strong>@Html.DisplayFor(modelItem => item.Materia.Nombre)</strong>
                                                <br><small class="text-muted">Código: @item.Materia.Codigo</small>
                                                @if (item.Materia.Creditos > 0)
                                                {
                                                    <br><small class="text-info">Créditos: @item.Materia.Creditos</small>
                                                }
                                            </td>
                                            <td>
                                                <span class="badge bg-info">@item.PeriodoAcademico?.NombreCompleto</span>
                                            </td>
                                            <td>
                                                @if (item.InstrumentoEvaluacion.Activo)
                                                {
                                                    <span class="badge bg-success">Activo</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger">Inactivo</span>
                                                }
                                            </td>
                                            <td>
                                                @if (item.Materia.Activa)
                                                {
                                                    <span class="badge bg-success">Activa</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger">Inactiva</span>
                                                }
                                            </td>
                                            <td class="text-center">
                                                <div class="btn-group" role="group">
                                                    <a asp-action="Details" 
                                                       asp-route-instrumentoId="@item.InstrumentoId" 
                                                       asp-route-materiaId="@item.MateriaId" 
                                                       class="btn btn-outline-info btn-sm" 
                                                       title="Ver detalles">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                    <a asp-action="Edit" 
                                                       asp-route-instrumentoId="@item.InstrumentoId" 
                                                       asp-route-materiaId="@item.MateriaId" 
                                                       class="btn btn-outline-warning btn-sm" 
                                                       title="Editar">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    <a asp-action="Delete" 
                                                       asp-route-instrumentoId="@item.InstrumentoId" 
                                                       asp-route-materiaId="@item.MateriaId" 
                                                       class="btn btn-outline-danger btn-sm" 
                                                       title="Eliminar">
                                                        <i class="fas fa-trash"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-4">
                                            <i class="fas fa-inbox fa-2x mb-2"></i>
                                            <br>No se encontraron relaciones instrumento-materia.
                                            <br><a asp-action="Create" class="btn btn-success btn-sm mt-2">
                                                <i class="fas fa-plus"></i> Crear la primera relación
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    @if (Model.Any())
                    {
                        <div class="mt-3">
                            <small class="text-muted">
                                <i class="fas fa-info-circle"></i> 
                                Total de relaciones encontradas: <strong>@Model.Count()</strong>
                            </small>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Auto-submit del formulario de filtros cuando cambian los select
        $('#instrumentoId, #materiaId, #periodoAcademicoId').change(function() {
            $(this).closest('form').submit();
        });

        // Confirmación para eliminar
        $('.btn-outline-danger').click(function(e) {
            if (!confirm('¿Está seguro de que desea eliminar esta relación instrumento-materia?')) {
                e.preventDefault();
            }
        });
    </script>
}
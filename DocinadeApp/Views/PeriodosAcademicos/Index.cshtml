@model DocinadeApp.ViewModels.Academic.PagedResult<DocinadeApp.ViewModels.Academic.PeriodoListVm>

@{
    ViewData["Title"] = "Períodos Académicos";
    Layout = "_Layout";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2><i class="fas fa-calendar-alt"></i> Períodos Académicos </h2>
                <a asp-action="Create" class="btn btn-primary">
                    <i class="fas fa-plus"></i> Nuevo Período
                </a>
            </div>

            <!-- Filtros y búsqueda -->
            <div class="card mb-4">
                <div class="card-body">
                    <form method="get" class="row g-3">
                        <div class="col-md-4">
                            <label for="searchTerm" class="form-label">Buscar</label>
                            <input type="text" class="form-control" id="searchTerm" name="searchTerm" 
                                   value="@ViewBag.CurrentFilter" placeholder="Código, nombre, año o ciclo...">
                        </div>
                        <div class="col-md-3">
                            <label for="tipoFiltro" class="form-label">Tipo de Período</label>
                            <select class="form-select" id="tipoFiltro" name="tipoFiltro">
                                <option value="">Todos los tipos</option>
                                @if (ViewBag.TiposDisponibles != null)
                                {
                                    @foreach (string tipo in ViewBag.TiposDisponibles)
                                    {
                                        <option value="@tipo" selected="@(ViewBag.TipoFiltro?.ToString() == tipo)">@tipo</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label for="pageSize" class="form-label">Registros por página</label>
                            <select class="form-select" id="pageSize" name="pageSize">
                                <option value="10" selected="@(ViewBag.PageSize == 10)">10</option>
                                <option value="25" selected="@(ViewBag.PageSize == 25)">25</option>
                                <option value="50" selected="@(ViewBag.PageSize == 50)">50</option>
                            </select>
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <button type="submit" class="btn btn-outline-primary me-2">
                                <i class="fas fa-search"></i> Buscar
                            </button>
                            <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                                <i class="fas fa-times"></i> Limpiar
                            </a>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Tabla de resultados -->
            <div class="card">
                <div class="card-body">
                    @if (Model.Items.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead class="table-light">
                                    <tr>
                                        <th>Código</th>
                                        <th>Nombre</th>
                                        <th>Año</th>
                                        <th>Ciclo</th>
                                        <th>Tipo</th>
                                        <th>Fechas</th>
                                        <th>Estado</th>
                                        <th>Ofertas</th>
                                        <th width="150">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var periodo in Model.Items)
                                    {
                                        <tr>
                                            <td><strong>@periodo.Codigo</strong></td>
                                            <td>@periodo.Nombre</td>
                                            <td>
                                                <span class="badge bg-info">@periodo.Anio</span>
                                            </td>
                                            <td>
                                                <span class="badge bg-secondary">@periodo.Ciclo</span>
                                            </td>
                                            <td>
                                                <span class="badge bg-primary">@periodo.Tipo</span>
                                            </td>
                                            <td>
                                                <small class="text-muted">
                                                    @periodo.FechaInicio.ToString("dd/MM/yyyy") - 
                                                    @periodo.FechaFin.ToString("dd/MM/yyyy")
                                                </small>
                                            </td>
                                            <td>
                                                @if (periodo.Activo)
                                                {
                                                    <span class="badge bg-success">Activo</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger">Inactivo</span>
                                                }
                                            </td>
                                            <td>
                                                <span class="badge bg-warning text-dark">@periodo.NumeroOfertas</span>
                                            </td>
                                            <td>
                                                <div class="btn-group" role="group">
                                                    <a asp-action="Details" asp-route-id="@periodo.Id" 
                                                       class="btn btn-sm btn-outline-info" title="Ver detalles">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                    <a asp-action="Edit" asp-route-id="@periodo.Id" 
                                                       class="btn btn-sm btn-outline-warning" title="Editar">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    @if (periodo.NumeroOfertas == 0)
                                                    {
                                                        <button type="button" class="btn btn-sm btn-outline-danger" 
                                                                onclick="confirmarEliminacion(@periodo.Id, '@periodo.Nombre')" title="Eliminar">
                                                            <i class="fas fa-trash"></i>
                                                        </button>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <!-- Paginación -->
                        @if (Model.TotalPages > 1)
                        {
                            <nav aria-label="Paginación">
                                <ul class="pagination justify-content-center mt-4">
                                    @if (Model.Page > 1)
                                    {
                                        <li class="page-item">
                                            <a class="page-link" href="@Url.Action("Index", new { page = Model.Page - 1, pageSize = ViewBag.PageSize, searchTerm = ViewBag.CurrentFilter, tipoFiltro = ViewBag.TipoFiltro })">
                                                Anterior
                                            </a>
                                        </li>
                                    }

                                    @for (int i = Math.Max(1, Model.Page - 2); i <= Math.Min(Model.TotalPages, Model.Page + 2); i++)
                                    {
                                        <li class="page-item @(i == Model.Page ? "active" : "")">
                                            <a class="page-link" href="@Url.Action("Index", new { page = i, pageSize = ViewBag.PageSize, searchTerm = ViewBag.CurrentFilter, tipoFiltro = ViewBag.TipoFiltro })">
                                                @i
                                            </a>
                                        </li>
                                    }

                                    @if (Model.Page < Model.TotalPages)
                                    {
                                        <li class="page-item">
                                            <a class="page-link" href="@Url.Action("Index", new { page = Model.Page + 1, pageSize = ViewBag.PageSize, searchTerm = ViewBag.CurrentFilter, tipoFiltro = ViewBag.TipoFiltro })">
                                                Siguiente
                                            </a>
                                        </li>
                                    }
                                </ul>
                            </nav>
                        }

                        <div class="mt-3 text-muted">
                            Mostrando @((Model.Page - 1) * Model.PageSize + 1) - @Math.Min(Model.Page * Model.PageSize, Model.TotalCount) 
                            de @Model.TotalCount registros
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <div class="mb-3">
                                <i class="fas fa-calendar-times fa-3x text-muted"></i>
                            </div>
                            <h5 class="text-muted">No se encontraron períodos académicos</h5>
                            <p class="text-muted">Intenta con otros criterios de búsqueda o crea un nuevo período.</p>
                            <a asp-action="Create" class="btn btn-primary">
                                <i class="fas fa-plus"></i> Crear Nuevo Período
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal de confirmación para eliminar -->
<div class="modal fade" id="modalEliminar" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Confirmar Eliminación</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>¿Está seguro que desea eliminar el período académico <strong id="nombrePeriodo"></strong>?</p>
                <p class="text-danger">Esta acción no se puede deshacer.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <form id="formEliminar" method="post" style="display: inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">Eliminar</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Auto submit form on page size or tipo change
        document.getElementById('pageSize').addEventListener('change', function() {
            this.form.submit();
        });
        
        document.getElementById('tipoFiltro').addEventListener('change', function() {
            this.form.submit();
        });

        // Función para confirmar eliminación
        function confirmarEliminacion(id, nombre) {
            document.getElementById('nombrePeriodo').textContent = nombre;
            document.getElementById('formEliminar').action = '@Url.Action("Delete")/' + id;
            
            var modal = new bootstrap.Modal(document.getElementById('modalEliminar'));
            modal.show();
        }
    </script>
}
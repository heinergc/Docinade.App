@model IEnumerable<RubricasApp.Web.Models.InstrumentoRubrica>

@{
    ViewData["Title"] = "Asignación de Rúbricas a Instrumentos";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <h4 class="mb-0">
                            <i class="fas fa-link me-2"></i>
                            Asignación de Rúbricas a Instrumentos
                        </h4>
                        <a asp-action="Create" class="btn btn-light btn-sm">
                            <i class="fas fa-plus me-1"></i>
                            Nueva Asignación
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="fas fa-check-circle me-2"></i>
                            @TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="fas fa-exclamation-circle me-2"></i>
                            @TempData["ErrorMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <!-- Filtros y acciones rápidas -->
                    <div class="row mb-3">
                        <div class="col-md-4">
                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="fas fa-search"></i>
                                </span>
                                <input type="text" id="searchInput" class="form-control" placeholder="Buscar por instrumento o rúbrica...">
                            </div>
                        </div>
                        <div class="col-md-4">
                            <form method="get" class="d-flex">
                                <select name="materiaFilter" class="form-select me-2" onchange="this.form.submit()">
                                    <option value="">Todas las materias</option>
                                    @if (ViewBag.MateriasDisponibles != null)
                                    {
                                        @foreach (string materia in ViewBag.MateriasDisponibles)
                                        {
                                            <option value="@materia" selected="@(ViewBag.FiltroActual == materia)">@materia</option>
                                        }
                                    }
                                </select>
                                @if (!string.IsNullOrEmpty(ViewBag.FiltroActual))
                                {
                                    <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                                        <i class="fas fa-times"></i>
                                    </a>
                                }
                            </form>
                        </div>
                        <div class="col-md-4 text-end">
                            <div class="btn-group" role="group">
                                <button type="button" class="btn btn-outline-info btn-sm" onclick="filterByInstrumento()">
                                    <i class="fas fa-clipboard-list me-1"></i>
                                    Ver por Instrumento
                                </button>
                                <button type="button" class="btn btn-outline-primary btn-sm" onclick="filterByRubrica()">
                                    <i class="fas fa-list me-1"></i>
                                    Ver por Rúbrica
                                </button>
                            </div>
                        </div>
                    </div>

                    @if (Model.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover" id="asignacionesTable">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Instrumento de Evaluación</th>
                                        <th>Rúbrica Asignada</th>
                                        <th>Materia(s) Asignada(s)</th>
                                        <th>Ponderación</th>
                                        <th>Fecha de Asignación</th>
                                        <th class="text-center">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <i class="fas fa-clipboard-list text-info me-2"></i>
                                                    <div>
                                                        <strong>@item.InstrumentoEvaluacion.Nombre</strong>
                                                        @if (!string.IsNullOrEmpty(item.InstrumentoEvaluacion.Descripcion))
                                                        {
                                                            <br><small class="text-muted">@item.InstrumentoEvaluacion.Descripcion</small>
                                                        }
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <i class="fas fa-list text-primary me-2"></i>
                                                    <div>
                                                        <strong>@item.Rubrica.NombreRubrica</strong>
                                                        @if (!string.IsNullOrEmpty(item.Rubrica.Descripcion))
                                                        {
                                                            <br><small class="text-muted">@item.Rubrica.Descripcion</small>
                                                        }
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                @if (item.InstrumentoEvaluacion.InstrumentoMaterias.Any())
                                                {
                                                    <div class="d-flex flex-wrap">
                                                        @foreach (var instrumentoMateria in item.InstrumentoEvaluacion.InstrumentoMaterias.Take(2))
                                                        {
                                                            <span class="badge bg-secondary me-1 mb-1">
                                                                <i class="fas fa-book me-1"></i>
                                                                @instrumentoMateria.Materia.Codigo
                                                            </span>
                                                        }
                                                        @if (item.InstrumentoEvaluacion.InstrumentoMaterias.Count > 2)
                                                        {
                                                            <span class="badge bg-info">
                                                                +@(item.InstrumentoEvaluacion.InstrumentoMaterias.Count - 2) más
                                                            </span>
                                                        }
                                                    </div>
                                                    @if (item.InstrumentoEvaluacion.InstrumentoMaterias.Count > 0)
                                                    {
                                                        <small class="text-muted d-block mt-1">
                                                            @string.Join(", ", item.InstrumentoEvaluacion.InstrumentoMaterias.Take(3).Select(im => im.Materia.Nombre))
                                                            @if (item.InstrumentoEvaluacion.InstrumentoMaterias.Count > 3)
                                                            {
                                                                <text>...</text>
                                                            }
                                                        </small>
                                                    }
                                                }
                                                else
                                                {
                                                    <div class="text-center">
                                                        <i class="fas fa-minus-circle text-muted me-1"></i>
                                                        <span class="text-muted">Sin materia asignada</span>
                                                    </div>
                                                }
                                            </td>
                                            <td>
                                                <span class="badge bg-warning text-dark fs-6">
                                                    @item.Ponderacion.ToString("F2")%
                                                </span>
                                            </td>
                                            <td>
                                                <small class="text-muted">
                                                    <i class="fas fa-calendar-alt me-1"></i>
                                                    @item.FechaAsignacion.ToString("dd/MM/yyyy HH:mm")
                                                </small>
                                            </td>
                                            <td class="text-center">
                                                <div class="btn-group" role="group">
                                                    <a asp-action="Details" 
                                                       asp-route-instrumentoId="@item.InstrumentoId" 
                                                       asp-route-rubricaId="@item.RubricaId"
                                                       class="btn btn-info btn-sm" title="Ver detalles">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                    <a asp-action="Edit" 
                                                       asp-route-instrumentoId="@item.InstrumentoId" 
                                                       asp-route-rubricaId="@item.RubricaId"
                                                       class="btn btn-warning btn-sm" title="Editar">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    <a asp-action="Delete" 
                                                       asp-route-instrumentoId="@item.InstrumentoId" 
                                                       asp-route-rubricaId="@item.RubricaId"
                                                       class="btn btn-danger btn-sm" title="Eliminar">
                                                        <i class="fas fa-unlink"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <!-- Estadísticas -->
                        <div class="row mt-4">
                            <div class="col-md-4">
                                <div class="card bg-light">
                                    <div class="card-body text-center">
                                        <h5 class="text-info">@Model.Count()</h5>
                                        <small class="text-muted">Total Asignaciones</small>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="card bg-light">
                                    <div class="card-body text-center">
                                        <h5 class="text-primary">@Model.Select(m => m.InstrumentoId).Distinct().Count()</h5>
                                        <small class="text-muted">Instrumentos Utilizados</small>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="card bg-light">
                                    <div class="card-body text-center">
                                        <h5 class="text-success">@Model.Select(m => m.RubricaId).Distinct().Count()</h5>
                                        <small class="text-muted">Rúbricas Asignadas</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-link fa-3x text-muted mb-3"></i>
                            <h5 class="text-muted">No hay asignaciones registradas</h5>
                            <p class="text-muted">Comience creando la primera asignación de rúbrica a instrumento.</p>
                            <a asp-action="Create" class="btn btn-success">
                                <i class="fas fa-plus me-1"></i>
                                Crear Primera Asignación
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Auto-hide alerts after 5 seconds
        setTimeout(function() {
            $('.alert').fadeOut('slow');
        }, 5000);

        // Search functionality
        document.getElementById('searchInput').addEventListener('keyup', function() {
            const searchTerm = this.value.toLowerCase();
            const tableRows = document.querySelectorAll('#asignacionesTable tbody tr');
            
            tableRows.forEach(row => {
                const text = row.textContent.toLowerCase();
                if (text.includes(searchTerm)) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        });

        // Filter functions
        function filterByInstrumento() {
            // Redirect to a grouped view by instrumento (could be implemented later)
            alert('Funcionalidad de filtro por instrumento - próximamente');
        }

        function filterByRubrica() {
            // Redirect to a grouped view by rubrica (could be implemented later)
            alert('Funcionalidad de filtro por rúbrica - próximamente');
        }
    </script>
}
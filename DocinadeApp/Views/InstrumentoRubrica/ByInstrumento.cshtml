@model IEnumerable<RubricasApp.Web.Models.InstrumentoRubrica>

@{
    ViewData["Title"] = "Rúbricas del Instrumento";
    var instrumentoNombre = ViewBag.InstrumentoNombre as string;
    var instrumentoId = ViewBag.InstrumentoId as int?;
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-info text-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <h4 class="mb-0">
                            <i class="fas fa-clipboard-list me-2"></i>
                            Rúbricas del Instrumento: @instrumentoNombre
                        </h4>
                        <div class="btn-group">
                            <a asp-action="Create" class="btn btn-light btn-sm">
                                <i class="fas fa-plus me-1"></i>
                                Agregar Rúbrica
                            </a>
                            <a asp-controller="InstrumentosEvaluacion" 
                               asp-action="Details" 
                               asp-route-id="@instrumentoId" 
                               class="btn btn-outline-light btn-sm">
                                <i class="fas fa-eye me-1"></i>
                                Ver Instrumento
                            </a>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item">
                                <a asp-action="Index">Asignaciones</a>
                            </li>
                            <li class="breadcrumb-item">
                                <a asp-controller="InstrumentosEvaluacion" asp-action="Index">Instrumentos</a>
                            </li>
                            <li class="breadcrumb-item active" aria-current="page">@instrumentoNombre</li>
                        </ol>
                    </nav>

                    @if (Model.Any())
                    {
                        <div class="row mb-3">
                            <div class="col-md-8">
                                <div class="alert alert-info">
                                    <i class="fas fa-info-circle me-2"></i>
                                    Este instrumento tiene <strong>@Model.Count()</strong> rúbrica(s) asignada(s) 
                                    con una ponderación total de <strong>@Model.Sum(m => m.Ponderacion).ToString("F2")%</strong>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="fas fa-search"></i>
                                    </span>
                                    <input type="text" id="searchInput" class="form-control" placeholder="Buscar rúbrica...">
                                </div>
                            </div>
                        </div>

                        <div class="table-responsive">
                            <table class="table table-striped table-hover" id="rubricasTable">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Rúbrica</th>
                                        <th>Descripción</th>
                                        <th>Ponderación</th>
                                        <th>Estado</th>
                                        <th>Fecha Asignación</th>
                                        <th class="text-center">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.OrderBy(m => m.Rubrica.NombreRubrica))
                                    {
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <i class="fas fa-list text-primary me-2"></i>
                                                    <div>
                                                        <strong>@item.Rubrica.NombreRubrica</strong>
                                                        <br><small class="text-muted">ID: @item.Rubrica.IdRubrica</small>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(item.Rubrica.Descripcion))
                                                {
                                                    <span>@item.Rubrica.Descripcion</span>
                                                }
                                                else
                                                {
                                                    <em class="text-muted">Sin descripción</em>
                                                }
                                            </td>
                                            <td>
                                                <span class="badge bg-warning text-dark fs-6">
                                                    @item.Ponderacion.ToString("F2")%
                                                </span>
                                            </td>
                                            <td>
                                                @if (item.Rubrica.Estado == "ACTIVO")
                                                {
                                                    <span class="badge bg-success">
                                                        <i class="fas fa-check me-1"></i>Activo
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">
                                                        <i class="fas fa-times me-1"></i>@item.Rubrica.Estado
                                                    </span>
                                                }
                                            </td>
                                            <td>
                                                <small class="text-muted">
                                                    <i class="fas fa-calendar-alt me-1"></i>
                                                    @item.FechaAsignacion.ToString("dd/MM/yyyy")
                                                </small>
                                            </td>
                                            <td class="text-center">
                                                <div class="btn-group" role="group">
                                                    <a asp-action="Details" 
                                                       asp-route-instrumentoId="@item.InstrumentoId" 
                                                       asp-route-rubricaId="@item.RubricaId"
                                                       class="btn btn-info btn-sm" title="Ver detalles">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                    <a asp-controller="Rubricas" 
                                                       asp-action="Details" 
                                                       asp-route-id="@item.RubricaId"
                                                       class="btn btn-primary btn-sm" title="Ver rúbrica">
                                                        <i class="fas fa-list"></i>
                                                    </a>
                                                    <a asp-action="Edit" 
                                                       asp-route-instrumentoId="@item.InstrumentoId" 
                                                       asp-route-rubricaId="@item.RubricaId"
                                                       class="btn btn-warning btn-sm" title="Editar">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    <a asp-action="Delete" 
                                                       asp-route-instrumentoId="@item.InstrumentoId" 
                                                       asp-route-rubricaId="@item.RubricaId"
                                                       class="btn btn-danger btn-sm" title="Eliminar">
                                                        <i class="fas fa-unlink"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <!-- Resumen de ponderaciones -->
                        <div class="row mt-4">
                            <div class="col-md-6">
                                <div class="card bg-light">
                                    <div class="card-header">
                                        <h6 class="mb-0">
                                            <i class="fas fa-chart-pie me-2"></i>
                                            Distribución de Ponderaciones
                                        </h6>
                                    </div>
                                    <div class="card-body">
                                        @{
                                            var totalPonderacion = Model.Sum(m => m.Ponderacion);
                                            var faltante = 100 - totalPonderacion;
                                        }
                                        <div class="progress mb-2" style="height: 25px;">
                                            <div class="progress-bar bg-success" role="progressbar" 
                                                 style="width: @totalPonderacion%" 
                                                 aria-valuenow="@totalPonderacion" aria-valuemin="0" aria-valuemax="100">
                                                @totalPonderacion.ToString("F1")%
                                            </div>
                                        </div>
                                        <small class="text-muted">
                                            @if (faltante > 0)
                                            {
                                                <span class="text-warning">
                                                    <i class="fas fa-exclamation-triangle me-1"></i>
                                                    Falta @faltante.ToString("F2")% para completar el 100%
                                                </span>
                                            }
                                            else if (faltante < 0)
                                            {
                                                <span class="text-danger">
                                                    <i class="fas fa-exclamation-circle me-1"></i>
                                                    Excede el 100% en @Math.Abs(faltante).ToString("F2")%
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="text-success">
                                                    <i class="fas fa-check-circle me-1"></i>
                                                    Ponderación completa (100%)
                                                </span>
                                            }
                                        </small>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="card bg-light">
                                    <div class="card-header">
                                        <h6 class="mb-0">
                                            <i class="fas fa-info-circle me-2"></i>
                                            Estadísticas
                                        </h6>
                                    </div>
                                    <div class="card-body">
                                        <div class="row text-center">
                                            <div class="col-4">
                                                <h5 class="text-primary mb-0">@Model.Count()</h5>
                                                <small class="text-muted">Rúbricas</small>
                                            </div>
                                            <div class="col-4">
                                                <h5 class="text-success mb-0">@Model.Count(m => m.Rubrica.Estado == "ACTIVO")</h5>
                                                <small class="text-muted">Activas</small>
                                            </div>
                                            <div class="col-4">
                                                <h5 class="text-warning mb-0">@totalPonderacion.ToString("F0")%</h5>
                                                <small class="text-muted">Total</small>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-list fa-3x text-muted mb-3"></i>
                            <h5 class="text-muted">No hay rúbricas asignadas</h5>
                            <p class="text-muted">Este instrumento no tiene rúbricas asignadas aún.</p>
                            <a asp-action="Create" class="btn btn-info">
                                <i class="fas fa-plus me-1"></i>
                                Asignar Primera Rúbrica
                            </a>
                        </div>
                    }

                    <hr class="my-4">

                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="fas fa-arrow-left me-1"></i>
                            Volver a Todas las Asignaciones
                        </a>
                        <a asp-controller="InstrumentosEvaluacion" asp-action="Index" class="btn btn-outline-primary">
                            <i class="fas fa-clipboard-list me-1"></i>
                            Ver Todos los Instrumentos
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Search functionality
        document.getElementById('searchInput').addEventListener('keyup', function() {
            const searchTerm = this.value.toLowerCase();
            const tableRows = document.querySelectorAll('#rubricasTable tbody tr');
            
            tableRows.forEach(row => {
                const text = row.textContent.toLowerCase();
                if (text.includes(searchTerm)) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        });
    </script>
}
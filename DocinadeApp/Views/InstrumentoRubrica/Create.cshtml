@model DocinadeApp.ViewModels.InstrumentoRubricaViewModel

@{
    ViewData["Title"] = "Crear Asignación";
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-link me-2"></i>
                        Crear Nueva Asignación de Rúbrica
                    </h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="InstrumentoId" class="form-label">
                                    <i class="fas fa-clipboard-list me-1"></i>
                                    Instrumento de Evaluación
                                    <span class="text-danger">*</span>
                                </label>
                                <select asp-for="InstrumentoId" class="form-select" asp-items="ViewBag.InstrumentoId" id="instrumentoSelect">
                                    <option value="">-- Seleccione un instrumento --</option>
                                </select>
                                <span asp-validation-for="InstrumentoId" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="RubricaId" class="form-label">
                                    <i class="fas fa-list me-1"></i>
                                    Rúbrica
                                    <span class="text-danger">*</span>
                                </label>
                                <select asp-for="RubricaId" class="form-select" asp-items="ViewBag.RubricaId" id="rubricaSelect">
                                    <option value="">-- Seleccione una rúbrica --</option>
                                </select>
                                <span asp-validation-for="RubricaId" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Ponderacion" class="form-label">
                                    <i class="fas fa-percentage me-1"></i>
                                    Ponderación (%)
                                    <span class="text-danger">*</span>
                                </label>
                                <div class="input-group">
                                    <input asp-for="Ponderacion" class="form-control" type="number" 
                                           step="0.01" min="0" max="100" placeholder="0.00" />
                                    <span class="input-group-text">%</span>
                                </div>
                                <span asp-validation-for="Ponderacion" class="text-danger"></span>
                                <small class="form-text text-muted">
                                    Ingrese la ponderación como porcentaje (0-100)
                                </small>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Vista Previa</label>
                                <div class="card bg-light">
                                    <div class="card-body">
                                        <div id="preview" class="text-muted">
                                            <small>Seleccione un instrumento y rúbrica para ver la vista previa</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Selección de Materia -->
                        <div class="row">
                            <div class="col-md-12 mb-3">
                                <label asp-for="MateriaId" class="form-label">
                                    <i class="fas fa-book me-1"></i>
                                    Materia (Opcional)
                                </label>
                                <select asp-for="MateriaId" class="form-select" id="materiaSelect">
                                    <option value="">-- Seleccione una materia (opcional) --</option>
                                    @if (Model?.MateriasDisponibles != null)
                                    {
                                        @foreach (var materia in Model.MateriasDisponibles)
                                        {
                                            <option value="@materia.Value">@materia.Text</option>
                                        }
                                    }
                                </select>
                                <span asp-validation-for="MateriaId" class="text-danger"></span>
                                <small class="form-text text-muted">
                                    Si selecciona una materia, el instrumento se asociará específicamente a esa materia
                                </small>
                            </div>
                        </div>

                        <!-- Información adicional -->
                        <div class="row">
                            <div class="col-12">
                                <div class="alert alert-info">
                                    <h6><i class="fas fa-info-circle me-2"></i>Información importante:</h6>
                                    <ul class="mb-0">
                                        <li>La ponderación indica el peso que tendrá esta rúbrica dentro del instrumento</li>
                                        <li>No se puede asignar la misma rúbrica dos veces al mismo instrumento</li>
                                        <li>Solo se muestran instrumentos activos y rúbricas en estado ACTIVO</li>
                                        <li><strong>Materia:</strong> Al seleccionar una materia, el instrumento se asociará a ella. Si no selecciona ninguna, el instrumento no tendrá materia asignada</li>
                                    </ul>
                                </div>
                            </div>
                        </div>

                        <hr class="my-4">

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-arrow-left me-1"></i>
                                Volver a la Lista
                            </a>
                            <button type="submit" class="btn btn-success">
                                <i class="fas fa-save me-1"></i>
                                Crear Asignación
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        $(document).ready(function() {
            // Focus on the first select
            $('#instrumentoSelect').focus();
            
            // Update preview when selections change
            $('#instrumentoSelect, #rubricaSelect, #materiaSelect, input[name="Ponderacion"]').on('change input', function() {
                updatePreview();
            });
            
            // Load available rubricas when instrumento changes
            $('#instrumentoSelect').on('change', function() {
                const instrumentoId = $(this).val();
                if (instrumentoId) {
                    loadAvailableRubricas(instrumentoId);
                } else {
                    $('#rubricaSelect').html('<option value="">-- Seleccione una rúbrica --</option>');
                }
                updatePreview();
            });
            
            // Validation for ponderacion
            $('input[name="Ponderacion"]').on('input', function() {
                const value = parseFloat($(this).val());
                if (value < 0) {
                    $(this).val(0);
                } else if (value > 100) {
                    $(this).val(100);
                }
                updatePreview();
            });
        });
        
        function loadAvailableRubricas(instrumentoId) {
            $.ajax({
                url: '@Url.Action("GetRubricasDisponibles", "InstrumentoRubrica")',
                type: 'GET',
                data: { instrumentoId: instrumentoId },
                dataType: 'json',
                success: function(data) {
                    const rubricaSelect = $('#rubricaSelect');
                    rubricaSelect.html('<option value="">-- Seleccione una rúbrica --</option>');
                    
                    // Ensure data is an array and check its length properly
                    if (Array.isArray(data) && data.length === 0) {
                        rubricaSelect.append('<option value="" disabled>No hay rúbricas disponibles</option>');
                    } else if (Array.isArray(data) && data.length > 0) {
                        $.each(data, function(index, item) {
                            rubricaSelect.append('<option value="' + item.value + '">' + item.text + '</option>');
                        });
                    } else {
                        // Handle unexpected data format
                        console.error('Formato de datos inesperado:', data);
                        rubricaSelect.append('<option value="" disabled>Error al cargar rúbricas</option>');
                    }
                },
                error: function(xhr, status, error) {
                    console.error('Error en la solicitud AJAX:', status, error);
                    console.error('Respuesta del servidor:', xhr.responseText);
                    alert('Error al cargar las rúbricas disponibles');
                }
            });
        }
        
        function updatePreview() {
            const instrumentoText = $('#instrumentoSelect option:selected').text();
            const rubricaText = $('#rubricaSelect option:selected').text();
            const materiaText = $('#materiaSelect option:selected').text();
            const ponderacion = $('input[name="Ponderacion"]').val();
            
            let preview = '';
            
            if (instrumentoText && instrumentoText !== '-- Seleccione un instrumento --' &&
                rubricaText && rubricaText !== '-- Seleccione una rúbrica --') {
                
                preview = `<strong>Asignación:</strong><br>
                          <i class="fas fa-clipboard-list text-info me-1"></i> ${instrumentoText}<br>
                          <i class="fas fa-arrow-down text-muted me-1"></i><br>
                          <i class="fas fa-list text-primary me-1"></i> ${rubricaText}`;
                
                if (materiaText && materiaText !== '-- Seleccione una materia (opcional) --') {
                    preview += `<br><i class="fas fa-book text-success me-1"></i> ${materiaText}`;
                }
                
                if (ponderacion) {
                    preview += `<br><span class="badge bg-warning text-dark mt-1">${ponderacion}%</span>`;
                }
            } else {
                preview = '<small class="text-muted">Seleccione un instrumento y rúbrica para ver la vista previa</small>';
            }
            
            $('#preview').html(preview);
        }
    </script>
}
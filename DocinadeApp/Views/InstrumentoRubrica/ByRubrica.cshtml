@model IEnumerable<DocinadeApp.Models.InstrumentoRubrica>

@{
    ViewData["Title"] = "Instrumentos de la Rúbrica";
    var rubricaNombre = ViewBag.RubricaNombre as string;
    var rubricaId = ViewBag.RubricaId as int?;
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <h4 class="mb-0">
                            <i class="fas fa-list me-2"></i>
                            Instrumentos que usan: @rubricaNombre
                        </h4>
                        <div class="btn-group">
                            <a asp-action="Create" class="btn btn-light btn-sm">
                                <i class="fas fa-plus me-1"></i>
                                Asignar a Instrumento
                            </a>
                            <a asp-controller="Rubricas" 
                               asp-action="Details" 
                               asp-route-id="@rubricaId" 
                               class="btn btn-outline-light btn-sm">
                                <i class="fas fa-eye me-1"></i>
                                Ver Rúbrica
                            </a>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item">
                                <a asp-action="Index">Asignaciones</a>
                            </li>
                            <li class="breadcrumb-item">
                                <a asp-controller="Rubricas" asp-action="Index">Rúbricas</a>
                            </li>
                            <li class="breadcrumb-item active" aria-current="page">@rubricaNombre</li>
                        </ol>
                    </nav>

                    @if (Model.Any())
                    {
                        <div class="row mb-3">
                            <div class="col-md-8">
                                <div class="alert alert-primary">
                                    <i class="fas fa-info-circle me-2"></i>
                                    Esta rúbrica está asignada a <strong>@Model.Count()</strong> instrumento(s) de evaluación
                                    con ponderaciones que van desde <strong>@Model.Min(m => m.Ponderacion).ToString("F2")%</strong>
                                    hasta <strong>@Model.Max(m => m.Ponderacion).ToString("F2")%</strong>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="fas fa-search"></i>
                                    </span>
                                    <input type="text" id="searchInput" class="form-control" placeholder="Buscar instrumento...">
                                </div>
                            </div>
                        </div>

                        <div class="table-responsive">
                            <table class="table table-striped table-hover" id="instrumentosTable">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Instrumento de Evaluación</th>
                                        <th>Descripción</th>
                                        <th>Ponderación</th>
                                        <th>Estado</th>
                                        <th>Fecha Asignación</th>
                                        <th class="text-center">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.OrderBy(m => m.InstrumentoEvaluacion.Nombre))
                                    {
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <i class="fas fa-clipboard-list text-info me-2"></i>
                                                    <div>
                                                        <strong>@item.InstrumentoEvaluacion.Nombre</strong>
                                                        <br><small class="text-muted">ID: @item.InstrumentoEvaluacion.InstrumentoId</small>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(item.InstrumentoEvaluacion.Descripcion))
                                                {
                                                    <span>@item.InstrumentoEvaluacion.Descripcion</span>
                                                }
                                                else
                                                {
                                                    <em class="text-muted">Sin descripción</em>
                                                }
                                            </td>
                                            <td>
                                                <span class="badge bg-warning text-dark fs-6">
                                                    @item.Ponderacion.ToString("F2")%
                                                </span>
                                            </td>
                                            <td>
                                                @if (item.InstrumentoEvaluacion.Activo)
                                                {
                                                    <span class="badge bg-success">
                                                        <i class="fas fa-check me-1"></i>Activo
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">
                                                        <i class="fas fa-times me-1"></i>Inactivo
                                                    </span>
                                                }
                                            </td>
                                            <td>
                                                <small class="text-muted">
                                                    <i class="fas fa-calendar-alt me-1"></i>
                                                    @item.FechaAsignacion.ToString("dd/MM/yyyy")
                                                </small>
                                            </td>
                                            <td class="text-center">
                                                <div class="btn-group" role="group">
                                                    <a asp-action="Details" 
                                                       asp-route-instrumentoId="@item.InstrumentoId" 
                                                       asp-route-rubricaId="@item.RubricaId"
                                                       class="btn btn-info btn-sm" title="Ver detalles">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                    <a asp-controller="InstrumentosEvaluacion" 
                                                       asp-action="Details" 
                                                       asp-route-id="@item.InstrumentoId"
                                                       class="btn btn-primary btn-sm" title="Ver instrumento">
                                                        <i class="fas fa-clipboard-list"></i>
                                                    </a>
                                                    <a asp-action="Edit" 
                                                       asp-route-instrumentoId="@item.InstrumentoId" 
                                                       asp-route-rubricaId="@item.RubricaId"
                                                       class="btn btn-warning btn-sm" title="Editar">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    <a asp-action="Delete" 
                                                       asp-route-instrumentoId="@item.InstrumentoId" 
                                                       asp-route-rubricaId="@item.RubricaId"
                                                       class="btn btn-danger btn-sm" title="Eliminar">
                                                        <i class="fas fa-unlink"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <!-- Análisis de uso de la rúbrica -->
                        <div class="row mt-4">
                            <div class="col-md-8">
                                <div class="card bg-light">
                                    <div class="card-header">
                                        <h6 class="mb-0">
                                            <i class="fas fa-chart-line me-2"></i>
                                            Análisis de Ponderaciones
                                        </h6>
                                    </div>
                                    <div class="card-body">
                                        @{
                                            var ponderaciones = Model.Select(m => m.Ponderacion).ToList();
                                            var promedio = ponderaciones.Average();
                                            var minima = ponderaciones.Min();
                                            var maxima = ponderaciones.Max();
                                        }
                                        <div class="row text-center">
                                            <div class="col-3">
                                                <h5 class="text-success mb-1">@promedio.ToString("F1")%</h5>
                                                <small class="text-muted">Promedio</small>
                                            </div>
                                            <div class="col-3">
                                                <h5 class="text-info mb-1">@minima.ToString("F1")%</h5>
                                                <small class="text-muted">Mínima</small>
                                            </div>
                                            <div class="col-3">
                                                <h5 class="text-warning mb-1">@maxima.ToString("F1")%</h5>
                                                <small class="text-muted">Máxima</small>
                                            </div>
                                            <div class="col-3">
                                                <h5 class="text-primary mb-1">@(maxima - minima).ToString("F1")%</h5>
                                                <small class="text-muted">Rango</small>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="card bg-light">
                                    <div class="card-header">
                                        <h6 class="mb-0">
                                            <i class="fas fa-info-circle me-2"></i>
                                            Estado de Instrumentos
                                        </h6>
                                    </div>
                                    <div class="card-body">
                                        <div class="row text-center">
                                            <div class="col-6">
                                                <h5 class="text-success mb-0">@Model.Count(m => m.InstrumentoEvaluacion.Activo)</h5>
                                                <small class="text-muted">Activos</small>
                                            </div>
                                            <div class="col-6">
                                                <h5 class="text-secondary mb-0">@Model.Count(m => !m.InstrumentoEvaluacion.Activo)</h5>
                                                <small class="text-muted">Inactivos</small>
                                            </div>
                                        </div>
                                        <hr class="my-2">
                                        <small class="text-muted">
                                            <i class="fas fa-lightbulb me-1"></i>
                                            @if (Model.All(m => m.InstrumentoEvaluacion.Activo))
                                            {
                                                <span class="text-success">Todos los instrumentos están activos</span>
                                            }
                                            else if (Model.Any(m => !m.InstrumentoEvaluacion.Activo))
                                            {
                                                <span class="text-warning">Algunos instrumentos están inactivos</span>
                                            }
                                        </small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-clipboard-list fa-3x text-muted mb-3"></i>
                            <h5 class="text-muted">No hay instrumentos asignados</h5>
                            <p class="text-muted">Esta rúbrica no está siendo utilizada por ningún instrumento de evaluación.</p>
                            <a asp-action="Create" class="btn btn-primary">
                                <i class="fas fa-plus me-1"></i>
                                Asignar a Primer Instrumento
                            </a>
                        </div>
                    }

                    <hr class="my-4">

                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="fas fa-arrow-left me-1"></i>
                            Volver a Todas las Asignaciones
                        </a>
                        <a asp-controller="Rubricas" asp-action="Index" class="btn btn-outline-primary">
                            <i class="fas fa-list me-1"></i>
                            Ver Todas las Rúbricas
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Search functionality
        document.getElementById('searchInput').addEventListener('keyup', function() {
            const searchTerm = this.value.toLowerCase();
            const tableRows = document.querySelectorAll('#instrumentosTable tbody tr');
            
            tableRows.forEach(row => {
                const text = row.textContent.toLowerCase();
                if (text.includes(searchTerm)) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        });
    </script>
}
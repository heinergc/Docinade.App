@model DocinadeApp.Models.InstrumentoRubrica

@{
    ViewData["Title"] = "Detalles de la Asignación";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-info text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-link me-2"></i>
                        Detalles de la Asignación de Rúbrica
                    </h4>
                </div>
                <div class="card-body">
                    <!-- Información principal de la asignación -->
                    <div class="row">
                        <div class="col-lg-6">
                            <div class="card h-100">
                                <div class="card-header bg-light">
                                    <h5 class="mb-0">
                                        <i class="fas fa-clipboard-list text-info me-2"></i>
                                        Instrumento de Evaluación
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <table class="table table-borderless mb-0">
                                        <tr>
                                            <td class="fw-bold text-muted" style="width: 120px;">ID:</td>
                                            <td>@Model.InstrumentoEvaluacion.InstrumentoId</td>
                                        </tr>
                                        <tr>
                                            <td class="fw-bold text-muted">Nombre:</td>
                                            <td><strong class="fs-5">@Model.InstrumentoEvaluacion.Nombre</strong></td>
                                        </tr>
                                        <tr>
                                            <td class="fw-bold text-muted">Descripción:</td>
                                            <td>
                                                @if (string.IsNullOrEmpty(Model.InstrumentoEvaluacion.Descripcion))
                                                {
                                                    <em class="text-muted">Sin descripción</em>
                                                }
                                                else
                                                {
                                                    @Model.InstrumentoEvaluacion.Descripcion
                                                }
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="fw-bold text-muted">Estado:</td>
                                            <td>
                                                @if (Model.InstrumentoEvaluacion.Activo)
                                                {
                                                    <span class="badge bg-success">
                                                        <i class="fas fa-check me-1"></i>Activo
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">
                                                        <i class="fas fa-times me-1"></i>Inactivo
                                                    </span>
                                                }
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="fw-bold text-muted">Fecha Creación:</td>
                                            <td>@Model.InstrumentoEvaluacion.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</td>
                                        </tr>
                                    </table>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-6">
                            <div class="card h-100">
                                <div class="card-header bg-light">
                                    <h5 class="mb-0">
                                        <i class="fas fa-list text-primary me-2"></i>
                                        Rúbrica Asignada
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <table class="table table-borderless mb-0">
                                        <tr>
                                            <td class="fw-bold text-muted" style="width: 120px;">ID:</td>
                                            <td>@Model.Rubrica.IdRubrica</td>
                                        </tr>
                                        <tr>
                                            <td class="fw-bold text-muted">Nombre:</td>
                                            <td><strong class="fs-5">@Model.Rubrica.NombreRubrica</strong></td>
                                        </tr>
                                        <tr>
                                            <td class="fw-bold text-muted">Descripción:</td>
                                            <td>
                                                @if (string.IsNullOrEmpty(Model.Rubrica.Descripcion))
                                                {
                                                    <em class="text-muted">Sin descripción</em>
                                                }
                                                else
                                                {
                                                    @Model.Rubrica.Descripcion
                                                }
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="fw-bold text-muted">Estado:</td>
                                            <td>
                                                @if (Model.Rubrica.Estado == "ACTIVO")
                                                {
                                                    <span class="badge bg-success">
                                                        <i class="fas fa-check me-1"></i>Activo
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">
                                                        <i class="fas fa-times me-1"></i>@Model.Rubrica.Estado
                                                    </span>
                                                }
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="fw-bold text-muted">Fecha Creación:</td>
                                            <td>@Model.Rubrica.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</td>
                                        </tr>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4">

                    <!-- Información de la asignación -->
                    <div class="row">
                        <div class="col-lg-8">
                            <div class="card">
                                <div class="card-header bg-success text-white">
                                    <h5 class="mb-0">
                                        <i class="fas fa-link me-2"></i>
                                        Información de la Asignación
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="text-center p-3">
                                                <h3 class="text-warning mb-1">@Model.Ponderacion.ToString("F2")%</h3>
                                                <small class="text-muted">Ponderación</small>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="text-center p-3">
                                                <h6 class="text-muted mb-1">
                                                    <i class="fas fa-calendar-alt me-1"></i>
                                                    @Model.FechaAsignacion.ToString("dd/MM/yyyy")
                                                </h6>
                                                <small class="text-muted">
                                                    a las @Model.FechaAsignacion.ToString("HH:mm")
                                                </small>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-4">
                            <div class="card bg-light">
                                <div class="card-header">
                                    <h6 class="mb-0">
                                        <i class="fas fa-info-circle me-2"></i>
                                        Información Adicional
                                    </h6>
                                </div>
                                <div class="card-body">
                                    <small class="text-muted">
                                        <i class="fas fa-lightbulb me-1"></i>
                                        Esta asignación permite que el instrumento de evaluación utilice la rúbrica seleccionada con el peso especificado.
                                    </small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4">

                    <!-- Información de materias asignadas -->
                    <div class="row">
                        <div class="col-12">
                            <div class="card">
                                <div class="card-header bg-secondary text-white">
                                    <h5 class="mb-0">
                                        <i class="fas fa-book me-2"></i>
                                        Materias Asignadas al Instrumento
                                    </h5>
                                </div>
                                <div class="card-body">
                                    @if (Model.InstrumentoEvaluacion.InstrumentoMaterias.Any())
                                    {
                                        <div class="row">
                                            @foreach (var instrumentoMateria in Model.InstrumentoEvaluacion.InstrumentoMaterias)
                                            {
                                                <div class="col-md-6 col-lg-4 mb-3">
                                                    <div class="card h-100 border-success">
                                                        <div class="card-body">
                                                            <h6 class="card-title text-success">
                                                                <i class="fas fa-book me-1"></i>
                                                                @instrumentoMateria.Materia.Codigo
                                                            </h6>
                                                            <p class="card-text">@instrumentoMateria.Materia.Nombre</p>
                                                            <small class="text-muted">
                                                                <i class="fas fa-calendar me-1"></i>
                                                                Asignada: @instrumentoMateria.FechaAsignacion.ToString("dd/MM/yyyy")
                                                            </small>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="text-center py-4">
                                            <div class="mb-3">
                                                <i class="fas fa-exclamation-triangle text-warning" style="font-size: 3rem;"></i>
                                            </div>
                                            <h5 class="text-muted">Sin Materia Asignada</h5>
                                            <p class="text-muted">Este instrumento no tiene ninguna materia asignada actualmente.</p>
                                            
                                            <!-- Botón para asignar materia usando modal -->
                                            <button type="button" class="btn btn-success me-2" data-bs-toggle="modal" data-bs-target="#asignarMateriaModal">
                                                <i class="fas fa-plus me-1"></i>
                                                Asignar Materia
                                            </button>
                                            
                                            <!-- Botón para ir a Create -->
                                            <a href="https://localhost:18163/InstrumentoRubrica/Create" class="btn btn-outline-success">
                                                <i class="fas fa-external-link-alt me-1"></i>
                                                Asignar Otra Materia
                                            </a>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4">

                    <!-- Acciones rápidas -->
                    <div class="row">
                        <div class="col-12">
                            <div class="card">
                                <div class="card-header">
                                    <h6 class="mb-0">
                                        <i class="fas fa-bolt me-2"></i>
                                        Acciones Rápidas
                                    </h6>
                                </div>
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <h6>Ver elementos relacionados:</h6>
                                            <div class="btn-group-vertical w-100" role="group">
                                                <a asp-controller="InstrumentosEvaluacion" 
                                                   asp-action="Details" 
                                                   asp-route-id="@Model.InstrumentoId" 
                                                   class="btn btn-outline-info btn-sm">
                                                    <i class="fas fa-clipboard-list me-1"></i>
                                                    Ver detalles del instrumento
                                                </a>
                                                <a asp-controller="Rubricas" 
                                                   asp-action="Details" 
                                                   asp-route-id="@Model.RubricaId" 
                                                   class="btn btn-outline-primary btn-sm">
                                                    <i class="fas fa-list me-1"></i>
                                                    Ver detalles de la rúbrica
                                                </a>
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <h6>Gestionar asignaciones:</h6>
                                            <div class="btn-group-vertical w-100" role="group">
                                                <a asp-action="ByInstrumento" 
                                                   asp-route-id="@Model.InstrumentoId" 
                                                   class="btn btn-outline-success btn-sm">
                                                    <i class="fas fa-search me-1"></i>
                                                    Ver todas las rúbricas de este instrumento
                                                </a>
                                                <a asp-action="ByRubrica" 
                                                   asp-route-id="@Model.RubricaId" 
                                                   class="btn btn-outline-warning btn-sm">
                                                    <i class="fas fa-search me-1"></i>
                                                    Ver todos los instrumentos de esta rúbrica
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <hr class="my-4">

                    <!-- Botones de acción principal -->
                    <div class="d-flex justify-content-between flex-wrap gap-2">
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="fas fa-arrow-left me-1"></i>
                            Volver a la Lista
                        </a>
                        <div class="btn-group" role="group">
                            <a asp-action="Edit" 
                               asp-route-instrumentoId="@Model.InstrumentoId" 
                               asp-route-rubricaId="@Model.RubricaId" 
                               class="btn btn-warning">
                                <i class="fas fa-edit me-1"></i>
                                Editar Ponderación
                            </a>
                            <a asp-action="Delete" 
                               asp-route-instrumentoId="@Model.InstrumentoId" 
                               asp-route-rubricaId="@Model.RubricaId" 
                               class="btn btn-danger">
                                <i class="fas fa-unlink me-1"></i>
                                Eliminar Asignación
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal para asignar materia -->
<div class="modal fade" id="asignarMateriaModal" tabindex="-1" aria-labelledby="asignarMateriaModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="AsignarMateria" method="post">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title" id="asignarMateriaModalLabel">
                        <i class="fas fa-book me-2"></i>
                        Asignar Materia al Instrumento
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="instrumentoId" value="@Model.InstrumentoId" />
                    <input type="hidden" name="rubricaId" value="@Model.RubricaId" />
                    
                    <div class="mb-3">
                        <label for="materiaSelect" class="form-label">
                            <i class="fas fa-book me-1"></i>
                            Seleccionar Materia
                            <span class="text-danger">*</span>
                        </label>
                        <select id="materiaSelect" name="materiaId" class="form-select" required>
                            <option value="">-- Seleccione una materia --</option>
                            @if (ViewBag.MateriasDisponibles != null)
                            {
                                @foreach (var materia in (ViewBag.MateriasDisponibles as List<SelectListItem> ?? new List<SelectListItem>()))
                                {
                                    <option value="@materia.Value">@materia.Text</option>
                                }
                            }
                        </select>
                    </div>
                    
                    <div class="alert alert-info">
                        <i class="fas fa-info-circle me-2"></i>
                        <strong>Información:</strong> Al asignar una materia, el instrumento estará disponible para evaluaciones específicas de esa materia.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="fas fa-times me-1"></i>
                        Cancelar
                    </button>
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-check me-1"></i>
                        Asignar Materia
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
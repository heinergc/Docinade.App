@model RubricasApp.Web.Models.InstrumentoRubrica

@{
    ViewData["Title"] = "Eliminar Asignación";
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        Confirmar Eliminación de Asignación
                    </h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-danger">
                        <i class="fas fa-warning me-2"></i>
                        <strong>¿Está seguro que desea eliminar esta asignación?</strong>
                        <br>
                        Esta acción eliminará permanentemente la relación entre el instrumento y la rúbrica.
                        <br>
                        <strong>Esta acción no se puede deshacer.</strong>
                    </div>

                    <!-- Información de la asignación a eliminar -->
                    <div class="card mb-4">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">
                                <i class="fas fa-info-circle me-2"></i>
                                Información de la Asignación a Eliminar
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-6">
                                    <h6 class="text-info">
                                        <i class="fas fa-clipboard-list me-1"></i>
                                        Instrumento de Evaluación
                                    </h6>
                                    <table class="table table-borderless table-sm">
                                        <tr>
                                            <td class="fw-bold text-muted" style="width: 80px;">ID:</td>
                                            <td>@Model.InstrumentoEvaluacion.InstrumentoId</td>
                                        </tr>
                                        <tr>
                                            <td class="fw-bold text-muted">Nombre:</td>
                                            <td><strong>@Model.InstrumentoEvaluacion.Nombre</strong></td>
                                        </tr>
                                        <tr>
                                            <td class="fw-bold text-muted">Estado:</td>
                                            <td>
                                                @if (Model.InstrumentoEvaluacion.Activo)
                                                {
                                                    <span class="badge bg-success">Activo</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">Inactivo</span>
                                                }
                                            </td>
                                        </tr>
                                    </table>
                                </div>
                                <div class="col-md-6">
                                    <h6 class="text-primary">
                                        <i class="fas fa-list me-1"></i>
                                        Rúbrica Asignada
                                    </h6>
                                    <table class="table table-borderless table-sm">
                                        <tr>
                                            <td class="fw-bold text-muted" style="width: 80px;">ID:</td>
                                            <td>@Model.Rubrica.IdRubrica</td>
                                        </tr>
                                        <tr>
                                            <td class="fw-bold text-muted">Nombre:</td>
                                            <td><strong>@Model.Rubrica.NombreRubrica</strong></td>
                                        </tr>
                                        <tr>
                                            <td class="fw-bold text-muted">Estado:</td>
                                            <td>
                                                @if (Model.Rubrica.Estado == "ACTIVO")
                                                {
                                                    <span class="badge bg-success">Activo</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">@Model.Rubrica.Estado</span>
                                                }
                                            </td>
                                        </tr>
                                    </table>
                                </div>
                            </div>
                            <hr>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="text-center p-2 bg-warning rounded">
                                        <h5 class="mb-1">@Model.Ponderacion.ToString("F2")%</h5>
                                        <small class="text-muted">Ponderación</small>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="text-center p-2 bg-light rounded">
                                        <h6 class="mb-1">@Model.FechaAsignacion.ToString("dd/MM/yyyy HH:mm")</h6>
                                        <small class="text-muted">Fecha de Asignación</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Consecuencias de la eliminación -->
                    <div class="alert alert-warning">
                        <h6><i class="fas fa-exclamation-triangle me-2"></i>Consecuencias de esta acción:</h6>
                        <ul class="mb-0">
                            <li>Se eliminará la relación entre el instrumento "@Model.InstrumentoEvaluacion.Nombre" y la rúbrica "@Model.Rubrica.NombreRubrica"</li>
                            <li>La ponderación del @Model.Ponderacion.ToString("F2")% se perderá</li>
                            <li>El instrumento ya no podrá utilizar esta rúbrica para evaluaciones</li>
                            <li>Los datos históricos de evaluaciones realizadas no se verán afectados</li>
                        </ul>
                    </div>

                    <form asp-action="Delete" class="mt-4">
                        <input type="hidden" asp-for="InstrumentoId" />
                        <input type="hidden" asp-for="RubricaId" />
                        
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-arrow-left me-1"></i>
                                Cancelar
                            </a>
                            <div>
                                <a asp-action="Details" 
                                   asp-route-instrumentoId="@Model.InstrumentoId" 
                                   asp-route-rubricaId="@Model.RubricaId" 
                                   class="btn btn-info me-2">
                                    <i class="fas fa-eye me-1"></i>
                                    Ver Detalles
                                </a>
                                <button type="submit" class="btn btn-danger">
                                    <i class="fas fa-unlink me-1"></i>
                                    Confirmar Eliminación
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Add confirmation dialog
            $('form').on('submit', function(e) {
                const instrumentoNombre = '@Model.InstrumentoEvaluacion.Nombre';
                const rubricaNombre = '@Model.Rubrica.NombreRubrica';
                const mensaje = `¿Está absolutamente seguro que desea eliminar la asignación entre "${instrumentoNombre}" y "${rubricaNombre}"?\n\nEsta acción es permanente y no se puede deshacer.`;
                
                if (!confirm(mensaje)) {
                    e.preventDefault();
                    return false;
                }
            });
        });
    </script>
}
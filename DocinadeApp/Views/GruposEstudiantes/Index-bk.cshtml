@model RubricasApp.Web.ViewModels.Grupos.GrupoEstudianteIndexViewModel
@using RubricasApp.Web.Models
@{
    ViewData["Title"] = "Grupos de Estudiantes";
}

<div class="page-header">
    <div class="row align-items-center">
        <div class="col-md-8">
            <h1 class="page-title mb-0">
                <i class="fas fa-users-cog text-primary me-2"></i>
                Grupos de Estudiantes
            </h1>
            <p class="text-muted mt-2">Gestiona y organiza estudiantes por grupos académicos</p>
        </div>
        <div class="col-md-4 text-end">
            <div class="btn-group">
                <a href="@Url.Action("Create")" class="btn btn-modern primary">
                    <i class="fas fa-plus"></i> Crear Grupo
                </a>
                <a href="@Url.Action("Estadisticas")" class="btn btn-modern secondary">
                    <i class="fas fa-chart-bar"></i> Estadísticas
                </a>
                <a href="@Url.Action("ExportarExcel", Model.Filtros)" class="btn btn-modern info">
                    <i class="fas fa-download"></i> Exportar
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Estadísticas rápidas -->
<div class="row mb-4">
    @foreach (var estadistica in Model.EstadisticasPorTipo)
    {
        <div class="col-md-3 mb-3">
            <div class="modern-card">
                <div class="card-body text-center">
                    <div class="stat-icon mb-2">
                        @{
                            string iconClass = estadistica.Key switch
                            {
                                TipoGrupo.Seccion => "fas fa-layer-group",
                                TipoGrupo.Nivel => "fas fa-graduation-cap", 
                                TipoGrupo.Modalidad => "fas fa-laptop",
                                _ => "fas fa-users"
                            };
                        }
                        <i class="@iconClass fa-2x text-primary"></i>
                    </div>
                    <h3 class="stat-number">@estadistica.Value</h3>
                    <p class="stat-label">@estadistica.Key.ToString()</p>
                </div>
            </div>
        </div>
    }
</div>

<!-- Filtros -->
<div class="filters-container modern-card mb-4">
    <div class="card-header">
        <h5 class="mb-0">
            <i class="fas fa-filter me-2"></i>
            Filtros de Búsqueda
        </h5>
    </div>
    <div class="card-body">
        <form method="get" action="@Url.Action("Index")" id="filtrosForm">
            <div class="row">
                <div class="col-md-3">
                    <label class="form-label">Período Académico</label>
                    <select name="Filtros.PeriodoAcademicoId" class="form-select" asp-for="Filtros.PeriodoAcademicoId">
                        <option value="">Todos los períodos</option>
                        @if (ViewBag.PeriodosAcademicos != null)
                        {
                            @foreach (var periodo in (List<RubricasApp.Web.ViewModels.Shared.PeriodoAcademicoDropdownViewModel>)ViewBag.PeriodosAcademicos)
                            {
                                <option value="@periodo.Id" selected="@(periodo.Id == Model.Filtros.PeriodoAcademicoId)">
                                    @periodo.Nombre
                                </option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Tipo de Grupo</label>
                    <select name="Filtros.TipoGrupo" class="form-select" asp-for="Filtros.TipoGrupo">
                        <option value="">Todos los tipos</option>
                        <option value="Seccion" selected="@(Model.Filtros.TipoGrupo == TipoGrupo.Seccion)">Sección</option>
                        <option value="Nivel" selected="@(Model.Filtros.TipoGrupo == TipoGrupo.Nivel)">Nivel</option>
                        <option value="Modalidad" selected="@(Model.Filtros.TipoGrupo == TipoGrupo.Modalidad)">Modalidad</option>
                        <option value="Custom" selected="@(Model.Filtros.TipoGrupo == TipoGrupo.Custom)">Personalizado</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Estado</label>
                    <select name="Filtros.Estado" class="form-select" asp-for="Filtros.Estado">
                        <option value="">Todos los estados</option>
                        <option value="Activo" selected="@(Model.Filtros.Estado == EstadoGrupo.Activo)">Activo</option>
                        <option value="Inactivo" selected="@(Model.Filtros.Estado == EstadoGrupo.Inactivo)">Inactivo</option>
                        <option value="Cerrado" selected="@(Model.Filtros.Estado == EstadoGrupo.Cerrado)">Cerrado</option>
                        <option value="Suspendido" selected="@(Model.Filtros.Estado == EstadoGrupo.Suspendido)">Suspendido</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Código</label>
                    <input type="text" name="Filtros.Codigo" class="form-control" placeholder="Buscar código..." 
                           value="@Model.Filtros.Codigo" asp-for="Filtros.Codigo">
                </div>
                <div class="col-md-3">
                    <label class="form-label">Nombre</label>
                    <input type="text" name="Filtros.Nombre" class="form-control" placeholder="Buscar nombre..." 
                           value="@Model.Filtros.Nombre" asp-for="Filtros.Nombre">
                </div>
            </div>
            <div class="row mt-3">
                <div class="col-md-6">
                    <div class="form-check">
                        <input type="checkbox" name="Filtros.SoloConEspacio" class="form-check-input" 
                               asp-for="Filtros.SoloConEspacio" checked="@Model.Filtros.SoloConEspacio">
                        <label class="form-check-label">Solo grupos con capacidad disponible</label>
                    </div>
                </div>
                <div class="col-md-6 text-end">
                    <button type="submit" class="btn btn-modern primary">
                        <i class="fas fa-search"></i> Buscar
                    </button>
                    <a href="@Url.Action("Index")" class="btn btn-modern secondary">
                        <i class="fas fa-times"></i> Limpiar
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Lista de grupos -->
<div class="table-container modern-card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
            <i class="fas fa-list me-2"></i>
            Grupos (@Model.Paginacion.TotalElementos total)
        </h5>
        <div class="btn-group btn-group-sm">
            <button class="btn btn-outline-secondary" onclick="toggleView('card')">
                <i class="fas fa-th-large"></i>
            </button>
            <button class="btn btn-outline-secondary active" onclick="toggleView('table')">
                <i class="fas fa-list"></i>
            </button>
        </div>
    </div>
    <div class="card-body p-0">
        @if (Model.Grupos.Any())
        {
            <div class="table-responsive">
                <table class="table table-modern table-hover mb-0">
                    <thead>
                        <tr>
                            <th>
                                <i class="fas fa-tag me-1"></i>
                                Código
                            </th>
                            <th>
                                <i class="fas fa-users me-1"></i>
                                Grupo
                            </th>
                            <th>
                                <i class="fas fa-layer-group me-1"></i>
                                Tipo
                            </th>
                            <th>
                                <i class="fas fa-user-friends me-1"></i>
                                Estudiantes
                            </th>
                            <th>
                                <i class="fas fa-book me-1"></i>
                                Materias
                            </th>
                            <th>
                                <i class="fas fa-info-circle me-1"></i>
                                Estado
                            </th>
                            <th>
                                <i class="fas fa-calendar me-1"></i>
                                Creado
                            </th>
                            <th width="140">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var grupo in Model.Grupos)
                        {
                            <tr class="@(grupo.EstaCompleto ? "table-warning" : "")">
                                <td>
                                    <span class="badge bg-primary fs-6">@grupo.Codigo</span>
                                </td>
                                <td>
                                    <div>
                                        <strong>@grupo.Nombre</strong>
                                        @if (!string.IsNullOrEmpty(grupo.Nivel))
                                        {
                                            <br><small class="text-muted">Nivel: @grupo.Nivel</small>
                                        }
                                    </div>
                                </td>
                                <td>
                                    <span class="badge badge-tipo-@(grupo.TipoGrupo.ToString().ToLower())">
                                        @grupo.TipoGrupoDisplay
                                    </span>
                                </td>
                                <td>
                                    <div class="estudiantes-info">
                                        <span class="fw-bold">@grupo.CantidadEstudiantes</span>
                                        @if (grupo.CapacidadMaxima.HasValue)
                                        {
                                            <span class="text-muted">/@grupo.CapacidadMaxima</span>
                                        }
                                        <br>
                                        <small class="text-@(grupo.EstaCompleto ? "warning" : "success")">
                                            @grupo.EstadoCapacidad
                                        </small>
                                    </div>
                                </td>
                                <td>
                                    @if (grupo.Materias.Any())
                                    {
                                        <span class="badge bg-info">@grupo.Materias.Count</span>
                                        <small class="d-block text-muted">
                                            @string.Join(", ", grupo.Materias.Take(2))
                                            @if (grupo.Materias.Count > 2)
                                            {
                                                <span>y @(grupo.Materias.Count - 2) más...</span>
                                            }
                                        </small>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Sin materias</span>
                                    }
                                </td>
                                <td>
                                    <span class="badge bg-@(grupo.Estado == EstadoGrupo.Activo ? "success" : grupo.Estado == EstadoGrupo.Inactivo ? "secondary" : "danger")">
                                        @grupo.EstadoDisplay
                                    </span>
                                </td>
                                <td>
                                    <small>
                                        @grupo.FechaCreacion.ToString("dd/MM/yyyy")
                                        @if (!string.IsNullOrEmpty(grupo.CreadoPor))
                                        {
                                            <br><span class="text-muted">por @grupo.CreadoPor</span>
                                        }
                                    </small>
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a href="@Url.Action("Details", new { id = grupo.GrupoId })" 
                                           class="btn btn-outline-info" title="Ver detalles">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a href="@Url.Action("AsignarEstudiantes", new { id = grupo.GrupoId })" 
                                           class="btn btn-outline-success" title="Asignar estudiantes">
                                            <i class="fas fa-user-plus"></i>
                                        </a>
                                        <a href="@Url.Action("Edit", new { id = grupo.GrupoId })" 
                                           class="btn btn-outline-warning" title="Editar">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <div class="dropdown">
                                            <button class="btn btn-outline-secondary btn-sm dropdown-toggle" 
                                                    type="button" data-bs-toggle="dropdown">
                                                <i class="fas fa-ellipsis-v"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end">
                                                <li>
                                                    <a class="dropdown-item" href="@Url.Action("ExportarEstudiantesExcel", new { id = grupo.GrupoId })">
                                                        <i class="fas fa-download me-2"></i>Exportar estudiantes
                                                    </a>
                                                </li>
                                                <li><hr class="dropdown-divider"></li>
                                                <li>
                                                    <a class="dropdown-item text-danger" 
                                                       href="@Url.Action("Delete", new { id = grupo.GrupoId })"
                                                       onclick="return confirm('żEstá seguro de eliminar este grupo?')">
                                                        <i class="fas fa-trash me-2"></i>Eliminar
                                                    </a>
                                                </li>
                                            </ul>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="fas fa-users fa-3x text-muted mb-3"></i>
                <h5 class="text-muted">No se encontraron grupos</h5>
                <p class="text-muted">
                    @if (Model.Filtros.PeriodoAcademicoId.HasValue || !string.IsNullOrEmpty(Model.Filtros.Codigo) || !string.IsNullOrEmpty(Model.Filtros.Nombre))
                    {
                        <span>No hay grupos que coincidan con los filtros aplicados.</span>
                        <br>
                        <a href="@Url.Action("Index")" class="btn btn-link">Limpiar filtros</a>
                    }
                    else
                    {
                        <span>Comience creando su primer grupo de estudiantes.</span>
                        <br>
                        <a href="@Url.Action("Create")" class="btn btn-primary">
                            <i class="fas fa-plus"></i> Crear primer grupo
                        </a>
                    }
                </p>
            </div>
        }
    </div>
</div>

<!-- Paginación -->
@if (Model.Paginacion.TotalPaginas > 1)
{
    <nav aria-label="Paginación de grupos" class="mt-4">
        <ul class="pagination justify-content-center">
            <li class="page-item @(!Model.Paginacion.TienePaginaAnterior ? "disabled" : "")">
                <a class="page-link" href="@Url.Action("Index", new { pagina = Model.Paginacion.PaginaActual - 1, Filtros = Model.Filtros })">
                    <i class="fas fa-chevron-left"></i> Anterior
                </a>
            </li>
            
            @for (int i = Math.Max(1, Model.Paginacion.PaginaActual - 2); i <= Math.Min(Model.Paginacion.TotalPaginas, Model.Paginacion.PaginaActual + 2); i++)
            {
                <li class="page-item @(i == Model.Paginacion.PaginaActual ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { pagina = i, Filtros = Model.Filtros })">@i</a>
                </li>
            }
            
            <li class="page-item @(!Model.Paginacion.TienePaginaSiguiente ? "disabled" : "")">
                <a class="page-link" href="@Url.Action("Index", new { pagina = Model.Paginacion.PaginaActual + 1, Filtros = Model.Filtros })">
                    Siguiente <i class="fas fa-chevron-right"></i>
                </a>
            </li>
        </ul>
    </nav>
}

@section Scripts {
    <script>
        function toggleView(view) {
            // Implementar cambio de vista entre tabla y tarjetas
            const buttons = document.querySelectorAll('.btn-group button');
            buttons.forEach(btn => btn.classList.remove('active'));
            event.target.closest('button').classList.add('active');
        }
        
        // Auto-submit al cambiar filtros
        document.addEventListener('DOMContentLoaded', function() {
            const selectFiltros = document.querySelectorAll('.filters-container select');
            selectFiltros.forEach(select => {
                select.addEventListener('change', function() {
                    if (this.value !== '' || this.selectedIndex > 0) {
                        document.getElementById('filtrosForm').submit();
                    }
                });
            });
        });
    </script>
}

@section Styles {
    <style>
        .stat-icon {
            opacity: 0.8;
        }
        
        .stat-number {
            font-size: 2rem;
            font-weight: bold;
            margin: 0;
            color: var(--primary-color);
        }
        
        .stat-label {
            margin: 0;
            font-size: 0.9rem;
            color: #6c757d;
        }
        
        .badge-tipo-seccion { background-color: #0d6efd; }
        .badge-tipo-nivel { background-color: #198754; }
        .badge-tipo-modalidad { background-color: #fd7e14; }
        .badge-tipo-custom { background-color: #6f42c1; }
        
        .estudiantes-info {
            font-size: 0.9rem;
        }
        
        .table-modern tbody tr:hover {
            background-color: rgba(0,123,255,0.05);
        }
        
        .table-warning {
            --bs-table-bg: rgba(255, 193, 7, 0.1);
        }
    </style>
}
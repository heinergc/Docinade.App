@model DocinadeApp.ViewModels.Grupos.GrupoEstudianteIndexViewModel
@using DocinadeApp.Models
@using Microsoft.AspNetCore.Routing
@{
    ViewData["Title"] = "Grupos de Estudiantes";
}

<div class="page-header">
    <div class="row align-items-center">
        <div class="col">
            <h1 class="page-title">
                <i class="fas fa-users text-white me-2"></i>
                Grupos de Estudiantes
            </h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb breadcrumb-white">
                    <li class="breadcrumb-item">
                        <a href="@Url.Action("Index", "Home")" class="text-white">
                            <i class="fas fa-home"></i> Inicio
                        </a>
                    </li>
                    <li class="breadcrumb-item active text-white">Grupos de Estudiantes</li>
                </ol>
            </nav>
        </div>
        <div class="col-auto">
            <div class="btn-group">
                <a href="@Url.Action("Create")" class="btn btn-light">
                    <i class="fas fa-plus" style="color: black;"></i> <span style="color: black;">Nuevo Grupo</span>
                </a>
                <a href="@Url.Action("Estadisticas")" class="btn btn-info">
                    <i class="fas fa-chart-bar"></i> Estadísticas
                </a>
                <a href="@Url.Action("ExportarExcel", Model.Filtros)" class="btn btn-light">
                    <i class="fas fa-download" style="color: black;"></i> <span style="color: black;">Exportar</span>
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Estadísticas -->
<div class="stats-container-generic">
    @{
        var tiposArray = Model.EstadisticasPorTipo.ToArray();
        for (int i = 0; i < Math.Min(4, tiposArray.Length); i++)
        {
            var estadistica = tiposArray[i];
            string iconClass = estadistica.Key switch
            {
                TipoGrupo.Seccion => "fas fa-layer-group",
                TipoGrupo.Nivel => "fas fa-users",
                TipoGrupo.Modalidad => "fas fa-laptop",
                TipoGrupo.Custom => "fas fa-cog",
                _ => "fas fa-users"
            };
            
            string colorClass = i switch
            {
                0 => "text-primary",
                1 => "text-success", 
                2 => "text-info",
                3 => "text-warning",
                _ => "text-secondary"
            };

            <div class="stat-card-generic">
                <div class="stat-icon-generic @colorClass">
                    <i class="@iconClass"></i>
                </div>
                <div class="stat-number-generic">@estadistica.Value</div>
                <div class="stat-label-generic">@estadistica.Key.ToString().ToUpper()</div>
            </div>
        }
        
        // Si hay menos de 4 tipos, completar con estadística total
        if (tiposArray.Length < 4)
        {
            <div class="stat-card-generic">
                <div class="stat-icon-generic text-info">
                    <i class="fas fa-chart-bar"></i>
                </div>
                <div class="stat-number-generic">@Model.Paginacion.TotalElementos</div>
                <div class="stat-label-generic">TOTAL GRUPOS</div>
            </div>
        }
    }
</div>

<!-- Filtros -->
<div class="card-generic grupos-filter-section">
    <div class="card-header-generic">
        <h5 class="card-title-generic">
            <i class="fas fa-filter"></i>
            Filtros de Búsqueda
        </h5>
    </div>
    <div class="card-body-generic">
        <form method="get" action="@Url.Action("Index")" id="filtrosForm">
            <div class="row">
                <div class="col-xl-3 col-lg-4 col-md-6">
                    <div class="form-group-generic">
                        <label class="form-label-generic">
                            <i class="fas fa-calendar-alt"></i>
                            Período Académico
                        </label>
                        <select name="Filtros.PeriodoAcademicoId" class="form-control-generic" asp-for="Filtros.PeriodoAcademicoId">
                            <option value="">Todos los períodos</option>
                            @if (ViewBag.PeriodosAcademicos != null)
                            {
                                @foreach (var periodo in (List<DocinadeApp.ViewModels.Shared.PeriodoAcademicoDropdownViewModel>)ViewBag.PeriodosAcademicos)
                                {
                                    <option value="@periodo.Id" selected="@(periodo.Id == Model.Filtros.PeriodoAcademicoId)">
                                        @periodo.Nombre
                                    </option>
                                }
                            }
                        </select>
                    </div>
                </div>
                
                <div class="col-xl-2 col-lg-3 col-md-6">
                    <div class="form-group-generic">
                        <label class="form-label-generic">
                            <i class="fas fa-layer-group"></i>
                            Tipo de Grupo
                        </label>
                        <select name="Filtros.TipoGrupo" class="form-control-generic" asp-for="Filtros.TipoGrupo">
                            <option value="">Todos los tipos</option>
                            @{
                                var tiposGrupoDisponibles = ViewBag.TiposGrupoDisponibles as List<SelectListItem> ?? new List<SelectListItem>();
                            }
                            @foreach (var tipo in tiposGrupoDisponibles)
                            {
                                <option value="@tipo.Value" selected="@(tipo.Value == Model.Filtros.TipoGrupo?.ToString())">
                                    @tipo.Text
                                </option>
                            }
                            @if (!tiposGrupoDisponibles.Any())
                            {
                                <option value="Seccion" selected="@(Model.Filtros.TipoGrupo == TipoGrupo.Seccion)">Sección</option>
                                <option value="Nivel" selected="@(Model.Filtros.TipoGrupo == TipoGrupo.Nivel)">Nivel</option>
                                <option value="Modalidad" selected="@(Model.Filtros.TipoGrupo == TipoGrupo.Modalidad)">Modalidad</option>
                                <option value="Custom" selected="@(Model.Filtros.TipoGrupo == TipoGrupo.Custom)">Personalizado</option>
                            }
                        </select>
                    </div>
                </div>
                
                <div class="col-xl-2 col-lg-3 col-md-6">
                    <div class="form-group-generic">
                        <label class="form-label-generic">
                            <i class="fas fa-toggle-on"></i>
                            Estado
                        </label>
                        <select name="Filtros.Estado" class="form-control-generic" asp-for="Filtros.Estado">
                            <option value="">Todos los estados</option>
                            <option value="Activo" selected="@(Model.Filtros.Estado == EstadoGrupo.Activo)">Activo</option>
                            <option value="Inactivo" selected="@(Model.Filtros.Estado == EstadoGrupo.Inactivo)">Inactivo</option>
                            <option value="Cerrado" selected="@(Model.Filtros.Estado == EstadoGrupo.Cerrado)">Cerrado</option>
                            <option value="Suspendido" selected="@(Model.Filtros.Estado == EstadoGrupo.Suspendido)">Suspendido</option>
                        </select>
                    </div>
                </div>
                
                <div class="col-xl-3 col-lg-4 col-md-6">
                    <div class="form-group-generic">
                        <label class="form-label-generic">
                            <i class="fas fa-school"></i>
                            Institución
                        </label>
                        <select name="Filtros.InstitucionId" class="form-control-generic" asp-for="Filtros.InstitucionId">
                            <option value="">Todas las instituciones</option>
                            @if (ViewBag.Instituciones != null)
                            {
                                @foreach (var institucion in ViewBag.Instituciones)
                                {
                                    <option value="@institucion.Value" selected="@(institucion.Value == Model.Filtros.InstitucionId?.ToString())">
                                        @institucion.Text
                                    </option>
                                }
                            }
                        </select>
                    </div>
                </div>
                
                <div class="col-xl-2 col-lg-3 col-md-6">
                    <div class="form-group-generic">
                        <label class="form-label-generic">
                            <i class="fas fa-hashtag"></i>
                            Código
                        </label>
                        <input type="text" name="Filtros.Codigo" class="form-control-generic" 
                               placeholder="Buscar código..." value="@Model.Filtros.Codigo" asp-for="Filtros.Codigo">
                    </div>
                </div>
                
                <div class="col-xl-3 col-lg-4 col-md-6">
                    <div class="form-group-generic">
                        <label class="form-label-generic">
                            <i class="fas fa-signature"></i>
                            Nombre
                        </label>
                        <input type="text" name="Filtros.Nombre" class="form-control-generic" 
                               placeholder="Buscar nombre..." value="@Model.Filtros.Nombre" asp-for="Filtros.Nombre">
                    </div>
                </div>
            </div>
            
            <div class="d-flex justify-content-between align-items-center mt-4">
                <div class="form-check-generic">
                    <input type="checkbox" name="Filtros.SoloConEspacio" class="form-check-input-generic"
                           asp-for="Filtros.SoloConEspacio" checked="@Model.Filtros.SoloConEspacio" id="soloConEspacio">
                    <label class="form-check-label-generic" for="soloConEspacio">
                        <i class="fas fa-users-slash"></i>
                        Solo grupos con capacidad disponible
                    </label>
                </div>
                <div class="btn-group-generic">
                    <button type="submit" class="btn-generic btn-primary-generic">
                        <i class="fas fa-search"></i> 
                        Buscar
                    </button>
                    <a href="@Url.Action("Index")" class="btn-generic btn-secondary-generic">
                        <i class="fas fa-times"></i> 
                        Limpiar
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Lista de Grupos -->
<div class="table-container-generic">
    <div class="card-header-generic">
        <div class="row align-items-center">
            <div class="col">
                <h5 class="card-title-generic">
                    <i class="fas fa-list"></i>
                    Lista de Grupos (@Model.Paginacion.TotalElementos total)
                </h5>
            </div>
            <div class="col-auto">
                <div class="btn-group-generic">
                    <button class="btn-generic btn-small-generic btn-secondary-generic" onclick="toggleView('card')" title="Vista de tarjetas">
                        <i class="fas fa-th-large"></i>
                    </button>
                    <button class="btn-generic btn-small-generic btn-primary-generic active" onclick="toggleView('table')" title="Vista de tabla">
                        <i class="fas fa-list"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="card-body-generic p-0">
        @if (Model.Grupos.Any())
        {
            <div class="table-responsive-generic">
                <table class="table-generic">
                    <thead>
                        <tr>
                            <th>Código</th>
                            <th>Información del Grupo</th>
                            <th>Institución</th>
                            <th>Tipo</th>
                            <th>Estudiantes</th>
                            <th>Materias</th>
                            <th>Estado</th>
                            <th>Creado</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var grupo in Model.Grupos)
                        {
                            <tr>
                                <td>
                                    <span class="badge-generic badge-primary-generic">@grupo.Codigo</span>
                                </td>
                                
                                <td>
                                    <div>
                                        <strong>@grupo.Nombre</strong>
                                        @if (!string.IsNullOrEmpty(grupo.Nivel))
                                        {
                                            <br>
                                            <small class="text-muted-black">
                                                <i class="fas fa-level-up-alt"></i>
                                                Nivel: @grupo.Nivel
                                            </small>
                                        }
                                    </div>
                                </td>
                                
                                <td>
                                    @if (!string.IsNullOrEmpty(grupo.InstitucionNombre))
                                    {
                                        <span class="badge bg-info text-dark">
                                            <i class="fas fa-school me-1"></i>@grupo.InstitucionNombre
                                        </span>
                                    }
                                    else
                                    {
                                        <small class="text-muted">Sin institución</small>
                                    }
                                </td>
                                
                                <td>
                                    @{
                                        string tipoBadgeClass = grupo.TipoGrupoDisplay switch
                                        {
                                            "Sección" => "badge-tipo-seccion",
                                            "Nivel" => "badge-tipo-nivel",
                                            "Modalidad" => "badge-tipo-modalidad",
                                            "Custom" => "badge-tipo-custom",
                                            _ => "badge-secondary-generic"
                                        };
                                    }
                                    <span class="badge-generic grupos-badge-tipo @tipoBadgeClass">
                                        @grupo.TipoGrupoDisplay
                                    </span>
                                </td>
                                
                                <td class="text-center-generic">
                                    <div>
                                        <span class="fw-bold">@grupo.CantidadEstudiantes</span>
                                        @if (grupo.CapacidadMaxima.HasValue)
                                        {
                                            <span class="text-muted-black">/@grupo.CapacidadMaxima</span>
                                        }
                                    </div>
                                    @if (grupo.EstaCompleto)
                                    {
                                        <small class="badge-generic badge-warning-generic status-badge-generic">Completo</small>
                                    }
                                    else
                                    {
                                        <small class="text-muted-black">Disponible</small>
                                    }
                                </td>
                                
                                <td class="text-center-generic">
                                    @if (grupo.Materias.Any())
                                    {
                                        <span class="badge-generic badge-success-generic">@grupo.Materias.Count</span>
                                        <br>
                                        <small class="text-muted-white">
                                            @string.Join(", ", grupo.Materias.Take(2))
                                            @if (grupo.Materias.Count > 2)
                                            {
                                                <span>...</span>
                                            }
                                        </small>
                                    }
                                    else
                                    {
                                        <span class="text-muted-black">Sin materias</span>
                                    }
                                </td>
                                
                                <td>
                                    @{
                                        string estadoBadgeClass = grupo.Estado switch
                                        {
                                            EstadoGrupo.Activo => "badge-success-generic",
                                            EstadoGrupo.Inactivo => "badge-secondary-generic",
                                            EstadoGrupo.Cerrado => "badge-danger-generic",
                                            EstadoGrupo.Suspendido => "badge-warning-generic",
                                            _ => "badge-secondary-generic"
                                        };
                                    }
                                    <span class="badge-generic @estadoBadgeClass status-badge-generic">
                                        @grupo.EstadoDisplay
                                    </span>
                                </td>
                                
                                <td class="text-center-generic">
                                    <small>
                                        @grupo.FechaCreacion.ToString("dd/MM/yyyy")
                                        @if (!string.IsNullOrEmpty(grupo.CreadoPor))
                                        {
                                            <br>
                                            <span class="text-muted-black">@grupo.CreadoPor</span>
                                        }
                                    </small>
                                </td>
                                
                                <td>
                                    <div class="grupos-table-actions">
                                        <a href="@Url.Action("Details", new { id = grupo.GrupoId })"
                                           class="btn-generic btn-small-generic btn-outline-info-generic"
                                           title="Ver detalles">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a href="@Url.Action("AsignarEstudiantes", new { id = grupo.GrupoId })"
                                           class="btn-generic btn-small-generic badge-success-generic"
                                           title="Asignar estudiantes">
                                            <i class="fas fa-user-plus"></i>
                                        </a>
                                        <a href="@Url.Action("Edit", new { id = grupo.GrupoId })"
                                           class="btn-generic btn-small-generic badge-warning-generic"
                                           title="Editar">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a href="@Url.Action("ExportarEstudiantesExcel", new { id = grupo.GrupoId })"
                                           class="btn-generic btn-small-generic btn-primary-generic"
                                           title="Exportar estudiantes">
                                            <i class="fas fa-download"></i>
                                        </a>
                                        <a href="@Url.Action("HistorialGrupo", "Auditoria", new { grupoId = grupo.GrupoId })"
                                           class="btn-generic btn-small-generic btn-outline-secondary-generic"
                                           title="Ver historial de auditoría">
                                            <i class="fas fa-history"></i>
                                        </a>
                                        <a href="@Url.Action("Delete", new { id = grupo.GrupoId })"
                                           class="btn-generic btn-small-generic badge-danger-generic"
                                           title="Eliminar grupo"
                                           onclick="return confirm('¿Está seguro de eliminar este grupo?')">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="fas fa-users fa-3x text-muted mb-3"></i>
                <h5 class="text-muted">No se encontraron grupos</h5>
                @if (Model.Filtros.PeriodoAcademicoId.HasValue || !string.IsNullOrEmpty(Model.Filtros.Codigo) || !string.IsNullOrEmpty(Model.Filtros.Nombre))
                {
                    <p class="text-muted">No hay grupos que coincidan con los filtros aplicados.</p>
                    <a href="@Url.Action("Index")" class="btn btn-outline-primary">
                        <i class="fas fa-times"></i> Limpiar filtros
                    </a>
                }
                else
                {
                    <p class="text-muted">Comience creando su primer grupo de estudiantes.</p>
                    <a href="@Url.Action("Create")" class="btn btn-primary">
                        <i class="fas fa-plus"></i> Crear primer grupo
                    </a>
                }
            </div>
        }
    </div>
</div>

<!-- Paginación con clases genéricas -->
@if (Model.Paginacion.TotalPaginas > 1)
{
    <div class="pagination-container">
        <div class="pagination-info">
            <span class="info-text">
                Mostrando @((Model.Paginacion.PaginaActual - 1) * Model.Paginacion.ElementosPorPagina + 1) - 
                @(Math.Min(Model.Paginacion.PaginaActual * Model.Paginacion.ElementosPorPagina, Model.Paginacion.TotalElementos)) 
                de @Model.Paginacion.TotalElementos grupos
            </span>
        </div>
        
        <nav aria-label="Paginación de grupos">
            <ul class="pagination pagination-modern">
                <li class="page-item @(!Model.Paginacion.TienePaginaAnterior ? "disabled" : "")">
                    <a class="page-link" 
                       href="@Url.Action("Index", new { pagina = Model.Paginacion.PaginaActual - 1, Filtros = Model.Filtros })"
                       aria-label="Página anterior">
                        <i class="fas fa-chevron-left"></i>
                        <span>Anterior</span>
                    </a>
                </li>

                @for (int i = Math.Max(1, Model.Paginacion.PaginaActual - 2); i <= Math.Min(Model.Paginacion.TotalPaginas, Model.Paginacion.PaginaActual + 2); i++)
                {
                    <li class="page-item @(i == Model.Paginacion.PaginaActual ? "active" : "")">
                        <a class="page-link" 
                           href="@Url.Action("Index", new { pagina = i, Filtros = Model.Filtros })"
                           aria-label="Página @i">@i</a>
                    </li>
                }

                <li class="page-item @(!Model.Paginacion.TienePaginaSiguiente ? "disabled" : "")">
                    <a class="page-link" 
                       href="@Url.Action("Index", new { pagina = Model.Paginacion.PaginaActual + 1, Filtros = Model.Filtros })"
                       aria-label="Página siguiente">
                        <span>Siguiente</span>
                        <i class="fas fa-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    </div>
}

@section Scripts {
    <script>
        // ===== VARIABLES GLOBALES =====
        let currentView = 'table';
        let tooltipsInitialized = false;

        // ===== INICIALIZACIÓN =====
        document.addEventListener('DOMContentLoaded', function() {
            initializeTooltips();
            initializeFilters();
            initializeViewControls();
            initializeTableAnimations();
            initializeDropdowns();
            
            console.log('GruposEstudiantes - Página inicializada correctamente');
        });

        // ===== INICIALIZACIÓN DE DROPDOWNS =====
        function initializeDropdowns() {
            // Asegurar que todos los dropdowns en la tabla funcionen correctamente
            const dropdownToggleList = [].slice.call(document.querySelectorAll('.table-actions .dropdown-toggle'));
            dropdownToggleList.map(function(dropdownToggleEl) {
                // Crear instancia de Bootstrap dropdown si no existe
                if (!bootstrap.Dropdown.getInstance(dropdownToggleEl)) {
                    return new bootstrap.Dropdown(dropdownToggleEl, {
                        autoClose: true,
                        boundary: 'viewport'
                    });
                }
            });

            // Manejar eventos de apertura/cierre para z-index
            document.querySelectorAll('.table-actions .dropdown').forEach(function(dropdown) {
                dropdown.addEventListener('show.bs.dropdown', function() {
                    // Asegurar que el dropdown tenga el z-index más alto
                    this.style.zIndex = '9999';
                    const menu = this.querySelector('.dropdown-menu');
                    if (menu) {
                        menu.style.zIndex = '9999';
                    }
                });

                dropdown.addEventListener('hide.bs.dropdown', function() {
                    // Resetear z-index cuando se cierre
                    this.style.zIndex = '';
                });
            });
        }

        // ===== FUNCIONES DE VISTA =====
        function toggleView(view) {
            const buttons = document.querySelectorAll('.view-controls .btn-group button');
            buttons.forEach(btn => btn.classList.remove('active'));
            
            const clickedButton = event.target.closest('button');
            if (clickedButton) {
                clickedButton.classList.add('active');
            }
            
            currentView = view;
            
            // Aquí se puede implementar la lógica para cambiar entre tabla y cards
            if (view === 'card') {
                // TODO: Implementar vista de tarjetas
                console.log('Vista de tarjetas seleccionada');
            } else {
                // Vista de tabla (actual)
                console.log('Vista de tabla seleccionada');
            }
        }

        // ===== FILTROS =====
        function initializeFilters() {
            const form = document.getElementById('filtrosForm');
            const selects = form.querySelectorAll('select.form-control-modern');
            const inputs = form.querySelectorAll('input.form-control-modern');
            
            // Auto-submit en selects (excepto si es valor vacío)
            selects.forEach(select => {
                select.addEventListener('change', function() {
                    if (this.value !== '') {
                        showLoadingState();
                        form.submit();
                    }
                });
            });
            
            // Enter en inputs para submit
            inputs.forEach(input => {
                input.addEventListener('keypress', function(e) {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        showLoadingState();
                        form.submit();
                    }
                });
            });
            
            // Toggle de filtros
            const filterToggle = document.querySelector('[data-bs-target="#filtrosCollapse"]');
            if (filterToggle) {
                filterToggle.addEventListener('click', function() {
                    const icon = this.querySelector('.filters-toggle i');
                    setTimeout(() => {
                        const isExpanded = this.getAttribute('aria-expanded') === 'true';
                        icon.className = isExpanded ? 'fas fa-chevron-up' : 'fas fa-chevron-down';
                    }, 150);
                });
            }
        }

        function clearFilters() {
            const form = document.getElementById('filtrosForm');
            const inputs = form.querySelectorAll('input, select');
            
            inputs.forEach(input => {
                if (input.type === 'checkbox') {
                    input.checked = false;
                } else {
                    input.value = '';
                }
            });
            
            showLoadingState();
            window.location.href = '@Url.Action("Index")';
        }

        // ===== ANIMACIONES Y EFECTOS =====
        function initializeTableAnimations() {
            const rows = document.querySelectorAll('.table-row');
            
            rows.forEach((row, index) => {
                // Animación de entrada escalonada
                row.style.animationDelay = `${index * 0.05}s`;
                row.classList.add('table-row-animate');
                
                // Hover effects mejorados
                row.addEventListener('mouseenter', function() {
                    this.classList.add('row-hover');
                });
                
                row.addEventListener('mouseleave', function() {
                    this.classList.remove('row-hover');
                });
            });
        }

        function initializeTooltips() {
            if (typeof bootstrap !== 'undefined' && !tooltipsInitialized) {
                const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
                tooltipTriggerList.map(function(tooltipTriggerEl) {
                    return new bootstrap.Tooltip(tooltipTriggerEl, {
                        trigger: 'hover',
                        delay: { show: 500, hide: 100 }
                    });
                });
                tooltipsInitialized = true;
            }
        }

        function initializeViewControls() {
            const viewButtons = document.querySelectorAll('.view-controls button');
            
            viewButtons.forEach(button => {
                button.addEventListener('click', function() {
                    // Efecto de pulsación
                    this.style.transform = 'scale(0.95)';
                    setTimeout(() => {
                        this.style.transform = 'scale(1)';
                    }, 150);
                });
            });
        }

        // ===== ESTADOS DE CARGA =====
        function showLoadingState() {
            const submitBtn = document.querySelector('button[type="submit"]');
            if (submitBtn) {
                const originalContent = submitBtn.innerHTML;
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i> <span class="btn-text">Buscando...</span>';
                
                // Restore button after a reasonable time
                setTimeout(() => {
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalContent;
                }, 5000);
            }
        }

        // ===== UTILIDADES =====
        function confirmDelete(grupoNombre, deleteUrl) {
            if (confirm(`¿Está seguro de eliminar el grupo "${grupoNombre}"?\n\nEsta acción no se puede deshacer.`)) {
                window.location.href = deleteUrl;
            }
        }

        function exportarEstudiantes(grupoId, grupoNombre) {
            const loadingToast = showToast('info', 'Preparando exportación...', false);
            
            fetch(`@Url.Action("ExportarEstudiantesExcel")?id=${grupoId}`)
                .then(response => {
                    if (response.ok) {
                        return response.blob();
                    }
                    throw new Error('Error en la exportación');
                })
                .then(blob => {
                    // Crear enlace de descarga
                    const url = window.URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.href = url;
                    a.download = `estudiantes_${grupoNombre}_${new Date().toISOString().slice(0,10)}.xlsx`;
                    document.body.appendChild(a);
                    a.click();
                    window.URL.revokeObjectURL(url);
                    document.body.removeChild(a);
                    
                    hideToast(loadingToast);
                    showToast('success', 'Archivo exportado correctamente');
                })
                .catch(error => {
                    console.error('Error:', error);
                    hideToast(loadingToast);
                    showToast('error', 'Error al exportar el archivo');
                });
        }

        function showToast(type, message, autoHide = true) {
            // Implementación básica de toast - se puede mejorar con Bootstrap Toast
            const toastContainer = document.getElementById('toast-container') || createToastContainer();
            
            const toast = document.createElement('div');
            toast.className = `alert alert-${type === 'error' ? 'danger' : type} alert-dismissible fade show`;
            toast.innerHTML = `
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            `;
            
            toastContainer.appendChild(toast);
            
            if (autoHide) {
                setTimeout(() => hideToast(toast), 5000);
            }
            
            return toast;
        }

        function hideToast(toast) {
            if (toast && toast.parentNode) {
                toast.parentNode.removeChild(toast);
            }
        }

        function createToastContainer() {
            const container = document.createElement('div');
            container.id = 'toast-container';
            container.style.cssText = 'position: fixed; top: 20px; right: 20px; z-index: 9999; max-width: 350px;';
            document.body.appendChild(container);
            return container;
        }

        // ===== EVENTOS GLOBALES =====
        window.toggleView = toggleView;
        window.clearFilters = clearFilters;
        window.confirmDelete = confirmDelete;
        window.exportarEstudiantes = exportarEstudiantes;
    </script>
}


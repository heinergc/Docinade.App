@functions {
    private string GenerarUrlPaginacion(int pagina)
    {
        var routeValues = new RouteValueDictionary
        {
            ["pagina"] = pagina
        };

        // Agregar filtros a la URL
        if (Model.Filtros.PeriodoAcademicoId.HasValue)
            routeValues["Filtros.PeriodoAcademicoId"] = Model.Filtros.PeriodoAcademicoId;
        
        if (!string.IsNullOrEmpty(Model.Filtros.Codigo))
            routeValues["Filtros.Codigo"] = Model.Filtros.Codigo;
        
        if (!string.IsNullOrEmpty(Model.Filtros.Nombre))
            routeValues["Filtros.Nombre"] = Model.Filtros.Nombre;
        
        if (Model.Filtros.TipoGrupo.HasValue)
            routeValues["Filtros.TipoGrupo"] = Model.Filtros.TipoGrupo;
        
        if (Model.Filtros.Estado.HasValue)
            routeValues["Filtros.Estado"] = Model.Filtros.Estado;

        return Url.Action("Index", routeValues) ?? "#";
    }
}
   
    
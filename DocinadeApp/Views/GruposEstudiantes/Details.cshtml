@model RubricasApp.Web.ViewModels.Grupos.DetalleGrupoViewModel

@{
    ViewData["Title"] = $"Grupo: {Model.Codigo}";
}

<div class="page-header">
    <div class="row align-items-center">
        <div class="col-md-8">
            <h1 class="page-title">
                <span class="badge bg-primary me-2">@Model.Codigo</span>
                @Model.Nombre
            </h1>
      
        </div>
        <div class="card-text">
                  <nav aria-label="breadcrumb">
                <ol class="breadcrumb" style="background-color: rgba(255,255,255,0.1); padding: 0.5rem 1rem; border-radius: 0.375rem;">
                    <li class="breadcrumb-item">
                        <a href="@Url.Action("Index")" style="color: white; text-decoration: none;">
                            <i class="fas fa-users-cog"></i> Grupos
                        </a>
                    </li>
                    <li class="breadcrumb-item active" style="color: white;" aria-current="page">@Model.Codigo</li>
                </ol>
            </nav>
        </div>


        <div class="col-md-12">
            <div class="d-flex justify-content-end">
                <div style="display: flex; gap: 0.25rem; flex-wrap: wrap;">
                    <a href="@Url.Action("AsignarEstudiantes", new { id = Model.GrupoId })"
                       class="btn success btn-modern">
                        <i class="fas fa-plus"></i> Estudiantes
                    </a>
                    <a href="@Url.Action("Edit", new { id = Model.GrupoId })"
                       class="btn btn-modern warning btn-sm">
                        <i class="fas fa-edit"></i> Editar
                    </a>
                    <a href="@Url.Action("ExportarEstudiantesExcel", new { id = Model.GrupoId })"
                       class="btn btn-modern secondary btn-sm">
                        <i class="fas fa-download"></i> Exportar
                    </a>
                    <a href="@Url.Action("Delete", new { id = Model.GrupoId })"
                       class="btn btn-danger btn-sm"
                       onclick="return confirm('¿Está seguro de eliminar este grupo?')">
                        <i class="fas fa-trash"></i> Eliminar
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Tarjetas de estadísticas -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="modern-card stat-card">
            <div class="card-body text-center">
                <div class="stat-icon mb-2">
                    <i class="fas fa-users fa-2x text-primary"></i>
                </div>
                <h3 class="stat-number">@Model.CantidadEstudiantes</h3>
                <p class="stat-label">Estudiantes</p>
                @if (Model.CapacidadMaxima.HasValue)
                {
                    <small class="text-muted">de @Model.CapacidadMaxima máximo</small>
                }
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="modern-card stat-card">
            <div class="card-body text-center">
                <div class="stat-icon mb-2">
                    <i class="fas fa-chart-pie fa-2x text-success"></i>
                </div>
                <h3 class="stat-number @(Model.EstaCompleto ? "text-warning" : "text-success")">
                    @Model.EstadoCapacidad
                </h3>
                <p class="stat-label">Capacidad</p>
                @if (Model.CapacidadMaxima.HasValue)
                {
                    <small class="text-muted">
                        @(((double)Model.CantidadEstudiantes / Model.CapacidadMaxima.Value * 100).ToString("F1"))% ocupado
                    </small>
                }
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="modern-card stat-card">
            <div class="card-body text-center">
                <div class="stat-icon mb-2">
                    <i class="fas fa-book fa-2x text-info"></i>
                </div>
                <h3 class="stat-number">@Model.Materias.Count</h3>
                <p class="stat-label">Materias</p>
                <small class="text-muted">asociadas</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="modern-card stat-card">
            <div class="card-body text-center">
                <div class="stat-icon mb-2">
                    <i class="fas fa-info-circle fa-2x text-secondary"></i>
                </div>
                <h3 class="stat-number">
                    <span class="badge bg-@(Model.Estado == RubricasApp.Web.Models.EstadoGrupo.Activo ? "success" : Model.Estado == RubricasApp.Web.Models.EstadoGrupo.Inactivo ? "secondary" : "danger")">
                        @Model.EstadoDisplay
                    </span>
                </h3>
                <p class="stat-label">Estado</p>
                <small class="text-muted">del grupo</small>
            </div>
        </div>
    </div>
</div>

<!-- Información del grupo -->
<div class="row">
    <div class="col-md-4">
        <div class="modern-card">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="fas fa-info-circle me-2"></i>
                    Información del Grupo
                </h5>
            </div>
            <div class="card-body">
                <table class="table table-borderless">
                    <tr>
                        <td><strong>Código:</strong></td>
                        <td><span class="badge bg-primary">@Model.Codigo</span></td>
                    </tr>
                    <tr>
                        <td><strong>Tipo:</strong></td>
                        <td>
                            <span class="badge badge-tipo-@(Model.TipoGrupo.ToString().ToLower())">
                                @Model.TipoGrupoDisplay
                            </span>
                        </td>
                    </tr>
                    @if (!string.IsNullOrEmpty(Model.Nivel))
                    {
                        <tr>
                            <td><strong>Nivel:</strong></td>
                            <td>@Model.Nivel</td>
                        </tr>
                    }
                    <tr>
                        <td><strong>Período:</strong></td>
                        <td>@Model.PeriodoAcademico</td>
                    </tr>
                    @if (!string.IsNullOrEmpty(Model.InstitucionNombre))
                    {
                        <tr>
                            <td><strong><i class="fas fa-school me-1"></i>Institución:</strong></td>
                            <td>
                                <span class="badge bg-primary">@Model.InstitucionNombre</span>
                            </td>
                        </tr>
                    }
                    <tr>
                        <td><strong>Creado:</strong></td>
                        <td>
                            @Model.FechaCreacion.ToString("dd/MM/yyyy")
                            @if (!string.IsNullOrEmpty(Model.CreadoPor))
                            {
                                <br>
                            
                                <small class="text-muted">por @Model.CreadoPor</small>
                            }
                        </td>
                    </tr>
                    @if (Model.FechaModificacion.HasValue)
                    {
                        <tr>
                            <td><strong>Modificado:</strong></td>
                            <td>@Model.FechaModificacion.Value.ToString("dd/MM/yyyy HH:mm")</td>
                        </tr>
                    }
                </table>

                @if (!string.IsNullOrEmpty(Model.Descripcion))
                {
                    <hr>
                    <h6><strong>Descripción:</strong></h6>
                    <p class="text-muted">@Model.Descripcion</p>
                }

                @if (!string.IsNullOrEmpty(Model.Observaciones))
                {
                    <hr>
                    <h6><strong>Observaciones:</strong></h6>
                    <p class="text-muted">@Model.Observaciones</p>
                }
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <!-- Pestañas para estudiantes y materias -->
        <div class="modern-card">
            <div class="card-header">
                <ul class="nav nav-tabs card-header-tabs" id="groupTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="students-tab" data-bs-toggle="tab"
                                data-bs-target="#students" type="button" role="tab">
                            <i class="fas fa-users me-2"></i>
                            Estudiantes (@Model.Estudiantes.Count)
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="subjects-tab" data-bs-toggle="tab"
                                data-bs-target="#subjects" type="button" role="tab">
                            <i class="fas fa-book me-2"></i>
                            Materias (@Model.Materias.Count)
                        </button>
                    </li>
                </ul>
            </div>
            <div class="card-body">
                <div class="tab-content" id="groupTabsContent">
                    <!-- Pestaña de Estudiantes -->
                    <div class="tab-pane fade show active" id="students" role="tabpanel">
                        @if (Model.Estudiantes.Any())
                        {
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h6 class="mb-0">Lista de Estudiantes</h6>
                                <div class="d-flex gap-2">
                                    <button type="button" class="btn btn-sm btn-outline-danger" id="btnDesasignarSeleccionados" style="display: none;">
                                        <i class="fas fa-user-minus"></i> Desasignar Seleccionados
                                    </button>
                                    <a href="@Url.Action("AsignarEstudiantes", new { id = Model.GrupoId })"
                                       class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-plus"></i> Agregar más
                                    </a>
                                </div>
                            </div>

                            <!-- Formulario para desasignación múltiple -->
                            <form id="formDesasignacionMultiple" asp-action="DesasignarEstudiantesMultiples" method="post" style="display: none;">
                                <input type="hidden" name="grupoId" value="@Model.GrupoId" />
                                <input type="hidden" name="motivo" id="motivoDesasignacion" />
                                <div id="estudiantesSeleccionadosInputs"></div>
                            </form>

                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead>
                                        <tr>
                                            <th style="width: 40px;">
                                                <div class="form-check">
                                                    <input class="form-check-input" type="checkbox" id="selectAllStudents">
                                                    <label class="form-check-label" for="selectAllStudents"></label>
                                                </div>
                                            </th>
                                            <th>ID</th>
                                            <th>Estudiante</th>
                                            <th>Email</th>
                                            <th>Asignado</th>
                                            <th>Principal</th>
                                            <th>Acciones</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var estudiante in Model.Estudiantes.OrderBy(e => e.NombreCompleto))
                                        {
                                            <tr>
                                                <td>
                                                    <div class="form-check">
                                                        <input class="form-check-input student-checkbox" 
                                                               type="checkbox" 
                                                               value="@estudiante.EstudianteId"
                                                               id="student_@estudiante.EstudianteId"
                                                               data-student-name="@estudiante.NombreCompleto">
                                                        <label class="form-check-label" for="student_@estudiante.EstudianteId"></label>
                                                    </div>
                                                </td>
                                                <td>
                                                    <code>@estudiante.NumeroId</code>
                                                </td>
                                                <td>
                                                    <strong>@estudiante.NombreCompleto</strong>
                                                </td>
                                                <td>
                                                    <a href="mailto:@estudiante.Email">@estudiante.Email</a>
                                                </td>
                                                <td>
                                                    <small class="text-muted">
                                                        @estudiante.FechaAsignacion.ToString("dd/MM/yyyy")
                                                        @if (!string.IsNullOrEmpty(estudiante.AsignadoPor))
                                                        {
                                                            <br>
                                                            <span>por @estudiante.AsignadoPor</span>
                                                        }
                                                    </small>
                                                </td>
                                                <td>
                                                    @if (estudiante.EsGrupoPrincipal)
                                                    {
                                                        <span class="badge bg-success">Principal</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-secondary">Secundario</span>
                                                    }
                                                </td>
                                                <td>
                                                    <form asp-action="DesasignarEstudiante" method="post" class="d-inline">
                                                        <input type="hidden" name="grupoId" value="@Model.GrupoId" />
                                                        <input type="hidden" name="estudianteId" value="@estudiante.EstudianteId" />
                                                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                                                onclick="return confirm('¿Desasignar a @estudiante.NombreCompleto del grupo?')"
                                                                title="Desasignar estudiante">
                                                            <i class="fas fa-user-minus"></i>
                                                        </button>
                                                    </form>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-5">
                                <i class="fas fa-user-plus fa-3x text-muted mb-3"></i>
                                <h6 class="text-muted">No hay estudiantes asignados</h6>
                                <p class="text-muted">Comience agregando estudiantes a este grupo.</p>
                                <a href="@Url.Action("AsignarEstudiantes", new { id = Model.GrupoId })"
                                   class="btn btn-primary">
                                    <i class="fas fa-plus"></i> Asignar Estudiantes
                                </a>
                            </div>
                        }
                    </div>

                    <!-- Pestaña de Materias -->
                    <div class="tab-pane fade" id="subjects" role="tabpanel">
                        @if (Model.Materias.Any())
                        {
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h6 class="mb-0">Materias Asociadas</h6>
                                <button class="btn btn-sm btn-outline-info" data-bs-toggle="modal" data-bs-target="#materiasModal">
                                    <i class="fas fa-cog"></i> Gestionar
                                </button>
                            </div>

                            <div class="row">
                                @foreach (var materia in Model.Materias.OrderBy(m => m.Nombre))
                                {
                                    <div class="col-md-6 mb-3">
                                        <div class="card border-left-info">
                                            <div class="card-body py-2">
                                                <div class="d-flex justify-content-between align-items-center">
                                                    <div>
                                                        <h6 class="mb-0">@materia.Nombre</h6>
                                                        <small class="text-muted">
                                                            Código: @materia.Codigo
                                                        </small>
                                                        <br>
                                                        <small class="text-muted">
                                                            Asociada: @materia.FechaAsignacion.ToString("dd/MM/yyyy")
                                                        </small>
                                                    </div>
                                                    <div>
                                                        <span class="badge bg-@(materia.Estado == RubricasApp.Web.Models.EstadoAsignacion.Activo ? "success" : "secondary")">
                                                            @materia.EstadoDisplay
                                                        </span>
                                                        <div class="mt-1">
                                                            <form asp-action="DesasignarMateria" method="post" class="d-inline"
                                                                  onsubmit="return confirm('¿Desasociar la materia @materia.Nombre?')">
                                                                <input type="hidden" name="grupoId" value="@Model.GrupoId" />
                                                                <input type="hidden" name="materiaId" value="@materia.MateriaId" />
                                                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Desasociar materia">
                                                                    <i class="fas fa-unlink"></i>
                                                                </button>
                                                            </form>
                                                        </div>
                                                    </div>
                                                </div>
                                                @if (!string.IsNullOrEmpty(materia.Observaciones))
                                                {
                                                    <small class="text-muted d-block mt-1">
                                                        <em>@materia.Observaciones</em>
                                                    </small>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-5">
                                <i class="fas fa-book fa-3x text-muted mb-3"></i>
                                <h6 class="text-muted">No hay materias asociadas</h6>
                                <p class="text-muted">Este grupo no tiene materias específicas asociadas.</p>
                                <button class="btn btn-info" data-bs-toggle="modal" data-bs-target="#materiasModal">
                                    <i class="fas fa-plus"></i> Asociar Materias
                                </button>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal para gestionar materias -->
<div class="modal fade" id="materiasModal" tabindex="-1" aria-labelledby="materiasModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title" id="materiasModalLabel">
                    <i class="fas fa-book me-2"></i>
                    Gestionar Materias del Grupo
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="materiasForm" asp-action="AsignarMaterias" method="post">
                    <input type="hidden" name="grupoId" value="@Model.GrupoId" />

                    <div class="mb-3">
                        <h6>Materias Disponibles</h6>
                        <p class="text-muted">Seleccione las materias que desea asociar al grupo <strong>@Model.Codigo</strong></p>

                        <div id="materiasContainer" class="row">
                            <!-- Las materias se cargarán aquí via AJAX -->
                            <div class="col-12 text-center">
                                <div class="spinner-border text-primary" role="status">
                                    <span class="visually-hidden">Cargando materias...</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="observacionesMaterias" class="form-label">Observaciones (Opcional)</label>
                        <textarea name="observaciones" id="observacionesMaterias" class="form-control" rows="2"
                                  placeholder="Observaciones sobre la asociación de materias..."></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times"></i> Cancelar
                </button>
                <button type="button" class="btn btn-info" onclick="guardarMaterias()">
                    <i class="fas fa-save"></i> Guardar Cambios
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let materiasDisponibles = [];

        $(document).ready(function() {
            // Configurar el modal de materias
            $('#materiasModal').on('show.bs.modal', function() {
                cargarMateriasDisponibles();
            });

            // Confirmar desasignación con SweetAlert
            $('form[action*="DesasignarEstudiante"]').on('submit', function(e) {
                e.preventDefault();
                const form = this;
                const estudianteNombre = $(this).find('button').attr('onclick').match(/'([^']+)'/)[1].split(' del grupo')[0].replace('¿Desasignar a ', '');

                Swal.fire({
                    title: '¿Desasignar estudiante?',
                    text: `Se desasignará a ${estudianteNombre} de este grupo.`,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#3085d6',
                    confirmButtonText: 'Sí, desasignar',
                    cancelButtonText: 'Cancelar'
                }).then((result) => {
                    if (result.isConfirmed) {
                        form.submit();
                    }
                });
            });

            // Funcionalidad de selección múltiple de estudiantes
            initializeMultipleSelection();
        });

        // Inicializar funcionalidad de selección múltiple
        function initializeMultipleSelection() {
            const selectAllCheckbox = document.getElementById('selectAllStudents');
            const studentCheckboxes = document.querySelectorAll('.student-checkbox');
            const btnDesasignarSeleccionados = document.getElementById('btnDesasignarSeleccionados');

            // Seleccionar/deseleccionar todos
            if (selectAllCheckbox) {
                selectAllCheckbox.addEventListener('change', function() {
                    studentCheckboxes.forEach(checkbox => {
                        checkbox.checked = this.checked;
                        // Agregar/quitar clase visual a las filas
                        const row = checkbox.closest('tr');
                        if (this.checked) {
                            row.classList.add('selected');
                        } else {
                            row.classList.remove('selected');
                        }
                    });
                    updateDesasignarButton();
                });
            }

            // Evento para checkboxes individuales
            studentCheckboxes.forEach(checkbox => {
                checkbox.addEventListener('change', function() {
                    // Agregar/quitar clase visual a la fila
                    const row = this.closest('tr');
                    if (this.checked) {
                        row.classList.add('selected');
                    } else {
                        row.classList.remove('selected');
                    }
                    
                    updateSelectAllCheckbox();
                    updateDesasignarButton();
                });
            });

            // Evento para botón de desasignar seleccionados
            if (btnDesasignarSeleccionados) {
                btnDesasignarSeleccionados.addEventListener('click', function() {
                    const selectedStudents = getSelectedStudents();
                    if (selectedStudents.length > 0) {
                        showMultipleUnassignConfirmation(selectedStudents);
                    }
                });
            }
        }

        // Actualizar estado del checkbox "Seleccionar todo"
        function updateSelectAllCheckbox() {
            const selectAllCheckbox = document.getElementById('selectAllStudents');
            const studentCheckboxes = document.querySelectorAll('.student-checkbox');
            const checkedBoxes = document.querySelectorAll('.student-checkbox:checked');

            if (selectAllCheckbox) {
                selectAllCheckbox.indeterminate = checkedBoxes.length > 0 && checkedBoxes.length < studentCheckboxes.length;
                selectAllCheckbox.checked = checkedBoxes.length === studentCheckboxes.length && studentCheckboxes.length > 0;
            }
        }

        // Mostrar/ocultar botón de desasignar seleccionados
        function updateDesasignarButton() {
            const checkedBoxes = document.querySelectorAll('.student-checkbox:checked');
            const btnDesasignarSeleccionados = document.getElementById('btnDesasignarSeleccionados');
            
            if (btnDesasignarSeleccionados) {
                if (checkedBoxes.length > 0) {
                    btnDesasignarSeleccionados.style.display = 'inline-block';
                    btnDesasignarSeleccionados.textContent = `Desasignar ${checkedBoxes.length} estudiante(s)`;
                } else {
                    btnDesasignarSeleccionados.style.display = 'none';
                }
            }
        }

        // Obtener estudiantes seleccionados
        function getSelectedStudents() {
            const checkedBoxes = document.querySelectorAll('.student-checkbox:checked');
            return Array.from(checkedBoxes).map(checkbox => ({
                id: checkbox.value,
                name: checkbox.getAttribute('data-student-name')
            }));
        }

        // Mostrar confirmación para desasignación múltiple
        function showMultipleUnassignConfirmation(selectedStudents) {
            const count = selectedStudents.length;
            const names = selectedStudents.map(s => s.name).join(', ');
            const displayNames = count <= 3 ? names : `${selectedStudents.slice(0, 3).map(s => s.name).join(', ')} y ${count - 3} más`;

            Swal.fire({
                title: '⚠️ ¡ATENCIÓN! Desasignación Múltiple',
                html: `
                    <div class="text-start">
                        <p><strong>Está a punto de liberar a ${count} estudiante(s) de este grupo:</strong></p>
                        <div class="alert alert-warning mb-3">
                            <i class="fas fa-exclamation-triangle me-2"></i>
                            <strong>CRITICIDAD ALTA:</strong> Esta acción removerá permanentemente a los estudiantes seleccionados del grupo.
                        </div>
                        <div class="mb-3">
                            <strong>Estudiantes afectados:</strong><br>
                            <small class="text-muted">${displayNames}</small>
                        </div>
                        <div class="mb-3">
                            <label for="motivoModal" class="form-label"><strong>Motivo de desasignación (opcional):</strong></label>
                            <textarea class="form-control" id="motivoModal" rows="2" placeholder="Ej: Cambio de grupo, retiro temporal, etc."></textarea>
                        </div>
                        <div class="alert alert-danger">
                            <i class="fas fa-info-circle me-2"></i>
                            Los estudiantes quedarán <strong>SIN GRUPO ASIGNADO</strong> y deberán ser reasignados manualmente.
                        </div>
                    </div>
                `,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: `<i class="fas fa-user-minus"></i> Sí, liberar ${count} estudiante(s)`,
                cancelButtonText: '<i class="fas fa-times"></i> Cancelar',
                width: '600px',
                customClass: {
                    confirmButton: 'btn btn-danger me-2',
                    cancelButton: 'btn btn-secondary'
                },
                buttonsStyling: false
            }).then((result) => {
                if (result.isConfirmed) {
                    const motivo = document.getElementById('motivoModal').value;
                    executeMultipleUnassign(selectedStudents, motivo);
                }
            });
        }

        // Ejecutar desasignación múltiple
        function executeMultipleUnassign(selectedStudents, motivo) {
            const form = document.getElementById('formDesasignacionMultiple');
            const motivoInput = document.getElementById('motivoDesasignacion');
            const estudiantesContainer = document.getElementById('estudiantesSeleccionadosInputs');

            // Establecer motivo
            motivoInput.value = motivo || '';

            // Limpiar inputs anteriores
            estudiantesContainer.innerHTML = '';

            // Agregar inputs para estudiantes seleccionados
            selectedStudents.forEach(student => {
                const input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'estudiantesIds';
                input.value = student.id;
                estudiantesContainer.appendChild(input);
            });

            // Mostrar loading
            Swal.fire({
                title: 'Procesando...',
                text: 'Desasignando estudiantes del grupo',
                allowOutsideClick: false,
                allowEscapeKey: false,
                didOpen: () => {
                    Swal.showLoading();
                }
            });

            // Enviar formulario
            form.submit();
        }

        async function cargarMateriasDisponibles() {
            try {
                const response = await fetch(`/GruposEstudiantes/ObtenerMateriasDisponibles/@Model.GrupoId`);
                if (!response.ok) {
                    throw new Error('Error al cargar materias');
                }

                const data = await response.json();
                mostrarMaterias(data.materias, data.materiasAsociadas);
            } catch (error) {
                console.error('Error:', error);
                document.getElementById('materiasContainer').innerHTML = `
                    <div class="col-12">
                        <div class="alert alert-danger">
                            <i class="fas fa-exclamation-triangle me-2"></i>
                            Error al cargar las materias. Intente nuevamente.
                        </div>
                    </div>
                `;
            }
        }

        function mostrarMaterias(materias, materiasAsociadas) {
            const container = document.getElementById('materiasContainer');

            if (!materias || materias.length === 0) {
                container.innerHTML = `
                    <div class="col-12">
                        <div class="alert alert-info">
                            <i class="fas fa-info-circle me-2"></i>
                            No hay materias disponibles para asociar.
                        </div>
                    </div>
                `;
                return;
            }

            let html = '';
            materias.forEach(materia => {
                const isChecked = materiasAsociadas.includes(materia.materiaId);
                html += `
                    <div class="col-md-6 mb-2">
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" name="materiasSeleccionadas"
                                   value="${materia.materiaId}" id="materia_${materia.materiaId}"
                                   ${isChecked ? 'checked' : ''}>
                            <label class="form-check-label" for="materia_${materia.materiaId}">
                                <strong>${materia.codigo}</strong> - ${materia.nombre}
                            </label>
                        </div>
                    </div>
                `;
            });

            container.innerHTML = html;
        }

        async function guardarMaterias() {
            try {
                const form = document.getElementById('materiasForm');
                const formData = new FormData(form);

                // Mostrar loading
                Swal.fire({
                    title: 'Guardando cambios...',
                    text: 'Por favor espere',
                    allowOutsideClick: false,
                    didOpen: () => {
                        Swal.showLoading();
                    }
                });

                const response = await fetch(form.action, {
                    method: 'POST',
                    body: formData,
                    headers: {
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    }
                });

                if (response.ok) {
                    Swal.fire({
                        title: '¡Éxito!',
                        text: 'Las materias se han actualizado correctamente.',
                        icon: 'success'
                    }).then(() => {
                        location.reload(); // Recargar la página para mostrar los cambios
                    });
                } else {
                    throw new Error('Error en el servidor');
                }
            } catch (error) {
                console.error('Error:', error);
                Swal.fire({
                    title: 'Error',
                    text: 'No se pudieron guardar los cambios. Intente nuevamente.',
                    icon: 'error'
                });
            }
        }
    </script>
}


@model RubricasApp.Web.ViewModels.Grupos.AsignarEstudiantesViewModel

@{
    ViewData["Title"] = $"Asignar Estudiantes - {Model.GrupoCodigo}";
}

<div class="page-header">
    <div class="row align-items-center">
        <div class="col">
            <h1 class="page-title">
                <i class="fas fa-user-plus text-success me-2"></i>
                Asignar Estudiantes al Grupo
            </h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a href="@Url.Action("Index")">
                            <i class="fas fa-users-cog"></i> Grupos
                        </a>
                    </li>
                    <li class="breadcrumb-item">
                        <a href="@Url.Action("Details", new { id = Model.GrupoId })">
                            @Model.GrupoCodigo
                        </a>
                    </li>
                    <li class="breadcrumb-item active">Asignar Estudiantes</li>
                </ol>
            </nav>
        </div>
    </div>
</div>

<!-- Información del grupo -->
<div class="row mb-4">
    <div class="col-12">
        <div class="modern-card">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0">
                    <i class="fas fa-info-circle me-2"></i>
                    Información del Grupo
                </h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-3">
                        <strong>Código:</strong>
                        <span class="badge bg-primary fs-6">@Model.GrupoCodigo</span>
                    </div>
                    <div class="col-md-6">
                        <strong>Nombre:</strong>
                        @Model.GrupoNombre
                    </div>
                    <div class="col-md-3">
                        <strong>Capacidad:</strong>
                        @if (Model.CapacidadMaxima.HasValue)
                        {
                            <span class="text-@(Model.EspaciosDisponibles <= 0 ? "danger" : "success")">
                                @Model.EstudiantesActuales/@Model.CapacidadMaxima
                            </span>
                            <small class="text-muted">(@Model.EspaciosDisponibles disponibles)</small>
                        }
                        else
                        {
                            <span class="text-success">@Model.EstudiantesActuales (Sin límite)</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Formulario de asignación -->
<div class="row">
    <div class="col-12">
        <div class="modern-card">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="fas fa-users me-2"></i>
                    Estudiantes Disponibles (@Model.EstudiantesDisponibles.Count total)
                </h5>
            </div>
            <div class="card-body">
                @if (Model.EstudiantesDisponibles.Any())
                {
                    <form asp-action="AsignarEstudiantes" method="post" id="asignacionForm">
                        <input type="hidden" asp-for="GrupoId" />
                        
                        <!-- Filtros -->
                        <div class="row mb-3">
                            <div class="col-md-4">
                                <input type="text" class="form-control" placeholder="Buscar por nombre..." 
                                       id="filtroNombre" onkeyup="filtrarEstudiantes()">
                            </div>
                            <div class="col-md-4">
                                <input type="text" class="form-control" placeholder="Buscar por ID..." 
                                       id="filtroId" onkeyup="filtrarEstudiantes()">
                            </div>
                            <div class="col-md-4">
                                <input type="text" class="form-control" placeholder="Buscar por email..." 
                                       id="filtroEmail" onkeyup="filtrarEstudiantes()">
                            </div>
                        </div>

                        <!-- Opciones de asignación -->
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="MotivoAsignacion" class="form-label">Motivo de Asignación (Opcional)</label>
                                    <input asp-for="MotivoAsignacion" class="form-control" 
                                           placeholder="Ej: Asignación inicial, transferencia, etc." maxlength="200" />
                                    <span asp-validation-for="MotivoAsignacion" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-check mt-4">
                                    <input asp-for="EsGrupoPrincipal" class="form-check-input" checked="@Model.EsGrupoPrincipal" />
                                    <label asp-for="EsGrupoPrincipal" class="form-check-label">
                                        Establecer como grupo principal
                                    </label>
                                    <div class="form-text">Los estudiantes pueden tener solo un grupo principal</div>
                                </div>
                            </div>
                        </div>

                        <hr>

                        <!-- Selección masiva -->
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div>
                                <button type="button" class="btn btn-sm btn-outline-primary" onclick="seleccionarTodos()">
                                    <i class="fas fa-check-square"></i> Seleccionar Todos
                                </button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" onclick="deseleccionarTodos()">
                                    <i class="fas fa-square"></i> Deseleccionar Todos
                                </button>
                                <span class="badge bg-info ms-2" id="contadorSeleccionados">0 seleccionados</span>
                            </div>
                            @if (Model.CapacidadMaxima.HasValue && Model.EspaciosDisponibles <= 10)
                            {
                                <div class="alert alert-warning mb-0 py-1 px-2">
                                    <small><i class="fas fa-exclamation-triangle"></i> Solo quedan @Model.EspaciosDisponibles espacios disponibles</small>
                                </div>
                            }
                        </div>

                        <!-- Lista de estudiantes -->
                        <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                            <table class="table table-striped table-hover">
                                <thead class="table-dark sticky-top">
                                    <tr>
                                        <th width="50">
                                            <input type="checkbox" id="checkboxTodos" onchange="toggleTodos(this)">
                                        </th>
                                        <th>ID</th>
                                        <th>Estudiante</th>
                                        <th>Email</th>
                                        <th>Grupo Principal</th>
                                        <th>Estado</th>
                                    </tr>
                                </thead>
                                <tbody id="tablaEstudiantes">
                                    @foreach (var estudiante in Model.EstudiantesDisponibles)
                                    {
                                        <tr class="estudiante-row" 
                                            data-nombre="@estudiante.NombreCompleto.ToLower()" 
                                            data-id="@estudiante.NumeroId.ToLower()" 
                                            data-email="@estudiante.Email.ToLower()">
                                            <td>
                                                <input type="checkbox" name="EstudiantesSeleccionados" 
                                                       value="@estudiante.EstudianteId" 
                                                       class="form-check-input checkbox-estudiante"
                                                       onchange="actualizarContador()" />
                                            </td>
                                            <td>
                                                <code>@estudiante.NumeroId</code>
                                            </td>
                                            <td>
                                                <div>
                                                    <strong>@estudiante.NombreCompleto</strong>
                                                </div>
                                            </td>
                                            <td>
                                                <a href="mailto:@estudiante.Email">@estudiante.Email</a>
                                            </td>
                                            <td>
                                                @if (estudiante.TieneGrupoPrincipal)
                                                {
                                                    <span class="badge bg-warning">
                                                        @(string.IsNullOrEmpty(estudiante.GrupoActual) ? "Sí" : estudiante.GrupoActual)
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">Sin grupo</span>
                                                }
                                            </td>
                                            <td>
                                                <span class="badge bg-success">Disponible</span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <!-- Botones de acción -->
                        <div class="row mt-4">
                            <div class="col-12">
                                <hr>
                                <div class="d-flex justify-content-between">
                                    <a href="@Url.Action("Details", new { id = Model.GrupoId })" class="btn btn-modern secondary">
                                        <i class="fas fa-arrow-left"></i> Cancelar
                                    </a>
                                    <button type="submit" class="btn btn-modern success" id="btnAsignar" disabled>
                                        <i class="fas fa-user-plus"></i> Asignar Estudiantes Seleccionados
                                    </button>
                                </div>
                            </div>
                        </div>
                    </form>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="fas fa-users-slash fa-3x text-muted mb-3"></i>
                        <h5 class="text-muted">No hay estudiantes disponibles</h5>
                        <p class="text-muted">
                            Todos los estudiantes del período académico ya están asignados a este grupo
                            o no hay estudiantes registrados.
                        </p>
                        <a href="@Url.Action("Details", new { id = Model.GrupoId })" class="btn btn-primary">
                            <i class="fas fa-arrow-left"></i> Volver al Grupo
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        let espaciosDisponibles = @(Model.CapacidadMaxima?.ToString() ?? "null");
        let estudiantesActuales = @Model.EstudiantesActuales;
        
        function filtrarEstudiantes() {
            const filtroNombre = document.getElementById('filtroNombre').value.toLowerCase();
            const filtroId = document.getElementById('filtroId').value.toLowerCase();
            const filtroEmail = document.getElementById('filtroEmail').value.toLowerCase();
            
            const filas = document.querySelectorAll('.estudiante-row');
            let visibles = 0;
            
            filas.forEach(fila => {
                const nombre = fila.dataset.nombre;
                const id = fila.dataset.id;
                const email = fila.dataset.email;
                
                const coincide = (!filtroNombre || nombre.includes(filtroNombre)) &&
                               (!filtroId || id.includes(filtroId)) &&
                               (!filtroEmail || email.includes(filtroEmail));
                
                fila.style.display = coincide ? '' : 'none';
                if (coincide) visibles++;
            });
            
            // Actualizar contador de checkboxes después del filtro
            actualizarContador();
        }
        
        function seleccionarTodos() {
            const checkboxes = document.querySelectorAll('.checkbox-estudiante');
            const filasVisibles = document.querySelectorAll('.estudiante-row[style=""], .estudiante-row:not([style])');
            
            filasVisibles.forEach(fila => {
                const checkbox = fila.querySelector('.checkbox-estudiante');
                if (checkbox) {
                    checkbox.checked = true;
                }
            });
            
            actualizarContador();
        }
        
        function deseleccionarTodos() {
            const checkboxes = document.querySelectorAll('.checkbox-estudiante');
            checkboxes.forEach(cb => cb.checked = false);
            const checkboxTodos = document.getElementById('checkboxTodos');
            if (checkboxTodos) checkboxTodos.checked = false;
            actualizarContador();
        }
        
        function toggleTodos(checkbox) {
            const filasVisibles = document.querySelectorAll('.estudiante-row[style=""], .estudiante-row:not([style])');
            
            filasVisibles.forEach(fila => {
                const cb = fila.querySelector('.checkbox-estudiante');
                if (cb) {
                    cb.checked = checkbox.checked;
                }
            });
            
            actualizarContador();
        }
        
        function actualizarContador() {
            const seleccionados = document.querySelectorAll('.checkbox-estudiante:checked').length;
            const contadorElement = document.getElementById('contadorSeleccionados');
            if (contadorElement) {
                contadorElement.textContent = `${seleccionados} seleccionados`;
            }
            
            const btnAsignar = document.getElementById('btnAsignar');
            if (!btnAsignar) return; // Exit if button doesn't exist
            
            btnAsignar.disabled = seleccionados === 0;
            
            // Validar capacidad
            if (espaciosDisponibles !== null) {
                const espaciosRestantes = espaciosDisponibles - estudiantesActuales;
                if (seleccionados > espaciosRestantes) {
                    btnAsignar.disabled = true;
                    btnAsignar.innerHTML = `<i class="fas fa-exclamation-triangle"></i> Excede la capacidad (${espaciosRestantes} disponibles)`;
                    btnAsignar.className = 'btn btn-modern danger';
                } else if (seleccionados > 0) {
                    btnAsignar.disabled = false;
                    btnAsignar.innerHTML = `<i class="fas fa-user-plus"></i> Asignar ${seleccionados} Estudiantes`;
                    btnAsignar.className = 'btn btn-modern success';
                }
            } else if (seleccionados > 0) {
                btnAsignar.innerHTML = `<i class="fas fa-user-plus"></i> Asignar ${seleccionados} Estudiantes`;
                btnAsignar.className = 'btn btn-modern success';
            }
        }
        
        // Inicializar cuando el DOM esté listo
        document.addEventListener('DOMContentLoaded', function() {
            // ?? CORRECCIÓN: Verificar que el formulario existe antes de agregar event listeners
            const asignacionForm = document.getElementById('asignacionForm');
            if (asignacionForm) {
                // Validación del formulario
                asignacionForm.addEventListener('submit', function(e) {
                    const seleccionados = document.querySelectorAll('.checkbox-estudiante:checked').length;
                    
                    if (seleccionados === 0) {
                        e.preventDefault();
                        if (typeof Swal !== 'undefined') {
                            Swal.fire({
                                title: 'Sin selección',
                                text: 'Debe seleccionar al menos un estudiante para asignar.',
                                icon: 'warning'
                            });
                        } else {
                            alert('Debe seleccionar al menos un estudiante para asignar.');
                        }
                        return false;
                    }
                    
                    // Mostrar confirmación
                    e.preventDefault();
                    if (typeof Swal !== 'undefined') {
                        Swal.fire({
                            title: 'żConfirmar asignación?',
                            text: `Se asignarán ${seleccionados} estudiantes al grupo @Model.GrupoCodigo.`,
                            icon: 'question',
                            showCancelButton: true,
                            confirmButtonColor: '#28a745',
                            cancelButtonColor: '#6c757d',
                            confirmButtonText: 'Sí, asignar',
                            cancelButtonText: 'Cancelar'
                        }).then((result) => {
                            if (result.isConfirmed) {
                                // Mostrar loading
                                Swal.fire({
                                    title: 'Asignando estudiantes...',
                                    text: 'Por favor espere',
                                    allowOutsideClick: false,
                                    didOpen: () => {
                                        Swal.showLoading();
                                    }
                                });
                                
                                asignacionForm.submit();
                            }
                        });
                    } else {
                        // Fallback si SweetAlert no está disponible
                        if (confirm(`żConfirmar asignación de ${seleccionados} estudiantes al grupo @Model.GrupoCodigo?`)) {
                            asignacionForm.submit();
                        }
                    }
                });
            }
            
            // Inicializar contador solo si hay elementos
            actualizarContador();
        });
    </script>
}

@section Styles {
    <style>
        .estudiante-row:hover {
            background-color: rgba(0,123,255,0.05);
        }
        
        .checkbox-estudiante:checked {
            transform: scale(1.1);
        }
        
        .sticky-top {
            position: sticky;
            top: 0;
            z-index: 10;
        }
        
        .btn-modern.success {
            background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
            border: none;
            color: white;
        }
        
        .btn-modern.danger {
            background: linear-gradient(135deg, #dc3545 0%, #fd7e14 100%);
            border: none;
            color: white;
        }
        
        .btn-modern.secondary {
            background: linear-gradient(135deg, #6c757d 0%, #495057 100%);
            border: none;
            color: white;
        }
        
        .modern-card {
            border: none;
            box-shadow: 0 0 15px rgba(0,0,0,0.1);
            border-radius: 8px;
        }
        
        .table-responsive {
            border-radius: 8px;
        }
        
        code {
            background-color: #f8f9fa;
            color: #495057;
            padding: 2px 4px;
            border-radius: 3px;
        }
    </style>
}
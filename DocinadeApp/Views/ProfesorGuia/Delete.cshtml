@model RubricasApp.Web.ViewModels.ProfesorGuiaViewModel

@{
    ViewData["Title"] = "Desactivar Profesor Guía";
}

<div class="container">
    <div class="row mb-3">
        <div class="col-12">
            <h2><i class="fas fa-ban text-danger"></i> Desactivar Profesor Guía</h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index">Profesores Guía</a></li>
                    <li class="breadcrumb-item active">Desactivar</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0"><i class="fas fa-exclamation-triangle"></i> Confirmación de Desactivación</h5>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        <i class="fas fa-exclamation-triangle"></i>
                        <strong>¿Está seguro que desea desactivar esta asignación de profesor guía?</strong>
                        <p class="mb-0">Esta acción marcará al profesor como inactivo para este grupo.</p>
                    </div>

                    <dl class="row">
                        <dt class="col-sm-4">Profesor:</dt>
                        <dd class="col-sm-8">
                            <i class="fas fa-user-tie text-primary"></i> @Model.NombreProfesor
                        </dd>

                        <dt class="col-sm-4">Email:</dt>
                        <dd class="col-sm-8">
                            @if (!string.IsNullOrEmpty(Model.EmailProfesor))
                            {
                                <a href="mailto:@Model.EmailProfesor">@Model.EmailProfesor</a>
                            }
                            else
                            {
                                <span class="text-muted">N/A</span>
                            }
                        </dd>

                        <dt class="col-sm-4">Grupo:</dt>
                        <dd class="col-sm-8">
                            <strong>@Model.NombreGrupo</strong>
                            @if (!string.IsNullOrEmpty(Model.CodigoGrupo))
                            {
                                <span class="badge bg-secondary">@Model.CodigoGrupo</span>
                            }
                        </dd>

                        <dt class="col-sm-4">Período Académico:</dt>
                        <dd class="col-sm-8">@Model.PeriodoAcademico</dd>

                        <dt class="col-sm-4">Fecha de Asignación:</dt>
                        <dd class="col-sm-8">@Model.FechaAsignacion.ToString("dd/MM/yyyy")</dd>

                        @if (Model.FechaInicio.HasValue)
                        {
                            <dt class="col-sm-4">Fecha de Inicio:</dt>
                            <dd class="col-sm-8">@Model.FechaInicio.Value.ToString("dd/MM/yyyy")</dd>
                        }

                        @if (Model.FechaFin.HasValue)
                        {
                            <dt class="col-sm-4">Fecha de Fin:</dt>
                            <dd class="col-sm-8">@Model.FechaFin.Value.ToString("dd/MM/yyyy")</dd>
                        }

                        <dt class="col-sm-4">Estado Actual:</dt>
                        <dd class="col-sm-8">
                            @if (Model.Estado)
                            {
                                <span class="badge bg-success">
                                    <i class="fas fa-check"></i> Activo
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-danger">
                                    <i class="fas fa-times"></i> Inactivo
                                </span>
                            }
                        </dd>

                        @if (!string.IsNullOrEmpty(Model.Observaciones))
                        {
                            <dt class="col-sm-4">Observaciones:</dt>
                            <dd class="col-sm-8">@Model.Observaciones</dd>
                        }
                    </dl>

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Id" />
                        
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Volver al Listado
                            </a>
                            <button type="submit" class="btn btn-danger">
                                <i class="fas fa-ban"></i> Confirmar Desactivación
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

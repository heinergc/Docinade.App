@model IEnumerable<DocinadeApp.ViewModels.ProfesorGuiaViewModel>

@{
    ViewData["Title"] = "Profesores Guía";
    var periodoSeleccionado = ViewBag.PeriodoSeleccionado as int?;
    var grupoSeleccionado = ViewBag.GrupoSeleccionado as int?;
}

<div class="container-fluid">
    <div class="row mb-3">
        <div class="col-md-8">
            <h2><i class="fas fa-user-tie"></i> Profesores Guía</h2>
            <p class="text-muted">Gestión de profesores guía asignados a grupos</p>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Create" class="btn btn-primary">
                <i class="fas fa-plus"></i> Asignar Profesor Guía
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Filtros -->
    <div class="card mb-3">
        <div class="card-body">
            <form method="get" asp-action="Index" class="row g-3">
                <div class="col-md-5">
                    <label for="periodoId" class="form-label">Período Académico</label>
                    <select name="periodoId" id="periodoId" class="form-select">
                        <option value="">Todos los períodos</option>
                        @foreach (var item in (SelectList)ViewBag.Periodos)
                        {
                            <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                        }
                    </select>
                </div>
                <div class="col-md-5">
                    <label for="grupoId" class="form-label">Grupo</label>
                    <select name="grupoId" id="grupoId" class="form-select">
                        <option value="">Todos los grupos</option>
                        @foreach (var item in (SelectList)ViewBag.Grupos)
                        {
                            <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                        }
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-secondary w-100">
                        <i class="fas fa-filter"></i> Filtrar
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Tabla de Profesores Guía -->
    <div class="card">
        <div class="card-body">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover table-striped">
                        <thead class="table-dark">
                            <tr>
                                <th>Grupo</th>
                                <th>Código</th>
                                <th>Profesor Guía</th>
                                <th>Email</th>
                                <th>Período</th>
                                <th>Fecha Asignación</th>
                                <th>Fecha Inicio</th>
                                <th>Fecha Fin</th>
                                <th>Estado</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <strong>@item.NombreGrupo</strong>
                                    </td>
                                    <td>
                                        <span class="badge bg-secondary">@item.CodigoGrupo</span>
                                    </td>
                                    <td>
                                        <i class="fas fa-user-tie" style="color: black;"></i> @item.NombreProfesor
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(item.EmailProfesor))
                                        {
                                            <a href="mailto:@item.EmailProfesor" class="text-decoration-none">
                                                <i class="fas fa-envelope"></i> @item.EmailProfesor
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">N/A</span>
                                        }
                                    </td>
                                    <td>@item.PeriodoAcademico</td>
                                    <td>@item.FechaAsignacion.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        @if (item.FechaInicio.HasValue)
                                        {
                                            @item.FechaInicio.Value.ToString("dd/MM/yyyy")
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        @if (item.FechaFin.HasValue)
                                        {
                                            @item.FechaFin.Value.ToString("dd/MM/yyyy")
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        @if (item.Estado)
                                        {
                                            <span class="badge bg-success">
                                                <i class="fas fa-check"></i> Activo
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">
                                                <i class="fas fa-times"></i> Inactivo
                                            </span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group" role="group">
                                            <a asp-action="Edit" asp-route-id="@item.Id" 
                                               class="btn btn-sm btn-warning" 
                                               title="Editar">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            @if (item.Estado)
                                            {
                                                <a asp-action="Delete" asp-route-id="@item.Id" 
                                                   class="btn btn-sm btn-danger" 
                                                   title="Desactivar">
                                                    <i class="fas fa-ban"></i>
                                                </a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="mt-3">
                    <p class="text-muted">
                        <i class="fas fa-info-circle"></i> 
                        Total: <strong>@Model.Count()</strong> asignaciones
                        (@Model.Count(x => x.Estado) activas, @Model.Count(x => !x.Estado) inactivas)
                    </p>
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    <i class="fas fa-info-circle"></i> No hay profesores guía asignados con los filtros seleccionados.
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Auto-submit al cambiar período
        $('#periodoId').on('change', function() {
            $(this).closest('form').submit();
        });
    </script>
}

@model RubricasApp.Web.Models.ConfigurarRubricaViewModel

@{
    ViewData["Title"] = "Configurar Rúbrica Masivamente";
    var rubrica = Model.Rubrica;
    var items = Model.Rubrica.ItemsEvaluacion;
    var niveles = Model.Niveles;
}

@* Token CSRF para peticiones AJAX *@
@Html.AntiForgeryToken()

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <div class="d-flex justify-content-between align-items-center">
                        <h4 class="card-title mb-0">
                            <i class="fas fa-cog"></i> @ViewData["Title"]
                        </h4>
                        <div>
                            <a asp-action="Index" asp-route-idRubrica="@rubrica!.IdRubrica" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Volver
                            </a>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <!-- Información de la rúbrica -->
                        <div class="alert alert-info mb-4">
                            <h5><i class="fas fa-clipboard-list"></i> @rubrica!.NombreRubrica</h5>
                            @if (!string.IsNullOrEmpty(rubrica!.Descripcion))
                            {
                                <p class="mb-0">@rubrica.Descripcion</p>
                            }
                        </div>                    <!-- Herramientas de configuración rápida -->
                    <div class="card mb-4">
                        <div class="card-header">
                            <h6 class="card-title mb-0">
                                <i class="fas fa-magic"></i> Herramientas de Configuración Rápida
                            </h6>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-4">
                                    <button type="button" class="btn btn-outline-primary w-100" onclick="aplicarValoresLineales()">
                                        <i class="fas fa-chart-line"></i> Aplicar Valores Lineales
                                    </button>
                                    <small class="text-muted">Distribuye valores uniformemente</small>
                                </div>
                                <div class="col-md-4">
                                    <button type="button" class="btn btn-outline-info w-100" onclick="copiarFilaCompleta()">
                                        <i class="fas fa-copy"></i> Copiar Fila Completa
                                    </button>
                                    <small class="text-muted">Copia valores de un item a otros</small>
                                </div>
                                <div class="col-md-4">
                                    <button type="button" class="btn btn-outline-warning w-100" onclick="limpiarTodo()">
                                        <i class="fas fa-eraser"></i> Limpiar Todo
                                    </button>
                                    <small class="text-muted">Elimina todos los valores</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Formulario de configuración masiva -->
                    <form asp-action="ConfigurarRubrica" method="post" id="formConfiguracion">
                        <input type="hidden" name="id" value="@rubrica!.IdRubrica" />
                        
                        <!-- Tabla de configuración -->
                        <div class="table-scroll-container">
                            <!-- Header fijo con scroll horizontal -->
                            <div class="table-header-fixed">
                                <table class="table table-bordered" id="tablaHeader">
                                    <thead class="table-dark">
                                        <tr>
                                            <th width="25%">Item de Evaluación</th>
                                            @foreach (var nivel in niveles!.OrderBy(n => n.OrdenNivel))
                                            {
                                                <th class="text-center">
                                                    @if (!string.IsNullOrEmpty(nivel.Descripcion))
                                                    {
                                                        <span data-bs-toggle="tooltip"
                                                              data-bs-placement="top"
                                                              title="@nivel.Descripcion"
                                                              class="nivel-tooltip">
                                                            @nivel.NombreNivel
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        @nivel.NombreNivel
                                                    }
                                                </th>
                                            }
                                            <th width="10%">Acciones</th>
                                        </tr>
                                    </thead>
                                </table>
                            </div>
                            
                            <!-- Cuerpo de la tabla con scroll -->
                            <div class="table-body-scroll">
                                <table class="table table-bordered table-hover" id="tablaConfiguracion">
                                <tbody>
                                    @foreach (var item in items!)
                                    {
                                        <tr data-item-id="@item.IdItem">
                                            <td>
                                                @if (!string.IsNullOrEmpty(item.Descripcion))
                                                {
                                                    <strong class="item-tooltip" title="@item.Descripcion">@item.NombreItem</strong>
                                                }
                                                else
                                                {
                                                    <strong>@item.NombreItem</strong>
                                                }
                                                @if (!string.IsNullOrEmpty(item.Descripcion) && !string.Equals(item.Descripcion.Trim(), item.NombreItem.Trim(), StringComparison.OrdinalIgnoreCase))
                                                {
                                                    <br><small class="text-muted">@item.Descripcion</small>
                                                }
                                            </td>
                                            @foreach (var nivel in niveles!.OrderBy(n => n.OrdenNivel))
                                            {
                                                var valorExistente = Model.ValoresExistentes.FirstOrDefault(v => v.IdItem == item.IdItem && v.IdNivel == nivel.IdNivel);
                                                <td class="text-center">
                                                    <div class="input-group">
                                                        <input type="number" 
                                                               name="valores[@item.IdItem][@nivel.IdNivel]" 
                                                               value="@(valorExistente?.ValorPuntos.ToString("F1", System.Globalization.CultureInfo.InvariantCulture) ?? "")"
                                                               class="form-control text-center valor-input" 
                                                               step="0.1" 
                                                               min="0" 
                                                               max="100"
                                                               data-item="@item.IdItem"
                                                               data-nivel="@nivel.IdNivel"
                                                               placeholder="0.0" />
                                                        <span class="input-group-text">pts</span>
                                                    </div>
                                                    @if (valorExistente != null)
                                                    {
                                                        <input type="hidden" name="idsExistentes[@item.IdItem][@nivel.IdNivel]" value="@valorExistente.IdValor" />
                                                    }
                                                </td>
                                            }
                                            <td class="text-center">
                                                <div class="btn-group-vertical">
                                                    <button type="button" class="btn btn-sm btn-outline-info" onclick="copiarFila(@item.IdItem)" title="Copiar esta fila">
                                                        <i class="fas fa-copy"></i>
                                                    </button>
                                                    <button type="button" class="btn btn-sm btn-outline-secondary" onclick="aplicarProgresion(@item.IdItem)" title="Aplicar progresión lineal">
                                                        <i class="fas fa-chart-line"></i>
                                                    </button>
                                                    <button type="button" class="btn btn-sm btn-outline-danger" onclick="limpiarFila(@item.IdItem)" title="Limpiar fila">
                                                        <i class="fas fa-eraser"></i>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot>
                                    <tr class="table-primary">
                                        <th class="text-end" style="font-weight:bold; font-size:1.1em;">
                                            <i class="fas fa-sigma"></i> Total
                                        </th>
                                        @foreach (var nivel in niveles!.OrderBy(n => n.OrdenNivel))
                                        {
                                            <th class="text-center" id="total-nivel-@nivel.IdNivel" style="font-weight:bold; font-size:1.1em;">
                                                0.0
                                            </th>
                                        }
                                        <th></th>
                                    </tr>
                                </tfoot>
@*                                 <tfoot>
                                    <tr>
                                        <th class="text-end">Total</th>
                                        @foreach (var nivel in niveles!.OrderBy(n => n.OrdenNivel))
                                        {
                                            <th class="text-center" id="total-nivel-@nivel.IdNivel">0.0</th>
                                        }
                                        <th></th>
                                    </tr>
                                </tfoot> *@
                                </table>
                            </div>
                        </div>

                        <!-- Estadísticas en tiempo real -->
                        <div class="row mt-4">
                            <div class="col-md-3">
                                <div class="card text-center">
                                    <div class="card-body">
                                        <h5 class="card-title text-primary" id="totalConfiguraciones">0</h5>
                                        <p class="card-text small">Configuraciones</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="card text-center">
                                    <div class="card-body">
                                        <h5 class="card-title text-success" id="promedioGeneral">0.0</h5>
                                        <p class="card-text small">Promedio General</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="card text-center">
                                    <div class="card-body">
                                        <h5 class="card-title text-warning" id="valorMinimo">0.0</h5>
                                        <p class="card-text small">Valor Mínimo</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="card text-center">
                                    <div class="card-body">
                                        <h5 class="card-title text-danger" id="valorMaximo">0.0</h5>
                                        <p class="card-text small">Valor Máximo</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <hr>

                        <!-- Botones de acción -->
                        <div class="d-flex justify-content-between">
                            <div>
                                <a asp-action="Index" asp-route-idRubrica="@rubrica!.IdRubrica" class="btn btn-secondary">
                                    <i class="fas fa-times"></i> Cancelar
                                </a>
                                <button type="button" class="btn btn-outline-info" onclick="previsualizarCambios()">
                                    <i class="fas fa-eye"></i> Previsualizar
                                </button>
                            </div>
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="fas fa-save"></i> Guardar Configuración
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal para herramientas -->
<div class="modal fade" id="modalHerramientas" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">Herramienta</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="modalBody">
                <!-- Contenido dinámico -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" id="modalConfirmar">Aplicar</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Función debounce para optimizar eventos de input
        function debounce(func, wait) {
            var timeout;
            return function executedFunction() {
                var context = this;
                var args = arguments;
                var later = function() {
                    clearTimeout(timeout);
                    func.apply(context, args);
                };
                clearTimeout(timeout);
                timeout = setTimeout(later, wait);
            };
        }

        $(document).ready(function() {
            console.log('=== INICIALIZANDO TOOLTIPS ===');
            
            // Verificar que jQuery esté disponible
            console.log('jQuery disponible:', typeof $ !== 'undefined');
            
            // Inicializar scroll sincronizado
            inicializarScrollSincronizado();
            
            // IMPLEMENTACIÓN LIMPIA: Tooltips con CSS puro
            $('.nivel-tooltip, .item-tooltip').each(function() {
                var $element = $(this);
                var title = $element.attr('title') || $element.attr('data-bs-original-title');
                
                if (title && title.trim() !== '') {
                    // Crear tooltip con CSS puro
                    var $tooltip = $('<div class="simple-tooltip"></div>');
                    $tooltip.text(title);
                    $('body').append($tooltip);
                    $tooltip.hide();
                    
                    $element.hover(
                        function(e) {
                            var offset = $element.offset();
                            var tooltipWidth = $tooltip.outerWidth();
                            var tooltipHeight = $tooltip.outerHeight();
                            var elementWidth = $element.outerWidth();
                            var elementHeight = $element.outerHeight();
                            
                            // Posicionar arriba del elemento, centrado
                            var left = offset.left + (elementWidth / 2) - (tooltipWidth / 2);
                            var top = offset.top - tooltipHeight - 8;
                            
                            // Asegurar que no se salga de la pantalla
                            if (left < 10) left = 10;
                            if (left + tooltipWidth > $(window).width() - 10) {
                                left = $(window).width() - tooltipWidth - 10;
                            }
                            
                            $tooltip.css({
                                top: top,
                                left: left,
                                display: 'block'
                            }).addClass('show');
                        },
                        function() {
                            $tooltip.removeClass('show').hide();
                        }
                    );
                }
            });
            
            // Calcular estadísticas al cargar y cuando cambien los valores (con debounce)
            $('.valor-input').on('input', debounce(function() {
                calcularEstadisticas();
                validarRango(this);
            }, 150));
            
            calcularEstadisticas();
        });

        function inicializarScrollSincronizado() {
            var $headerFixed = $('.table-header-fixed');
            var $bodyScroll = $('.table-body-scroll');
            var isScrolling = false;
            
            // Sincronizar scroll horizontal con debounce para evitar bucles
            $bodyScroll.on('scroll', function() {
                if (!isScrolling) {
                    isScrolling = true;
                    $headerFixed.scrollLeft($(this).scrollLeft());
                    setTimeout(function() { isScrolling = false; }, 10);
                }
            });
            
            $headerFixed.on('scroll', function() {
                if (!isScrolling) {
                    isScrolling = true;
                    $bodyScroll.scrollLeft($(this).scrollLeft());
                    setTimeout(function() { isScrolling = false; }, 10);
                }
            });
        }

        function calcularEstadisticas() {
            var valores = [];
            $('.valor-input').each(function() {
                var valor = parseFloat($(this).val());
                if (!isNaN(valor)) {
                    valores.push(valor);
                }
            });

            var total = valores.length;
            var suma = valores.reduce((a, b) => a + b, 0);
            var promedio = total > 0 ? suma / total : 0;
            var minimo = total > 0 ? Math.min(...valores) : 0;
            var maximo = total > 0 ? Math.max(...valores) : 0;

                    // Calcular totales por nivel (columna)
            var nivelesIds = @Html.Raw(Json.Serialize(niveles.OrderBy(n => n.OrdenNivel).Select(n => n.IdNivel)));
            nivelesIds.forEach(function(nivelId) {
                var totalNivel = 0;
                $('.valor-input[data-nivel="' + nivelId + '"]').each(function() {
                    var valor = parseFloat($(this).val());
                    if (!isNaN(valor)) {
                        totalNivel += valor;
                    }
                });
                $('#total-nivel-' + nivelId).text(totalNivel.toFixed(1));
            });

            // REMOVIDO: Cálculo de pesos porcentuales que causaba parpadeo del scrollbar
            // La funcionalidad de mostrar porcentajes se eliminó para evitar cambios dinámicos en el layout
     

            $('#totalConfiguraciones').text(total);
            $('#promedioGeneral').text(promedio.toFixed(1));
            $('#valorMinimo').text(minimo.toFixed(1));
            $('#valorMaximo').text(maximo.toFixed(1));
        }

        function validarRango(input) {
            var valor = parseFloat($(input).val());
            if (valor < 0 || valor > 100) {
                $(input).addClass('is-invalid');
            } else {
                $(input).removeClass('is-invalid');
            }
        }

        function aplicarValoresLineales() {
            var niveles = @Html.Raw(Json.Serialize(niveles!.OrderBy(n => n.OrdenNivel).Select(n => n.IdNivel)));
            var nivelesCount = niveles.length;
            
            $('.valor-input').each(function() {
                var nivelIndex = niveles.indexOf(parseInt($(this).data('nivel')));
                // Invertir la lógica: el primer nivel (index 0) debe tener el valor más bajo
                // y el último nivel debe tener el valor más alto
                var valor = ((nivelesCount - 1 - nivelIndex) / (nivelesCount - 1)) * 100;
                $(this).val(valor.toFixed(1));
            });
            
            calcularEstadisticas();
        }

        function copiarFilaCompleta() {
            // Mostrar modal para seleccionar fila origen
            var html = '<div class="mb-3">';
            html += '<label class="form-label"><strong>Selecciona la fila origen (de donde copiar):</strong></label>';
            html += '<select class="form-select" id="filaOrigen">';
            html += '<option value="">-- Selecciona un ítem --</option>';
            
            $('tr[data-item-id]').each(function() {
                var id = $(this).data('item-id');
                var nombre = $(this).find('td:first strong').text();
                html += '<option value="' + id + '">' + nombre + '</option>';
            });
            
            html += '</select></div>';
            html += '<div class="mb-3">';
            html += '<label class="form-label"><strong>Selecciona las filas destino (donde copiar):</strong></label>';
            html += '<div id="filasDestino">';
            
            $('tr[data-item-id]').each(function() {
                var id = $(this).data('item-id');
                var nombre = $(this).find('td:first strong').text();
                html += '<div class="form-check">';
                html += '<input class="form-check-input fila-destino" type="checkbox" value="' + id + '" id="dest_' + id + '">';
                html += '<label class="form-check-label" for="dest_' + id + '">' + nombre + '</label>';
                html += '</div>';
            });
            
            html += '</div></div>';
            
            $('#modalTitle').text('Copiar Fila Completa');
            $('#modalBody').html(html);
            
            // Actualizar filas destino cuando cambie la selección origen
            $('#filaOrigen').on('change', function() {
                var origenId = $(this).val();
                $('.fila-destino').each(function() {
                    if ($(this).val() == origenId) {
                        $(this).prop('disabled', true).prop('checked', false);
                        $(this).next('label').addClass('text-muted');
                    } else {
                        $(this).prop('disabled', false);
                        $(this).next('label').removeClass('text-muted');
                    }
                });
            });
            
            $('#modalConfirmar').off('click').on('click', function() {
                var origenId = $('#filaOrigen').val();
                if (!origenId) {
                    alert('Por favor selecciona una fila origen.');
                    return;
                }
                
                var destinosSeleccionados = $('.fila-destino:checked');
                if (destinosSeleccionados.length === 0) {
                    alert('Por favor selecciona al menos una fila destino.');
                    return;
                }
                
                // Obtener valores de la fila origen
                var filaOrigen = $('tr[data-item-id="' + origenId + '"]');
                var valores = [];
                filaOrigen.find('.valor-input').each(function() {
                    valores.push($(this).val());
                });
                
                // Copiar a filas destino
                destinosSeleccionados.each(function() {
                    var targetItemId = $(this).val();
                    var filaDestino = $('tr[data-item-id="' + targetItemId + '"]');
                    
                    filaDestino.find('.valor-input').each(function(index) {
                        $(this).val(valores[index]);
                    });
                });
                
                calcularEstadisticas();
                $('#modalHerramientas').modal('hide');
                
                var mensaje = 'Se copiaron los valores de "' + $('#filaOrigen option:selected').text() + 
                            '" a ' + destinosSeleccionados.length + ' fila(s) destino.';
                
                // Mostrar mensaje de confirmación
                setTimeout(function() {
                    alert(mensaje);
                }, 300);
            });
            
            $('#modalHerramientas').modal('show');
        }

        function copiarFila(itemId) {
            var filaOrigen = $('tr[data-item-id="' + itemId + '"]');
            var valores = [];
            
            filaOrigen.find('.valor-input').each(function() {
                valores.push($(this).val());
            });
            
            // Mostrar modal para seleccionar filas destino
            var html = '<p>Selecciona las filas donde copiar los valores:</p>';
            $('tr[data-item-id]').each(function() {
                var id = $(this).data('item-id');
                if (id != itemId) {
                    var nombre = $(this).find('td:first strong').text();
                    html += '<div class="form-check">';
                    html += '<input class="form-check-input" type="checkbox" value="' + id + '" id="item_' + id + '">';
                    html += '<label class="form-check-label" for="item_' + id + '">' + nombre + '</label>';
                    html += '</div>';
                }
            });
            
            $('#modalTitle').text('Copiar Fila');
            $('#modalBody').html(html);
            $('#modalConfirmar').off('click').on('click', function() {
                $('.form-check-input:checked').each(function() {
                    var targetItemId = $(this).val();
                    var filaDestino = $('tr[data-item-id="' + targetItemId + '"]');
                    
                    filaDestino.find('.valor-input').each(function(index) {
                        $(this).val(valores[index]);
                    });
                });
                
                calcularEstadisticas();
                $('#modalHerramientas').modal('hide');
            });
            
            $('#modalHerramientas').modal('show');
        }

        function aplicarProgresion(itemId) {
            var fila = $('tr[data-item-id="' + itemId + '"]');
            var inputs = fila.find('.valor-input');
            var count = inputs.length;
            
            inputs.each(function(index) {
                // Invertir la lógica: el primer input (index 0) debe tener el valor más bajo
                // y el último input debe tener el valor más alto
                var valor = ((count - 1 - index) / (count - 1)) * 100;
                $(this).val(valor.toFixed(1));
            });
            
            calcularEstadisticas();
        }

        function limpiarFila(itemId) {
            if (confirm('¿Limpiar todos los valores de esta fila?')) {
                $('tr[data-item-id="' + itemId + '"] .valor-input').val('');
                calcularEstadisticas();
            }
        }

        function limpiarTodo() {
            if (confirm('¿Está seguro de limpiar TODOS los valores?')) {
                $('.valor-input').val('');
                calcularEstadisticas();
            }
        }

        function previsualizarCambios() {
            var cambios = [];
            var itemsAfectados = {};
            
            $('.valor-input').each(function() {
                if ($(this).val()) {
                    var itemId = $(this).data('item');
                    var nivelId = $(this).data('nivel');
                    var valor = parseFloat($(this).val());
                    
                    // Obtener nombres para mostrar
                    var itemNombre = $('tr[data-item-id="' + itemId + '"] td:first strong').text();
                    var nivelNombre = $('th').filter(function() {
                        return $(this).text().includes($('input[data-nivel="' + nivelId + '"]').closest('td').index());
                    }).first().text().split('\n')[0];
                    
                    // Buscar el nombre del nivel de forma más confiable
                    var nivelIndex = $('input[data-nivel="' + nivelId + '"]').closest('td').index() - 1;
                    var nivelHeader = $('thead th').eq(nivelIndex + 1);
                    nivelNombre = nivelHeader.contents().filter(function() {
                        return this.nodeType === 3; // Text node
                    }).first().text().trim();
                    
                    if (!itemsAfectados[itemId]) {
                        itemsAfectados[itemId] = {
                            nombre: itemNombre,
                            niveles: []
                        };
                    }
                    
                    itemsAfectados[itemId].niveles.push({
                        nivel: nivelNombre,
                        valor: valor
                    });
                    
                    cambios.push({ item: itemId, nivel: nivelId, valor: valor });
                }
            });
            
            // Crear HTML para el modal
            var html = '<div class="preview-container">';
            
            if (cambios.length === 0) {
                html += '<div class="alert alert-warning">';
                html += '<i class="fas fa-exclamation-triangle"></i> ';
                html += 'No hay configuraciones para guardar. Todos los campos están vacíos.';
                html += '</div>';
            } else {
                // Resumen general
                html += '<div class="alert alert-info mb-3">';
                html += '<h6><i class="fas fa-info-circle"></i> Resumen de Cambios</h6>';
                html += '<ul class="mb-0">';
                html += '<li><strong>' + cambios.length + '</strong> configuraciones de valores</li>';
                html += '<li><strong>' + Object.keys(itemsAfectados).length + '</strong> ítems de evaluación afectados</li>';
                html += '</ul>';
                html += '</div>';
                
                // Detalles por ítem
                html += '<div class="row">';
                
                Object.keys(itemsAfectados).forEach(function(itemId) {
                    var item = itemsAfectados[itemId];
                    
                    html += '<div class="col-md-6 mb-3">';
                    html += '<div class="card border-primary">';
                    html += '<div class="card-header bg-primary text-white py-2">';
                    html += '<small><i class="fas fa-clipboard-check"></i> ' + item.nombre + '</small>';
                    html += '</div>';
                    html += '<div class="card-body p-2">';
                    html += '<div class="table-responsive">';
                    html += '<table class="table table-sm table-borderless mb-0">';
                    
                    // Ordenar niveles por valor (descendente)
                    item.niveles.sort(function(a, b) { return b.valor - a.valor; });
                    
                    item.niveles.forEach(function(config) {
                        var badgeClass = '';
                        if (config.valor >= 80) badgeClass = 'bg-success';
                        else if (config.valor >= 60) badgeClass = 'bg-info';
                        else if (config.valor >= 40) badgeClass = 'bg-warning text-dark';
                        else badgeClass = 'bg-danger';
                        
                        html += '<tr>';
                        html += '<td class="text-start">' + config.nivel + '</td>';
                        html += '<td class="text-end">';
                        html += '<span class="badge ' + badgeClass + '">' + config.valor.toFixed(1) + ' pts</span>';
                        html += '</td>';
                        html += '</tr>';
                    });
                    
                    html += '</table>';
                    html += '</div>';
                    html += '</div>';
                    html += '</div>';
                    html += '</div>';
                });
                
                html += '</div>';
                
                // Estadísticas adicionales
                var valores = cambios.map(c => c.valor);
                var promedio = valores.reduce((a, b) => a + b, 0) / valores.length;
                var minimo = Math.min(...valores);
                var maximo = Math.max(...valores);
                
                html += '<div class="mt-3">';
                html += '<h6><i class="fas fa-chart-bar"></i> Estadísticas</h6>';
                html += '<div class="row text-center">';
                html += '<div class="col-3">';
                html += '<div class="bg-light p-2 rounded">';
                html += '<strong class="text-success">' + promedio.toFixed(1) + '</strong><br>';
                html += '<small>Promedio</small>';
                html += '</div>';
                html += '</div>';
                html += '<div class="col-3">';
                html += '<div class="bg-light p-2 rounded">';
                html += '<strong class="text-warning">' + minimo.toFixed(1) + '</strong><br>';
                html += '<small>Mínimo</small>';
                html += '</div>';
                html += '</div>';
                html += '<div class="col-3">';
                html += '<div class="bg-light p-2 rounded">';
                html += '<strong class="text-danger">' + maximo.toFixed(1) + '</strong><br>';
                html += '<small>Máximo</small>';
                html += '</div>';
                html += '</div>';
                html += '<div class="col-3">';
                html += '<div class="bg-light p-2 rounded">';
                html += '<strong class="text-info">' + (maximo - minimo).toFixed(1) + '</strong><br>';
                html += '<small>Rango</small>';
                html += '</div>';
                html += '</div>';
                html += '</div>';
                html += '</div>';
            }
            
            html += '</div>';
            
            $('#modalTitle').text('Vista Previa de Configuración');
            $('#modalBody').html(html);
            
            // Cambiar el botón "Aplicar" por "Cerrar" ya que es solo vista previa
            $('#modalConfirmar').text('Cerrar').off('click').on('click', function() {
                $('#modalHerramientas').modal('hide');
            });
            
            $('#modalHerramientas').modal('show');
            
            // También mantener el log en consola para desarrolladores
            console.log('Cambios a aplicar:', cambios);
        }
    </script>
}


@model RubricasApp.Web.Models.ValorRubrica

@{
    ViewData["Title"] = "Crear Valor de Rúbrica";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h4 class="card-title mb-0">
                        <i class="fas fa-plus-circle"></i> @ViewData["Title"]
                    </h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="IdRubrica" class="form-label">Rúbrica *</label>
                                    @Html.DropDownListFor(m => m.IdRubrica, ViewBag.Rubricas as SelectList, "-- Seleccionar rúbrica --", new { @class = "form-select", required = "required", id = "rubricaSelect" })
                                    <span asp-validation-for="IdRubrica" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="IdItem" class="form-label">Item de Evaluación *</label>
                                    @Html.DropDownListFor(m => m.IdItem, ViewBag.Items as SelectList ?? new SelectList(new List<object>()), "-- Seleccionar item --", new { @class = "form-select", required = "required", id = "itemSelect", disabled = "disabled" })
                                    <span asp-validation-for="IdItem" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="IdNivel" class="form-label">Nivel de Calificación *</label>
                                    @Html.DropDownListFor(m => m.IdNivel, ViewBag.Niveles as SelectList, "-- Seleccionar nivel --", new { @class = "form-select", required = "required" })
                                    <span asp-validation-for="IdNivel" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="ValorPuntos" class="form-label">Valor en Puntos *</label>
                                    <div class="input-group">
                                        <input asp-for="ValorPuntos" class="form-control" type="number" step="0.1" min="0" max="100" required />
                                        <span class="input-group-text">pts</span>
                                    </div>
                                    <span asp-validation-for="ValorPuntos" class="text-danger"></span>
                                    <div class="form-text">Valor entre 0 y 100 puntos</div>
                                </div>
                            </div>
                        </div>

                        <!-- Información adicional cuando se seleccionen los valores -->
                        <div id="infoContainer" class="alert alert-info d-none">
                            <h6><i class="fas fa-info-circle"></i> Información Seleccionada</h6>
                            <div id="rubricaInfo"></div>
                            <div id="itemInfo"></div>
                            <div id="nivelInfo"></div>
                        </div>

                        <!-- Validación de duplicados -->
                        <div id="duplicadoAlert" class="alert alert-warning d-none">
                            <i class="fas fa-exclamation-triangle"></i>
                            <strong>¡Atención!</strong> Ya existe un valor configurado para esta combinación de Rúbrica, Item y Nivel.
                        </div>

                        <hr>
                        
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Volver a la Lista
                            </a>
                            <button type="submit" class="btn btn-primary" id="submitBtn">
                                <i class="fas fa-save"></i> Crear Valor
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Card de ayuda -->
            <div class="card mt-4">
                <div class="card-header">
                    <h6 class="card-title mb-0">
                        <i class="fas fa-question-circle"></i> Ayuda
                    </h6>
                </div>
                <div class="card-body">
                    <ul class="mb-0">
                        <li><strong>Rúbrica:</strong> Selecciona la rúbrica para la cual quieres configurar valores.</li>
                        <li><strong>Item de Evaluación:</strong> Los items disponibles dependen de la rúbrica seleccionada.</li>
                        <li><strong>Nivel de Calificación:</strong> Define el nivel de desempeño (Excelente, Bueno, Regular, etc.).</li>
                        <li><strong>Valor en Puntos:</strong> Asigna un puntaje numérico entre 0 y 100 puntos.</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        $(document).ready(function() {
            var rubricaSelect = $('#rubricaSelect');
            var itemSelect = $('#itemSelect');
            var nivelSelect = $('#IdNivel');
            var infoContainer = $('#infoContainer');
            var duplicadoAlert = $('#duplicadoAlert');
            var submitBtn = $('#submitBtn');

            // Cargar items cuando cambia la rúbrica
            rubricaSelect.change(function() {
                var rubricaId = $(this).val();
                
                // Limpiar y deshabilitar el select de items
                itemSelect.empty();
                itemSelect.append('<option value="">-- Seleccionar item --</option>');
                itemSelect.prop('disabled', true);
                
                if (rubricaId) {
                    // Mostrar indicador de carga
                    itemSelect.append('<option value="">Cargando...</option>');
                    
                    // Cargar items via AJAX
                    $.get('@Url.Action("GetItemsByRubrica", "ItemsEvaluacion")', { rubricaId: rubricaId })
                        .done(function(data) {
                            itemSelect.empty();
                            itemSelect.append('<option value="">-- Seleccionar item --</option>');
                            
                            if (data && data.length > 0) {
                                $.each(data, function(index, item) {
                                    itemSelect.append('<option value="' + item.value + '">' + item.text + '</option>');
                                });
                                itemSelect.prop('disabled', false);
                            } else {
                                itemSelect.append('<option value="">No hay items disponibles</option>');
                            }
                        })
                        .fail(function(xhr, status, error) {
                            console.error('Error cargando items:', error);
                            itemSelect.empty();
                            itemSelect.append('<option value="">-- Seleccionar item --</option>');
                            itemSelect.append('<option value="">Error al cargar items</option>');
                            
                            // Fallback: recargar página con parámetro
                            console.log('Intentando fallback...');
                            setTimeout(function() {
                                window.location.href = '@Url.Action("Create")?rubricaId=' + rubricaId;
                            }, 2000);
                        });
                }
                
                updateInfo();
                checkDuplicado();
            });

            // Actualizar información cuando cambian las selecciones
            itemSelect.change(updateInfo);
            nivelSelect.change(function() {
                updateInfo();
                checkDuplicado();
            });

            function updateInfo() {
                var rubricaText = rubricaSelect.find('option:selected').text();
                var itemText = itemSelect.find('option:selected').text();
                var nivelText = nivelSelect.find('option:selected').text();
                
                if (rubricaSelect.val() && itemSelect.val() && nivelSelect.val()) {
                    $('#rubricaInfo').html('<strong>Rúbrica:</strong> ' + rubricaText);
                    $('#itemInfo').html('<strong>Item:</strong> ' + itemText);
                    $('#nivelInfo').html('<strong>Nivel:</strong> ' + nivelText);
                    infoContainer.removeClass('d-none');
                } else {
                    infoContainer.addClass('d-none');
                }
            }

            function checkDuplicado() {
                var rubricaId = rubricaSelect.val();
                var itemId = itemSelect.val();
                var nivelId = nivelSelect.val();
                
                if (rubricaId && itemId && nivelId) {
                    $.get('@Url.Action("CheckDuplicado")', {
                        idRubrica: rubricaId,
                        idItem: itemId,
                        idNivel: nivelId
                    })
                    .done(function(exists) {
                        if (exists) {
                            duplicadoAlert.removeClass('d-none');
                            submitBtn.prop('disabled', true);
                        } else {
                            duplicadoAlert.addClass('d-none');
                            submitBtn.prop('disabled', false);
                        }
                    });
                } else {
                    duplicadoAlert.addClass('d-none');
                    submitBtn.prop('disabled', false);
                }
            }

            // Verificar al cargar la página si hay valores preseleccionados
            if (rubricaSelect.val()) {
                // Si hay una rúbrica seleccionada, cargar los items
                rubricaSelect.trigger('change');
            } else {
                updateInfo();
                checkDuplicado();
            }
        });
    </script>
}

@model IEnumerable<DocinadeApp.Models.ValorRubrica>

@{
    ViewData["Title"] = "Gestión de Valores de Rúbrica";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1>@ViewData["Title"]</h1>
                <div>
                    <a asp-action="Create" class="btn btn-primary">
                        <i class="fas fa-plus"></i> Nuevo Valor
                    </a>
                    @if (ViewBag.RubricaSeleccionada != null)
                    {
                        <a asp-action="ConfigurarRubrica" asp-route-id="@ViewBag.RubricaSeleccionada.IdRubrica" class="btn btn-info">
                            <i class="fas fa-cog"></i> Configurar Rúbrica
                        </a>
                    }
                </div>
            </div>

            <!-- Filtros -->
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">
                        <i class="fas fa-filter"></i> Filtros
                    </h5>
                </div>
                <div class="card-body">
                    <form method="get" asp-action="Index">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="idRubrica" class="form-label">Rúbrica</label>
                                    @Html.DropDownList("idRubrica", ViewBag.Rubricas as SelectList, "-- Todas las rúbricas --", new { @class = "form-select", id = "filtroRubrica" })
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="idItem" class="form-label">Item de Evaluación</label>
                                    @Html.DropDownList("idItem", ViewBag.Items as SelectList ?? new SelectList(new List<object>()), "-- Todos los items --", new { @class = "form-select", id = "filtroItem" })
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-12">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-search"></i> Filtrar
                                </button>
                                <a asp-action="Index" class="btn btn-secondary">
                                    <i class="fas fa-times"></i> Limpiar
                                </a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Información de contexto -->
            @if (ViewBag.RubricaSeleccionada != null)
            {
                <div class="alert alert-info">
                    <strong>Rúbrica seleccionada:</strong> @ViewBag.RubricaSeleccionada.NombreRubrica
                    @if (ViewBag.ItemSeleccionado != null)
                    {
                        <br><strong>Item seleccionado:</strong> @ViewBag.ItemSeleccionado.NombreItem
                    }
                </div>
            }

            <!-- Tabla de valores -->
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">
                        <i class="fas fa-list"></i> Valores Configurados
                        <span class="badge bg-primary ms-2">@Model.Count() registro(s)</span>
                    </h5>
                </div>
                <div class="card-body">
                    @if (Model.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Rúbrica</th>
                                        <th>Item de Evaluación</th>
                                        <th>Nivel de Calificación</th>
                                        <th>Valor en Puntos</th>
                                        <th width="150">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>
                                                <strong>@item.Rubrica.NombreRubrica</strong>
                                                @if (!string.IsNullOrEmpty(item.Rubrica.Descripcion))
                                                {
                                                    <br><small class="text-muted">@item.Rubrica.Descripcion</small>
                                                }
                                            </td>
                                            <td>
                                                <strong>@item.ItemEvaluacion.NombreItem</strong>
                                                @if (!string.IsNullOrEmpty(item.ItemEvaluacion.Descripcion))
                                                {
                                                    <br><small class="text-muted">@item.ItemEvaluacion.Descripcion</small>
                                                }
                                            </td>
                                            <td>
                                                <span class="badge bg-secondary">@item.NivelCalificacion.NombreNivel</span>
                                                @if (!string.IsNullOrEmpty(item.NivelCalificacion.Descripcion))
                                                {
                                                    <br><small class="text-muted">@item.NivelCalificacion.Descripcion</small>
                                                }
                                            </td>
                                            <td>
                                                <span class="badge bg-success fs-6">@item.ValorPuntos.ToString("F1") pts</span>
                                            </td>
                                            <td>
                                                <div class="btn-group" role="group">
                                                    <a asp-action="Details" asp-route-id="@item.IdValor" class="btn btn-sm btn-outline-info" title="Ver detalles">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                    <a asp-action="Edit" asp-route-id="@item.IdValor" class="btn btn-sm btn-outline-warning" title="Editar">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    <a asp-action="Delete" asp-route-id="@item.IdValor" class="btn btn-sm btn-outline-danger" title="Eliminar">
                                                        <i class="fas fa-trash"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-chart-line fa-3x text-muted mb-3"></i>
                            <h5 class="text-muted">No hay valores configurados</h5>
                            <p class="text-muted">
                                @if (ViewBag.RubricaSeleccionada != null)
                                {
                                    <text>No se han configurado valores para los filtros seleccionados.</text>
                                }
                                else
                                {
                                    <text>Comienza creando valores para tus rúbricas.</text>
                                }
                            </p>
                            <a asp-action="Create" class="btn btn-primary">
                                <i class="fas fa-plus"></i> Crear Primer Valor
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Auto-submit cuando cambia cualquier filtro
            $('#filtroRubrica, #filtroItem').change(function() {
                $(this).closest('form').submit();
            });
            
            // Cargar items cuando cambia la rúbrica (mantener selección de item si es compatible)
            $('#filtroRubrica').change(function() {
                var rubricaId = $(this).val();
                var form = $(this).closest('form');
                var currentItemId = $('#filtroItem').val();
                
                if (rubricaId) {
                    // Si hay rúbrica seleccionada, hacer submit del formulario
                    // para cargar solo los items de esa rúbrica
                    form.submit();
                } else {
                    // Si no hay rúbrica seleccionada, cargar todos los items
                    form.submit();
                }
            });
        });
    </script>
}

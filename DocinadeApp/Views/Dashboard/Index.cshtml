@{
    ViewData["Title"] = "Panel de Administración";
    Layout = null; // Usamos layout personalizado para dashboard
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema de Rúbricas</title>
    
    <!-- CSS Framework y Estilos -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="~/css/estilos_genericos.css" rel="stylesheet" />
    <link href="~/css/dashboard.css" rel="stylesheet" />
</head>
<body>
    <div class="dashboard-container">
        <!-- Sidebar -->
        <nav class="dashboard-sidebar">
            <div class="sidebar-header">
                <a href="/" class="sidebar-logo">
                    <i class="fas fa-graduation-cap"></i>
                    <span class="nav-text">Sistema Rúbricas</span>
                </a>
            </div>
            
            <div class="sidebar-nav">
                <!-- Sección Principal -->
                <div class="nav-section">
                    <div class="nav-section-title">Principal</div>
                    <div class="nav-item">
                        <a href="#" class="nav-link active">
                            <i class="fas fa-tachometer-alt"></i>
                            <span class="nav-text">Dashboard</span>
                        </a>
                    </div>
                    <div class="nav-item">
                        <a href="/Home" class="nav-link">
                            <i class="fas fa-home"></i>
                            <span class="nav-text">Inicio</span>
                        </a>
                    </div>
                </div>

                <!-- Sección Gestión -->
                <div class="nav-section">
                    <div class="nav-section-title">Gestión</div>
                    <div class="nav-item">
                        <a href="/GruposEstudiantes" class="nav-link">
                            <i class="fas fa-users"></i>
                            <span class="nav-text">Grupos de Estudiantes</span>
                            <span class="nav-badge">7</span>
                        </a>
                    </div>
                    <div class="nav-item">
                        <a href="/Evaluaciones" class="nav-link">
                            <i class="fas fa-clipboard-list"></i>
                            <span class="nav-text">Evaluaciones</span>
                            <span class="nav-badge">3</span>
                        </a>
                    </div>
                    <div class="nav-item">
                        <a href="/Rubricas" class="nav-link">
                            <i class="fas fa-table"></i>
                            <span class="nav-text">Rúbricas</span>
                        </a>
                    </div>
                    <div class="nav-item">
                        <a href="/Instrumentos" class="nav-link">
                            <i class="fas fa-tools"></i>
                            <span class="nav-text">Instrumentos</span>
                        </a>
                    </div>
                </div>

                <!-- Sección Configuración -->
                <div class="nav-section">
                    <div class="nav-section-title">Sistema</div>
                    <div class="nav-item">
                        <a href="/Configuracion" class="nav-link">
                            <i class="fas fa-cogs"></i>
                            <span class="nav-text">Configuración</span>
                        </a>
                    </div>
                    <div class="nav-item">
                        <a href="/Reportes" class="nav-link">
                            <i class="fas fa-chart-bar"></i>
                            <span class="nav-text">Reportes</span>
                        </a>
                    </div>
                    <div class="nav-item">
                        <a href="/Usuarios" class="nav-link">
                            <i class="fas fa-users-cog"></i>
                            <span class="nav-text">Usuarios</span>
                        </a>
                    </div>
                </div>
            </div>
        </nav>

        <!-- Botón Toggle para móvil -->
        <button class="sidebar-toggle" onclick="Dashboard.toggleSidebar()">
            <i class="fas fa-bars"></i>
        </button>

        <!-- Contenido Principal -->
        <main class="dashboard-content">
            <!-- Header del contenido -->
            <div class="content-header">
                <h1 class="content-title">
                    <i class="fas fa-tachometer-alt"></i>
                    Panel de Administración
                </h1>
                <p class="content-subtitle">Resumen general del sistema de rúbricas académicas</p>
            </div>

            <!-- Contenido principal -->
            <div class="content-main">
                <!-- Grid de tarjetas principales -->
                <div class="dashboard-grid">
                    <!-- Tarjeta Grupos de Estudiantes -->
                    <div class="dashboard-card" data-card-id="grupos">
                        <div class="card-header-dashboard">
                            <div class="card-icon">
                                <i class="fas fa-users"></i>
                            </div>
                            <h3 class="card-title">Grupos de Estudiantes</h3>
                        </div>
                        <div class="card-metric">7</div>
                        <p class="card-subtitle">Total de grupos activos en el sistema</p>
                        <div class="card-actions">
                            <a href="/GruposEstudiantes" class="dashboard-btn btn-primary">
                                <i class="fas fa-eye"></i>
                                Ver Todos
                            </a>
                            <a href="/GruposEstudiantes/Create" class="dashboard-btn btn-outline">
                                <i class="fas fa-plus"></i>
                                Crear Nuevo
                            </a>
                        </div>
                    </div>

                    <!-- Tarjeta Evaluaciones -->
                    <div class="dashboard-card" data-card-id="evaluaciones">
                        <div class="card-header-dashboard">
                            <div class="card-icon success">
                                <i class="fas fa-clipboard-check"></i>
                            </div>
                            <h3 class="card-title">Evaluaciones</h3>
                        </div>
                        <div class="card-metric">24</div>
                        <p class="card-subtitle">Evaluaciones completadas este mes</p>
                        <div class="card-actions">
                            <a href="/Evaluaciones" class="dashboard-btn btn-primary">
                                <i class="fas fa-list"></i>
                                Gestionar
                            </a>
                            <a href="/Evaluaciones/Create" class="dashboard-btn btn-outline">
                                <i class="fas fa-plus"></i>
                                Nueva
                            </a>
                        </div>
                    </div>

                    <!-- Tarjeta Rúbricas -->
                    <div class="dashboard-card" data-card-id="rubricas">
                        <div class="card-header-dashboard">
                            <div class="card-icon warning">
                                <i class="fas fa-table"></i>
                            </div>
                            <h3 class="card-title">Rúbricas</h3>
                        </div>
                        <div class="card-metric">12</div>
                        <p class="card-subtitle">Rúbricas disponibles para evaluación</p>
                        <div class="card-actions">
                            <a href="/Rubricas" class="dashboard-btn btn-primary">
                                <i class="fas fa-search"></i>
                                Explorar
                            </a>
                            <a href="/Rubricas/Create" class="dashboard-btn btn-outline">
                                <i class="fas fa-plus"></i>
                                Crear
                            </a>
                        </div>
                    </div>

                    <!-- Tarjeta Estudiantes -->
                    <div class="dashboard-card" data-card-id="estudiantes">
                        <div class="card-header-dashboard">
                            <div class="card-icon info">
                                <i class="fas fa-user-graduate"></i>
                            </div>
                            <h3 class="card-title">Estudiantes</h3>
                        </div>
                        <div class="card-metric">156</div>
                        <p class="card-subtitle">Estudiantes registrados en el sistema</p>
                        <div class="card-actions">
                            <a href="/Estudiantes" class="dashboard-btn btn-primary">
                                <i class="fas fa-users"></i>
                                Ver Lista
                            </a>
                            <a href="/Estudiantes/Import" class="dashboard-btn btn-outline">
                                <i class="fas fa-upload"></i>
                                Importar
                            </a>
                        </div>
                    </div>

                    <!-- Tarjeta Reportes -->
                    <div class="dashboard-card" data-card-id="reportes">
                        <div class="card-header-dashboard">
                            <div class="card-icon danger">
                                <i class="fas fa-chart-bar"></i>
                            </div>
                            <h3 class="card-title">Reportes</h3>
                        </div>
                        <div class="card-metric">8</div>
                        <p class="card-subtitle">Reportes generados esta semana</p>
                        <div class="card-actions">
                            <a href="/Reportes" class="dashboard-btn btn-primary">
                                <i class="fas fa-chart-line"></i>
                                Ver Reportes
                            </a>
                            <a href="/Reportes/Generate" class="dashboard-btn btn-outline">
                                <i class="fas fa-file-export"></i>
                                Generar
                            </a>
                        </div>
                    </div>

                    <!-- Tarjeta Configuración -->
                    <div class="dashboard-card" data-card-id="configuracion">
                        <div class="card-header-dashboard">
                            <div class="card-icon">
                                <i class="fas fa-cogs"></i>
                            </div>
                            <h3 class="card-title">Configuración</h3>
                        </div>
                        <div class="card-metric">
                            <i class="fas fa-check-circle text-dashboard-accent" style="font-size: 2rem;"></i>
                        </div>
                        <p class="card-subtitle">Sistema configurado correctamente</p>
                        <div class="card-actions">
                            <a href="/Configuracion" class="dashboard-btn btn-primary">
                                <i class="fas fa-wrench"></i>
                                Configurar
                            </a>
                            <a href="/Configuracion/Backup" class="dashboard-btn btn-outline">
                                <i class="fas fa-download"></i>
                                Backup
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Widget de actividad reciente -->
                <div class="dashboard-widget">
                    <div class="widget-header">
                        <h2 class="widget-title">
                            <i class="fas fa-clock"></i>
                            Actividad Reciente
                        </h2>
                    </div>
                    <div class="widget-content">
                        <div class="list-group list-group-flush">
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <strong>Nuevo grupo creado:</strong> Grupo C1
                                    <br><small class="text-muted">Hace 2 horas</small>
                                </div>
                                <span class="badge bg-success">Nuevo</span>
                            </div>
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <strong>Evaluación completada:</strong> Rúbrica de Matemáticas
                                    <br><small class="text-muted">Hace 4 horas</small>
                                </div>
                                <span class="badge bg-info">Completado</span>
                            </div>
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <strong>Estudiantes asignados:</strong> 23 estudiantes al Grupo G1
                                    <br><small class="text-muted">Hace 6 horas</small>
                                </div>
                                <span class="badge bg-primary">Asignación</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Widget de estadísticas rápidas -->
                <div class="dashboard-widget">
                    <div class="widget-header">
                        <h2 class="widget-title">
                            <i class="fas fa-chart-pie"></i>
                            Estadísticas del Sistema
                        </h2>
                    </div>
                    <div class="widget-content">
                        <div class="row text-center">
                            <div class="col-md-3">
                                <h4 class="text-dashboard-primary">98%</h4>
                                <small class="text-muted">Grupos Activos</small>
                            </div>
                            <div class="col-md-3">
                                <h4 class="text-dashboard-accent">156</h4>
                                <small class="text-muted">Total Estudiantes</small>
                            </div>
                            <div class="col-md-3">
                                <h4 class="text-dashboard-accent">24</h4>
                                <small class="text-muted">Evaluaciones</small>
                            </div>
                            <div class="col-md-3">
                                <h4 class="text-dashboard-primary">12</h4>
                                <small class="text-muted">Rúbricas</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/dashboard.js"></script>
    <script>
        // Ejemplo de uso del dashboard
        document.addEventListener('DOMContentLoaded', function() {
            // Simular actualización de métricas después de 2 segundos
            setTimeout(() => {
                Dashboard.updateMetric('grupos', 8);
                Dashboard.showNotification('Sistema actualizado correctamente', 'success');
            }, 2000);

            // Simular notificación de nueva actividad
            setTimeout(() => {
                Dashboard.showNotification('Nueva evaluación pendiente de revisión', 'info');
            }, 5000);
        });
    </script>
</body>
</html>

@model string

@{
    ViewData["Title"] = "Sistema No Disponible";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-warning">
                <div class="card-header bg-warning text-dark text-center py-4">
                    <h2><i class="fas fa-exclamation-triangle"></i> Sistema No Disponible</h2>
                </div>
                <div class="card-body p-5 text-center">
                    <i class="fas fa-lock fa-5x text-warning mb-4"></i>
                    
                    <h4 class="mb-4">El Sistema de Empadronamiento Público está Temporalmente Deshabilitado</h4>
                    
                    <div class="alert alert-warning text-start">
                        <p class="mb-0">@Model</p>
                    </div>
                    
                    <p class="mt-4">
                        Para más información, por favor contacte a la administración del centro educativo.
                    </p>
                    
                    <div class="d-grid gap-2 mt-4">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-secondary btn-lg">
                            <i class="fas fa-home"></i> Volver al Inicio
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@model RubricasApp.Web.ViewModels.Conducta.DashboardConductaViewModel

@{
    ViewData["Title"] = "Dashboard de Conducta";
}

@section Styles {
<!-- DataTables CSS -->
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css">

<style>
    /* Estilos específicos para el Dashboard de Conducta */
    
    /* Corregir visibilidad de iconos */
    .fa, .fas, .far, .fal, .fab {
        font-family: "Font Awesome 6 Free" !important;
        font-weight: 900 !important;
        -moz-osx-font-smoothing: grayscale;
        -webkit-font-smoothing: antialiased;
        display: inline-block;
        font-style: normal;
        font-variant: normal;
        text-rendering: auto;
        line-height: 1;
    }

    /* Corregir select/combos */
    .card-body .form-select {
        background-color: #ffffff !important;
        color: #212529 !important;
        border: 1px solid #ced4da !important;
        padding: 0.375rem 2.25rem 0.375rem 0.75rem !important;
        font-size: 1rem !important;
        line-height: 1.5 !important;
        border-radius: 0.375rem !important;
        background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3e%3cpath fill='none' stroke='%23343a40' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='m2 5 6 6 6-6'/%3e%3c/svg%3e") !important;
        background-repeat: no-repeat !important;
        background-position: right 0.75rem center !important;
        background-size: 16px 12px !important;
        appearance: none !important;
    }

    .card-body .form-select:focus {
        border-color: #86b7fe !important;
        outline: 0 !important;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25) !important;
    }

    .card-body .form-select option {
        background-color: #ffffff !important;
        color: #212529 !important;
    }

    .card-body .form-label {
        margin-bottom: 0.5rem !important;
        font-weight: 500 !important;
        color: #212529 !important;
    }

    /* Mejorar cards de estadísticas */
    .card {
        border-radius: 0.5rem !important;
        margin-bottom: 1.5rem !important;
    }

    .card-header {
        background-color: #f8f9fa !important;
        border-bottom: 1px solid #dee2e6 !important;
        padding: 1rem 1.25rem !important;
        border-top-left-radius: 0.5rem !important;
        border-top-right-radius: 0.5rem !important;
    }

    .card-header h5 {
        margin: 0 !important;
        color: #212529 !important;
        font-weight: 600 !important;
    }

    .card-header i {
        margin-right: 0.5rem !important;
        color: #0d6efd !important;
    }

    /* Sobrescribir para card-header con texto blanco */
    .card-header.card-header-white-text {
        background: var(--primary-gradient) !important;
    }

    .card-header.card-header-white-text h5 {
        color: #ffffff !important;
    }

    .card-header.card-header-white-text i {
        color: #ffffff !important;
    }

    .card-body {
        padding: 1.25rem !important;
    }

    /* Cards de estadísticas mejoradas */
    .card.shadow-sm {
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075) !important;
        transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out !important;
    }

    .card.shadow-sm:hover {
        transform: translateY(-2px) !important;
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
    }

    /* Mejorar visualización de iconos en cards */
    .card-body .fas, .card-body .far {
        opacity: 0.5 !important;
    }

    .opacity-50 {
        opacity: 0.5 !important;
    }

    /* Badges */
    .badge {
        padding: 0.35em 0.65em !important;
        font-weight: 600 !important;
    }

    /* Botones */
    .btn {
        border-radius: 0.375rem !important;
        padding: 0.375rem 0.75rem !important;
        font-weight: 500 !important;
    }

    .btn i {
        margin-right: 0.25rem !important;
    }

    /* Tabla */
    .table-hover tbody tr:hover {
        background-color: rgba(0, 0, 0, 0.075) !important;
    }

    /* Header del dashboard */
    .container-fluid > .row:first-child h2 {
        color: #212529 !important;
        font-weight: 700 !important;
        margin-bottom: 0.5rem !important;
    }

    .container-fluid > .row:first-child h2 i {
        color: #0d6efd !important;
        margin-right: 0.5rem !important;
    }

    /* Alert mejorado */
    .alert i.fa-3x {
        font-size: 3rem !important;
        opacity: 0.8 !important;
    }

    /* Canvas para gráficos */
    canvas {
        max-height: 250px !important;
    }
</style>
}

<div class="container-fluid">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <h2><i class="fas fa-chart-line text-primary"></i> Dashboard de Conducta</h2>
            <p class="text-muted">Resumen general del estado de conducta de los estudiantes</p>
        </div>
    </div>

    <!-- Filtros -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" id="formFiltros">
                <div class="row align-items-end">
                    <div class="col-md-4">
                        <label for="idPeriodo" class="form-label">Período Académico</label>
                        <select id="idPeriodo" name="idPeriodo" class="form-select" onchange="$('#formFiltros').submit()">
                            @foreach (var periodo in ViewBag.Periodos)
                            {
                                <option value="@periodo.Value" selected="@(periodo.Value == Model.IdPeriodo.ToString())">
                                    @periodo.Text
                                </option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label for="idGrupo" class="form-label">Grupo (Opcional)</label>
                        <select id="idGrupo" name="idGrupo" class="form-select" onchange="$('#formFiltros').submit()">
                            <option value="">Todos los grupos</option>
                            @foreach (var grupo in ViewBag.Grupos)
                            {
                                <option value="@grupo.Value" selected="@(grupo.Value == Model.IdGrupo?.ToString())">
                                    @grupo.Text
                                </option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <button type="button" class="btn btn-secondary" onclick="location.href='@Url.Action("Dashboard")'">
                            <i class="fas fa-redo"></i> Limpiar Filtros
                        </button>
                    </div>
                </div>
            </form>
        </div>
        <div class="card-footer bg-light">
            <div class="d-flex justify-content-between align-items-center">
                <span class="text-muted"><i class="fas fa-file-pdf"></i> Reportes PDF Disponibles:</span>
                <div>
                    <a asp-action="ReporteMasivoProgramasAcciones" 
                       asp-route-idPeriodo="@Model.IdPeriodo" 
                       class="btn btn-success btn-sm me-2" 
                       target="_blank"
                       title="Generar reporte PDF de todos los Programas de Acciones">
                        <i class="fas fa-file-pdf"></i> Programas de Acciones
                    </a>
                    <a asp-action="ReporteMasivoDecisionesProfesionales" 
                       asp-route-idPeriodo="@Model.IdPeriodo" 
                       class="btn btn-info btn-sm" 
                       target="_blank"
                       title="Generar reporte PDF de todas las Decisiones Profesionales">
                        <i class="fas fa-file-pdf"></i> Decisiones Profesionales
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Tarjetas de estadísticas principales -->
    <div class="row mb-4">
        <!-- Total de estudiantes -->
        <div class="col-lg-3 col-md-6 mb-3">
            <div class="card border-primary shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Total Estudiantes</h6>
                            <h2 class="mb-0">@Model.TotalEstudiantes</h2>
                        </div>
                        <div class="text-primary">
                            <i class="fas fa-users fa-3x opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Estudiantes aprobados -->
        <div class="col-lg-3 col-md-6 mb-3">
            <div class="card border-success shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Aprobados</h6>
                            <h2 class="mb-0 text-success">@Model.EstudiantesAprobados</h2>
                            <small class="text-muted">@Model.PorcentajeAprobados.ToString("F1")%</small>
                        </div>
                        <div class="text-success">
                            <i class="fas fa-check-circle fa-3x opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Estudiantes en riesgo -->
        <div class="col-lg-3 col-md-6 mb-3">
            <div class="card border-warning shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">En Riesgo</h6>
                            <h2 class="mb-0 text-warning">@Model.EstudiantesEnRiesgo</h2>
                            <small class="text-muted">@Model.PorcentajeEnRiesgo.ToString("F1")%</small>
                        </div>
                        <div class="text-warning">
                            <i class="fas fa-exclamation-triangle fa-3x opacity-50"></i>
                        </div>
                    </div>
                    <a asp-action="EstudiantesRiesgo" asp-route-idPeriodo="@Model.IdPeriodo" class="stretched-link"></a>
                </div>
            </div>
        </div>

        <!-- Estudiantes aplazados -->
        <div class="col-lg-3 col-md-6 mb-3">
            <div class="card border-danger shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Aplazados</h6>
                            <h2 class="mb-0 text-danger">@Model.EstudiantesAplazados</h2>
                            <small class="text-muted">@Model.PorcentajeAplazados.ToString("F1")%</small>
                        </div>
                        <div class="text-danger">
                            <i class="fas fa-times-circle fa-3x opacity-50"></i>
                        </div>
                    </div>
                    <a asp-action="EstudiantesAplazados" asp-route-idPeriodo="@Model.IdPeriodo" class="stretched-link"></a>
                </div>
            </div>
        </div>
    </div>

    <!-- Tarjetas de estadísticas de boletas -->
    <div class="row mb-4">
        <!-- Total de boletas -->
        <div class="col-lg-4 col-md-6 mb-3">
            <div class="card border-info shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Total Boletas</h6>
                            <h3 class="mb-0">@Model.TotalBoletasEmitidas</h3>
                        </div>
                        <div class="text-info">
                            <i class="fas fa-file-alt fa-2x opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total de rebajos -->
        <div class="col-lg-4 col-md-6 mb-3">
            <div class="card border-secondary shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Total Rebajos</h6>
                            <h3 class="mb-0">@Model.TotalPuntosRebajados</h3>
                            <small class="text-muted">puntos</small>
                        </div>
                        <div class="text-secondary">
                            <i class="fas fa-minus-circle fa-2x opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Promedio general -->
        <div class="col-lg-4 col-md-6 mb-3">
            <div class="card border-primary shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted mb-1">Promedio General</h6>
                            <h3 class="mb-0">@Model.PromedioGeneralConducta.ToString("F2")</h3>
                            <small class="text-muted">/ 100 pts</small>
                        </div>
                        <div class="text-primary">
                            <i class="fas fa-chart-bar fa-2x opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Gráficos -->
    <div class="row mb-4">
        <!-- Distribución por estado -->
        <div class="col-lg-6 mb-3">
            <div class="card shadow-sm">
                <div class="card-header card-header-white-text">
                    <h5 class="mb-0"><i class="fas fa-chart-pie"></i> Distribución por Estado</h5>
                </div>
                <div class="card-body">
                    <canvas id="chartEstados" height="250"></canvas>
                </div>
            </div>
        </div>

        <!-- Distribución por tipo de falta -->
        <div class="col-lg-6 mb-3">
            <div class="card shadow-sm">
                <div class="card-header card-header-white-text">
                    <h5 class="mb-0"><i class="fas fa-chart-bar"></i> Boletas por Tipo de Falta</h5>
                </div>
                <div class="card-body">
                    <canvas id="chartTiposFalta" height="250"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabla de estudiantes en riesgo y aplazados -->
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header card-header-white-text">
                    <h5 class="mb-0"><i class="fas fa-exclamation-circle"></i> Estudiantes Requieren Atención</h5>
                </div>
                <div class="card-body">
                    @if (Model.EstudiantesRequierenAtencion != null && Model.EstudiantesRequierenAtencion.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover" id="tablaAtencion">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Estudiante</th>
                                        <th>Identificación</th>
                                        <th>Grupo</th>
                                        <th class="text-center">Nota</th>
                                        <th class="text-center">Estado</th>
                                        <th class="text-center">Boletas</th>
                                        <th class="text-center">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var estudiante in Model.EstudiantesRequierenAtencion)
                                    {
                                        <tr>
                                            <td>@estudiante.NombreCompleto</td>
                                            <td>@estudiante.NumeroIdentificacion</td>
                                            <td>@estudiante.NombreGrupo</td>
                                            <td class="text-center">
                                                <strong class="@(estudiante.NotaFinal >= 65 ? "text-success" : estudiante.NotaFinal >= 60 ? "text-warning" : "text-danger")">
                                                    @estudiante.NotaFinal.ToString("F2")
                                                </strong>
                                            </td>
                                            <td class="text-center">
                                                @if (estudiante.Estado == "Aprobado")
                                                {
                                                    <span class="badge bg-success">@estudiante.Estado</span>
                                                }
                                                else if (estudiante.Estado == "Riesgo")
                                                {
                                                    <span class="badge bg-warning">@estudiante.Estado</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger">@estudiante.Estado</span>
                                                }
                                            </td>
                                            <td class="text-center">
                                                <span class="badge bg-info">@estudiante.CantidadBoletas</span>
                                            </td>
                                            <td class="text-center">
                                                <a asp-action="EstudianteNota" asp-route-idEstudiante="@estudiante.IdEstudiante" asp-route-idPeriodo="@Model.IdPeriodo" 
                                                   class="btn btn-sm btn-primary" title="Ver detalle">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                                @if (estudiante.Estado == "Aplazado")
                                                {
                                                    <a asp-action="CrearPrograma" asp-route-idEstudiante="@estudiante.IdEstudiante" asp-route-idPeriodo="@Model.IdPeriodo" 
                                                       class="btn btn-sm btn-warning" title="Crear programa">
                                                        <i class="fas fa-clipboard-list"></i>
                                                    </a>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-success text-center">
                            <i class="fas fa-check-circle fa-3x mb-3"></i>
                            <p class="mb-0">¡Excelente! No hay estudiantes que requieran atención especial en este momento.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- DataTables JS -->
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>
    
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    
    <script>
        $(document).ready(function() {
            // Inicializar DataTable
            $('#tablaAtencion').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/es-ES.json'
                },
                order: [[3, 'asc']], // Ordenar por nota ascendente
                pageLength: 10
            });

            // Gráfico de distribución por estado
            const ctxEstados = document.getElementById('chartEstados').getContext('2d');
            const datosEstados = [@Model.EstudiantesAprobados, @Model.EstudiantesEnRiesgo, @Model.EstudiantesAplazados];
            console.log('Datos de estados:', datosEstados);
            
            new Chart(ctxEstados, {
                type: 'doughnut',
                data: {
                    labels: ['Aprobados', 'En Riesgo', 'Aplazados'],
                    datasets: [{
                        data: datosEstados,
                        backgroundColor: [
                            'rgba(40, 167, 69, 0.8)',    // Verde
                            'rgba(255, 193, 7, 0.8)',    // Amarillo
                            'rgba(220, 53, 69, 0.8)'     // Rojo
                        ],
                        borderColor: [
                            'rgba(40, 167, 69, 1)',
                            'rgba(255, 193, 7, 1)',
                            'rgba(220, 53, 69, 1)'
                        ],
                        borderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                color: getComputedStyle(document.documentElement).getPropertyValue('--chart-text-color').trim()
                            }
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    const label = context.label || '';
                                    const value = context.parsed || 0;
                                    const total = @Model.TotalEstudiantes;
                                    const percentage = total > 0 ? ((value / total) * 100).toFixed(1) : 0;
                                    return label + ': ' + value + ' (' + percentage + '%)';
                                }
                            }
                        }
                    }
                }
            });

            // Gráfico de boletas por tipo de falta
            const ctxTiposFalta = document.getElementById('chartTiposFalta').getContext('2d');
            const tiposFaltaLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.BoletasPorTipoFalta.Keys));
            const tiposFaltaData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.BoletasPorTipoFalta.Values));
            
            console.log('Tipos de Falta - Labels:', tiposFaltaLabels);
            console.log('Tipos de Falta - Data:', tiposFaltaData);
            
            new Chart(ctxTiposFalta, {
                type: 'bar',
                data: {
                    labels: tiposFaltaLabels,
                    datasets: [{
                        label: 'Cantidad de Boletas',
                        data: tiposFaltaData,
                        backgroundColor: 'rgba(13, 110, 253, 0.8)',
                        borderColor: 'rgba(13, 110, 253, 1)',
                        borderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: false
                        }
                    },
                    scales: {
                        x: {
                            ticks: {
                                color: getComputedStyle(document.documentElement).getPropertyValue('--chart-text-color').trim()
                            }
                        },
                        y: {
                            beginAtZero: true,
                            ticks: {
                                stepSize: 1,
                                color: getComputedStyle(document.documentElement).getPropertyValue('--chart-text-color').trim()
                            }
                        }
                    }
                }
            });
        });
    </script>
}

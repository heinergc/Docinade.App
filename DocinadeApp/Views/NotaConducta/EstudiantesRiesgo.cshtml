@model DocinadeApp.ViewModels.Conducta.EstudiantesRiesgoViewModel

@{
    ViewData["Title"] = "Estudiantes en Riesgo";
}

@section Styles {
    <!-- DataTables CSS -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css">
    
    <style>
        /* Hacer más pequeño el campo de búsqueda de DataTables */
        .dataTables_wrapper .dataTables_filter input {
            width: 200px !important;
            margin-left: 0.5em !important;
        }
    </style>
}

<div class="container-fluid">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Dashboard">Dashboard</a></li>
                    <li class="breadcrumb-item active">Estudiantes en Riesgo</li>
                </ol>
            </nav>
            <h2><i class="fas fa-exclamation-triangle text-warning"></i> Estudiantes en Riesgo</h2>
            <p class="text-muted">Estudiantes con nota de conducta entre 60 y 64 puntos</p>
        </div>
    </div>

    <!-- Filtros -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" id="formFiltros">
                <div class="row align-items-end">
                    <div class="col-md-4">
                        <label for="idPeriodo" class="form-label">Período Académico</label>
                        <select id="idPeriodo" name="idPeriodo" class="form-select" onchange="$('#formFiltros').submit()">
                            @if (ViewBag.Periodos != null)
                            {
                                @foreach (var periodo in ViewBag.Periodos)
                                {
                                    <option value="@periodo.Value" selected="@(periodo.Value == ViewBag.PeriodoSeleccionado?.ToString())">
                                        @periodo.Text
                                    </option>
                                }
                            }
                            else
                            {
                                <option value="">No hay períodos disponibles</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label for="idGrupo" class="form-label">Grupo (Opcional)</label>
                        <select id="idGrupo" name="idGrupo" class="form-select" onchange="$('#formFiltros').submit()">
                            <option value="">Todos los grupos</option>
                            @if (ViewBag.Grupos != null)
                            {
                                @foreach (var grupo in ViewBag.Grupos)
                                {
                                    <option value="@grupo.Value" selected="@(grupo.Value == ViewBag.IdGrupoSeleccionado)">
                                        @grupo.Text
                                    </option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <button type="button" class="btn btn-secondary" onclick="location.href='@Url.Action("EstudiantesRiesgo")'">
                            <i class="fas fa-redo"></i> Limpiar Filtros
                        </button>
                        <button type="button" class="btn btn-success" onclick="exportarExcel()">
                            <i class="fas fa-file-excel"></i> Exportar Excel
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Alerta informativa -->
    <div class="alert alert-warning border-warning">
        <div class="d-flex align-items-center">
            <i class="fas fa-info-circle fa-2x me-3"></i>
            <div>
                <h5 class="alert-heading">Atención Preventiva</h5>
                <p class="mb-0">
                    Estos estudiantes están en riesgo de aplazar conducta. Se recomienda:
                </p>
                <ul class="mb-0 mt-2">
                    <li>Comunicación inmediata con el profesor guía</li>
                    <li>Reunión con el estudiante y sus padres/encargados</li>
                    <li>Seguimiento semanal del comportamiento</li>
                    <li>Implementación de estrategias preventivas</li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Tabla de estudiantes -->
    <div class="card shadow-sm">
        <div class="card-header bg-warning">
            <h5 class="mb-0 text-white">
                <i class="fas fa-list"></i> Lista de Estudiantes en Riesgo 
                <span class="badge bg-white text-warning">@(Model?.Estudiantes?.Count ?? 0)</span>
            </h5>
        </div>
        <div class="card-body">
            @if (Model?.Estudiantes != null && Model.Estudiantes.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover" id="tablaRiesgo">
                        <thead class="table-dark">
                            <tr>
                                <th>Estudiante</th>
                                <th>Identificación</th>
                                <th>Grupo</th>
                                <th>Profesor Guía</th>
                                <th class="text-center">Nota</th>
                                <th class="text-center">Boletas</th>
                                <th class="text-center">Total Rebajos</th>
                                <th class="text-center">Última Boleta</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var estudiante in Model.Estudiantes.OrderBy(e => e.NotaFinal))
                            {
                                <tr>
                                    <td>
                                        <strong>@estudiante.NombreCompleto</strong>
                                    </td>
                                    <td>@estudiante.NumeroId</td>
                                    <td>@estudiante.Grupo</td>
                                    <td>@estudiante.ProfesorGuia</td>
                                    <td class="text-center">
                                        <span class="badge bg-warning fs-6">@estudiante.NotaFinal.ToString("F2")</span>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge bg-info">@estudiante.CantidadBoletas</span>
                                    </td>
                                    <td class="text-center">
                                        <strong class="text-danger">@estudiante.TotalRebajos</strong>
                                    </td>
                                    <td class="text-center">
                                        @if (estudiante.FechaUltimaBoleta.HasValue)
                                        {
                                            <span>@estudiante.FechaUltimaBoleta.Value.ToString("dd/MM/yyyy")</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">N/A</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <a asp-action="EstudianteNota" 
                                           asp-route-idEstudiante="@estudiante.IdEstudiante" 
                                           asp-route-idPeriodo="@ViewBag.IdPeriodoSeleccionado" 
                                           class="btn btn-sm btn-primary" 
                                           title="Ver detalle completo">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-controller="BoletasConducta" 
                                           asp-action="Create" 
                                           asp-route-idEstudiante="@estudiante.IdEstudiante" 
                                           class="btn btn-sm btn-warning" 
                                           title="Nueva boleta">
                                            <i class="fas fa-plus"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-success text-center">
                    <i class="fas fa-check-circle fa-3x mb-3"></i>
                    <p class="mb-0">¡Excelente! No hay estudiantes en riesgo en este período.</p>
                </div>
            }
        </div>
    </div>

    <!-- Botones -->
    <div class="mt-4">
        <a asp-action="Dashboard" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Volver al Dashboard
        </a>
    </div>
</div>

@section Scripts {
    <!-- DataTables JS -->
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>
    
    <script>
        $(document).ready(function() {
            $('#tablaRiesgo').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/es-ES.json'
                },
                order: [[4, 'asc']], // Ordenar por nota ascendente
                pageLength: 25,
                dom: 'Bfrtip',
                buttons: []
            });
        });

        function exportarExcel() {
            toastr.info('Exportando a Excel...');
            
            // Obtener los parámetros de filtro actuales
            const idPeriodo = $('#idPeriodo').val();
            const idGrupo = $('#idGrupo').val();
            
            // Construir URL con parámetros
            let url = '@Url.Action("ExportarEstudiantesRiesgo")?idPeriodo=' + idPeriodo;
            if (idGrupo) {
                url += '&idGrupo=' + idGrupo;
            }
            
            // Descargar archivo
            window.location.href = url;
        }
    </script>
}

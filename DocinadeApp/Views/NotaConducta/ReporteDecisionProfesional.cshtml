@model DocinadeApp.ViewModels.Conducta.ReporteDecisionProfesionalViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Decisión Profesional - @Model.NumeroActa</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Arial', sans-serif; font-size: 11pt; line-height: 1.5; color: #333; padding: 30px; }
        .header { text-align: center; margin-bottom: 25px; border-bottom: 2px solid #8e44ad; padding-bottom: 15px; }
        .header h1 { color: #8e44ad; font-size: 20pt; margin-bottom: 5px; }
        .header h2 { color: #7f8c8d; font-size: 14pt; font-weight: normal; }
        .info-section { margin-bottom: 20px; background-color: #f4ecf7; padding: 15px; border-left: 4px solid #9b59b6; }
        .info-label { font-weight: bold; color: #8e44ad; display: inline-block; width: 150px; }
        .info-value { display: inline-block; color: #34495e; }
        .section { margin-bottom: 20px; page-break-inside: avoid; }
        .section-title { background-color: #9b59b6; color: white; padding: 10px; font-size: 13pt; font-weight: bold; margin-bottom: 10px; }
        .section-content { padding: 10px; border: 1px solid #bdc3c7; background-color: #fff; }
        .boletas-table { width: 100%; border-collapse: collapse; margin-top: 10px; }
        .boletas-table th { background-color: #34495e; color: white; padding: 8px; text-align: left; font-size: 10pt; }
        .boletas-table td { padding: 8px; border: 1px solid #ddd; font-size: 10pt; }
        .boletas-table tr:nth-child(even) { background-color: #f9f9f9; }
        .footer { margin-top: 30px; padding-top: 15px; border-top: 1px solid #bdc3c7; text-align: center; font-size: 9pt; color: #7f8c8d; }
        .signatures { display: flex; justify-content: space-between; margin-top: 50px; }
        .signature-box { text-align: center; width: 45%; }
        .signature-line { border-top: 1px solid #000; margin-top: 40px; padding-top: 5px; }
        .decision-box { background-color: #e8f8f5; border: 2px solid #27ae60; padding: 15px; margin: 20px 0; text-align: center; }
        .decision-box h3 { color: #27ae60; margin-bottom: 10px; }
    </style>
</head>
<body>
    <div class="header">
        <h1>DECISIÓN PROFESIONAL DOCENTE</h1>
        <h2>@Model.NombreInstitucion</h2>
    </div>

    <div class="info-section">
        <div><span class="info-label">Número de Acta:</span> <span class="info-value">@Model.NumeroActa</span></div>
        <div><span class="info-label">Fecha de Reunión:</span> <span class="info-value">@Model.FechaReunion.ToString("dd/MM/yyyy")</span></div>
        <div><span class="info-label">Estudiante:</span> <span class="info-value">@Model.NombreEstudiante</span></div>
        <div><span class="info-label">Carnet:</span> <span class="info-value">@Model.CarnetEstudiante</span></div>
        <div><span class="info-label">Grado/Sección:</span> <span class="info-value">@Model.GradoSeccion</span></div>
        <div><span class="info-label">Período Académico:</span> <span class="info-value">@Model.PeriodoAcademico</span></div>
        <div><span class="info-label">Estado:</span> <span class="info-value"><strong>@Model.Estado</strong></span></div>
    </div>

    <div class="section">
        <div class="section-title">1. Antecedentes Expuestos</div>
        <div class="section-content">@Html.Raw(Model.AntecedentesExpuestos.Replace("\n", "<br/>"))</div>
    </div>

    @if (!string.IsNullOrEmpty(Model.VersionEstudiante))
    {
        <div class="section">
            <div class="section-title">2. Versión del Estudiante</div>
            <div class="section-content">@Html.Raw(Model.VersionEstudiante.Replace("\n", "<br/>"))</div>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.VersionPadres))
    {
        <div class="section">
            <div class="section-title">3. Versión de Padres/Encargados</div>
            <div class="section-content">@Html.Raw(Model.VersionPadres.Replace("\n", "<br/>"))</div>
        </div>
    }

    <div class="section">
        <div class="section-title">4. Análisis del Comité</div>
        <div class="section-content">@Html.Raw(Model.AnalisisComite.Replace("\n", "<br/>"))</div>
    </div>

    <div class="decision-box">
        <h3>DECISIÓN TOMADA</h3>
        <p style="font-size: 14pt; font-weight: bold; color: #27ae60;">@Model.DecisionTomada</p>
    </div>

    @if (!string.IsNullOrEmpty(Model.AccionesSeguimiento))
    {
        <div class="section">
            <div class="section-title">5. Acciones de Seguimiento</div>
            <div class="section-content">@Html.Raw(Model.AccionesSeguimiento.Replace("\n", "<br/>"))</div>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.ObservacionesComite))
    {
        <div class="section">
            <div class="section-title">6. Observaciones del Comité</div>
            <div class="section-content">@Html.Raw(Model.ObservacionesComite.Replace("\n", "<br/>"))</div>
        </div>
    }

    @if (Model.Boletas.Any())
    {
        <div class="section">
            <div class="section-title">Boletas de Conducta Asociadas</div>
            <table class="boletas-table">
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th>Tipo de Falta</th>
                        <th>Descripción</th>
                        <th>Reportado Por</th>
                        <th>Rebajo</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var boleta in Model.Boletas)
                    {
                        <tr>
                            <td>@boleta.FechaIncidente.ToString("dd/MM/yyyy")</td>
                            <td>@boleta.TipoFalta</td>
                            <td>@boleta.DescripcionIncidente</td>
                            <td>@boleta.ReportadoPor</td>
                            <td style="text-align: center;">@boleta.RebajoAplicado</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <div class="signatures">
        <div class="signature-box">
            <div class="signature-line">
                <strong>@Model.TomaDecisionPor</strong><br/>
                Coordinador / Director<br/>
                Fecha: @Model.FechaDecision.ToString("dd/MM/yyyy")
            </div>
        </div>
        <div class="signature-box">
            <div class="signature-line">
                <strong>Miembros del Comité</strong><br/>
                Comité de Evaluación
            </div>
        </div>
    </div>

    <div class="footer">
        Documento generado el @Model.FechaGeneracion.ToString("dd/MM/yyyy HH:mm")<br/>
        Decisión profesional docente conforme al Art. 132 del Reglamento de Evaluación
    </div>
</body>
</html>

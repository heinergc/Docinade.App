@model RubricasApp.Web.ViewModels.Conducta.ReporteProgramaAccionesViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Programa de Acciones - @Model.NumeroPrograma</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Arial', sans-serif; font-size: 11pt; line-height: 1.5; color: #333; padding: 30px; }
        .header { text-align: center; margin-bottom: 25px; border-bottom: 2px solid #2c3e50; padding-bottom: 15px; }
        .header h1 { color: #2c3e50; font-size: 20pt; margin-bottom: 5px; }
        .header h2 { color: #7f8c8d; font-size: 14pt; font-weight: normal; }
        .info-section { margin-bottom: 20px; background-color: #ecf0f1; padding: 15px; border-left: 4px solid #3498db; }
        .info-label { font-weight: bold; color: #2c3e50; display: inline-block; width: 150px; }
        .info-value { display: inline-block; color: #34495e; }
        .section { margin-bottom: 20px; page-break-inside: avoid; }
        .section-title { background-color: #3498db; color: white; padding: 10px; font-size: 13pt; font-weight: bold; margin-bottom: 10px; }
        .section-content { padding: 10px; border: 1px solid #bdc3c7; background-color: #fff; }
        .boletas-table { width: 100%; border-collapse: collapse; margin-top: 10px; }
        .boletas-table th { background-color: #34495e; color: white; padding: 8px; text-align: left; font-size: 10pt; }
        .boletas-table td { padding: 8px; border: 1px solid #ddd; font-size: 10pt; }
        .boletas-table tr:nth-child(even) { background-color: #f9f9f9; }
        .footer { margin-top: 30px; padding-top: 15px; border-top: 1px solid #bdc3c7; text-align: center; font-size: 9pt; color: #7f8c8d; }
        .signatures { display: flex; justify-content: space-between; margin-top: 50px; }
        .signature-box { text-align: center; width: 45%; }
        .signature-line { border-top: 1px solid #000; margin-top: 40px; padding-top: 5px; }
    </style>
</head>
<body>
    <div class="header">
        <h1>PROGRAMA DE ACCIONES INSTITUCIONAL</h1>
        <h2>@Model.NombreInstitucion</h2>
    </div>

    <div class="info-section">
        <div><span class="info-label">Número de Programa:</span> <span class="info-value">@Model.NumeroPrograma</span></div>
        <div><span class="info-label">Fecha de Elaboración:</span> <span class="info-value">@Model.FechaElaboracion.ToString("dd/MM/yyyy")</span></div>
        <div><span class="info-label">Estudiante:</span> <span class="info-value">@Model.NombreEstudiante</span></div>
        <div><span class="info-label">Carnet:</span> <span class="info-value">@Model.CarnetEstudiante</span></div>
        <div><span class="info-label">Grado/Sección:</span> <span class="info-value">@Model.GradoSeccion</span></div>
        <div><span class="info-label">Período Académico:</span> <span class="info-value">@Model.PeriodoAcademico</span></div>
        <div><span class="info-label">Estado:</span> <span class="info-value"><strong>@Model.Estado</strong></span></div>
    </div>

    <div class="section">
        <div class="section-title">1. Descripción de Faltas</div>
        <div class="section-content">@Html.Raw(Model.DescripcionFaltas.Replace("\n", "<br/>"))</div>
    </div>

    <div class="section">
        <div class="section-title">2. Acciones Formativas a Realizar</div>
        <div class="section-content">@Html.Raw(Model.AccionesFormativas.Replace("\n", "<br/>"))</div>
    </div>

    <div class="section">
        <div class="section-title">3. Compromisos del Estudiante</div>
        <div class="section-content">@Html.Raw(Model.CompromisosEstudiante.Replace("\n", "<br/>"))</div>
    </div>

    <div class="section">
        <div class="section-title">4. Apoyo de Padres/Encargados</div>
        <div class="section-content">@Html.Raw(Model.ApoyoPadres.Replace("\n", "<br/>"))</div>
    </div>

    <div class="section">
        <div class="section-title">5. Seguimiento y Evaluación</div>
        <div class="section-content">@Html.Raw(Model.SeguimientoEvaluacion.Replace("\n", "<br/>"))</div>
    </div>

    @if (!string.IsNullOrEmpty(Model.Observaciones))
    {
        <div class="section">
            <div class="section-title">6. Observaciones</div>
            <div class="section-content">@Html.Raw(Model.Observaciones.Replace("\n", "<br/>"))</div>
        </div>
    }

    @if (Model.Boletas.Any())
    {
        <div class="section">
            <div class="section-title">Boletas de Conducta Asociadas</div>
            <table class="boletas-table">
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th>Tipo de Falta</th>
                        <th>Descripción</th>
                        <th>Reportado Por</th>
                        <th>Rebajo</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var boleta in Model.Boletas)
                    {
                        <tr>
                            <td>@boleta.FechaIncidente.ToString("dd/MM/yyyy")</td>
                            <td>@boleta.TipoFalta</td>
                            <td>@boleta.DescripcionIncidente</td>
                            <td>@boleta.ReportadoPor</td>
                            <td style="text-align: center;">@boleta.RebajoAplicado</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <div class="signatures">
        <div class="signature-box">
            <div class="signature-line">
                <strong>@Model.AutorizadoPor</strong><br/>
                Responsable de Supervisión<br/>
                @if (Model.FechaAutorizacion.HasValue)
                {
                    <span>Fecha: @Model.FechaAutorizacion.Value.ToString("dd/MM/yyyy")</span>
                }
            </div>
        </div>
        <div class="signature-box">
            <div class="signature-line">
                <strong>Estudiante</strong><br/>
                @Model.NombreEstudiante
            </div>
        </div>
    </div>

    <div class="footer">
        Documento generado el @Model.FechaGeneracion.ToString("dd/MM/yyyy HH:mm")<br/>
        Conforme al Art. 132 del Reglamento de Evaluación de los Aprendizajes
    </div>
</body>
</html>

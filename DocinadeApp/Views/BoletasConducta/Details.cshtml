@model DocinadeApp.ViewModels.Conducta.BoletaConductaDetalleViewModel

@{
    ViewData["Title"] = "Detalles de Boleta";
}

<div class="container-fluid">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index">Boletas de Conducta</a></li>
                    <li class="breadcrumb-item active">Boleta #@Model.IdBoleta</li>
                </ol>
            </nav>
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2>
                        <i class="fas fa-clipboard-list text-primary"></i> 
                        Boleta de Conducta #@Model.IdBoleta
                    </h2>
                    <p class="text-muted mb-0">Emitida el @Model.FechaEmision.ToString("dd/MM/yyyy HH:mm")</p>
                </div>
                <div class="d-flex align-items-center gap-2">
                    @if (Model.Estado == "Activa")
                    {
                        <span class="badge bg-success fs-5">ACTIVA</span>
                    }
                    else if (Model.Estado == "Anulada")
                    {
                        <span class="badge bg-secondary fs-5">ANULADA</span>
                    }
                    <button onclick="window.print()" class="btn btn-primary btn-sm no-print">
                        <i class="fas fa-print"></i> Imprimir Boleta
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Columna izquierda -->
        <div class="col-lg-6">
            <!-- Información del estudiante -->
            <div class="card mb-3">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fas fa-user"></i> Información del Estudiante</h5>
                </div>
                <div class="card-body">
                    <div class="row mb-2">
                        <div class="col-4 text-muted">Nombre:</div>
                        <div class="col-8"><strong>@Model.NombreEstudiante</strong></div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-4 text-muted">Cédula/ID:</div>
                        <div class="col-8">@Model.NumeroIdEstudiante</div>
                    </div>
                    <div class="row">
                        <div class="col-4 text-muted">Período:</div>
                        <div class="col-8">@Model.Periodo</div>
                    </div>
                </div>
            </div>

            <!-- Clasificación de la falta -->
            <div class="card mb-3">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0"><i class="fas fa-exclamation-triangle"></i> Clasificación de la Falta</h5>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-4 text-muted">Tipo de Falta:</div>
                        <div class="col-8">
                            <span class="badge 
                                @(Model.TipoFalta == "Muy leve" ? "bg-info" : 
                                  Model.TipoFalta == "Leve" ? "bg-primary" :
                                  Model.TipoFalta == "Grave" ? "bg-warning" :
                                  Model.TipoFalta == "Muy grave" ? "bg-danger" :
                                  "bg-dark") fs-6">
                                @Model.TipoFalta
                            </span>
                        </div>
                    </div>

                    <div class="alert alert-info">
                        <p class="mb-2"><strong>Definición:</strong></p>
                        <p class="mb-2">@Model.DefinicionFalta</p>
                        
                        <p class="mb-2"><strong>Ejemplos típicos:</strong></p>
                        <p class="mb-2">@Model.EjemplosFalta</p>
                        
                        <p class="mb-2"><strong>Acción Correctiva:</strong></p>
                        <p class="mb-0">@Model.AccionCorrectiva</p>
                    </div>

                    <div class="row mb-2">
                        <div class="col-6 text-muted">Rango de rebajo:</div>
                        <div class="col-6">@Model.RebajoMinimo - @Model.RebajoMaximo puntos</div>
                    </div>
                    <div class="row">
                        <div class="col-6 text-muted">Rebajo aplicado:</div>
                        <div class="col-6">
                            <strong class="text-danger fs-5">-@Model.RebajoAplicado puntos</strong>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Personal involucrado -->
            <div class="card mb-3">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="fas fa-users"></i> Personal Involucrado</h5>
                </div>
                <div class="card-body">
                    <div class="row mb-2">
                        <div class="col-5 text-muted">Docente Emisor:</div>
                        <div class="col-7"><strong>@Model.DocenteEmisor</strong></div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-5 text-muted">Profesor Guía:</div>
                        <div class="col-7">@Model.ProfesorGuia</div>
                    </div>
                    <div class="row">
                        <div class="col-5 text-muted">Notificación:</div>
                        <div class="col-7">
                            @if (Model.NotificacionEnviada)
                            {
                                <span class="badge bg-success">
                                    <i class="fas fa-check-circle"></i> Enviada
                                </span>
                                @if (Model.FechaNotificacion.HasValue)
                                {
                                    <small class="d-block text-muted">
                                        @Model.FechaNotificacion.Value.ToString("dd/MM/yyyy HH:mm")
                                    </small>
                                }
                            }
                            else
                            {
                                <span class="badge bg-warning">
                                    <i class="fas fa-clock"></i> Pendiente
                                </span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Columna derecha -->
        <div class="col-lg-6">
            <!-- Descripción del incidente -->
            <div class="card mb-3">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0"><i class="fas fa-file-alt"></i> Descripción del Incidente</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <h6 class="text-muted">Descripción Detallada:</h6>
                        <p>@Model.Descripcion</p>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.LugarIncidente))
                    {
                        <div class="mb-3">
                            <h6 class="text-muted">Lugar del Incidente:</h6>
                            <p>@Model.LugarIncidente</p>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.Testigos))
                    {
                        <div class="mb-3">
                            <h6 class="text-muted">Testigos:</h6>
                            <p>@Model.Testigos</p>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.AccionInmediata))
                    {
                        <div class="mb-3">
                            <h6 class="text-muted">Acción Inmediata Tomada:</h6>
                            <p>@Model.AccionInmediata</p>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.Observaciones))
                    {
                        <div class="mb-3">
                            <h6 class="text-muted">Observaciones Adicionales:</h6>
                            <p>@Model.Observaciones</p>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.ArchivoEvidencia))
                    {
                        <div class="mb-3">
                            <h6 class="text-muted">Evidencia Adjunta:</h6>
                            <a href="@Model.ArchivoEvidencia" target="_blank" class="btn btn-sm btn-outline-primary">
                                <i class="fas fa-file-download"></i> Ver/Descargar Archivo
                            </a>
                        </div>
                    }
                </div>
            </div>

            <!-- Información de anulación (si aplica) -->
            @if (Model.Estado == "Anulada")
            {
                <div class="card mb-3 border-secondary">
                    <div class="card-header bg-secondary text-white">
                        <h5 class="mb-0"><i class="fas fa-ban"></i> Información de Anulación</h5>
                    </div>
                    <div class="card-body">
                        <div class="alert alert-secondary">
                            <p class="mb-2"><strong>Fecha de Anulación:</strong></p>
                            <p class="mb-3">@Model.FechaAnulacion?.ToString("dd/MM/yyyy HH:mm")</p>
                            
                            <p class="mb-2"><strong>Motivo:</strong></p>
                            <p class="mb-0">@Model.MotivoAnulacion</p>
                        </div>
                        <div class="alert alert-warning mb-0">
                            <i class="fas fa-info-circle"></i>
                            Esta boleta fue anulada y no se considera para el cálculo de la nota de conducta del estudiante.
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Acciones -->
    <div class="row no-print">
        <div class="col-12">
            <div class="card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="fas fa-arrow-left"></i> Volver al Listado
                        </a>
                        <div>
                            <button onclick="window.print()" class="btn btn-info me-2">
                                <i class="fas fa-print"></i> Imprimir/PDF
                            </button>
                            @if (Model.Estado == "Activa")
                            {
                                <a asp-action="Anular" asp-route-id="@Model.IdBoleta" class="btn btn-danger">
                                    <i class="fas fa-ban"></i> Anular Boleta
                                </a>
                            }
                            <a asp-controller="NotaConducta" asp-action="EstudianteNota" 
                               asp-route-idEstudiante="@Model.IdEstudiante" class="btn btn-primary">
                                <i class="fas fa-chart-line"></i> Ver Nota de Conducta
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Sección de firmas (solo visible en impresión) -->
    <div class="firmas-section print-only">
        <div class="row mt-5">
            <div class="col-6 text-center">
                <div class="firma-line"></div>
                <p class="mb-0"><strong>@Model.DocenteEmisor</strong></p>
                <p class="text-muted mb-0" style="font-size: 9pt;">Docente Emisor</p>
            </div>
            <div class="col-6 text-center">
                <div class="firma-line"></div>
                <p class="mb-0"><strong>@Model.ProfesorGuia</strong></p>
                <p class="text-muted mb-0" style="font-size: 9pt;">Profesor Guía</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Configuración para impresión
            console.log('Vista de boleta lista para imprimir');
        });
    </script>
}

<style>
    .gap-2 {
        gap: 0.5rem !important;
    }
    
    /* Ocultar sección de firmas en vista normal */
    .print-only {
        display: none;
    }
</style>

<style media="print">
    /* Configuración de página para orientación horizontal */
    @@page {
        size: landscape;
        margin: 1.5cm 2cm;  /* Márgenes adecuados para encuadernación */
        /* Sin pie de página */
    }
    
    /* Ocultar elementos de navegación, botones y footer */
    .btn, .breadcrumb, nav, .no-print, footer, .card-footer,
    .row.no-print, div.no-print {
        display: none !important;
        visibility: hidden !important;
        height: 0 !important;
        margin: 0 !important;
        padding: 0 !important;
    }
    
    /* Ajustar contenedor con padding */
    .container-fluid {
        width: 100% !important;
        max-width: 100% !important;
        padding: 10px 15px !important;  /* Padding interno para separación */
    }
    
    /* Información del encabezado compacta */
    .row.mb-4 {
        margin-bottom: 8px !important;  /* Reducido */
    }
    
    .row.mb-4 h2 {
        font-size: 14pt !important;  /* Más grande para visibilidad */
        margin-bottom: 2px !important;
        text-align: center !important;
        border-bottom: 2px solid #000;
        padding-bottom: 8px;
    }
    
    .row.mb-4 .text-muted {
        font-size: 9pt !important;
        text-align: center !important;
    }
    
    /* Tarjetas optimizadas y compactas */
    .card {
        break-inside: avoid;
        page-break-inside: avoid;
        border: 1px solid #333 !important;  /* Borde visible */
        box-shadow: none !important;
        margin-bottom: 8px !important;  /* Espacio entre tarjetas */
    }
    
    .card-header {
        print-color-adjust: exact;
        -webkit-print-color-adjust: exact;
        border-bottom: 1px solid #333 !important;
        padding: 6px 12px !important;  /* Padding adecuado */
    }
    
    .card-header h5 {
        font-size: 10pt !important;
        margin: 0 !important;
    }
    
    .card-body {
        padding: 10px 12px !important;  /* Padding interno */
        font-size: 9pt !important;
    }
    
    /* Colores de encabezados - Tonos formales y profesionales */
    .bg-primary {
        background-color: #2c3e50 !important;  /* Azul oscuro formal */
        color: white !important;
    }
    
    .bg-warning {
        background-color: #e8e8e8 !important;  /* Gris claro */
        color: #000 !important;
    }
    
    .bg-info {
        background-color: #95a5a6 !important;  /* Gris medio */
        color: #000 !important;
    }
    
    .bg-danger {
        background-color: #34495e !important;  /* Azul gris oscuro */
        color: white !important;
    }
    
    .bg-secondary {
        background-color: #7f8c8d !important;  /* Gris oscuro */
        color: white !important;
    }
    
    /* Badges compactos */
    .badge {
        border: 1px solid #000 !important;
        padding: 2px 6px !important;  /* Más pequeño */
        font-size: 8pt !important;  /* Reducido */
        print-color-adjust: exact;
        -webkit-print-color-adjust: exact;
    }
    
    .badge.bg-success {
        background-color: #27ae60 !important;
        color: white !important;
    }
    
    .badge.bg-info {
        background-color: #7f8c8d !important;
        color: white !important;
    }
    
    .badge.bg-primary {
        background-color: #2c3e50 !important;
        color: white !important;
    }
    
    .badge.bg-warning {
        background-color: #f39c12 !important;
        color: white !important;
    }
    
    .badge.bg-danger, .badge.bg-dark {
        background-color: #c0392b !important;
        color: white !important;
    }
    
    .fs-5, .fs-6 {
        font-size: 9pt !important;  /* Reducido */
    }
    
    /* Alertas compactas */
    .alert {
        border: 1px solid #000 !important;  /* Más delgado */
        print-color-adjust: exact;
        -webkit-print-color-adjust: exact;
        page-break-inside: avoid;
        padding: 6px !important;  /* Más compacto */
        margin-bottom: 5px !important;  /* Reducido */
    }
    
    .alert-info {
        background-color: #ecf0f1 !important;  /* Gris muy claro */
        border-color: #7f8c8d !important;
    }
    
    .alert-secondary {
        background-color: #d6dbdf !important;  /* Gris claro */
        border-color: #95a5a6 !important;
    }
    
    .alert-warning {
        background-color: #fdebd0 !important;  /* Beige claro */
        border-color: #f39c12 !important;
    }
    
    /* Textos y tipografía con colores formales */
    .text-danger {
        color: #c0392b !important;  /* Rojo oscuro */
        print-color-adjust: exact;
        -webkit-print-color-adjust: exact;
    }
    
    .text-primary {
        color: #2c3e50 !important;  /* Azul oscuro */
        print-color-adjust: exact;
        -webkit-print-color-adjust: exact;
    }
    
    .text-warning {
        color: #f39c12 !important;  /* Naranja formal */
        print-color-adjust: exact;
        -webkit-print-color-adjust: exact;
    }
    
    .text-info {
        color: #7f8c8d !important;  /* Gris medio */
        print-color-adjust: exact;
        -webkit-print-color-adjust: exact;
    }
    
    .text-success {
        color: #27ae60 !important;  /* Verde oscuro */
        print-color-adjust: exact;
        -webkit-print-color-adjust: exact;
    }
    
    .text-muted {
        color: #6c757d !important;
    }
    
    h6 {
        font-size: 9pt !important;  /* Reducido */
        margin-bottom: 3px !important;  /* Reducido */
        font-weight: bold;
    }
    
    p {
        font-size: 8.5pt !important;  /* Reducido */
        margin-bottom: 4px !important;  /* Reducido */
        line-height: 1.2 !important;  /* Más compacto */
    }
    
    /* Layout en dos columnas optimizado */
    .row {
        display: flex !important;
        flex-wrap: nowrap !important;
        margin-bottom: 0 !important;  /* Sin margen extra */
    }
    
    .col-lg-6 {
        width: 50% !important;
        flex: 0 0 50% !important;
        max-width: 50% !important;
        padding: 0 8px !important;  /* Padding adecuado */
    }
    
    /* Filas de información compactas */
    .row.mb-2, .row.mb-3 {
        display: flex !important;
        margin-bottom: 4px !important;  /* Espacio entre filas */
    }
    
    .col-4, .col-5, .col-6 {
        flex: 0 0 auto !important;
        padding-right: 8px !important;  /* Espacio entre columnas */
    }
    
    .col-4 { width: 33.33% !important; }
    .col-5 { width: 41.66% !important; }
    .col-6 { width: 50% !important; }
    .col-7 { width: 58.33% !important; }
    .col-8 { width: 66.66% !important; }
    
    /* Rebajo aplicado destacado pero compacto */
    .text-danger.fs-5 {
        font-size: 11pt !important;  /* Reducido pero destacado */
    }
    
    /* Espaciado optimizado para una sola página */
    .mb-1 { margin-bottom: 4px !important; }
    .mb-2 { margin-bottom: 5px !important; }
    .mb-3 { margin-bottom: 6px !important; }
    .mb-4 { margin-bottom: 8px !important; }
    
    /* Mostrar sección de firmas solo en impresión */
    .print-only {
        display: block !important;
        page-break-inside: avoid;
        margin-top: 30px;
    }
    
    /* Estilos para las firmas */
    .firmas-section .row {
        display: flex !important;
        justify-content: space-around !important;
    }
    
    .firmas-section .col-6 {
        width: 45% !important;
        padding: 0 20px !important;
    }
    
    .firma-line {
        border-top: 2px solid #000;
        width: 80%;
        margin: 50px auto 10px auto;  /* Espacio para firmar */
    }
    
    .firmas-section p {
        font-size: 9pt !important;
        margin: 3px 0 !important;
        line-height: 1.3 !important;
    }
    
    .firmas-section strong {
        font-size: 10pt !important;
    }
    
    /* Forzar contenido en una sola página */
    html, body {
        height: auto !important;
        overflow: visible !important;
    }
    
    .container-fluid {
        min-height: auto !important;
        height: auto !important;
    }
    
    /* Evitar saltos de página */
    .col-lg-6, .card, .alert {
        page-break-inside: avoid !important;
        break-inside: avoid !important;
    }
    
    /* Sección de anulación compacta */
    .border-secondary {
        border-width: 2px !important;
    }
    
    /* Iconos ocultos en impresión */
    .fas, .far, .fab {
        margin-right: 5px;
    }
}
</style>

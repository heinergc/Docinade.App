@model IEnumerable<DocinadeApp.Models.InstrumentoEvaluacion>

@{
    ViewData["Title"] = "Instrumentos de Evaluación";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <h4 class="mb-0">
                            <i class="fas fa-clipboard-list me-2"></i>
                            Instrumentos de Evaluación
                        </h4>
                        <a asp-action="Create" class="btn btn-light btn-sm">
                            <i class="fas fa-plus me-1"></i>
                            Nuevo Instrumento
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="fas fa-check-circle me-2"></i>
                            @TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="fas fa-exclamation-circle me-2"></i>
                            @TempData["ErrorMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <!-- Filtro de búsqueda -->
                    <div class="row mb-4">
                        <div class="col-md-12">
                            <div class="card bg-light">
                                <div class="card-body py-3">
                                    <form method="get" asp-action="Index" class="row g-3 align-items-end">
                                        <div class="col-md-8">
                                            <label for="busqueda" class="form-label">
                                                <i class="fas fa-search me-1"></i>
                                                Búsqueda libre
                                            </label>
                                            <input type="text" 
                                                   class="form-control" 
                                                   id="busqueda" 
                                                   name="busqueda" 
                                                   value="@ViewBag.BusquedaActual" 
                                                   placeholder="Buscar en nombre o descripción..." 
                                                   autocomplete="off">
                                        </div>
                                        <div class="col-md-4">
                                            <div class="d-flex gap-2">
                                                <button type="submit" class="btn btn-primary">
                                                    <i class="fas fa-search me-1"></i>
                                                    Buscar
                                                </button>
                                                <a asp-action="Index" class="btn btn-secondary">
                                                    <i class="fas fa-times me-1"></i>
                                                    Limpiar
                                                </a>
                                            </div>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Información de resultados -->
                    @if (!string.IsNullOrWhiteSpace(ViewBag.BusquedaActual))
                    {
                        <div class="alert alert-info">
                            <i class="fas fa-info-circle me-2"></i>
                            Mostrando resultados para: <strong>"@ViewBag.BusquedaActual"</strong>
                            <span class="badge bg-primary ms-2">@Model.Count() resultado(s)</span>
                        </div>
                    }

                    @if (Model.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>@Html.DisplayNameFor(model => model.Nombre)</th>
                                        <th>@Html.DisplayNameFor(model => model.Descripcion)</th>
                                        <th>@Html.DisplayNameFor(model => model.Activo)</th>
                                        <th>@Html.DisplayNameFor(model => model.FechaCreacion)</th>
                                        <th class="text-center">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td>
                                                <strong>@Html.DisplayFor(modelItem => item.Nombre)</strong>
                                            </td>
                                            <td>
                                                @Html.DisplayFor(modelItem => item.Descripcion)
                                            </td>
                                            <td>
                                                @if (item.Activo)
                                                {
                                                    <span class="badge bg-success">
                                                        <i class="fas fa-check me-1"></i>Activo
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary">
                                                        <i class="fas fa-times me-1"></i>Inactivo
                                                    </span>
                                                }
                                            </td>
                                            <td>
                                                @item.FechaCreacion.ToString("dd/MM/yyyy HH:mm")
                                            </td>
                                            <td class="text-center">
                                                <div class="btn-group" role="group">
                                                    <a asp-action="Details" asp-route-id="@item.InstrumentoId" 
                                                       class="btn btn-info btn-sm" title="Ver detalles">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                    <a asp-action="Edit" asp-route-id="@item.InstrumentoId" 
                                                       class="btn btn-warning btn-sm" title="Editar">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    <a asp-action="Delete" asp-route-id="@item.InstrumentoId" 
                                                       class="btn btn-danger btn-sm" title="Eliminar">
                                                        <i class="fas fa-trash"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-clipboard-list fa-3x text-muted mb-3"></i>
                            @if (!string.IsNullOrWhiteSpace(ViewBag.BusquedaActual))
                            {
                                <h5 class="text-muted">No se encontraron instrumentos que coincidan con la búsqueda</h5>
                                <p class="text-muted">
                                    No hay instrumentos de evaluación que contengan "<strong>@ViewBag.BusquedaActual</strong>" en su nombre o descripción.
                                </p>
                                <div class="d-flex justify-content-center gap-2">
                                    <a asp-action="Index" class="btn btn-secondary">
                                        <i class="fas fa-list me-1"></i>
                                        Ver Todos
                                    </a>
                                    <a asp-action="Create" class="btn btn-primary">
                                        <i class="fas fa-plus me-1"></i>
                                        Crear Instrumento
                                    </a>
                                </div>
                            }
                            else
                            {
                                <h5 class="text-muted">No hay instrumentos de evaluación registrados</h5>
                                <p class="text-muted">Comience creando su primer instrumento de evaluación.</p>
                                <a asp-action="Create" class="btn btn-primary">
                                    <i class="fas fa-plus me-1"></i>
                                    Crear Primer Instrumento
                                </a>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Auto-hide alerts after 5 seconds
            setTimeout(function() {
                $('.alert').fadeOut('slow');
            }, 5000);

            // Focus en el campo de búsqueda al cargar la página
            $('#busqueda').focus();

            // Búsqueda en tiempo real con debounce
            let searchTimeout;
            $('#busqueda').on('input', function() {
                clearTimeout(searchTimeout);
                const searchTerm = $(this).val();
                
                // Si el campo está vacío o tiene menos de 2 caracteres, no buscar automáticamente
                if (searchTerm.length === 0) {
                    return;
                }
                
                // Buscar después de 800ms de inactividad
                searchTimeout = setTimeout(function() {
                    if (searchTerm.length >= 2) {
                        $('#busqueda').closest('form').submit();
                    }
                }, 800);
            });

            // Enviar formulario con Enter
            $('#busqueda').on('keypress', function(e) {
                if (e.which === 13) { // Enter key
                    e.preventDefault();
                    $(this).closest('form').submit();
                }
            });

            // Resaltar texto de búsqueda en los resultados
            const searchTerm = '@ViewBag.BusquedaActual';
            if (searchTerm && searchTerm.length > 0) {
                highlightSearchTerm(searchTerm);
            }
        });

        // Función para resaltar el término de búsqueda
        function highlightSearchTerm(term) {
            if (!term) return;
            
            const regex = new RegExp(`(${term})`, 'gi');
            
            // Resaltar en nombres y descripciones
            $('tbody td').each(function() {
                const $this = $(this);
                const text = $this.html();
                if (text && typeof text === 'string') {
                    const highlightedText = text.replace(regex, '<mark class="bg-warning">$1</mark>');
                    if (highlightedText !== text) {
                        $this.html(highlightedText);
                    }
                }
            });
        }
    </script>
}
@model RubricasApp.Web.Models.InstrumentoEvaluacion

@{
    ViewData["Title"] = "Editar Instrumento de Evaluación";
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0">
                        <i class="fas fa-edit me-2"></i>
                        Editar Instrumento de Evaluación
                    </h4>
                </div>
                <div class="card-body">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                        <input type="hidden" asp-for="InstrumentoId" />
                        <input type="hidden" asp-for="FechaCreacion" />

                        <div class="row">
                            <div class="col-md-12 mb-3">
                                <label asp-for="Nombre" class="form-label">
                                    <i class="fas fa-tag me-1"></i>
                                    @Html.DisplayNameFor(model => model.Nombre)
                                    <span class="text-danger">*</span>
                                </label>
                                <input asp-for="Nombre" class="form-control" placeholder="Ingrese el nombre del instrumento" />
                                <span asp-validation-for="Nombre" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-12 mb-3">
                                <label asp-for="Descripcion" class="form-label">
                                    <i class="fas fa-align-left me-1"></i>
                                    @Html.DisplayNameFor(model => model.Descripcion)
                                </label>
                                <textarea asp-for="Descripcion" class="form-control" rows="4"
                                          placeholder="Describa el propósito y características del instrumento"></textarea>
                                <span asp-validation-for="Descripcion" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">

                                <label asp-for="Activo" class="form-label">Estado</label>
                                <div class="form-check form-switch">
                                    <input asp-for="Activo" class="form-check-input" type="checkbox" checked />
                                    <label class="form-check-label" asp-for="Activo">
                                        Activo
                                    </label>
                                </div>

                                @*     <div class="form-check">
                                    <input asp-for="Activo" class="form-check-input" type="checkbox" /> 
                                     <label asp-for="Activo" class="form-check-label">
                                       
                                    </label>
                                </div> *@
                                <small class="form-text text-muted">
                                    Marque esta opción si el instrumento debe estar activo.
                                </small>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Fecha de Creación</label>
                                <input type="text" class="form-control" value="@Model.FechaCreacion.ToString("dd/MM/yyyy HH:mm")" readonly />
                                <small class="form-text text-muted">
                                    Esta fecha no se puede modificar.
                                </small>
                            </div>
                        </div>

                        <hr class="my-4">

                        <div class="d-flex justify-content-between">
                            <div>
                                <a asp-action="Index" class="btn btn-secondary">
                                    <i class="fas fa-arrow-left me-1"></i>
                                    Volver a la Lista
                                </a>
                                <a asp-action="Details" asp-route-id="@Model?.InstrumentoId" class="btn btn-info">
                                    <i class="fas fa-eye me-1"></i>
                                    Ver Detalles
                                </a>
                            </div>
                            <button type="submit" class="btn btn-warning">
                                <i class="fas fa-save me-1"></i>
                                Guardar Cambios
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function() {
            // Focus on the first input
            $('#Nombre').focus();

            // Character counter for description
            $('#Descripcion').on('input', function() {
                var maxLength = 255;
                var currentLength = $(this).val().length;
                var remaining = maxLength - currentLength;

                if (!$('#char-counter').length) {
                    $(this).after('<small id="char-counter" class="form-text text-muted"></small>');
                }

                $('#char-counter').text(remaining + ' caracteres restantes')
                    .toggleClass('text-danger', remaining < 50)
                    .toggleClass('text-warning', remaining >= 50 && remaining < 100)
                    .toggleClass('text-muted', remaining >= 100);
            });

            // Trigger character counter on page load
            $('#Descripcion').trigger('input');
        });
    </script>
}
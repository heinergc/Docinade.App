@model DocinadeApp.Models.CrearCuadernoViewModel

@{
    ViewData["Title"] = "Crear Cuaderno Calificador";
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h4 class="mb-0">
                        <i class="fas fa-plus"></i> Crear Nuevo Cuaderno Calificador
                    </h4>
                </div>
                <div class="card-body">
                    <form asp-action="Crear" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                        
                        <div class="row">
                            <div class="col-md-12 mb-3">
                                <label asp-for="Nombre" class="form-label"></label>
                                <input asp-for="Nombre" class="form-control" placeholder="Ej: Cuaderno - Inglés Técnico I - 2025 C1">
                                <span asp-validation-for="Nombre" class="text-danger"></span>
                            </div>
                        </div>
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="MateriaId" class="form-label"></label>
                                <select asp-for="MateriaId" class="form-select" asp-items="Model.Materias">
                                    <option value="">-- Seleccione una materia --</option>
                                </select>
                                <span asp-validation-for="MateriaId" class="text-danger"></span>
                            </div>
                            
                            <div class="col-md-6 mb-3">
                                <label asp-for="PeriodoAcademicoId" class="form-label"></label>
                                <select asp-for="PeriodoAcademicoId" class="form-select" asp-items="Model.PeriodosAcademicos">
                                    <option value="">-- Seleccione un período --</option>
                                </select>
                                <span asp-validation-for="PeriodoAcademicoId" class="text-danger"></span>
                            </div>
                        </div>
                        
                        <div class="row">
                            <div class="col-12">
                                <div class="alert alert-info">
                                    <i class="fas fa-info-circle"></i>
                                    <strong>Información:</strong> Después de crear el cuaderno, podrá configurar los instrumentos de evaluación y sus ponderaciones.
                                </div>
                            </div>
                        </div>
                        
                        <div class="row">
                            <div class="col-12 text-end">
                                <a href="@Url.Action("Index")" class="btn btn-secondary">
                                    <i class="fas fa-times"></i> Cancelar
                                </a>
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-save"></i> Crear Cuaderno
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        // Auto-generar nombre basado en materia y período seleccionados
        function actualizarNombre() {
            const materiaSelect = document.getElementById('MateriaId');
            const periodoSelect = document.getElementById('PeriodoAcademicoId');
            const nombreInput = document.getElementById('Nombre');
            
            if (materiaSelect.selectedIndex > 0 && periodoSelect.selectedIndex > 0) {
                const materiaNombre = materiaSelect.options[materiaSelect.selectedIndex].text.split(' - ')[1] || materiaSelect.options[materiaSelect.selectedIndex].text;
                const periodoNombre = periodoSelect.options[periodoSelect.selectedIndex].text;
                
                nombreInput.value = `Cuaderno - ${materiaNombre} - ${periodoNombre}`;
            }
        }
        
        document.getElementById('MateriaId').addEventListener('change', actualizarNombre);
        document.getElementById('PeriodoAcademicoId').addEventListener('change', actualizarNombre);
    </script>
}
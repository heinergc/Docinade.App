@model RubricasApp.Web.ViewModels.Conducta.EditarProgramaViewModel

@{
    ViewData["Title"] = "Editar Programa de Acciones";
}

<div class="container-fluid">
    <div class="row mb-3">
        <div class="col">
            <h2><i class="fas fa-edit me-2"></i>@ViewData["Title"]</h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index">Programas de Acciones</a></li>
                    <li class="breadcrumb-item"><a asp-action="Details" asp-route-id="@Model.IdPrograma">Detalles</a></li>
                    <li class="breadcrumb-item active">Editar</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-10">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-user me-2"></i>@Model.NombreEstudiante
                        <span class="badge bg-light text-dark ms-2">@Model.NombrePeriodo</span>
                    </h5>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="IdPrograma" />
                        <input type="hidden" asp-for="IdEstudiante" />
                        <input type="hidden" asp-for="IdPeriodo" />
                        <input type="hidden" asp-for="NombreEstudiante" />
                        <input type="hidden" asp-for="NombrePeriodo" />

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label asp-for="TituloPrograma" class="form-label">Título del Programa</label>
                            <input asp-for="TituloPrograma" class="form-control" />
                            <span asp-validation-for="TituloPrograma" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Descripcion" class="form-label">Descripción General</label>
                            <textarea asp-for="Descripcion" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="Descripcion" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ObjetivosEspecificos" class="form-label">Objetivos Específicos</label>
                            <textarea asp-for="ObjetivosEspecificos" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="ObjetivosEspecificos" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ActividadesARealizar" class="form-label">Actividades a Realizar</label>
                            <textarea asp-for="ActividadesARealizar" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="ActividadesARealizar" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="CompromisosEstudiante" class="form-label">Compromisos del Estudiante</label>
                            <textarea asp-for="CompromisosEstudiante" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="CompromisosEstudiante" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="CompromisosFamilia" class="form-label">Compromisos de la Familia</label>
                            <textarea asp-for="CompromisosFamilia" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="CompromisosFamilia" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="CriteriosEvaluacion" class="form-label">Criterios de Evaluación</label>
                            <textarea asp-for="CriteriosEvaluacion" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="CriteriosEvaluacion" class="text-danger"></span>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label asp-for="FechaInicio" class="form-label">Fecha de Inicio</label>
                                <input asp-for="FechaInicio" type="date" class="form-control" />
                                <span asp-validation-for="FechaInicio" class="text-danger"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="FechaFinPrevista" class="form-label">Fecha de Fin Prevista</label>
                                <input asp-for="FechaFinPrevista" type="date" class="form-control" />
                                <span asp-validation-for="FechaFinPrevista" class="text-danger"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="FechaFinReal" class="form-label">Fecha de Fin Real</label>
                                <input asp-for="FechaFinReal" type="date" class="form-control" />
                                <span asp-validation-for="FechaFinReal" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="ResponsableSupervisionId" class="form-label">Responsable de Supervisión</label>
                                <select asp-for="ResponsableSupervisionId" class="form-select" asp-items="ViewBag.Supervisores">
                                    <option value="">-- Seleccione --</option>
                                </select>
                                <span asp-validation-for="ResponsableSupervisionId" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Estado" class="form-label">Estado</label>
                                <select asp-for="Estado" class="form-select" asp-items="ViewBag.Estados">
                                    <option value="">-- Seleccione --</option>
                                </select>
                                <span asp-validation-for="Estado" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ObservacionesSupervision" class="form-label">Observaciones de Supervisión</label>
                            <textarea asp-for="ObservacionesSupervision" class="form-control" rows="3" 
                                      placeholder="Notas y observaciones del supervisor..."></textarea>
                            <span asp-validation-for="ObservacionesSupervision" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ResultadoFinal" class="form-label">Resultado Final</label>
                            <select asp-for="ResultadoFinal" class="form-select" asp-items="ViewBag.Resultados">
                                <option value="">-- Seleccione --</option>
                            </select>
                            <span asp-validation-for="ResultadoFinal" class="text-danger"></span>
                        </div>

                        <div class="mt-4">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save me-1"></i> Guardar Cambios
                            </button>
                            <a asp-action="Details" asp-route-id="@Model.IdPrograma" class="btn btn-secondary">
                                <i class="fas fa-times me-1"></i> Cancelar
                            </a>
                            <a asp-action="Delete" asp-route-id="@Model.IdPrograma" class="btn btn-danger float-end">
                                <i class="fas fa-trash me-1"></i> Eliminar
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

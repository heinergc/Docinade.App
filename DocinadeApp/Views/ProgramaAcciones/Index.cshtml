@model IEnumerable<DocinadeApp.ViewModels.Conducta.ProgramaAccionesListViewModel>

@{
    ViewData["Title"] = "Programas de Acciones Institucional";
}

@section Styles {
    <!-- DataTables CSS -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css">
}

<div class="container-fluid">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="NotaConducta" asp-action="Dashboard">Dashboard</a></li>
                    <li class="breadcrumb-item active">Programas de Acciones</li>
                </ol>
            </nav>
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2><i class="fas fa-clipboard-list text-warning"></i> Programas de Acciones Institucional</h2>
                    <p class="text-muted">Gestión de programas para estudiantes aplazados en conducta</p>
                </div>
                <div>
                    <a asp-action="Create" class="btn btn-success">
                        <i class="fas fa-plus me-1"></i> Crear Programa
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Filtros -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" id="formFiltros">
                <div class="row align-items-end">
                    <div class="col-md-3">
                        <label for="idPeriodo" class="form-label">Período Académico</label>
                        <select id="idPeriodo" name="idPeriodo" class="form-select" onchange="$('#formFiltros').submit()">
                            <option value="">Todos los períodos</option>
                            @foreach (var periodo in ViewBag.Periodos)
                            {
                                <option value="@periodo.Value" selected="@(periodo.Value == ViewBag.IdPeriodoSeleccionado)">
                                    @periodo.Text
                                </option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label for="estado" class="form-label">Estado</label>
                        <select id="estado" name="estado" class="form-select" onchange="$('#formFiltros').submit()">
                            <option value="">Todos los estados</option>
                            <option value="Pendiente" selected="@(ViewBag.EstadoSeleccionado == "Pendiente")">Pendiente</option>
                            <option value="En Proceso" selected="@(ViewBag.EstadoSeleccionado == "En Proceso")">En Proceso</option>
                            <option value="Completado" selected="@(ViewBag.EstadoSeleccionado == "Completado")">Completado</option>
                            <option value="No Completado" selected="@(ViewBag.EstadoSeleccionado == "No Completado")">No Completado</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label for="idSupervisor" class="form-label">Supervisor</label>
                        <select id="idSupervisor" name="idSupervisor" class="form-select" onchange="$('#formFiltros').submit()">
                            <option value="">Todos los supervisores</option>
                            @foreach (var supervisor in ViewBag.Supervisores)
                            {
                                <option value="@supervisor.Value" selected="@(supervisor.Value == ViewBag.IdSupervisorSeleccionado)">
                                    @supervisor.Text
                                </option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <button type="button" class="btn btn-secondary" onclick="location.href='@Url.Action("Index")'">
                            <i class="fas fa-redo"></i> Limpiar
                        </button>
                        <button type="button" class="btn btn-success" onclick="exportarExcel()">
                            <i class="fas fa-file-excel"></i> Excel
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Estadísticas -->
    <div class="row mb-4">
        <div class="col-lg-3 col-md-6 mb-3">
            <div class="card border-info shadow-sm">
                <div class="card-body text-center">
                    <h6 class="text-muted">Total Programas</h6>
                    <h2 class="text-info">@Model.Count()</h2>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6 mb-3">
            <div class="card border-warning shadow-sm">
                <div class="card-body text-center">
                    <h6 class="text-muted">Pendientes</h6>
                    <h2 class="text-warning">@Model.Count(p => p.Estado == "Pendiente")</h2>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6 mb-3">
            <div class="card border-primary shadow-sm">
                <div class="card-body text-center">
                    <h6 class="text-muted">En Proceso</h6>
                    <h2 class="text-primary">@Model.Count(p => p.Estado == "En Proceso")</h2>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6 mb-3">
            <div class="card border-success shadow-sm">
                <div class="card-body text-center">
                    <h6 class="text-muted">Completados</h6>
                    <h2 class="text-success">@Model.Count(p => p.Estado == "Completado")</h2>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabla de programas -->
    <div class="card shadow-sm">
        <div class="card-header bg-warning">
            <h5 class="mb-0 text-white"><i class="fas fa-list"></i> Lista de Programas</h5>
        </div>
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover" id="tablaProgramas">
                        <thead class="table-dark">
                            <tr>
                                <th>Estudiante</th>
                                <th>Identificación</th>
                                <th>Período</th>
                                <th>Supervisor</th>
                                <th class="text-center">Fecha Inicio</th>
                                <th class="text-center">Fecha Fin</th>
                                <th class="text-center">Estado</th>
                                <th class="text-center">Verificado</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var programa in Model)
                            {
                                <tr>
                                    <td><strong>@programa.NombreEstudiante</strong></td>
                                    <td>@programa.NumeroIdentificacion</td>
                                    <td>@programa.NombrePeriodo</td>
                                    <td>@programa.NombreSupervisor</td>
                                    <td class="text-center">@programa.FechaInicio.ToString("dd/MM/yyyy")</td>
                                    <td class="text-center">
                                        @if (programa.FechaFinReal.HasValue)
                                        {
                                            <span>@programa.FechaFinReal.Value.ToString("dd/MM/yyyy")</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">@programa.FechaFinPrevista.ToString("dd/MM/yyyy")</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (programa.Estado == "Pendiente")
                                        {
                                            <span class="badge bg-warning">Pendiente</span>
                                        }
                                        else if (programa.Estado == "En Proceso")
                                        {
                                            <span class="badge bg-primary">En Proceso</span>
                                        }
                                        else if (programa.Estado == "Completado")
                                        {
                                            <span class="badge bg-success">Completado</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">No Completado</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (programa.FechaVerificacion.HasValue)
                                        {
                                            <i class="fas fa-check-circle text-success" 
                                               title="Verificado: @programa.FechaVerificacion.Value.ToString("dd/MM/yyyy")"></i>
                                        }
                                        else
                                        {
                                            <i class="fas fa-clock text-warning" title="Pendiente verificación"></i>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group" role="group">
                                            <a asp-action="Details" asp-route-id="@programa.IdPrograma" 
                                               class="btn btn-sm btn-info" title="Ver detalles">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            @if (!programa.FechaVerificacion.HasValue)
                                            {
                                                <a asp-action="Edit" asp-route-id="@programa.IdPrograma" 
                                                   class="btn btn-sm btn-warning" title="Editar">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <a asp-action="Delete" asp-route-id="@programa.IdPrograma" 
                                                   class="btn btn-sm btn-danger" title="Eliminar">
                                                    <i class="fas fa-trash"></i>
                                                </a>
                                            }
                                            @if (!programa.FechaVerificacion.HasValue && programa.Estado == "En Proceso")
                                            {
                                                <a asp-action="Verificar" asp-route-id="@programa.IdPrograma" 
                                                   class="btn btn-sm btn-success" title="Verificar programa">
                                                    <i class="fas fa-check"></i>
                                                </a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info text-center">
                    <i class="fas fa-info-circle fa-3x mb-3"></i>
                    <p class="mb-0">No hay programas de acciones registrados con los filtros seleccionados.</p>
                </div>
            }
        </div>
    </div>

    <!-- Botones -->
    <div class="mt-4">
        <a asp-controller="NotaConducta" asp-action="Dashboard" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Volver al Dashboard
        </a>
    </div>
</div>

@section Scripts {
    <!-- DataTables JS -->
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>
    
    <script>
        $(document).ready(function() {
            $('#tablaProgramas').DataTable({
                language: {
                    url: '//cdn.datatables.net/plug-ins/1.13.7/i18n/es-ES.json'
                },
                order: [[4, 'desc']], // Ordenar por fecha inicio descendente
                pageLength: 25
            });
        });

        function exportarExcel() {
            toastr.info('Exportando a Excel...');
            
            const params = new URLSearchParams();
            const idPeriodo = $('#idPeriodo').val();
            const estado = $('#estado').val();
            const idSupervisor = $('#idSupervisor').val();
            
            if (idPeriodo) params.append('idPeriodo', idPeriodo);
            if (estado) params.append('estado', estado);
            if (idSupervisor) params.append('idSupervisor', idSupervisor);
            
            window.location.href = '@Url.Action("ExportarProgramas")?' + params.toString();
        }
    </script>
}

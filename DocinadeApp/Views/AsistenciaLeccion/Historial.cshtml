@model DocinadeApp.ViewModels.HistorialAsistenciaViewModel

@{
    ViewData["Title"] = "Historial de Asistencia";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-info text-white">
                    <h3 class="mb-0">
                        <i class="fas fa-history me-2"></i>@ViewData["Title"]
                    </h3>
                </div>
                <div class="card-body">
                    <!-- Filtros -->
                    <form asp-action="Historial" method="get" class="mb-4">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label">Estudiante *</label>
                                <select name="estudianteId" class="form-select" required>
                                    <option value="">-- Seleccione un estudiante --</option>
                                    @foreach (var item in ViewBag.Estudiantes as IEnumerable<SelectListItem>)
                                    {
                                        <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Grupo (opcional)</label>
                                <select name="grupoId" class="form-select">
                                    <option value="">Todos los grupos</option>
                                    @foreach (var item in ViewBag.Grupos as IEnumerable<SelectListItem>)
                                    {
                                        <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">Fecha Inicio</label>
                                <input type="date" name="fechaInicio" class="form-control" 
                                       value="@ViewBag.FechaInicio?.ToString("yyyy-MM-dd")" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">Fecha Fin</label>
                                <input type="date" name="fechaFin" class="form-control" 
                                       value="@ViewBag.FechaFin?.ToString("yyyy-MM-dd")" />
                            </div>
                            <div class="col-md-1 d-flex align-items-end">
                                <button type="submit" class="btn btn-primary w-100">
                                    <i class="fas fa-search"></i>
                                </button>
                            </div>
                        </div>
                    </form>

                    @if (Model.EstudianteId > 0)
                    {
                        <!-- Información del estudiante -->
                        <div class="alert alert-primary mb-4">
                            <h5>
                                <i class="fas fa-user me-2"></i>@Model.NombreCompleto
                            </h5>
                            <div class="row mt-3">
                                <div class="col-md-3">
                                    <strong>Período:</strong><br />
                                    @Model.FechaInicio.ToString("dd/MM/yyyy") - @Model.FechaFin.ToString("dd/MM/yyyy")
                                </div>
                                <div class="col-md-3">
                                    <strong>Total de Registros:</strong><br />
                                    @Model.Asistencias.Count
                                </div>
                                <div class="col-md-3">
                                    <strong>% Asistencia:</strong><br />
                                    <span class="badge @(Model.PorcentajeAsistencia >= 80 ? "bg-success" : Model.PorcentajeAsistencia >= 60 ? "bg-warning" : "bg-danger") fs-6">
                                        @Model.PorcentajeAsistencia.ToString("F1")%
                                    </span>
                                </div>
                            </div>
                        </div>

                        <!-- Tarjetas de estadísticas -->
                        <div class="row mb-4">
                            @foreach (var stat in Model.Estadisticas)
                            {
                                var badgeClass = stat.Key switch
                                {
                                    "Presente" => "bg-success",
                                    "Ausente" => "bg-danger",
                                    "Tardanza" => "bg-warning",
                                    "Ausencia Justificada" => "bg-info",
                                    _ => "bg-secondary"
                                };

                                <div class="col-md-3 mb-3">
                                    <div class="card text-white @badgeClass">
                                        <div class="card-body text-center">
                                            <h2 class="mb-0">@stat.Value</h2>
                                            <p class="mb-0">@stat.Key</p>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>

                        <!-- Tabla de asistencias -->
                        @if (Model.Asistencias.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-hover table-striped">
                                    <thead class="table-dark">
                                        <tr>
                                            <th>Fecha</th>
                                            <th>Grupo</th>
                                            <th>Materia</th>
                                            <th>Lección</th>
                                            <th>Estado</th>
                                            <th>Observaciones</th>
                                            <th>Justificación</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var asistencia in Model.Asistencias.OrderByDescending(a => a.Fecha))
                                        {
                                            var estadoBadge = asistencia.Estado switch
                                            {
                                                "P" => "bg-success",
                                                "A" => "bg-danger",
                                                "T" => "bg-warning",
                                                "AJ" => "bg-info",
                                                _ => "bg-secondary"
                                            };

                                            var estadoTexto = asistencia.Estado switch
                                            {
                                                "P" => "Presente",
                                                "A" => "Ausente",
                                                "T" => "Tardanza",
                                                "AJ" => "Aus. Justificada",
                                                _ => "No marcado"
                                            };

                                            <tr>
                                                <td>@asistencia.Fecha.ToString("dd/MM/yyyy")</td>
                                                <td>@asistencia.Grupo?.Nombre</td>
                                                <td>@asistencia.Materia?.Nombre</td>
                                                <td>
                                                    @if (asistencia.Leccion != null)
                                                    {
                                                        <small>
                                                            @asistencia.Leccion.DiaSemana.ToString() 
                                                            @asistencia.Leccion.HorarioFormateado
                                                        </small>
                                                    }
                                                </td>
                                                <td>
                                                    <span class="badge @estadoBadge">@estadoTexto</span>
                                                </td>
                                                <td>
                                                    @if (!string.IsNullOrEmpty(asistencia.Observaciones))
                                                    {
                                                        <small>@asistencia.Observaciones</small>
                                                    }
                                                </td>
                                                <td>
                                                    @if (!string.IsNullOrEmpty(asistencia.Justificacion))
                                                    {
                                                        <small class="text-muted">@asistencia.Justificacion</small>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info">
                                <i class="fas fa-info-circle me-2"></i>
                                No se encontraron registros de asistencia para el período seleccionado.
                            </div>
                        }
                    }
                    else
                    {
                        <div class="alert alert-warning text-center">
                            <i class="fas fa-search me-2"></i>
                            Por favor, seleccione un estudiante para ver su historial de asistencia.
                        </div>
                    }

                    <div class="mt-4">
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="fas fa-arrow-left me-1"></i>Volver
                        </a>
                        @if (Model.EstudianteId > 0 && Model.Asistencias.Any())
                        {
                            <button onclick="window.print()" class="btn btn-primary">
                                <i class="fas fa-print me-1"></i>Imprimir
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        @@media print {
            .btn, form, .card-header {
                display: none !important;
            }
        }
    </style>
}

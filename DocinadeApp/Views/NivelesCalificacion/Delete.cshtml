@model DocinadeApp.Models.NivelCalificacion

@{
    ViewData["Title"] = "Eliminar Nivel de Calificación";
}

<div class="row">
    <div class="col-md-6 offset-md-3">
        <div class="card">
            <div class="card-header bg-danger text-white">
                <h4 class="mb-0">
                    <i class="fas fa-trash"></i> Eliminar Nivel de Calificación
                </h4>
            </div>
            <div class="card-body">
                <div class="alert alert-warning" role="alert">
                    <i class="fas fa-exclamation-triangle"></i>
                    ¿Está seguro que desea eliminar este nivel de calificación?
                </div>

                <dl class="row">
                    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.NombreNivel)</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(model => model.NombreNivel)</dd>

                    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Descripcion)</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(model => model.Descripcion)</dd>

                    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.OrdenNivel)</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(model => model.OrdenNivel)</dd>
                </dl>

                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="IdNivel" />
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash"></i> Eliminar
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Cancelar
                    </a>
                </form>
            </div>
        </div>
    </div>
</div>
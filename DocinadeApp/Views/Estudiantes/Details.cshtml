@model DocinadeApp.Models.Estudiante

@{
    ViewData["Title"] = "Detalles del Estudiante";
}

<!-- Contenido Principal -->
<main class="main-content fade-in">
    <div class="container-fluid px-4">
        <!-- Header de Página Mejorado -->
        <div class="page-header">
            <h3 class="page-title-white">
                <i class="fas fa-info-circle"></i>
                Detalles del Estudiante
            </h3>
        </div>

        <!-- Mensajes de alerta modernos -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert-modern success">
                <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert-modern danger">
                <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
            </div>
        }

        <div class="row">
            <div class="col-lg-8">
                <!-- Información Principal del Estudiante -->
                <div class="modern-card">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="mb-0">
                            <i class="fas fa-user-graduate"></i>
                            Información Personal
                        </h5>
                        <div class="btn-group-responsive">
                            <a asp-action="Edit" asp-route-id="@Model?.IdEstudiante" class="btn-modern warning">
                                <i class="fas fa-edit"></i> Editar
                            </a>
                        </div>
                    </div>

                    <dl class="row">
                        <dt class="col-sm-4 text-muted">
                            <i class="fas fa-user"></i> Nombre Completo:
                        </dt>
                        <dd class="col-sm-8">
                            <strong>@Html.DisplayFor(model => model.NombreCompleto)</strong>
                        </dd>

                        <dt class="col-sm-4 text-muted">
                            <i class="fas fa-id-card"></i> Número de ID:
                        </dt>
                        <dd class="col-sm-8">
                            <span class="badge-modern secondary">@Html.DisplayFor(model => model.NumeroId)</span>
                        </dd>

                        <dt class="col-sm-4 text-muted">
                            <i class="fas fa-envelope"></i> Correo Electrónico:
                        </dt>
                        <dd class="col-sm-8">
                            <a href="mailto:@Model.DireccionCorreo" class="text-decoration-none">
                                <i class="fas fa-external-link-alt"></i>
                                @Html.DisplayFor(model => model.DireccionCorreo)
                            </a>
                        </dd>

                        <dt class="col-sm-4 text-muted">
                            <i class="fas fa-building"></i> Institución:
                        </dt>
                        <dd class="col-sm-8">@Html.DisplayFor(model => model.Institucion)</dd>

                        <dt class="col-sm-4 text-muted">
                            <i class="fas fa-users"></i> Grupos:
                        </dt>
                        <dd class="col-sm-8">@Html.DisplayFor(model => model.Grupos)</dd>

                        <dt class="col-sm-4 text-muted">
                            <i class="fas fa-calendar"></i> Año:
                        </dt>
                        <dd class="col-sm-8">@Html.DisplayFor(model => model.Anio)</dd>

                        @if (Model.PeriodoAcademico != null)
                        {
                            <dt class="col-sm-4 text-muted">
                                <i class="fas fa-calendar-check"></i> Período Académico:
                            </dt>
                            <dd class="col-sm-8">
                                <span class="badge-modern info">@Model.PeriodoAcademico.Codigo</span>
                                @Model.PeriodoAcademico.Nombre
                            </dd>
                        }
                        
                        <dt class="col-sm-4 text-muted">
                            <i class="fas fa-toggle-on"></i> Estado:
                        </dt>
                        <dd class="col-sm-8">
                            @if (Model.Estado == 1)
                            {
                                <span class="badge-modern success">
                                    <i class="fas fa-check-circle"></i> Activo
                                </span>
                                <small class="text-muted ms-2">Tiene acceso al sistema</small>
                            }
                            else
                            {
                                <span class="badge-modern danger">
                                    <i class="fas fa-times-circle"></i> Inactivo
                                </span>
                                <small class="text-muted ms-2">Sin acceso al sistema</small>
                            }
                        </dd>
                    </dl>
                </div>

                <!-- Evaluaciones del Estudiante -->
                @if (Model.Evaluaciones != null && Model.Evaluaciones.Any())
                {
                    <div class="modern-card">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h5 class="mb-0">
                                <i class="fas fa-clipboard-check"></i>
                                Historial de Evaluaciones
                            </h5>
                            <span class="badge-modern info">@Model.Evaluaciones.Count() evaluación(es)</span>
                        </div>

                        <div class="table-responsive">
                            <table class="table table-modern">
                                <thead>
                                    <tr>
                                        <th><i class="fas fa-list"></i> Rúbrica</th>
                                        <th><i class="fas fa-calendar"></i> Fecha</th>
                                        <th><i class="fas fa-star"></i> Puntos</th>
                                        <th><i class="fas fa-cogs"></i> Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var evaluacion in Model.Evaluaciones.OrderByDescending(e => e.FechaEvaluacion))
                                    {
                                        <tr>
                                            <td>
                                                <strong>@evaluacion.Rubrica.NombreRubrica</strong>
                                            </td>
                                            <td>@evaluacion.FechaEvaluacion.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td>
                                                <span class="badge-modern success">@evaluacion.TotalPuntos pts</span>
                                            </td>
                                            <td>
                                                <div class="btn-group" role="group">
                                                    <a asp-controller="Evaluaciones" asp-action="Details" asp-route-id="@evaluacion.IdEvaluacion" 
                                                       class="btn btn-sm btn-outline-info" title="Ver evaluación">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
                else
                {
                    <div class="modern-card">
                        <div class="text-center py-4">
                            <div class="empty-icon">
                                <i class="fas fa-clipboard-check"></i>
                            </div>
                            <div class="empty-title">
                                Sin Evaluaciones Registradas
                            </div>
                            <div class="empty-description">
                                Este estudiante aún no tiene evaluaciones registradas en el sistema.
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="col-lg-4">
                <!-- Card de Acciones -->
                <div class="modern-card">
                    <h5 class="mb-3">
                        <i class="fas fa-tools"></i>
                        Acciones Disponibles
                    </h5>
                    
                    <div class="d-grid gap-2">
                        <a asp-action="Edit" asp-route-id="@Model?.IdEstudiante" class="btn-modern warning">
                            <i class="fas fa-edit"></i> Editar Información
                        </a>
                        
                        <a asp-controller="Evaluaciones" asp-action="Create" asp-route-estudianteId="@Model?.IdEstudiante" 
                           class="btn-modern primary">
                            <i class="fas fa-plus"></i> Nueva Evaluación
                        </a>
                        
                        <a asp-action="Index" class="btn-modern secondary">
                            <i class="fas fa-arrow-left"></i> Volver a la Lista
                        </a>
                        
                        <hr class="my-3">
                        
                        <a asp-action="Delete" asp-route-id="@Model?.IdEstudiante" class="btn-modern danger">
                            <i class="fas fa-trash"></i> Eliminar Estudiante
                        </a>
                    </div>
                </div>

                <!-- Card de Estadísticas -->
                @if (Model.Evaluaciones != null && Model.Evaluaciones.Any())
                {
                    <div class="modern-card">
                        <h5 class="mb-3">
                            <i class="fas fa-chart-line"></i>
                            Estadísticas
                        </h5>
                        
                        <div class="text-center">
                            <div class="row">
                                <div class="col-6">
                                    <div class="card-icon success mx-auto mb-2">
                                        <i class="fas fa-clipboard-check"></i>
                                    </div>
                                    <h6 class="mb-1">@Model.Evaluaciones.Count()</h6>
                                    <small class="text-muted">Evaluaciones</small>
                                </div>
                                <div class="col-6">
                                    <div class="card-icon primary mx-auto mb-2">
                                        <i class="fas fa-star"></i>
                                    </div>
                                    <h6 class="mb-1">@(Model.Evaluaciones.Any() ? Model.Evaluaciones.Average(e => e.TotalPuntos)?.ToString("F1") : "0")</h6>
                                    <small class="text-muted">Promedio</small>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</main>
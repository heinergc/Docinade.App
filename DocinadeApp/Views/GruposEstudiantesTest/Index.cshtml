@model dynamic

@{
    ViewData["Title"] = "Prueba del Sistema de Grupos";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-vial me-2"></i>
                        Prueba del Sistema de Grupos de Estudiantes
                    </h4>
                </div>
                <div class="card-body">
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">
                            <h5><i class="fas fa-exclamation-triangle me-2"></i>Error Detectado</h5>
                            <p><strong>Mensaje:</strong> @ViewBag.Error</p>
                            @if (ViewBag.StackTrace != null)
                            {
                                <details>
                                    <summary>Ver detalles técnicos</summary>
                                    <pre class="mt-2" style="font-size: 0.8rem;">@ViewBag.StackTrace</pre>
                                </details>
                            }
                        </div>
                    }
                    else if (ViewBag.Mensaje != null)
                    {
                        <div class="alert alert-success">
                            <h5><i class="fas fa-check-circle me-2"></i>Estado del Sistema</h5>
                            <p>@ViewBag.Mensaje</p>
                        </div>
                    }

                    <div class="row">
                        <div class="col-md-6">
                            <h5>?? Estadísticas</h5>
                            <ul class="list-group list-group-flush">
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    Total de Grupos
                                    <span class="badge bg-primary rounded-pill">@Model.TotalGrupos</span>
                                </li>
                            </ul>
                        </div>
                        <div class="col-md-6">
                            <h5>?? Acciones de Prueba</h5>
                            <div class="d-grid gap-2">
                                <a href="@Url.Action("TestDatos")" class="btn btn-outline-info">
                                    <i class="fas fa-database me-2"></i>Test de Datos
                                </a>
                                <a href="@Url.Action("Index", "GruposEstudiantes")" class="btn btn-outline-primary">
                                    <i class="fas fa-users-cog me-2"></i>Ir al Sistema Real
                                </a>
                            </div>
                        </div>
                    </div>

                    @if (Model.Grupos != null && Model.Grupos.Count > 0)
                    {
                        <hr>
                        <h5>?? Grupos Encontrados</h5>
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>ID</th>
                                        <th>Código</th>
                                        <th>Nombre</th>
                                        <th>Tipo</th>
                                        <th>Estado</th>
                                        <th>Fecha Creación</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var grupo in Model.Grupos)
                                    {
                                        <tr>
                                            <td>@grupo.GrupoId</td>
                                            <td><span class="badge bg-secondary">@grupo.Codigo</span></td>
                                            <td>@grupo.Nombre</td>
                                            <td>@grupo.TipoGrupo</td>
                                            <td>
                                                <span class="badge bg-@(grupo.Estado.ToString() == "Activo" ? "success" : "warning")">
                                                    @grupo.Estado
                                                </span>
                                            </td>
                                            <td>@grupo.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            console.log('?? Página de prueba cargada correctamente');
            console.log('?? Total de grupos:', @Model.TotalGrupos);
        });
    </script>
}
@model IEnumerable<RubricasApp.Web.Models.ItemEvaluacion>

@{
    ViewData["Title"] = "Gestión de Items de Evaluación";
}

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">
                    <i class="fas fa-tasks"></i> Gestión de Items de Evaluación
                </h4>
            </div>
            <div class="card-body">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                <div class="mb-3">
                    <div class="row">
                        <div class="col-md-6">
                            <a asp-action="Create" class="btn btn-success">
                                <i class="fas fa-plus"></i> Nuevo Item de Evaluación
                            </a>
                        </div>
                        <div class="col-md-6">
                            <form method="get" class="d-flex">
                                <div class="me-2 flex-grow-1">
                                    <select name="rubricaId" class="form-select" onchange="this.form.submit()">
                                        <option value="">-- Todas las Rúbricas --</option>
                                        @if (ViewBag.Rubricas != null)
                                        {
                                            var rubricasList = ViewBag.Rubricas as SelectList;
                                            if (rubricasList != null)
                                            {
                                                foreach (var rubrica in rubricasList)
                                                {
                                                    <option value="@rubrica.Value" selected="@rubrica.Selected">@rubrica.Text</option>
                                                }
                                            }
                                        }
                                    </select>
                                </div>
                                @if (ViewBag.RubricaSeleccionada != null)
                                {
                                    <a asp-action="Index" class="btn btn-outline-secondary">
                                        <i class="fas fa-times"></i> Limpiar
                                    </a>
                                }
                            </form>
                        </div>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Rúbrica</th>
                                <th>@Html.DisplayNameFor(model => model.NombreItem)</th>
                                <th>@Html.DisplayNameFor(model => model.Descripcion)</th>
                                <th>@Html.DisplayNameFor(model => model.OrdenItem)</th>
                                <th width="200">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Any())
                            {
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@Html.DisplayFor(modelItem => item.Rubrica.NombreRubrica)</td>
                                        <td>@Html.DisplayFor(modelItem => item.NombreItem)</td>
                                        <td>@Html.DisplayFor(modelItem => item.Descripcion)</td>
                                        <td>@Html.DisplayFor(modelItem => item.OrdenItem)</td>
                                        <td>
                                            <div class="btn-group" role="group">
                                                <a asp-action="Details" asp-route-id="@item.IdItem" class="btn btn-info btn-sm" title="Ver detalles">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                                <a asp-action="Edit" asp-route-id="@item.IdItem" class="btn btn-warning btn-sm" title="Editar">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <a asp-action="Delete" asp-route-id="@item.IdItem" class="btn btn-danger btn-sm" title="Eliminar">
                                                    <i class="fas fa-trash"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center">No hay items de evaluación registrados.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
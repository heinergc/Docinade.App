@model DocinadeApp.DTOs.Calificador.CuadernoCalificadorDto

@{
    ViewData["Title"] = $"Cuaderno Calificador - {Model.MateriaNombre}";
    var query = ViewBag.Query as DocinadeApp.DTOs.Calificador.CalificadorQueryDto;
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <!-- Header del cuaderno -->
            <div class="card mb-3">
                <div class="card-header bg-success text-white">
                    <div class="row align-items-center">
                        <div class="col-md-8">
                            <h4 class="card-title mb-0">
                                <i class="fas fa-table"></i> @ViewData["Title"]
                            </h4>
                            <small>@Model.PeriodoAcademicoNombre | Generado: @Model.FechaGeneracion.ToString("dd/MM/yyyy HH:mm")</small>
                        </div>
                        <div class="col-md-4 text-end">
                            <div class="btn-group">
                                <a asp-action="Index" class="btn btn-outline-light btn-sm">
                                    <i class="fas fa-arrow-left"></i> Volver
                                </a>
                                <a asp-action="ExportarCsv" asp-all-route-data="@(new Dictionary<string, string> {
                                    ["MateriaId"] = query?.MateriaId.ToString() ?? "0",
                                    ["PeriodoAcademicoId"] = query?.PeriodoAcademicoId.ToString() ?? "0",
                                    ["ModoCalculo"] = query?.ModoCalculo ?? "PROMEDIO",
                                    ["ValorPorDefecto"] = query?.ValorPorDefecto.ToString() ?? "0",
                                    ["IncluirInactivos"] = query?.IncluirInactivos.ToString() ?? "false"
                                })" class="btn btn-outline-light btn-sm">
                                    <i class="fas fa-download"></i> Exportar CSV
                                </a>
                                <button type="button" class="btn btn-outline-light btn-sm" id="btn-print">
                                    <i class="fas fa-print"></i> Imprimir
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Estad�sticas r�pidas -->
            <div class="row mb-3">
                <div class="col-md-3">
                    <div class="card border-primary">
                        <div class="card-body text-center py-2">
                            <h5 class="text-primary mb-0">@Model.Estadisticas.TotalEstudiantes</h5>
                            <small class="text-muted">Estudiantes</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card border-success">
                        <div class="card-body text-center py-2">
                            <h5 class="text-success mb-0">@Model.Estadisticas.TotalInstrumentos</h5>
                            <small class="text-muted">Instrumentos</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card border-info">
                        <div class="card-body text-center py-2">
                            <h5 class="text-info mb-0">@Model.Estadisticas.PromedioGeneral.ToString("F2")</h5>
                            <small class="text-muted">Promedio General</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card border-warning">
                        <div class="card-body text-center py-2">
                            <h5 class="text-warning mb-0">@Model.Estadisticas.EstudiantesConNotasPendientes</h5>
                            <small class="text-muted">Pendientes</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tabla del cuaderno -->
            <div class="card">
                <div class="card-body p-0">
                    <div class="table-responsive" id="cuaderno-table">
                        <table class="table table-striped table-hover mb-0">
                            <thead class="table-dark sticky-top">
                                <tr>
                                    <th style="min-width: 200px;">
                                        <i class="fas fa-user"></i> Estudiante
                                    </th>
                                    <th style="min-width: 100px;">
                                        <i class="fas fa-id-card"></i> ID
                                    </th>
                                    @foreach (var columna in Model.Columnas.OrderBy(c => c.InstrumentoId).ThenBy(c => c.OrdenPresentacion))
                                    {
                                        <th class="text-center" style="min-width: 120px;" title="@columna.NombreColumna">
                                            <div class="small">
                                                <strong>@columna.InstrumentoNombre</strong>
                                                <br>
                                                <span class="text-light">@columna.RubricaNombre</span>
                                                @if (columna.Ponderacion > 0)
                                                {
                                                    <br><span class="badge bg-light text-dark">@columna.Ponderacion.ToString("F0")%</span>
                                                }
                                            </div>
                                        </th>
                                    }
                                    <th class="text-center bg-warning" style="min-width: 100px;">
                                        <i class="fas fa-trophy"></i>
                                        <br><strong>TOTAL</strong>
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var fila in Model.Filas.OrderBy(f => f.EstudianteNombre))
                                {
                                    <tr>
                                        <td>
                                            <strong>@fila.EstudianteNombre</strong>
                                            @if (fila.Estado != "ACTIVO")
                                            {
                                                <span class="badge bg-secondary ms-1">@fila.Estado</span>
                                            }
                                        </td>
                                        <td class="text-muted">@fila.NumeroId</td>
                                        @foreach (var columna in Model.Columnas.OrderBy(c => c.InstrumentoId).ThenBy(c => c.OrdenPresentacion))
                                        {
                                            var calificacion = fila.CalificacionesPorInstrumentoRubrica.TryGetValue(columna.ClaveColumna, out decimal valor) ? valor : 0;
                                            var cssClass = calificacion >= 70 ? "text-success" : calificacion >= 60 ? "text-warning" : calificacion > 0 ? "text-danger" : "text-muted";
                                            
                                            <td class="text-center @cssClass">
                                                @if (calificacion > 0)
                                                {
                                                    <strong>@calificacion.ToString("F1")</strong>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">�</span>
                                                }
                                            </td>
                                        }
                                        @{
                                            var totalCssClass = fila.TotalFinal >= 70 ? "text-success fw-bold" : 
                                                              fila.TotalFinal >= 60 ? "text-warning fw-bold" : 
                                                              fila.TotalFinal > 0 ? "text-danger fw-bold" : "text-muted";
                                        }
                                        <td class="text-center bg-light @totalCssClass">
                                            <strong style="font-size: 1.1em;">@fila.TotalFinal.ToString("F2")</strong>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-secondary">
                                <tr>
                                    <td colspan="2"><strong>PROMEDIOS POR COLUMNA:</strong></td>
                                    @foreach (var columna in Model.Columnas.OrderBy(c => c.InstrumentoId).ThenBy(c => c.OrdenPresentacion))
                                    {
                                        var calificacionesColumna = Model.Filas
                                            .Where(f => f.CalificacionesPorInstrumentoRubrica.ContainsKey(columna.ClaveColumna))
                                            .Select(f => f.CalificacionesPorInstrumentoRubrica[columna.ClaveColumna])
                                            .Where(c => c > 0);
                                        var promedio = calificacionesColumna.Any() ? calificacionesColumna.Average() : 0;
                                        
                                        <td class="text-center">
                                            <strong>@promedio.ToString("F1")</strong>
                                        </td>
                                    }
                                    <td class="text-center bg-warning">
                                        <strong>@Model.Estadisticas.PromedioGeneral.ToString("F2")</strong>
                                    </td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Informaci�n adicional -->
            <div class="row mt-3">
                <div class="col-md-6">
                    <div class="card border-info">
                        <div class="card-header bg-info text-white py-2">
                            <h6 class="mb-0"><i class="fas fa-info-circle"></i> Informaci�n del C�lculo</h6>
                        </div>
                        <div class="card-body py-2">
                            <small>
                                <strong>Modo de c�lculo:</strong> @(query?.ModoCalculo ?? "PROMEDIO")<br>
                                <strong>Valor por defecto:</strong> @(query?.ValorPorDefecto.ToString("F2") ?? "0.00")<br>
                                <strong>Incluye inactivos:</strong> @(query?.IncluirInactivos == true ? "S�" : "No")<br>
                                <strong>F�rmula:</strong> Total = ?(Calificaci�n_Instrumento � Ponderaci�n_%)
                            </small>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card border-secondary">
                        <div class="card-header bg-secondary text-white py-2">
                            <h6 class="mb-0"><i class="fas fa-palette"></i> Leyenda de Colores</h6>
                        </div>
                        <div class="card-body py-2">
                            <small>
                                <span class="text-success"><i class="fas fa-square"></i></span> ? 70: Excelente<br>
                                <span class="text-warning"><i class="fas fa-square"></i></span> 60-69: Bueno<br>
                                <span class="text-danger"><i class="fas fa-square"></i></span> 1-59: Insuficiente<br>
                                <span class="text-muted"><i class="fas fa-square"></i></span> 0: Sin calificaci�n
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Funci�n de impresi�n
            $('#btn-print').on('click', function() {
                window.print();
            });
            
            // Resaltar fila al hover
            $('tbody tr').hover(
                function() {
                    $(this).addClass('table-active');
                },
                function() {
                    $(this).removeClass('table-active');
                }
            );
            
            // Tooltip para encabezados largos
            $('th[title]').tooltip();
            
            // Mensaje de �xito si todo est� correcto
            @if (Model.Filas.Any())
            {
                <text>
                console.log('Cuaderno generado exitosamente:', {
                    estudiantes: @Model.Estadisticas.TotalEstudiantes,
                    instrumentos: @Model.Estadisticas.TotalInstrumentos,
                    rubricas: @Model.Estadisticas.TotalRubricas,
                    promedio: @Model.Estadisticas.PromedioGeneral
                });
                </text>
            }
        });
    </script>
}

@section Styles {
    <style>
        @@media print {
            .btn-group, .card-header .col-md-4:last-child {
                display: none !important;
            }
            
            .card {
                border: none !important;
                box-shadow: none !important;
            }
            
            .table {
                font-size: 0.8em;
            }
            
            .sticky-top {
                position: static !important;
            }
        }
        
        .table th {
            vertical-align: top;
        }
        
        .sticky-top {
            top: 0;
            z-index: 1020;
        }
        
        .table-responsive {
            max-height: 70vh;
        }
        
        .card-body.py-2 {
            padding-top: 0.5rem !important;
            padding-bottom: 0.5rem !important;
        }
    </style>
}
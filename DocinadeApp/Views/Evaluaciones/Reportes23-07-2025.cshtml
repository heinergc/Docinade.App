@model DocinadeApp.ViewModels.ReporteEvaluacionesViewModel

@{
    ViewData["Title"] = "Reportes de Evaluaciones";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="fas fa-chart-bar text-success"></i> Reportes de Evaluaciones</h1>
    <a asp-action="Index" class="btn btn-primary">
        <i class="fas fa-arrow-left"></i> Volver a Evaluaciones
    </a>
</div>

<!-- Filtros -->
<div class="card mb-4">
    <div class="card-header bg-light">
        <h5 class="mb-0"><i class="fas fa-filter"></i> Filtros para Reportes</h5>
    </div>
    <div class="card-body">
        <form method="get" asp-action="Reportes">
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label for="periodoId">Período Académico:</label>
                        <select name="periodoId" id="periodoId" class="form-select">
                            <option value="">-- Todos los períodos --</option>
                            @if (ViewBag.Periodos != null)
                            {
                                @foreach (var periodo in ViewBag.Periodos as List<SelectListItem>)
                                {
                                    <option value="@periodo.Value" selected="@(periodo.Value == ViewBag.PeriodoSeleccionado?.ToString())">
                                        @periodo.Text
                                    </option>
                                }
                            }
                        </select>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label for="rubricaId">Rúbrica:</label>
                        <select name="rubricaId" id="rubricaId" class="form-select">
                            <option value="">-- Todas las rúbricas --</option>
                            @if (ViewBag.Rubricas != null)
                            {
                                @foreach (var rubrica in ViewBag.Rubricas as List<SelectListItem>)
                                {
                                    <option value="@rubrica.Value" selected="@(rubrica.Value == ViewBag.RubricaSeleccionada?.ToString())">
                                        @rubrica.Text
                                    </option>
                                }
                            }
                        </select>
                    </div>
                </div>
            </div>
            <div class="row mt-3">
                <div class="col-12">
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-chart-line"></i> Generar Reporte
                    </button>
                    <a asp-action="Reportes" class="btn btn-secondary">
                        <i class="fas fa-times"></i> Limpiar Filtros
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

@if (Model.Evaluaciones.Any())
{
    <!-- Estadísticas generales -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card bg-primary text-white">
                <div class="card-body text-center">
                    <i class="fas fa-clipboard-check fa-2x mb-2"></i>
                    <h4>@Model.TotalEvaluaciones</h4>
                    <p class="mb-0">Total Evaluaciones</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white">
                <div class="card-body text-center">
                    <i class="fas fa-chart-line fa-2x mb-2"></i>
                    <h4>@Model.PromedioGeneral.ToString("F2")</h4>
                    <p class="mb-0">Promedio General</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white">
                <div class="card-body text-center">
                    <i class="fas fa-arrow-up fa-2x mb-2"></i>
                    <h4>@Model.PuntajeMaximo.ToString("F2")</h4>
                    <p class="mb-0">Puntaje Máximo</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-white">
                <div class="card-body text-center">
                    <i class="fas fa-arrow-down fa-2x mb-2"></i>
                    <h4>@Model.PuntajeMinimo.ToString("F2")</h4>
                    <p class="mb-0">Puntaje Mínimo</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Gráfico de distribución de puntajes -->
    <div class="card mb-4">
        <div class="card-header bg-dark text-white">
            <h5 class="mb-0"><i class="fas fa-chart-bar"></i> Distribución de Puntajes</h5>
        </div>
        <div class="card-body">
            <canvas id="graficoPuntajes" width="400" height="100"></canvas>
        </div>
    </div>

    <!-- Tabla detallada -->
    <div class="card">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="fas fa-table"></i> Detalle de Evaluaciones</h5>
            <button onclick="exportarAExcel()" class="btn btn-sm btn-light">
                <i class="fas fa-file-excel"></i> Exportar a Excel
            </button>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover" id="tablaEvaluaciones">
                    <thead class="table-dark">
                        <tr>
                            <th>Estudiante</th>
                            <th>ID</th>
                            <th>Rúbrica</th>
                            <th>Período</th>
                            <th>Fecha</th>
                            <th>Puntaje</th>
                            <th>Items</th>
                            <th>Observaciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var evaluacion in Model.Evaluaciones.OrderByDescending(e => e.TotalPuntos))
                        {
                            <tr>
                                <td>
                                    <a asp-action="Details" asp-route-id="@evaluacion.IdEvaluacion" class="text-decoration-none">
                                        @evaluacion.Estudiante.Apellidos, @evaluacion.Estudiante.Nombre
                                    </a>
                                </td>
                                <td>@evaluacion.Estudiante.NumeroId</td>
                                <td>
                                    <span class="badge bg-info">@evaluacion.Rubrica.NombreRubrica</span>
                                </td>
                                <td>
                                    <small>@if (evaluacion.Estudiante.PeriodoAcademico != null) { @evaluacion.Estudiante.PeriodoAcademico.NombreCompleto }</small>
                                </td>
                                <td>@evaluacion.FechaEvaluacion.ToString("dd/MM/yyyy")</td>
                                <td>
                                    @if (evaluacion.TotalPuntos.HasValue)
                                    {
                                        var puntaje = evaluacion.TotalPuntos.Value;
                                        var porcentaje = Model.PuntajeMaximo > 0 ? (puntaje / Model.PuntajeMaximo) * 100 : 0;
                                        var clase = "";
                                        
                                        if (porcentaje >= 90) { clase = "bg-success"; }
                                        else if (porcentaje >= 80) { clase = "bg-info"; }
                                        else if (porcentaje >= 70) { clase = "bg-warning"; }
                                        else { clase = "bg-danger"; }
                                        
                                        <span class="badge @clase fs-6">
                                            @puntaje.ToString("F2") 
                                            <small>(@porcentaje.ToString("F0")%)</small>
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Sin calcular</span>
                                    }
                                </td>
                                <td>
                                    <span class="badge bg-secondary">@evaluacion.DetallesEvaluacion.Count</span>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(evaluacion.Observaciones))
                                    {
                                        <span title="@evaluacion.Observaciones" data-bs-toggle="tooltip">
                                            <i class="fas fa-comment text-info"></i>
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Sin observaciones</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
else
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="fas fa-chart-pie fa-3x text-muted mb-3"></i>
            <h5 class="text-muted">No hay datos para mostrar</h5>
            <p class="text-muted">
                @if (ViewBag.PeriodoSeleccionado != null || ViewBag.RubricaSeleccionada != null)
                {
                    <span>No se encontraron evaluaciones que coincidan con los filtros aplicados.</span>
                }
                else
                {
                    <span>No hay evaluaciones registradas en el sistema.</span>
                }
            </p>
            <a asp-action="Create" class="btn btn-success">
                <i class="fas fa-plus"></i> Crear Nueva Evaluación
            </a>
        </div>
    </div>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://unpkg.com/xlsx/dist/xlsx.full.min.js"></script>
    <script>
        $(document).ready(function() {
            // Inicializar tooltips
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl);
            });

            // Auto-submit cuando cambian los filtros
            $('#periodoId, #rubricaId').change(function() {
                $(this).closest('form').submit();
            });

            @if (Model.Evaluaciones.Any())
            {
                <text>
                // Generar gráfico de distribución de puntajes
                var puntajes = [@Html.Raw(string.Join(",", Model.Evaluaciones.Where(e => e.TotalPuntos.HasValue).Select(e => e.TotalPuntos.Value.ToString("F2"))))];
                var puntajeMaximo = @Model.PuntajeMaximo;
                
                // Crear rangos de puntajes
                var rangos = ['0-20', '21-40', '41-60', '61-80', '81-100'];
                var conteos = [0, 0, 0, 0, 0];
                
                // Usar forEach para evitar problemas con operadores de comparación en Razor
                puntajes.forEach(function(puntaje, index) {
                    var porcentaje = puntajeMaximo > 0 ? (puntaje / puntajeMaximo) * 100 : 0;
                    if (porcentaje @Html.Raw("&lt;=") 20) {
                        conteos[0]++;
                    } else if (porcentaje @Html.Raw("&lt;=") 40) {
                        conteos[1]++;
                    } else if (porcentaje @Html.Raw("&lt;=") 60) {
                        conteos[2]++;
                    } else if (porcentaje @Html.Raw("&lt;=") 80) {
                        conteos[3]++;
                    } else {
                        conteos[4]++;
                    }
                });

                var ctx = document.getElementById('graficoPuntajes').getContext('2d');
                var chart = new Chart(ctx, {
                    type: 'bar',
                    data: {
                        labels: rangos,
                        datasets: [{
                            label: 'Cantidad de Evaluaciones',
                            data: conteos,
                            backgroundColor: [
                                'rgba(220, 53, 69, 0.8)',   // Rojo
                                'rgba(255, 193, 7, 0.8)',   // Amarillo
                                'rgba(255, 193, 7, 0.8)',   // Amarillo
                                'rgba(23, 162, 184, 0.8)',  // Azul
                                'rgba(40, 167, 69, 0.8)'    // Verde
                            ],
                            borderColor: [
                                'rgba(220, 53, 69, 1)',
                                'rgba(255, 193, 7, 1)',
                                'rgba(255, 193, 7, 1)',
                                'rgba(23, 162, 184, 1)',
                                'rgba(40, 167, 69, 1)'
                            ],
                            borderWidth: 1
                        }]
                    },
                    options: {
                        responsive: true,
                        scales: {
                            y: {
                                beginAtZero: true,
                                stepSize: 1
                            }
                        },
                        plugins: {
                            legend: {
                                display: false
                            },
                            title: {
                                display: true,
                                text: 'Distribución de Puntajes (Porcentajes)'
                            }
                        }
                    }
                });
                </text>
            }

          function exportarAExcel() {
            // Crear una tabla temporal solo con los datos
            var tabla = document.getElementById('tablaEvaluaciones').cloneNode(true);

            // Limpiar enlaces y elementos HTML complejos
            var filas = tabla.querySelectorAll('tbody tr');
            filas.forEach(function(fila) {
                var celdas = fila.querySelectorAll('td');
                celdas.forEach(function(celda) {
                    celda.innerHTML = celda.textContent.trim();
                });
            });

            // Crear archivo Excel
            var wb = XLSX.utils.table_to_book(tabla, {sheet: "Evaluaciones"});
            XLSX.writeFile(wb, 'Reporte_Evaluaciones_' + new Date().toISOString().slice(0,10) + '.xlsx');
        }

        });

    
    </script>
}
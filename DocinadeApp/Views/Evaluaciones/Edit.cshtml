@model DocinadeApp.ViewModels.EditarEvaluacionViewModel

@{
    ViewData["Title"] = "Editar Evaluación";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header bg-warning text-white">
                <h4 class="mb-0">
                    <i class="fas fa-edit"></i> Editar Evaluación
                </h4>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post" id="formEvaluacion">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <input type="hidden" asp-for="IdEvaluacion" />
                    <input type="hidden" asp-for="IdEstudiante" />
                    <input type="hidden" asp-for="IdRubrica" />

                    <!-- Información de solo lectura -->
                    <div class="alert alert-info alert-permanent">
                        <div class="row">
                            <div class="col-md-6">
                                <strong><i class="fas fa-user me-1"></i> Estudiante:</strong>
                                <span>@ViewBag.EstudianteNombre</span>
                            </div>
                            <div class="col-md-6">
                                <strong><i class="fas fa-clipboard-list me-1"></i> Rúbrica:</strong>
                                <span>@ViewBag.RubricaNombre</span>
                            </div>
                        </div>
                        <small class="text-muted">
                            <i class="fas fa-info-circle"></i>
                            No es posible cambiar el estudiante o la rúbrica en una evaluación existente.
                        </small>
                    </div>


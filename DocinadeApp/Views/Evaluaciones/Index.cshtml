@model IEnumerable<RubricasApp.Web.Models.Evaluacion>

@{
    ViewData["Title"] = "Gestión de Evaluaciones";
}

@section Styles {
    <link rel="stylesheet" href="~/css/evaluaciones.css">
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-clipboard-check text-black"></i> Gestión de Evaluaciones</h2>
    @Html.AntiForgeryToken()
    <div>
        <a asp-action="Create" class="btn btn-success">
            <i class="fas fa-plus"></i> Nueva Evaluación
        </a>
        <a asp-action="Reportes" class="btn btn-info">
            <i class="fas fa-chart-bar"></i> Reportes
        </a>
        <button type="button" class="btn btn-warning" id="btnEnviarTodas" onclick="enviarTodasEvaluaciones()">
            <i class="fas fa-paper-plane"></i> Enviar Todas las Evaluaciones
        </button>
    </div>
</div>

<!-- Filtros ACTUALIZADOS: Filtros en cascada y modo "Ver todo" -->
<div class="card mb-4">
    <div class="card-header bg-light">
        <h5 class="mb-0">
            <i class="fas fa-filter"></i> Filtros de Búsqueda
            @* TODO: Filtro cascada - Indicador modo "Ver todo" *@
            @if (ViewBag.ShowAll == true)
            {
                <span class="badge bg-info ms-2">MODO VER TODO</span>
                //* Mostrar un badge o indicador visual cuando esté en modo "Ver todo" */

            }
        </h5>
    </div>
    <div class="card-body">
        @* TODO: Filtro cascada - Banner para modo "Ver todo" *@
        @if (ViewBag.ShowAll == true)
        {
            <div class="alert alert-info alert-dismissible fade show" role="alert">
                <i class="fas fa-info-circle"></i>
                <strong>Vista completa sin filtros:</strong> Se están mostrando todas las evaluaciones sin aplicar filtros.
                Los controles de filtro están deshabilitados en este modo.
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <form method="get" asp-action="Index" id="filtrosForm">
            @* Campo oculto para modo ShowAll *@
            <input type="hidden" name="showAll" value="@(ViewBag.ShowAll?.ToString().ToLower() ?? "false")" />

            @* FILTROS SIMPLES CON DROPDOWNS NORMALES *@
            <div class="row mb-3">
                <div class="col-md-2">
                    <div class="form-group">
                        <label for="estudianteId">Estudiante:</label>
                        <div class="input-group">
                            <select name="estudianteId" id="estudianteId" class="form-select" 
                                    disabled="@(ViewBag.ShowAll == true)">
                                <option value="">-- Todos los estudiantes --</option>
                                @if (ViewBag.Estudiantes != null)
                                {
                                    @foreach (var estudiante in ViewBag.Estudiantes as List<SelectListItem>)
                                    {
                                        <option value="@estudiante.Value" selected="@(estudiante.Value == ViewBag.EstudianteSeleccionado?.ToString())">
                                            @estudiante.Text
                                        </option>
                                    }
                                }
                            </select>
                            <button type="button" 
                                    class="btn btn-outline-primary" 
                                    data-bs-toggle="modal" 
                                    data-bs-target="#modalBuscadorEstudiante"
                                    title="Buscar estudiante"
                                    disabled="@(ViewBag.ShowAll == true)">
                                <i class="fas fa-search"></i>
                            </button>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <label for="rubricaId">Rúbrica:</label>
                        <select name="rubricaId" id="rubricaId" class="form-select"
                            disabled="@(ViewBag.ShowAll == true)">
                            <option value="">-- Todas las rúbricas --</option>
                            @if (ViewBag.Rubricas != null)
                            {
                                @foreach (var rubrica in ViewBag.Rubricas as List<SelectListItem>)
                                {
                                    <option value="@rubrica.Value"
                                        selected="@(rubrica.Value == ViewBag.RubricaSeleccionada?.ToString())">
                                        @rubrica.Text
                                    </option>
                                }
                            }
                        </select>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="form-group">
                        <label for="periodoId">Período Académico:</label>
                        <select name="periodoId" id="periodoId" class="form-select"
                            disabled="@(ViewBag.ShowAll == true)">
                            <option value="">-- Todos los períodos --</option>
                            @if (ViewBag.Periodos != null)
                            {
                                @foreach (var periodo in ViewBag.Periodos as List<SelectListItem>)
                                {
                                    <option value="@periodo.Value"
                                        selected="@(periodo.Value == ViewBag.PeriodoSeleccionado?.ToString())">
                                        @periodo.Text
                                    </option>
                                }
                            }
                        </select>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="form-group">
                        <label>&nbsp;</label>
                        <div class="form-check">
                            <input type="checkbox" name="showAll" id="showAll" class="form-check-input" value="true"
                                checked="@(ViewBag.ShowAll == true)" onchange="this.form.submit()">
                            <label class="form-check-label" for="showAll">
                                <strong>Ver todo</strong>
                            </label>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="form-group">
                        <label>&nbsp;</label>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary" disabled="@(ViewBag.ShowAll == true)">
                                <i class="fas fa-search"></i> Filtrar
                            </button>
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-times"></i> Limpiar
                            </a>
                            @if (ViewBag.ShowAll == true)
                            {
                                <a asp-action="Index" asp-route-showAll="false" class="btn btn-warning">
                                    <i class="fas fa-filter"></i> Activar Filtros
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Estadísticas de envío -->
@if (Model.Any())
{
    <div class="estadisticas-envio" id="estadisticasEnvio">
        <div class="row text-center">
            <div class="col-md-3">
                <h5><i class="fas fa-clipboard-list"></i> Total Evaluaciones</h5>
                <h3 id="totalEvaluaciones">@Model.Count()</h3>
            </div>
            <div class="col-md-3">
                <h5><i class="fas fa-check-circle"></i> Completadas</h5>
                <h3 id="evaluacionesCompletadas">@Model.Count(e => e.Estado == "COMPLETADA")</h3>
            </div>
            <div class="col-md-3">
                <h5><i class="fas fa-edit"></i> Borradores</h5>
                <h3 id="evaluacionesBorrador">@Model.Count(e => e.Estado == "BORRADOR")</h3>
            </div>
            <div class="col-md-3">
                <h5><i class="fas fa-envelope"></i> Listas para Enviar</h5>
                <h3 id="listasParaEnviar">@Model.Count(e => e.Estado == "COMPLETADA")</h3>
            </div>
        </div>
    </div>
}

<!-- Resultados -->
<div class="card">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0">
            <i class="fas fa-list"></i>
            Evaluaciones (@Model.Count() registros)
        </h5>
    </div>
    <div class="card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>
                                <a asp-action="Index" 
                                   asp-route-sortOrder="@ViewBag.ApellidosSortParam"
                                   asp-route-estudianteId="@ViewBag.EstudianteSeleccionado"
                                   asp-route-rubricaId="@ViewBag.RubricaSeleccionada"
                                   asp-route-periodoId="@ViewBag.PeriodoSeleccionado"
                                   asp-route-showAll="@ViewBag.ShowAll"
                                   class="text-white text-decoration-none"
                                   title="Ordenar por apellidos">
                                    Estudiante
                                    @if (ViewBag.CurrentSort == "apellidos")
                                    {
                                        <i class="fas fa-sort-up"></i>
                                    }
                                    else if (ViewBag.CurrentSort == "apellidos_desc")
                                    {
                                        <i class="fas fa-sort-down"></i>
                                    }
                                    else
                                    {
                                        <i class="fas fa-sort"></i>
                                    }
                                </a>
                            </th>
                            <th>Rúbrica</th>
                            <th>Período</th>
                            <th>Estado</th>
                            <th>
                                <a asp-action="Index" 
                                   asp-route-sortOrder="@ViewBag.FechaSortParam"
                                   asp-route-estudianteId="@ViewBag.EstudianteSeleccionado"
                                   asp-route-rubricaId="@ViewBag.RubricaSeleccionada"
                                   asp-route-periodoId="@ViewBag.PeriodoSeleccionado"
                                   asp-route-showAll="@ViewBag.ShowAll"
                                   class="text-white text-decoration-none"
                                   title="Ordenar por fecha">
                                    Fecha
                                    @if (ViewBag.CurrentSort == "fecha")
                                    {
                                        <i class="fas fa-sort-up"></i>
                                    }
                                    else if (ViewBag.CurrentSort == "fecha_desc")
                                    {
                                        <i class="fas fa-sort-down"></i>
                                    }
                                    else
                                    {
                                        <i class="fas fa-sort"></i>
                                    }
                                </a>
                            </th>
                            <th>Total Puntos</th>
                            <th>Items Evaluados</th>
                            <th class="text-center">Acciones</th>
                            <th class="text-center">Enviar</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var evaluacion in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex flex-column">
                                        <strong>@evaluacion.Estudiante.Apellidos, @evaluacion.Estudiante.Nombre</strong>
                                        <small class="text-muted">ID: @evaluacion.Estudiante.NumeroId</small>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge bg-info text-dark">@evaluacion.Rubrica.NombreRubrica</span>
                                </td>
                                <td>
                                    <small>@(evaluacion.Estudiante.PeriodoAcademico != null ? $"{evaluacion.Estudiante.PeriodoAcademico.Anio} - {evaluacion.Estudiante.PeriodoAcademico.Ciclo}" : "Sin período")</small>
                                </td>
                                <td>
                                    @{
                                        var estado = string.IsNullOrEmpty(evaluacion.Estado) ? "COMPLETADA" : evaluacion.Estado;
                                        var badgeClass = estado == "BORRADOR" ? "bg-warning text-dark" : "bg-success";
                                        var iconClass = estado == "BORRADOR" ? "fas fa-edit" : "fas fa-check-circle";
                                    }
                                    <span class="badge @badgeClass">
                                        <i class="@iconClass"></i> @estado
                                    </span>
                                </td>
                                <td>
                                    @evaluacion.FechaEvaluacion.ToString("dd/MM/yyyy HH:mm")
                                </td>
                                <td>
                                    @if (evaluacion.TotalPuntos.HasValue)
                                    {
                                        <span class="badge bg-success fs-6">
                                            @evaluacion.TotalPuntos.Value.ToString("F2") pts
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning">Sin calcular</span>
                                    }
                                </td>
                                <td>
                                    <span class="badge bg-secondary">
                                        @evaluacion.DetallesEvaluacion.Count items
                                    </span>
                                </td>
                                <td class="text-center">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Details" asp-route-id="@evaluacion.IdEvaluacion"
                                            class="btn btn-sm btn-outline-info" title="Ver detalles">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@evaluacion.IdEvaluacion"
                                            class="btn btn-sm btn-outline-warning" title="Editar">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@evaluacion.IdEvaluacion"
                                            class="btn btn-sm btn-outline-danger" title="Eliminar">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                                <td class="text-center">
                                    @if (estado == "COMPLETADA")
                                    {
                                        <div class="btn-grupo-envios">
                                            <button type="button" class="btn btn-sm btn-success btn-enviar-evaluacion"
                                                onclick="enviarEvaluacion(@evaluacion.IdEvaluacion, '@evaluacion.Estudiante.NombreCompleto')"
                                                title="Enviar evaluación por correo" data-evaluacion-id="@evaluacion.IdEvaluacion">
                                                <i class="fas fa-envelope"></i>
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn btn-sm btn-secondary" disabled
                                            title="Solo se pueden enviar evaluaciones completadas">
                                            <i class="fas fa-envelope"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                <h5 class="text-muted">No hay evaluaciones registradas</h5>
                <p class="text-muted">
                    @if (ViewBag.EstudianteSeleccionado != null || ViewBag.RubricaSeleccionada != null ||
                                    ViewBag.PeriodoSeleccionado != null)
                    {
                        <span>No se encontraron evaluaciones que coincidan con los filtros aplicados.</span>
                    }
                    else
                    {
                        <span>Comience creando una nueva evaluación.</span>
                    }
                </p>
                <a asp-action="Create" class="btn btn-success">
                    <i class="fas fa-plus"></i> Crear Primera Evaluación
                </a>
            </div>
        }
    </div>
</div>

<!-- Componente BuscadorEstudiante -->
@await Component.InvokeAsync("BuscadorEstudiante", new {
    modalId = "modalBuscadorEstudiante",
    selectId = "estudianteId",
    controllerName = "Test",
    actionName = "BuscarEstudiantes",
    titulo = "Buscar Estudiante para Filtrar",
    placeholder = "Escriba nombre, apellido o número de identificación...",
    incluirScripts = true
})

@section Scripts {
    <!-- El JavaScript del buscador se carga automáticamente con incluirScripts=true -->

    <script>
        $(document).ready(function () {
            console.log('📋 Filtros simples inicializados');

            // Auto-submit simple cuando cambian los filtros
            $('#estudianteId, #rubricaId, #periodoId').change(function () {
                if (!$('#showAll').is(':checked')) {
                    console.log('🔄 Aplicando filtro:', $(this).attr('id'), '=', $(this).val());
                    $(this).closest('form').submit();
                }
            });

            // Inicializar el buscador de estudiantes para los filtros
            console.log('🔍 Inicializando buscador de estudiantes para filtros...');
            
            // El buscador se inicializa automáticamente con incluirScripts=true
            // No necesitamos inicialización manual adicional

        });

        // Función para enviar evaluación individual
        function enviarEvaluacion(evaluacionId, nombreEstudiante) {
            const nombreLimpio = nombreEstudiante.replace(/["']/g, '');

            if (confirm(`¿Está seguro de enviar la evaluación a ${nombreLimpio}?`)) {
                const boton = document.querySelector(`button[data-evaluacion-id="${evaluacionId}"]`);
                if (!boton) {
                    mostrarMensaje('error', 'No se pudo encontrar el botón de envío');
                    return;
                }

                const textoOriginal = boton.innerHTML;
                boton.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
                boton.disabled = true;
                boton.classList.remove('btn-success');
                boton.classList.add('btn-warning');

                $.ajax({
                    url: '@Url.Action("EnviarEvaluacion", "Evaluaciones")',
                    type: 'POST',
                    data: {
                        evaluacionId: evaluacionId,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function (response) {
                        if (response.success) {
                            mostrarMensaje('success', response.message);
                            boton.innerHTML = '<i class="fas fa-check"></i>';
                            boton.classList.remove('btn-warning', 'btn-success');
                            boton.classList.add('btn-outline-success');
                            boton.title = 'Evaluación enviada exitosamente';
                            boton.disabled = true;
                        } else {
                            mostrarMensaje('error', response.message || 'Error desconocido al enviar la evaluación');
                            restaurarBoton(boton, textoOriginal);
                        }
                    },
                    error: function (xhr, status, error) {
                        let mensajeError = 'Error de conexión';
                        if (xhr.responseJSON && xhr.responseJSON.message) {
                            mensajeError = xhr.responseJSON.message;
                        } else if (xhr.status === 0) {
                            mensajeError = 'Error de red - verifique su conexión a internet';
                        } else if (xhr.status === 500) {
                            mensajeError = 'Error interno del servidor';
                        } else {
                            mensajeError += ': ' + error;
                        }

                        mostrarMensaje('error', mensajeError);
                        restaurarBoton(boton, textoOriginal);
                    }
                });
            }
        }

        // Función para enviar todas las evaluaciones
        function enviarTodasEvaluaciones() {
            const estudianteId = $('#estudianteId').val() || null;
            const rubricaId = $('#rubricaId').val() || null;
            const periodoId = $('#periodoId').val() || null;

            const evaluacionesCompletadas = $('button[data-evaluacion-id]:not([disabled])').length;

            if (evaluacionesCompletadas === 0) {
                mostrarMensaje('warning', 'No hay evaluaciones completadas para enviar con los filtros actuales.');
                return;
            }

            let mensaje = `¿Está seguro de enviar ${evaluacionesCompletadas} evaluación(es) completada(s)`;
            if (estudianteId || rubricaId || periodoId) {
                mensaje += ' que coincidan con los filtros aplicados';
            }
            mensaje += '?\n\nEste proceso puede tomar unos minutos.';

            if (confirm(mensaje)) {
                const boton = $('#btnEnviarTodas');
                const textoOriginal = boton.html();
                boton.html('<i class="fas fa-spinner fa-spin"></i> Enviando...');
                boton.prop('disabled', true);

                $.ajax({
                    url: '@Url.Action("EnviarTodasEvaluaciones", "Evaluaciones")',
                    type: 'POST',
                    data: {
                        estudianteId: estudianteId,
                        rubricaId: rubricaId,
                        periodoId: periodoId,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function (response) {
                        if (response.success) {
                            mostrarMensaje('success', response.message);

                            if (response.detalles && response.detalles.errores && response.detalles.errores.length > 0) {
                                let detalleErrores = '<div class="mt-3"><strong>Detalles de errores:</strong><ul class="mb-0">';
                                response.detalles.errores.forEach(function (error) {
                                    detalleErrores += '<li>' + error + '</li>';
                                });
                                detalleErrores += '</ul></div>';
                                mostrarMensaje('warning', 'Proceso completado con algunos errores:' + detalleErrores, false);
                            }

                            marcarTodosComoEnviados();

                            setTimeout(function () {
                                if (confirm('El envío ha sido completado. ¿Desea recargar la página para ver el estado actualizado?')) {
                                    location.reload();
                                }
                            }, 3000);
                        } else {
                            mostrarMensaje('error', response.message || 'Error desconocido al enviar las evaluaciones');
                        }

                        boton.html(textoOriginal);
                        boton.prop('disabled', false);
                    },
                    error: function (xhr, status, error) {
                        let mensajeError = 'Error de conexión';
                        if (xhr.responseJSON && xhr.responseJSON.message) {
                            mensajeError = xhr.responseJSON.message;
                        } else if (xhr.status === 0) {
                            mensajeError = 'Error de red - verifique su conexión a internet';
                        } else if (xhr.status === 500) {
                            mensajeError = 'Error interno del servidor';
                        } else if (xhr.status === 413) {
                            mensajeError = 'Error: demasiadas evaluaciones para procesar de una vez';
                        } else {
                            mensajeError += ': ' + error;
                        }

                        mostrarMensaje('error', mensajeError);
                        boton.html(textoOriginal);
                        boton.prop('disabled', false);
                    }
                });
            }
        }

        // Funciones auxiliares
        function mostrarMensaje(tipo, mensaje, autoOcultar = true) {
            $('.mensaje-temporal').remove();

            let claseAlerta = '';
            let icono = '';

            switch (tipo) {
                case 'success':
                    claseAlerta = 'alert-success';
                    icono = 'fas fa-check-circle';
                    break;
                case 'error':
                    claseAlerta = 'alert-danger';
                    icono = 'fas fa-exclamation-circle';
                    break;
                case 'warning':
                    claseAlerta = 'alert-warning';
                    icono = 'fas fa-exclamation-triangle';
                    break;
                default:
                    claseAlerta = 'alert-info';
                    icono = 'fas fa-info-circle';
            }

            const alerta = `
                            <div class="alert ${claseAlerta} alert-dismissible mensaje-temporal" role="alert">
                                <i class="${icono}"></i> ${mensaje}
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        `;

            $('h1').after(alerta);
            $('html, body').animate({ scrollTop: 0 }, 500);

            if (autoOcultar && tipo !== 'error') {
                setTimeout(function () {
                    $('.mensaje-temporal').fadeOut();
                }, 8000);
            }
        }

        function restaurarBoton(boton, textoOriginal) {
            boton.innerHTML = textoOriginal;
            boton.disabled = false;
            boton.classList.remove('btn-warning', 'btn-outline-success');
            boton.classList.add('btn-success');
        }

        function marcarTodosComoEnviados() {
            $('button[data-evaluacion-id]:not([disabled])').each(function () {
                const boton = $(this)[0];
                boton.innerHTML = '<i class="fas fa-check"></i>';
                boton.classList.remove('btn-warning', 'btn-success');
                boton.classList.add('btn-outline-success');
                boton.title = 'Evaluación enviada exitosamente';
                boton.disabled = true;

                const fila = boton.closest('tr');
                if (fila) {
                    fila.classList.add('evaluacion-enviada');
                }
            });
        }

        // Hacer las funciones globales
        window.enviarEvaluacion = enviarEvaluacion;
        window.enviarTodasEvaluaciones = enviarTodasEvaluaciones;
    </script>
}
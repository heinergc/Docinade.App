@model DocinadeApp.Models.Evaluacion

@{
    ViewData["Title"] = "Detalles de Evaluación";
}

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header bg-info text-white">
                <h4 class="mb-0">
                    <i class="fas fa-eye"></i> Detalles de Evaluación
                </h4>
            </div>
            <div class="card-body">
                <!-- Información general -->
                <div class="row mb-4">
                    <div class="col-md-6">
                        <div class="card bg-light">
                            <div class="card-header">
                                <h6 class="mb-0"><i class="fas fa-user"></i> Información del Estudiante</h6>
                            </div>
                            <div class="card-body">
                                <dl class="row mb-0">
                                    <dt class="col-sm-4">Nombre:</dt>
                                    <dd class="col-sm-8">@Model.Estudiante.Apellidos, @Model.Estudiante.Nombre</dd>

                                    <dt class="col-sm-4">ID:</dt>
                                    <dd class="col-sm-8">@Model.Estudiante.NumeroId</dd>

                                    <dt class="col-sm-4">Período:</dt>
                                    <dd class="col-sm-8">@(Model.Estudiante.PeriodoAcademico != null ? $"{Model.Estudiante.PeriodoAcademico.Anio} - {Model.Estudiante.PeriodoAcademico.Ciclo}" : "Sin período")</dd>

                                    <dt class="col-sm-4">Correo:</dt>
                                    <dd class="col-sm-8">@Model.Estudiante.DireccionCorreo</dd>
                                </dl>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card bg-light">
                            <div class="card-header">
                                <h6 class="mb-0"><i class="fas fa-clipboard-list"></i> Información de la Evaluación</h6>
                            </div>
                            <div class="card-body">
                                <dl class="row mb-0">
                                    <dt class="col-sm-4">Rúbrica:</dt>
                                    <dd class="col-sm-8">
                                        <span class="badge bg-primary">@Model.Rubrica.Titulo</span>
                                    </dd>

                                    <dt class="col-sm-4">Estado:</dt>
                                    <dd class="col-sm-8">
                                        @{
                                            var estado = string.IsNullOrEmpty(Model.Estado) ? "COMPLETADA" : Model.Estado;
                                            var badgeClass = estado == "BORRADOR" ? "bg-warning text-dark" : "bg-success";
                                            var iconClass = estado == "BORRADOR" ? "fas fa-edit" : "fas fa-check-circle";
                                        }
                                        <span class="badge @badgeClass">
                                            <i class="@iconClass"></i> @estado
                                        </span>
                                        @if (estado == "BORRADOR")
                                        {
                                            <small class="text-muted d-block">Esta evaluación puede continuar siendo editada</small>
                                        }
                                    </dd>

                                    <dt class="col-sm-4">Fecha:</dt>
                                    <dd class="col-sm-8">@Model.FechaEvaluacion.ToString("dd/MM/yyyy HH:mm")</dd>

                                    <dt class="col-sm-4">Total Puntos:</dt>
                                    <dd class="col-sm-8">
                                        @if (Model.TotalPuntos.HasValue)
                                        {
                                            <span class="badge bg-success fs-6">@Model.TotalPuntos.Value.ToString("F2") puntos</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning">Sin calcular</span>
                                        }
                                    </dd>

                                    <dt class="col-sm-4">Items:</dt>
                                    <dd class="col-sm-8">@Model.DetallesEvaluacion.Count items evaluados</dd>
                                </dl>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Observaciones -->
               @*  @if (!string.IsNullOrEmpty(Model.Observaciones))
                {
                    <div class="alert alert-info">
                        <h6><i class="fas fa-comment"></i> Observaciones</h6>
                        <p class="mb-0">@Model.Observaciones</p>
                    </div>
                } *@
                   @if (!string.IsNullOrEmpty(Model.Observaciones))
                {
                <div class="card">
                        <div class="card-header">
                        <h5 class="mb-0"><i class="fas fa-list-alt"></i> Observaciones</h5>
                    </div>
                    <div class="card-body">
                            <p class="mb-0">Retroalimentación: @Html.Raw(Model.Observaciones)</p>
                    </div>
                </div>
                }
                <br />
                <!-- Detalles de la evaluación -->
                <div class="card">
                    <div class="card-header bg-dark text-white">
                        <h5 class="mb-0"><i class="fas fa-list-alt"></i> Detalles de la Evaluación</h5>
                    </div>
                    <div class="card-body">
                        @if (Model.DetallesEvaluacion.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-striped table-hover">
                                    <thead class="table-dark">
                                        <tr>
                                            <th>Item de Evaluación</th>
                                            <th>Nivel Obtenido</th>
                                            <th>Puntos</th>
                                            <th>Descripción del Nivel</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var detalle in Model.DetallesEvaluacion.OrderBy(d => d.ItemEvaluacion.Orden))
                                        {
                                            <tr>
                                                <td>
                                                    <strong>@detalle.ItemEvaluacion.NombreItem</strong>
                                                    <br>
                                                    <small class="text-muted">Peso: @detalle.ItemEvaluacion.Peso%</small>
                                                </td>
                                                <td>
                                                    <span class="badge bg-info">
                                                        @detalle.NivelCalificacion.NombreNivel
                                                    </span>
                                                </td>
                                                <td>
                                                    <span class="badge bg-success fs-6">
                                                        @detalle.PuntosObtenidos.ToString("F2")
                                                    </span>
                                                </td>
                                                <td>
                                                    <small>@detalle.NivelCalificacion.Descripcion</small>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                    <tfoot class="table-dark">
                                        <tr>
                                            <th colspan="2">TOTAL</th>
                                            <th>
                                                @if (Model.TotalPuntos.HasValue)
                                                {
                                                    <span class="badge bg-success fs-6">@Model.TotalPuntos.Value.ToString("F2")</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-warning">0.00</span>
                                                }
                                            </th>
                                            <th></th>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-4">
                                <i class="fas fa-exclamation-triangle fa-2x text-warning mb-3"></i>
                                <h6 class="text-muted">No hay detalles de evaluación</h6>
                                <p class="text-muted">Esta evaluación no tiene items evaluados.</p>
                            </div>
                        }
                    </div>
                </div>

                <!-- Botones de acción -->
                <div class="mt-4">
                    <a asp-action="Edit" asp-route-id="@Model.IdEvaluacion" class="btn btn-warning">
                        <i class="fas fa-edit"></i> Editar
                    </a>
                    <a asp-action="Delete" asp-route-id="@Model.IdEvaluacion" class="btn btn-danger">
                        <i class="fas fa-trash"></i> Eliminar
                    </a>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Volver a la Lista
                    </a>

                    <!-- Botón para imprimir -->
                    <button onclick="window.print()" class="btn btn-outline-primary">
                        <i class="fas fa-print"></i> Imprimir
                    </button>

                    <!-- Botón para crear nueva evaluación con el mismo estudiante -->
                    <a asp-action="Create" asp-route-estudianteId="@Model.IdEstudiante" class="btn btn-success">
                        <i class="fas fa-plus"></i> Nueva Evaluación para este Estudiante
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        @@media print {
            .btn, .card-header {
                display: none !important;
            }

            .card {
                border: none !important;
                box-shadow: none !important;
            }
        }
    </style>

    <script>

         $(document).ready(function() {
            tinymce.init({
                selector: '#Observaciones',
                
                // Plugins recomendados para observaciones educativas
                plugins: [
                    'lists', 'link', 'autolink', 'charmap', 
                    'fullscreen', 'wordcount', 'emoticons', 
                    'insertdatetime', 'table', 'searchreplace'
                ],
                
                // Barra de herramientas optimizada
                toolbar: 'undo redo | formatselect | bold italic underline | ' +
                         'forecolor | alignleft aligncenter alignright | ' +
                         'bullist numlist | outdent indent | ' +
                         'table link emoticons | fullscreen',
                
                // Formatos de bloque
                block_formats: 'Párrafo=p; Título 1=h3; Título 2=h4',
                
                // Tamaños de fuente
                fontsize_formats: '10pt 12pt 14pt 16pt 18pt',
                
                // Idioma español
                language: 'es',
                
                // Apariencia
                menubar: false,
                branding: false,
                height: 250,
                resize: true,
                statusbar: true,
                
                // Placeholder
                placeholder: 'Observaciones sobre el desempeño del estudiante...',
                
                // Corrector ortográfico
                browser_spellcheck: true,
                
                // Pegado limpio
                paste_as_text: false,
                
                // Seguridad
                valid_elements: 'p,br,strong,em,u,h3,h4,ul,ol,li,a[href],table,tr,td,th,span[style]',
                
                setup: function(editor) {
                    editor.on('init', function() {
                        // Obtén el valor desde Razor
                        var contenido = '@(Model.Observaciones ?? "").Replace("'", "\\'").Replace("\r\n", "\\n").Replace("\n", "\\n")';
                        if (contenido.trim().length > 0) {
                            editor.setContent(contenido);
                        }
                    });
                }
            });
        });

    </script>
}
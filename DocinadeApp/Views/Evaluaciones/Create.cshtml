@model DocinadeApp.ViewModels.CrearEvaluacionViewModel

@{
    ViewData["Title"] = "Nueva Evaluación";
}

<!-- Page Header moderno con framework CSS genérico -->
<div class="header-section">
    <div class="row">
        <div class="col-12">
            <div class="header-title">
                <h1 class="page-title">
                    <i class="fas fa-plus text-success me-2"></i>
                    Nueva Evaluación
                </h1>
                <p class="header-subtitle">Crear una nueva evaluación para un estudiante específico</p>
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col-12">
            <div class="card-body p-3">
                <div class="d-flex justify-content-end">
                    <a href="@Url.Action("Index")" class="btn btn-secondary">
                        <i class="fas fa-arrow-left me-1"></i>
                        <span class="btn-text">Volver a Lista</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card-modern">
            <div class="card-header">
                <h4 class="card-title mb-0">
                    <i class="fas fa-clipboard-check me-2"></i>
                    Formulario de Evaluación
                </h4>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post" id="formEvaluacion">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <!-- Información básica mejorada -->
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="IdEstudiante" class="form-label">
                                    <i class="fas fa-user me-1"></i>
                                    Estudiante
                                </label>
                                <div class="input-group">
                                    <select asp-for="IdEstudiante" class="form-control" id="selectEstudiante">
                                        <option value="">-- Seleccionar estudiante --</option>
                                        @{
                                            var estudiantes = ViewBag.Estudiantes as List<SelectListItem>;
                                        }
                                        @if (estudiantes != null)
                                        {
                                            foreach (var estudiante in estudiantes)
                                            {
                                                <option value="@estudiante.Value"
                                                    selected="@(estudiante.Value == Model.IdEstudiante.ToString())">
                                                    @estudiante.Text
                                                </option>
                                            }
                                        }
                                    </select>
                                    <button type="button" class="btn btn-outline-primary" data-bs-toggle="modal"
                                        data-bs-target="#modalBuscadorEstudianteCreate" title="Buscar estudiante">
                                        <i class="fas fa-search"></i>
                                    </button>
                                </div>
                                <span asp-validation-for="IdEstudiante" class="invalid-feedback"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="IdRubrica" class="form-label">
                                    <i class="fas fa-clipboard-list me-1"></i>
                                    Rúbrica
                                </label>
                                <div class="input-group">
                                    <select asp-for="IdRubrica" class="form-control" id="selectRubrica">
                                        <option value="">-- Seleccionar rúbrica --</option>
                                        @{
                                            var rubricasDesc = ViewBag.RubricasDescripciones as Dictionary<int, string>;
                                        }
                                        @if (ViewBag.Rubricas is List<SelectListItem> rubricas)
                                        {
                                            @foreach (var rubrica in rubricas)
                                            {
                                                var idRubrica = int.Parse(rubrica.Value);
                                                var desc = rubricasDesc != null && rubricasDesc.ContainsKey(idRubrica) ? rubricasDesc[idRubrica] : null;
                                                <option value="@rubrica.Value"
                                                    selected="@(rubrica.Value == Model.IdRubrica.ToString())"
                                                    data-descripcion="@desc">
                                                    @rubrica.Text
                                                </option>
                                            }
                                        }
                                    </select>
                                    <button type="button" class="btn btn-outline-info" id="btnVerDescripcionRubrica"
                                        style="display:none;" title="Ver descripción de la rúbrica"
                                        data-bs-toggle="modal" data-bs-target="#modalDescripcionRubrica">
                                        <i class="fas fa-info-circle"></i>
                                    </button>
                                </div>
                                <span asp-validation-for="IdRubrica" class="invalid-feedback"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="FechaEvaluacion" class="form-label">
                                    <i class="fas fa-calendar me-1"></i>
                                    Fecha de Evaluación
                                </label>
                                <input asp-for="FechaEvaluacion" type="datetime-local" class="form-control" />
                                <span asp-validation-for="FechaEvaluacion" class="invalid-feedback"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Observaciones" class="form-label">
                                    <i class="fas fa-comment me-1"></i>
                                    Observaciones (Opcional)
                                </label>
                                <textarea asp-for="Observaciones" class="form-control" rows="2"
                                    maxlength="3000"
                                    placeholder="Observaciones generales sobre la evaluación"></textarea>
                                <span asp-validation-for="Observaciones" class="invalid-feedback"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Sección de evaluación de items con diseño moderno -->
                    <div id="seccionEvaluacion" style="display: none;" class="mt-4">
                        <div class="card-modern">
                            <div class="card-header">
                                <h5 class="card-title mb-0">
                                    <i class="fas fa-tasks me-2"></i>
                                    Evaluación de Criterios
                                </h5>
                            </div>
                            <div class="card-body p-0">
                                <div class="table-container">
                                    <div id="itemsEvaluacion">
                                        <!-- Los items se cargarán aquí dinámicamente -->
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Resumen de puntuación mejorado -->
                        <div class="card-modern mt-3" id="resumenPuntuacion" style="display: none;">
                            <div class="card-header">
                                <h6 class="card-title mb-0">
                                    <i class="fas fa-calculator me-2"></i>
                                    Resumen de Puntuación
                                </h6>
                            </div>
                            <div class="card-body">
                                <div id="detallesPuntuacion" class="mb-3"></div>
                                <div class="d-flex justify-content-between align-items-center p-3 bg-light rounded">
                                    <strong class="fs-5">Total Obtenido:</strong>
                                    <span class="badge badge-primary fs-5 px-3 py-2">
                                        <span id="totalPuntos">0</span> puntos
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Botones de acción mejorados -->
                    <div class="d-flex justify-content-between align-items-center mt-4 pt-3 border-top">
                        <div class="btn-group-modern">
                            <button type="submit" name="submitAction" value="guardarBorrador" class="btn btn-warning"
                                id="btnGuardarBorrador">
                                <i class="fas fa-save me-1"></i>
                                Guardar como Borrador
                            </button>
                            <button type="submit" name="submitAction" value="guardarCompleta" class="btn btn-success"
                                id="btnGuardar" disabled>
                                <i class="fas fa-check-circle me-1"></i>
                                Completar Evaluación
                            </button>
                        </div>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="fas fa-times me-1"></i>
                            Cancelar
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Descripción de la Rúbrica -->
<div class="modal fade" id="modalDescripcionRubrica" tabindex="-1" aria-labelledby="modalDescripcionRubricaLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalDescripcionRubricaLabel">
                    <i class="fas fa-info-circle me-2"></i>
                    <span id="modalDescripcionRubricaNombre"></span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <p id="modalDescripcionRubricaTexto" class="mb-0"></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Descripción del Item de la Rúbrica -->
<div class="modal fade" id="modalDescripcionItem" tabindex="-1" aria-labelledby="modalDescripcionItemLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalDescripcionItemLabel">
                    <i class="fas fa-info-circle me-2"></i>
                    <span id="modalDescripcionItemNombre"></span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <p id="modalDescripcionItemTexto" class="mb-0"></p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

<!-- Componente BuscadorEstudiante -->
@await Component.InvokeAsync("BuscadorEstudiante", new {
modalId = "modalBuscadorEstudianteCreate",
selectId = "selectEstudiante",
controllerName = "Test",
actionName = "BuscarEstudiantes",
titulo = "Buscar Estudiante para Evaluación",
placeholder = "Escriba nombre, apellido o número de identificación...",
incluirScripts = true
})

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // Diccionario de descripciones de rúbricas (generado en servidor)
        var rubricasDescripcionesMap = @Html.Raw(
            System.Text.Json.JsonSerializer.Serialize(
                (ViewBag.RubricasDescripciones is Dictionary<int, string> dm) ? dm : new Dictionary<int, string>()
            )
        );

        $(document).ready(function () {
            console.log('Iniciando aplicacion de evaluaciones...');

            // Inicializar TinyMCE solo si existe el elemento
            if ($('#Observaciones').length > 0) {
                tinymce.init({
                    selector: '#Observaciones',
                    
                    // Plugins recomendados para observaciones educativas
                    plugins: [
                        'lists', 'link', 'autolink', 'charmap', 
                        'fullscreen', 'wordcount', 'emoticons', 
                        'insertdatetime', 'table', 'searchreplace'
                    ],
                    
                    // Barra de herramientas optimizada
                    toolbar: 'undo redo | formatselect | bold italic underline | ' +
                             'forecolor | alignleft aligncenter alignright | ' +
                             'bullist numlist | outdent indent | ' +
                             'table link emoticons | fullscreen',
                    
                    // Formatos de bloque
                    block_formats: 'Párrafo=p; Título 1=h3; Título 2=h4',
                    
                    // Tamaños de fuente
                    fontsize_formats: '10pt 12pt 14pt 16pt 18pt',
                    
                    // Idioma español
                    language: 'es',
                    
                    // Apariencia
                    menubar: false,
                    branding: false,
                    height: 250,
                    resize: true,
                    statusbar: true,
                    
                    // Placeholder
                    placeholder: 'Observaciones sobre el desempeño del estudiante...',
                    
                    // Corrector ortográfico
                    browser_spellcheck: true,
                    
                    // Pegado limpio
                    paste_as_text: false,
                    
                    // Seguridad
                    valid_elements: 'p,br,strong,em,u,h3,h4,ul,ol,li,a[href],table,tr,td,th,span[style]'
                });
            }

            // Variables globales para almacenar datos
            window.itemsRubrica = [];
            window.nivelesRubrica = [];

            console.log('📋 Variables inicializadas');

            // Muestra/oculta el boton de descripcion segun la rubrica seleccionada
            function actualizarBotonDescripcion() {
                var rubricaId = $('#selectRubrica').val();
                var opcionSeleccionada = $('#selectRubrica option:selected');
                // Primero buscar en el mapa JS, luego en el atributo DOM como respaldo
                var descripcion = rubricasDescripcionesMap[rubricaId] ||
                                  opcionSeleccionada.attr('data-descripcion') || '';
                if (descripcion && descripcion.trim() !== '') {
                    $('#btnVerDescripcionRubrica').show();
                    $('#modalDescripcionRubricaNombre').text(opcionSeleccionada.text());
                    $('#modalDescripcionRubricaTexto').text(descripcion);
                } else {
                    $('#btnVerDescripcionRubrica').hide();
                }
            }

            // Cargar items cuando se selecciona una rúbrica
            $('#selectRubrica').on('change', function () {
                var rubricaId = $(this).val();
                console.log('Rubrica seleccionada:', rubricaId);

                actualizarBotonDescripcion();

                if (rubricaId) {
                    cargarItemsRubrica(rubricaId);
                } else {
                    $('#seccionEvaluacion').hide();
                    $('#btnGuardar').prop('disabled', true);
                    $('#resumenPuntuacion').hide();
                    // Limpiar arrays
                    window.itemsRubrica = [];
                    window.nivelesRubrica = [];
                }
            });

            // Rellenar modal de descripción del item al hacer click en el botón
            $(document).on('click', '.btn-descripcion-item', function () {
                var nombre = $(this).data('nombre');
                var descripcionItem = $(this).data('descripcion');
                $('#modalDescripcionItemNombre').text(nombre);
                $('#modalDescripcionItemTexto').text(descripcionItem);
            });

            // Verificar validación cuando cambian los niveles
            $(document).on('change', '.nivel-select', function () {
                verificarValidacion();
                calcularPuntuacion();
            });

            // Verificar validación cuando cambia el estudiante
            $('#selectEstudiante').on('change', function () {
                verificarValidacion();
            });

            // Si hay una rúbrica preseleccionada, cargar sus items
            var rubricaPreseleccionada = $('#selectRubrica').val();
            if (rubricaPreseleccionada) {
                console.log('Cargando rubrica preseleccionada:', rubricaPreseleccionada);
                actualizarBotonDescripcion();
                cargarItemsRubrica(rubricaPreseleccionada);
            }

            function cargarItemsRubrica(rubricaId) {
                console.log('🔄 Cargando items para rúbrica ID:', rubricaId);

                // Reinicializar arrays
                window.itemsRubrica = [];
                window.nivelesRubrica = [];

                $.ajax({
                    url: '@Url.Action("ObtenerItemsPorRubrica", "Evaluaciones")',
                    type: 'GET',
                    data: { rubricaId: rubricaId },
                    dataType: 'json',
                    beforeSend: function () {
                        console.log('📡 Enviando petición AJAX...');
                        $('#itemsEvaluacion').html(
                            '<div class="text-center p-5">' +
                            '<div class="spinner-border text-primary mb-3" role="status">' +
                            '<span class="visually-hidden">Cargando...</span>' +
                            '</div>' +
                            '<h6 class="text-muted">Cargando criterios de evaluación...</h6>' +
                            '</div>'
                        );
                        $('#seccionEvaluacion').show();
                        $('#btnGuardar').prop('disabled', true);
                    },
                    success: function (response) {
                        console.log('✅ Respuesta del servidor recibida:', response);

                        // Validar que la respuesta sea válida
                        if (!response) {
                            console.error('❌ Respuesta vacía del servidor');
                            mostrarError('Error: Respuesta vacía del servidor');
                            return;
                        }

                        if (response.error) {
                            console.error('❌ Error en la respuesta:', response.error);
                            mostrarError('Error: ' + response.error);
                            return;
                        }

                        // Validar que existan las propiedades esperadas
                        if (!response.hasOwnProperty('items') || !response.hasOwnProperty('niveles')) {
                            console.error('❌ Estructura de respuesta inválida:', response);
                            mostrarError('Error: Estructura de respuesta inválida');
                            return;
                        }

                        console.log('📋 Items recibidos:', response.items);
                        console.log('🎯 Niveles recibidos:', response.niveles);

                        // Asegurar que sean arrays válidos
                        window.itemsRubrica = Array.isArray(response.items) ? response.items : [];
                        window.nivelesRubrica = Array.isArray(response.niveles) ? response.niveles : [];

                        console.log('📊 Items almacenados localmente:', window.itemsRubrica.length);
                        console.log('🎚️ Niveles almacenados localmente:', window.nivelesRubrica.length);

                        if (window.itemsRubrica.length === 0) {
                            mostrarAdvertencia('Esta rúbrica no tiene items de evaluación configurados.');
                        } else {
                            generarFormularioEvaluacion();
                            verificarValidacion();
                        }
                    },
                    error: function (xhr, status, error) {
                        console.error('❌ Error AJAX:', {
                            status: status,
                            error: error,
                            responseText: xhr.responseText,
                            xhr: xhr
                        });

                        // Reinicializar arrays en caso de error
                        window.itemsRubrica = [];
                        window.nivelesRubrica = [];

                        var mensajeError = 'Error al cargar los items de la rúbrica';
                        if (xhr.responseText) {
                            try {
                                var errorResponse = JSON.parse(xhr.responseText);
                                if (errorResponse.message) {
                                    mensajeError += ': ' + errorResponse.message;
                                }
                            } catch (e) {
                                mensajeError += ': ' + error;
                            }
                        } else {
                            mensajeError += ': ' + error;
                        }

                        mostrarError(mensajeError);
                    }
                });
            }

            function generarFormularioEvaluacion() {
                console.log('🎨 Iniciando generación del formulario...');
                console.log('📁 Items disponibles:', window.itemsRubrica.length);
                console.log('🎆 Niveles disponibles:', window.nivelesRubrica.length);

                var html = '';

                if (!Array.isArray(window.itemsRubrica) || window.itemsRubrica.length === 0) {
                    console.warn('⚠️ No hay items en la rúbrica');
                    mostrarAdvertencia('Esta rúbrica no tiene items de evaluación configurados.');
                    return;
                }

                console.log('📝 Generando tabla moderna con', window.itemsRubrica.length, 'items');

                // Aplicar framework CSS moderno
                html = '<div class="table-content">';
                html += '<table class="table-modern">';
                html += '<thead>';
                html += '<tr>';
                html += '<th style="width: 33%"><i class="fas fa-list me-2"></i>Criterio de Evaluación</th>';
                html += '<th style="width: 7%" class="text-center"></th>';
                html += '<th style="width: 11%" class="text-center"><i class="fas fa-weight me-2"></i>Peso</th>';
                html += '<th style="width: 32%"><i class="fas fa-star me-2"></i>Nivel de Calificación</th>';
                html += '<th style="width: 17%" class="text-center"><i class="fas fa-trophy me-2"></i>Puntos</th>';
                html += '</tr>';
                html += '</thead>';
                html += '<tbody>';

                window.itemsRubrica.forEach(function (item, index) {
                    if (!item || typeof item !== 'object') {
                        console.warn('⚠️ Item inválido en índice', index, ':', item);
                        return;
                    }

                    console.log(`🔍 Procesando item ${index + 1}:`, item);

                    // Manejar propiedades con diferentes casos (camelCase vs PascalCase)
                    var itemId = item.idItem || item.IdItem;
                    var descripcion = item.nombreItem || item.NombreItem || 'Sin descripción';
                    var itemDescripcionDetalle = item.descripcion || item.Descripcion || '';
                    var peso = item.peso || item.Peso || 0;

                    var nivelesItem = window.nivelesRubrica.filter(function (n) {
                        var nivelItemId = n.idItem || n.IdItem;
                        return nivelItemId === itemId;
                    });

                    console.log(`  - Niveles para este item (${nivelesItem.length}):`, nivelesItem);

                    html += '<tr>';

                    // Columna de descripción con diseño mejorado
                    html += '<td>';
                    html += '<div class="d-flex align-items-start">';
                    html += '<div class="me-2 mt-1">';
                    html += '<div class="badge badge-primary rounded-circle" style="width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; font-size: 0.75rem;">' + (index + 1) + '</div>';
                    html += '</div>';
                    html += '<div>';
                    html += '<div class="fw-semibold">' + descripcion + '</div>';
                    html += '<small class="text-muted">Criterio ' + (index + 1) + ' de evaluación</small>';
                    html += '</div>';
                    html += '</div>';
                    html += '</td>';

                    // Columna del botón de descripción del item
                    html += '<td class="text-center">';
                    if (itemDescripcionDetalle && itemDescripcionDetalle.trim() !== '') {
                        html += '<button type="button" class="btn btn-sm btn-outline-info btn-descripcion-item" ' +
                                'title="Ver descripción del criterio" ' +
                                'data-nombre="' + descripcion.replace(/"/g, '&quot;') + '" ' +
                                'data-descripcion="' + itemDescripcionDetalle.replace(/"/g, '&quot;') + '" ' +
                                'data-bs-toggle="modal" data-bs-target="#modalDescripcionItem">' +
                                '<i class="fas fa-info-circle"></i>' +
                                '</button>';
                    }
                    html += '</td>';

                    // Columna de peso con badge
                    html += '<td class="text-center">';
                    html += '<span class="badge badge-secondary fs-6">' + peso + '%</span>';
                    html += '</td>';

                    // Columna de selección de nivel con diseño mejorado
                    html += '<td>';
                    html += '<select name="DetallesEvaluacion[' + index + '].IdNivel" class="form-control nivel-select" data-item-id="' + itemId + '">';
                    html += '<option value="0">-- Seleccionar nivel de desempeño --</option>';

                    nivelesItem.forEach(function (nivel) {
                        var nivelId = nivel.idNivel || nivel.IdNivel;
                        var nombreNivel = nivel.nombreNivel || nivel.NombreNivel || 'Sin nombre';
                        var valor = nivel.valor || nivel.Valor || 0;

                        console.log('    * Agregando nivel:', {
                            IdNivel: nivelId,
                            NombreNivel: nombreNivel,
                            Valor: valor
                        });
                        html += '<option value="' + nivelId + '" data-valor="' + valor + '">' + nombreNivel + ' (' + valor + ' pts)</option>';
                    });

                    html += '</select>';
                    html += '<input type="hidden" name="DetallesEvaluacion[' + index + '].IdItem" value="' + itemId + '" />';
                    html += '</td>';

                    // Columna de puntos con badge dinámico
                    html += '<td class="text-center">';
                    html += '<span class="puntos-item badge badge-info fs-5 px-3 py-2" data-item-id="' + itemId + '" style="min-width: 70px;">0 pts</span>';
                    html += '</td>';

                    html += '</tr>';
                });

                html += '</tbody>';
                html += '</table>';
                html += '</div>';

                console.log('🎉 HTML moderno generado exitosamente');
                $('#itemsEvaluacion').html(html);
                console.log('✅ Formulario moderno insertado en el DOM');
            }

            function verificarValidacion() {
                var todosCompletos = true;
                var estudiante = $('#selectEstudiante').val();
                var rubrica = $('#selectRubrica').val();

                if (!estudiante || !rubrica) {
                    todosCompletos = false;
                }

                $('.nivel-select').each(function () {
                    if (!$(this).val()) {
                        todosCompletos = false;
                    }
                });

                $('#btnGuardar').prop('disabled', !todosCompletos);
                $('#btnGuardarBorrador').prop('disabled', !estudiante || !rubrica);

                if (todosCompletos && Array.isArray(window.itemsRubrica) && window.itemsRubrica.length > 0) {
                    $('#resumenPuntuacion').show();
                } else {
                    $('#resumenPuntuacion').hide();
                }
            }

            function calcularPuntuacion() {
                var totalPuntos = 0;
                var detalles = [];

                $('.nivel-select').each(function () {
                    var select = $(this);
                    var itemId = select.data('item-id');
                    var opcionSeleccionada = select.find('option:selected');
                    var valor = parseFloat(opcionSeleccionada.data('valor') || 0);
                    var nombreNivel = opcionSeleccionada.text();

                    // Actualizar puntos del item con formato mejorado
                    var puntosTexto = valor > 0 ? valor.toFixed(2) + ' pts' : '0 pts';
                    $('.puntos-item[data-item-id="' + itemId + '"]').text(puntosTexto);

                    if (valor > 0) {
                        totalPuntos += valor;

                        // Buscar el item correspondiente
                        var item = null;
                        if (Array.isArray(window.itemsRubrica)) {
                            item = window.itemsRubrica.find(function (i) {
                                var iId = i.idItem || i.IdItem;
                                return iId === itemId;
                            });
                        }

                        if (item) {
                            var descripcion = item.nombreItem || item.NombreItem || 'Sin descripción';
                            detalles.push({
                                descripcion: descripcion,
                                nivel: nombreNivel,
                                puntos: valor
                            });
                        }
                    }
                });

                $('#totalPuntos').text(totalPuntos.toFixed(2));

                // Mostrar detalles con diseño mejorado
                var htmlDetalles = '';
                if (detalles.length > 0) {
                    htmlDetalles += '<div class="row fw-semibold text-muted border-bottom pb-2 mb-2">';
                    htmlDetalles += '<div class="col-6">Criterio</div>';
                    htmlDetalles += '<div class="col-3">Nivel</div>';
                    htmlDetalles += '<div class="col-3 text-end">Puntos</div>';
                    htmlDetalles += '</div>';

                    detalles.forEach(function (detalle, index) {
                        htmlDetalles += '<div class="row mb-2 align-items-center">';
                        htmlDetalles += '<div class="col-6">';
                        htmlDetalles += '<div class="d-flex align-items-center">';
                        htmlDetalles += '<span class="badge badge-primary rounded-circle me-2" style="width: 20px; height: 20px; font-size: 0.7rem;">' + (index + 1) + '</span>';
                        htmlDetalles += '<span class="small">' + detalle.descripcion + '</span>';
                        htmlDetalles += '</div>';
                        htmlDetalles += '</div>';
                        htmlDetalles += '<div class="col-3">';
                        htmlDetalles += '<span class="badge badge-secondary small">' + detalle.nivel.split('(')[0].trim() + '</span>';
                        htmlDetalles += '</div>';
                        htmlDetalles += '<div class="col-3 text-end">';
                        htmlDetalles += '<span class="badge badge-success">' + detalle.puntos.toFixed(2) + ' pts</span>';
                        htmlDetalles += '</div>';
                        htmlDetalles += '</div>';
                    });
                } else {
                    htmlDetalles = '<div class="text-center text-muted py-3">';
                    htmlDetalles += '<i class="fas fa-info-circle me-2"></i>';
                    htmlDetalles += 'Seleccione los niveles de calificación para ver el desglose de puntos';
                    htmlDetalles += '</div>';
                }

                $('#detallesPuntuacion').html(htmlDetalles);
            }

            // Funciones auxiliares para mostrar mensajes con diseño mejorado
            function mostrarError(mensaje) {
                $('#itemsEvaluacion').html(
                    '<div class="empty-state">' +
                    '<div class="empty-state-icon text-danger">' +
                    '<i class="fas fa-exclamation-circle fa-3x"></i>' +
                    '</div>' +
                    '<div class="empty-state-content">' +
                    '<h5 class="empty-state-title text-danger">Error</h5>' +
                    '<p class="empty-state-text">' + mensaje + '</p>' +
                    '</div>' +
                    '</div>'
                );
            }

            function mostrarAdvertencia(mensaje) {
                $('#itemsEvaluacion').html(
                    '<div class="empty-state">' +
                    '<div class="empty-state-icon text-warning">' +
                    '<i class="fas fa-exclamation-triangle fa-3x"></i>' +
                    '</div>' +
                    '<div class="empty-state-content">' +
                    '<h5 class="empty-state-title text-warning">Atención</h5>' +
                    '<p class="empty-state-text">' + mensaje + '</p>' +
                    '</div>' +
                    '</div>'
                );
            }

            // Capturar qué botón de submit fue clickeado antes de que pierda el foco
            var submitActionCapturada = 'guardarCompleta';
            $('button[type="submit"]').on('click', function () {
                submitActionCapturada = $(this).val() || 'guardarCompleta';
            });

            // Validar formulario antes de enviar
            $('#formEvaluacion').submit(function (e) {
                var estudianteId = $('#selectEstudiante').val();
                var rubricaId = $('#selectRubrica').val();

                if (!estudianteId || !rubricaId) {
                    e.preventDefault();
                    alert('Debe seleccionar un estudiante y una rúbrica.');
                    return false;
                }

                var submitAction = submitActionCapturada;

                // Para borrador, no es necesario que todos los niveles estén seleccionados
                if (submitAction === 'guardarCompleta') {
                    var nivelesSinSeleccionar = $('.nivel-select').filter(function () {
                        return !$(this).val();
                    }).length;

                    if (nivelesSinSeleccionar > 0) {
                        e.preventDefault();
                        alert('Debe seleccionar un nivel de calificación para todos los criterios.');
                        return false;
                    }
                }

                // Deshabilitar botones para evitar doble envío
                var botonPresionado = $('button[type="submit"][value="' + submitActionCapturada + '"]');
                var textoOriginal = botonPresionado.html();

                botonPresionado.prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-1"></i>Guardando...');

                // Restaurar el botón después de 3 segundos por si hay error
                setTimeout(function () {
                    botonPresionado.prop('disabled', false).html(textoOriginal);
                }, 3000);

                return true;
            });

            // Función de depuración global
            window.debugEvaluacion = function () {
                console.log('🔧 DEBUG - Estado actual:');
                console.log('  📋 Items en memoria:', window.itemsRubrica);
                console.log('  🎆 Niveles en memoria:', window.nivelesRubrica);
                console.log('  🎯 Rúbrica seleccionada:', $('#selectRubrica').val());
                console.log('  👥 Estudiante seleccionado:', $('#selectEstudiante').val());
                console.log('  📝 Elementos .nivel-select encontrados:', $('.nivel-select').length);

                return {
                    items: window.itemsRubrica,
                    niveles: window.nivelesRubrica,
                    rubricaId: $('#selectRubrica').val(),
                    estudianteId: $('#selectEstudiante').val(),
                    url: '@Url.Action("ObtenerItemsPorRubrica", "Evaluaciones")'
                };
            };

            console.log('🛠️ Función de debug disponible: window.debugEvaluacion()');
        });
    </script>
}

@section Styles {
    <style>
        /* Estilos específicos para la vista de creación de evaluaciones */
        .nivel-select {
            transition: all 0.3s ease;
        }

        .nivel-select:focus {
            border-color: var(--color-primary);
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
        }

        .puntos-item {
            transition: all 0.3s ease;
            font-weight: 600;
        }

        .table-modern tbody tr:hover .puntos-item {
            transform: scale(1.05);
        }

        /* Animación para los badges de puntos */
        .puntos-item.updating {
            animation: pulse-success 0.6s ease-in-out;
        }

        @@keyframes pulse-success {
            0% {
                transform: scale(1);
            }

            50% {
                transform: scale(1.1);
                background-color: var(--color-success);
            }

            100% {
                transform: scale(1);
            }
        }

        /* Mejoras en el spinner de carga */
        .spinner-border {
            border-width: 3px;
        }

        /* Mejoras en responsive para la tabla */
        @@media (max-width: 768px) {

            .table-modern th:nth-child(2),
            .table-modern td:nth-child(2) {
                display: none;
            }

            .table-modern th:first-child,
            .table-modern td:first-child {
                width: 40%;
            }

            .table-modern th:nth-child(3),
            .table-modern td:nth-child(3) {
                width: 40%;
            }

            .table-modern th:last-child,
            .table-modern td:last-child {
                width: 20%;
            }
        }

        @@media (max-width: 576px) {
            .badge.rounded-circle {
                width: 18px !important;
                height: 18px !important;
                font-size: 0.65rem !important;
            }

            .puntos-item {
                font-size: 0.8rem !important;
                padding: 0.4rem 0.6rem !important;
            }
        }

        /* Estados de validación mejorados */
        .nivel-select.is-invalid {
            border-color: var(--color-danger);
            animation: shake 0.5s ease-in-out;
        }

        @@keyframes shake {

            0%,
            100% {
                transform: translateX(0);
            }

            25% {
                transform: translateX(-5px);
            }

            75% {
                transform: translateX(5px);
            }
        }

        /* Mejorar la apariencia del resumen de puntuación */
        #detallesPuntuacion .badge {
            font-size: 0.75rem;
        }

        .header-section {
            margin-bottom: 1.5rem;
        }
    </style>
}
@model DocinadeApp.ViewModels.ResumenAsistenciaViewModel

@{
    ViewData["Title"] = "Resumen de Asistencia";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4">
    <!-- Encabezado -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-6">
                <i class="fas fa-check-circle text-success"></i> 
                Asistencia Guardada
            </h1>
            <div class="text-muted">
                <strong>Grupo:</strong> @Model.Grupo.Nombre
                @if (!string.IsNullOrEmpty(Model.Grupo.Codigo))
                {
                    <span class="badge bg-secondary ms-2">@Model.Grupo.Codigo</span>
                }
            </div>
        </div>
        <div class="text-end">
            <div class="card border-0 bg-light">
                <div class="card-body p-3">
                    <h6 class="card-title mb-1">
                        <i class="fas fa-calendar-day text-info"></i> 
                        Fecha Registrada
                    </h6>
                    <p class="card-text h5 mb-0 text-primary">
                        @Model.Fecha.ToString("dddd, dd 'de' MMMM 'de' yyyy", new System.Globalization.CultureInfo("es-ES"))
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Mensaje de éxito -->
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle"></i>
        <strong>¡Asistencia guardada exitosamente!</strong> 
        Los datos han sido registrados correctamente en el sistema.
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>

    <!-- Tarjetas de resumen estadístico -->
    <div class="row mb-4">
        <div class="col-lg-2 col-md-4 col-6 mb-3">
            <div class="card border-primary text-center">
                <div class="card-body">
                    <i class="fas fa-users fa-2x text-primary mb-2"></i>
                    <h3 class="text-primary">@Model.TotalEstudiantes</h3>
                    <small class="text-muted">Total</small>
                </div>
            </div>
        </div>
        <div class="col-lg-2 col-md-4 col-6 mb-3">
            <div class="card border-success text-center">
                <div class="card-body">
                    <i class="fas fa-user-check fa-2x text-success mb-2"></i>
                    <h3 class="text-success">@Model.EstudiantesPresentes</h3>
                    <small class="text-muted">Presentes</small>
                </div>
            </div>
        </div>
        <div class="col-lg-2 col-md-4 col-6 mb-3">
            <div class="card border-danger text-center">
                <div class="card-body">
                    <i class="fas fa-user-times fa-2x text-danger mb-2"></i>
                    <h3 class="text-danger">@Model.EstudiantesAusentes</h3>
                    <small class="text-muted">Ausentes</small>
                </div>
            </div>
        </div>
        <div class="col-lg-2 col-md-4 col-6 mb-3">
            <div class="card border-warning text-center">
                <div class="card-body">
                    <i class="fas fa-user-clock fa-2x text-warning mb-2"></i>
                    <h3 class="text-warning">@Model.EstudiantesTardanza</h3>
                    <small class="text-muted">Tardanzas</small>
                </div>
            </div>
        </div>
        <div class="col-lg-2 col-md-4 col-6 mb-3">
            <div class="card border-info text-center">
                <div class="card-body">
                    <i class="fas fa-file-alt fa-2x text-info mb-2"></i>
                    <h3 class="text-info">@Model.AusenciasJustificadas</h3>
                    <small class="text-muted">Justificadas</small>
                </div>
            </div>
        </div>
        <div class="col-lg-2 col-md-4 col-6 mb-3">
            <div class="card border-dark text-center">
                <div class="card-body">
                    <i class="fas fa-percentage fa-2x text-dark mb-2"></i>
                    <h3 class="text-dark">@Model.PorcentajeAsistencia.ToString("F1")%</h3>
                    <small class="text-muted">Asistencia</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Gráfico de resumen -->
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h6 class="mb-0">
                        <i class="fas fa-chart-pie"></i> 
                        Distribución de Asistencia
                    </h6>
                </div>
                <div class="card-body">
                    <canvas id="chartAsistencia" width="400" height="200"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h6 class="mb-0">
                        <i class="fas fa-info-circle"></i> 
                        Detalles del Registro
                    </h6>
                </div>
                <div class="card-body">
                    <table class="table table-sm">
                        <tr>
                            <td><strong>Grupo:</strong></td>
                            <td>@Model.Grupo.Nombre</td>
                        </tr>
                        <tr>
                            <td><strong>Fecha:</strong></td>
                            <td>@Model.Fecha.ToString("dd/MM/yyyy")</td>
                        </tr>
                        <tr>
                            <td><strong>Hora de Registro:</strong></td>
                            <td>@DateTime.Now.ToString("HH:mm")</td>
                        </tr>
                        <tr>
                            <td><strong>% de Asistencia:</strong></td>
                            <td>
                                <span class="badge bg-@(Model.PorcentajeAsistencia >= 80 ? "success" : Model.PorcentajeAsistencia >= 60 ? "warning" : "danger")">
                                    @Model.PorcentajeAsistencia.ToString("F1")%
                                </span>
                            </td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Observaciones generales -->
    @if (!string.IsNullOrWhiteSpace(Model.ObservacionesGenerales))
    {
        <div class="card mb-4">
            <div class="card-header">
                <h6 class="mb-0">
                    <i class="fas fa-sticky-note"></i> 
                    Observaciones Generales
                </h6>
            </div>
            <div class="card-body">
                <p class="mb-0">@Model.ObservacionesGenerales</p>
            </div>
        </div>
    }

    <!-- Detalle de estudiantes (si están disponibles) -->
    @if (Model.DetalleEstudiantes != null && Model.DetalleEstudiantes.Any())
    {
        <div class="card mb-4">
            <div class="card-header">
                <h6 class="mb-0">
                    <i class="fas fa-list"></i> 
                    Detalle por Estudiante
                </h6>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Estudiante</th>
                                <th class="text-center">Estado</th>
                                <th>Justificación</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < Model.DetalleEstudiantes.Count; i++)
                            {
                                var estudiante = Model.DetalleEstudiantes[i];
                                var claseEstado = estudiante.Estado switch
                                {
                                    "P" => "table-success",
                                    "A" => "table-danger",
                                    "T" => "table-warning",
                                    _ => ""
                                };
                                
                                <tr class="@claseEstado">
                                    <td>@(i + 1)</td>
                                    <td>
                                        <strong>@estudiante.NombreCompleto</strong>
                                        @if (!string.IsNullOrEmpty(estudiante.NumeroId))
                                        {
                                            <br><small class="text-muted">ID: @estudiante.NumeroId</small>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @switch (estudiante.Estado)
                                        {
                                            case "P":
                                                <span class="badge bg-success">
                                                    <i class="fas fa-check"></i> Presente
                                                </span>
                                                break;
                                            case "A":
                                                <span class="badge bg-danger">
                                                    <i class="fas fa-times"></i> Ausente
                                                </span>
                                                break;
                                            case "T":
                                                <span class="badge bg-warning">
                                                    <i class="fas fa-clock"></i> Tardanza
                                                </span>
                                                break;
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrWhiteSpace(estudiante.Justificacion))
                                        {
                                            <i class="fas fa-comment-alt text-info me-1"></i>
                                            @estudiante.Justificacion
                                        }
                                        else
                                        {
                                            <small class="text-muted">Sin justificación</small>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    <!-- Acciones disponibles -->
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> 
                Volver a Grupos
            </a>
            <a asp-action="PaseLista" asp-route-grupoId="@Model.Grupo.Id" class="btn btn-outline-primary">
                <i class="fas fa-redo"></i> 
                Nuevo Pase de Lista
            </a>
        </div>
        <div>
            <a asp-action="ImprimirResumen" asp-route-grupoId="@Model.Grupo.Id" asp-route-fecha="@Model.Fecha.ToString("yyyy-MM-dd")" class="btn btn-outline-info me-2" target="_blank">
                <i class="fas fa-print"></i> 
                Imprimir Resumen
            </a>
            <a asp-action="ExportarExcel" asp-route-grupoId="@Model.Grupo.Id" asp-route-fecha="@Model.Fecha.ToString("yyyy-MM-dd")" class="btn btn-success">
                <i class="fas fa-file-excel"></i> 
                Exportar a Excel
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Chart.js para el gráfico -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    
    <script>
        $(document).ready(function() {
            // Configurar el gráfico de pastel
            var ctx = document.getElementById('chartAsistencia').getContext('2d');
            var chartAsistencia = new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: ['Presentes', 'Ausentes', 'Tardanzas'],
                    datasets: [{
                        data: [@Model.EstudiantesPresentes, @Model.EstudiantesAusentes, @Model.EstudiantesTardanza],
                        backgroundColor: [
                            '#28a745', // Verde para presentes
                            '#dc3545', // Rojo para ausentes
                            '#ffc107'  // Amarillo para tardanzas
                        ],
                        borderWidth: 2,
                        borderColor: '#fff'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom'
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    var label = context.label || '';
                                    var value = context.parsed;
                                    var total = @Model.TotalEstudiantes;
                                    var percentage = ((value / total) * 100).toFixed(1);
                                    return label + ': ' + value + ' (' + percentage + '%)';
                                }
                            }
                        }
                    }
                }
            });

            // Ajustar altura del gráfico
            ctx.canvas.style.height = '200px';
        });
    </script>

    <style>
        @@media print {
            .btn, .alert-dismissible .btn-close {
                display: none !important;
            }
            
            .card {
                border: 1px solid #dee2e6 !important;
                box-shadow: none !important;
            }
        }
        
        .card {
            box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
            border: 1px solid rgba(0, 0, 0, 0.125);
        }
    </style>
}
@model DocinadeApp.ViewModels.PaseListaViewModel

@{
    ViewData["Title"] = "Pase de Lista";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4">
    <!-- Encabezado con información del grupo -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-6">
                <i class="fas fa-clipboard-check text-primary"></i> 
                Pase de Lista
            </h1>
            <div class="text-muted">
                <strong>Grupo:</strong> @Model.Grupo.Nombre
                @if (!string.IsNullOrEmpty(Model.Grupo.Codigo))
                {
                    <span class="badge bg-secondary ms-2">@Model.Grupo.Codigo</span>
                }
            </div>
        </div>
        <div class="text-end">
            <div class="card border-0 bg-light">
                <div class="card-body p-3">
                    <h6 class="card-title mb-1">
                        <i class="fas fa-calendar-day text-info"></i> 
                        Fecha del Pase de Lista
                    </h6>
                    <p class="card-text h5 mb-0 text-primary">
                        @Model.Fecha.ToString("dddd, dd 'de' MMMM 'de' yyyy", new System.Globalization.CultureInfo("es-ES"))
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Tarjetas de resumen (se actualizan dinámicamente con JavaScript) -->
    <div class="row mb-4" id="resumen-asistencia">
        <div class="col-lg-3 col-md-6 mb-3">
            <div class="card border-primary">
                <div class="card-body text-center">
                    <i class="fas fa-users fa-2x text-primary mb-2"></i>
                    <h4 id="total-estudiantes" class="text-primary">@Model.TotalEstudiantes</h4>
                    <small class="text-muted">Total Estudiantes</small>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6 mb-3">
            <div class="card border-success">
                <div class="card-body text-center">
                    <i class="fas fa-user-check fa-2x text-success mb-2"></i>
                    <h4 id="estudiantes-presentes" class="text-success">0</h4>
                    <small class="text-muted">Presentes</small>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6 mb-3">
            <div class="card border-danger">
                <div class="card-body text-center">
                    <i class="fas fa-user-times fa-2x text-danger mb-2"></i>
                    <h4 id="estudiantes-ausentes" class="text-danger">0</h4>
                    <small class="text-muted">Ausentes</small>
                </div>
            </div>
        </div>
        <div class="col-lg-3 col-md-6 mb-3">
            <div class="card border-warning">
                <div class="card-body text-center">
                    <i class="fas fa-user-clock fa-2x text-warning mb-2"></i>
                    <h4 id="estudiantes-tardanza" class="text-warning">0</h4>
                    <small class="text-muted">Tardanzas</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Formulario principal de pase de lista -->
    <form asp-action="GuardarAsistencia" asp-controller="Asistencia" method="post" id="form-pase-lista">
        
        <!-- Campos ocultos para el modelo -->
        <input type="hidden" asp-for="Grupo.Id" />
        <input type="hidden" asp-for="Grupo.Nombre" />
        <input type="hidden" asp-for="Grupo.Codigo" />
        <input type="hidden" asp-for="Grupo.Descripcion" />
        <input type="hidden" asp-for="Grupo.PeriodoAcademico" />
        <input type="hidden" asp-for="MateriaId" />
        <input type="hidden" asp-for="Fecha" />

        <!-- Selección de materia -->
        <div class="row mb-4">
            <div class="col-md-6">
                <div class="card border-info">
                    <div class="card-header bg-info text-white">
                        <h6 class="mb-0">
                            <i class="fas fa-book"></i> Materia
                        </h6>
                    </div>
                    <div class="card-body">
                        <div class="form-group">
                            <label asp-for="MateriaId" class="form-label">Seleccionar Materia:</label>
                            <select asp-for="MateriaId" asp-items="ViewBag.Materias" class="form-select" 
                                    onchange="cambiarMateria()" id="select-materia">
                                <option value="">-- Seleccione una materia --</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tabla de estudiantes -->
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">
                    <i class="fas fa-list-alt"></i> 
                    Lista de Estudiantes
                    <span class="badge bg-light text-primary ms-2">@Model.TotalEstudiantes estudiantes</span>
                </h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 60px;" class="text-center">#</th>
                                <th style="width: 35%;">
                                    <i class="fas fa-user"></i> Estudiante
                                </th>
                                <th style="width: 80px;" class="text-center">
                                    <i class="fas fa-check-circle text-success"></i><br>
                                    <small>Presente</small>
                                </th>
                                <th style="width: 80px;" class="text-center">
                                    <i class="fas fa-times-circle text-danger"></i><br>
                                    <small>Ausente</small>
                                </th>
                                <th style="width: 80px;" class="text-center">
                                    <i class="fas fa-clock text-warning"></i><br>
                                    <small>Tardanza</small>
                                </th>
                                <th style="width: 80px;" class="text-center">
                                    <i class="fas fa-exclamation-triangle text-orange"></i><br>
                                    <small>Ausencia Justificada</small>
                                </th>
                                <th style="width: 35%;">
                                    <i class="fas fa-comment-alt text-info"></i> 
                                    Justificación (Requerida para Ausencia Justificada)
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int i = 0; i < Model.Estudiantes.Count; i++)
                            {
                                <tr data-estudiante-id="@Model.Estudiantes[i].EstudianteId" data-fila="@i">
                                    <td class="text-center align-middle">
                                        <span class="badge bg-secondary">@(i + 1)</span>
                                    </td>
                                    <td class="align-middle">
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-sm bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3">
                                                <i class="fas fa-user"></i>
                                            </div>
                                            <div>
                                                <strong>@Model.Estudiantes[i].NombreCompleto</strong>
                                                @if (!string.IsNullOrEmpty(Model.Estudiantes[i].NumeroId))
                                                {
                                                    <br><small class="text-muted">ID: @Model.Estudiantes[i].NumeroId</small>
                                                }
                                            </div>
                                        </div>
                                    </td>

                                    <!-- Campos ocultos para el binding -->
                                    <input type="hidden" asp-for="Estudiantes[i].EstudianteId" />
                                    <input type="hidden" asp-for="Estudiantes[i].NombreCompleto" />
                                    <input type="hidden" asp-for="Estudiantes[i].NumeroId" />

                                    <!-- Radio button: Presente -->
                                    <td class="text-center align-middle">
                                        <div class="form-check form-check-inline">
                                            <input type="radio" 
                                                   class="form-check-input asistencia-radio" 
                                                   name="Estudiantes[@i].Estado" 
                                                   value="P" 
                                                   id="presente_@i"
                                                   checked 
                                                   data-estado="Presente" />
                                            <label class="form-check-label visually-hidden" for="presente_@i">Presente</label>
                                        </div>
                                    </td>

                                    <!-- Radio button: Ausente -->
                                    <td class="text-center align-middle">
                                        <div class="form-check form-check-inline">
                                            <input type="radio" 
                                                   class="form-check-input asistencia-radio" 
                                                   name="Estudiantes[@i].Estado" 
                                                   value="A" 
                                                   id="ausente_@i"
                                                   data-estado="Ausente" />
                                            <label class="form-check-label visually-hidden" for="ausente_@i">Ausente</label>
                                        </div>
                                    </td>

                                    <!-- Radio button: Tardanza -->
                                    <td class="text-center align-middle">
                                        <div class="form-check form-check-inline">
                                            <input type="radio" 
                                                   class="form-check-input asistencia-radio" 
                                                   name="Estudiantes[@i].Estado" 
                                                   value="T" 
                                                   id="tardanza_@i"
                                                   data-estado="Tardanza" />
                                            <label class="form-check-label visually-hidden" for="tardanza_@i">Tardanza</label>
                                        </div>
                                    </td>

                                    <!-- Radio button: Ausencia Justificada -->
                                    <td class="text-center align-middle">
                                        <div class="form-check form-check-inline">
                                            <input type="radio" 
                                                   class="form-check-input asistencia-radio" 
                                                   name="Estudiantes[@i].Estado" 
                                                   value="AJ" 
                                                   id="ausencia_justificada_@i"
                                                   data-estado="Ausencia Justificada" />
                                            <label class="form-check-label visually-hidden" for="ausencia_justificada_@i">Ausencia Justificada</label>
                                        </div>
                                    </td>

                                    <!-- Textarea para justificación -->
                                    <td class="align-middle">
                                        <div class="justificacion-container">
                                            <textarea asp-for="Estudiantes[i].Justificacion" 
                                                      class="form-control justificacion-input" 
                                                      rows="2" 
                                                      placeholder="Ingrese la justificación de la ausencia..." 
                                                      style="display: none; min-height: 45px;"
                                                      id="justificacion_@i"></textarea>
                                            <small class="text-muted justificacion-help" style="display: none;">
                                                <i class="fas fa-info-circle"></i> 
                                                Proporcione los detalles de la justificación
                                            </small>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- Observaciones generales (opcional) -->
        <div class="card mt-4">
            <div class="card-header">
                <h6 class="mb-0">
                    <i class="fas fa-sticky-note text-info"></i> 
                    Observaciones Generales (Opcional)
                </h6>
            </div>
            <div class="card-body">
                <textarea asp-for="ObservacionesGenerales" 
                          class="form-control" 
                          rows="3" 
                          placeholder="Ingrese cualquier observación relevante sobre la clase o asistencia..."></textarea>
            </div>
        </div>

        <!-- Botones de acción -->
        <div class="d-flex justify-content-between align-items-center mt-4 mb-5">
            <div>
                <a asp-action="Index" asp-controller="Asistencia" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left"></i> Cancelar
                </a>
            </div>
            <div>
                <button type="button" class="btn btn-outline-primary me-2" id="btn-vista-previa">
                    <i class="fas fa-eye"></i> Vista Previa
                </button>
                <button type="submit" class="btn btn-primary btn-lg">
                    <i class="fas fa-save"></i> Guardar Asistencia
                </button>
            </div>
        </div>
    </form>
</div>

<!-- Modal para vista previa del resumen -->
<div class="modal fade" id="modalVistaPrevia" tabindex="-1" aria-labelledby="modalVistaPreviaLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalVistaPreviaLabel">
                    <i class="fas fa-eye"></i> Vista Previa del Pase de Lista
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="contenido-vista-previa">
                <!-- El contenido se llenará dinámicamente con JavaScript -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" class="btn btn-primary" onclick="$('#form-pase-lista').submit();">
                    <i class="fas fa-save"></i> Confirmar y Guardar
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Función para cambiar de materia
        function cambiarMateria() {
            var materiaId = $('#select-materia').val();
            var grupoId = '@Model.Grupo.Id';
            
            if (materiaId) {
                window.location.href = '@Url.Action("PaseLista", "Asistencia")?grupoId=' + grupoId + '&materiaId=' + materiaId;
            }
        }

        $(document).ready(function () {
            // Función para actualizar los contadores de resumen
            function actualizarResumen() {
                var totalEstudiantes = $('.asistencia-radio').length / 4; // 4 radios por estudiante (P, A, T, AJ)
                var presentes = $('.asistencia-radio[value="P"]:checked').length;
                var ausentes = $('.asistencia-radio[value="A"]:checked').length;
                var tardanzas = $('.asistencia-radio[value="T"]:checked').length;
                var ausenciasJustificadas = $('.asistencia-radio[value="AJ"]:checked').length;
                
                $('#total-estudiantes').text(totalEstudiantes);
                $('#estudiantes-presentes').text(presentes);
                $('#estudiantes-ausentes').text(ausentes + ausenciasJustificadas); // Total de ausencias (justificadas y no justificadas)
                $('#estudiantes-tardanza').text(tardanzas);
            }

            // Función para mostrar/ocultar campo de justificación
            function toggleJustificacion($fila, mostrar) {
                var $justificacionInput = $fila.find('.justificacion-input');
                var $justificacionHelp = $fila.find('.justificacion-help');
                
                if (mostrar) {
                    $justificacionInput.slideDown(300).focus();
                    $justificacionHelp.slideDown(300);
                    $fila.addClass('table-warning'); // Resaltar fila con ausencia
                } else {
                    $justificacionInput.val('').slideUp(300);
                    $justificacionHelp.slideUp(300);
                    $fila.removeClass('table-warning table-danger').addClass('table-success');
                }
            }

            // Manejador de eventos para los radio buttons de asistencia
            $('.asistencia-radio').on('change', function () {
                var estadoSeleccionado = $(this).val();
                var $fila = $(this).closest('tr');
                
                // Remover todas las clases de estado
                $fila.removeClass('table-success table-warning table-danger');
                
                switch(estadoSeleccionado) {
                    case 'A': // Ausente (sin justificar)
                        toggleJustificacion($fila, false); // No requiere justificación obligatoria
                        $fila.addClass('table-danger');
                        break;
                    case 'AJ': // Ausencia Justificada
                        toggleJustificacion($fila, true); // Sí requiere justificación
                        $fila.addClass('table-warning');
                        break;
                    case 'P': // Presente
                        toggleJustificacion($fila, false);
                        $fila.addClass('table-success');
                        break;
                    case 'T': // Tardanza
                        toggleJustificacion($fila, false);
                        break;
                }
                
                // Actualizar contadores
                actualizarResumen();
            });

            // Función para generar vista previa
            $('#btn-vista-previa').on('click', function() {
                var resumen = generarResumenAsistencia();
                $('#contenido-vista-previa').html(resumen);
                $('#modalVistaPrevia').modal('show');
            });

            function generarResumenAsistencia() {
                var grupo = '@Model.Grupo.Nombre';
                var fecha = '@Model.Fecha.ToString("dd/MM/yyyy")';
                
                // Calcular contadores directamente desde los radio buttons
                var presentes = $('.asistencia-radio[value="P"]:checked').length;
                var ausentesSinJustificar = $('.asistencia-radio[value="A"]:checked').length;
                var ausenciasJustificadas = $('.asistencia-radio[value="AJ"]:checked').length;
                var tardanzas = $('.asistencia-radio[value="T"]:checked').length;
                var totalEstudiantes = presentes + ausentesSinJustificar + ausenciasJustificadas + tardanzas;
                var porcentaje = totalEstudiantes > 0 ? Math.round((presentes / totalEstudiantes) * 100) : 0;
                
                var html = '<div class="row">';
                html += '<div class="col-md-6">';
                html += '<h6><strong>Información del Grupo:</strong></h6>';
                html += '<p><strong>Grupo:</strong> ' + grupo + '<br>';
                html += '<strong>Fecha:</strong> ' + fecha + '</p>';
                html += '</div>';
                html += '<div class="col-md-6">';
                html += '<h6><strong>Resumen de Asistencia:</strong></h6>';
                html += '<p><strong>Total:</strong> ' + totalEstudiantes + ' estudiantes<br>';
                html += '<strong>Presentes:</strong> ' + presentes + '<br>';
                html += '<strong>Ausentes sin justificar:</strong> ' + ausentesSinJustificar + '<br>';
                html += '<strong>Ausencias justificadas:</strong> ' + ausenciasJustificadas + '<br>';
                html += '<strong>Tardanzas:</strong> ' + tardanzas + '<br>';
                html += '<strong>% Asistencia:</strong> ' + porcentaje + '%</p>';
                html += '</div></div>';
                
                // Agregar lista de ausentes sin justificar
                var $ausentesSinJustificar = $('.asistencia-radio[value="A"]:checked');
                if ($ausentesSinJustificar.length > 0) {
                    html += '<hr><h6><strong>Estudiantes Ausentes (sin justificar):</strong></h6><ul>';
                    $ausentesSinJustificar.each(function() {
                        var $fila = $(this).closest('tr');
                        var nombre = $fila.find('strong').first().text();
                        html += '<li>' + nombre + '</li>';
                    });
                    html += '</ul>';
                }
                
                // Agregar lista de ausencias justificadas con sus justificaciones
                var $ausenciasJustificadas = $('.asistencia-radio[value="AJ"]:checked');
                if ($ausenciasJustificadas.length > 0) {
                    html += '<hr><h6><strong>Ausencias Justificadas:</strong></h6><ul>';
                    $ausenciasJustificadas.each(function() {
                        var $fila = $(this).closest('tr');
                        var nombre = $fila.find('strong').first().text();
                        var justificacion = $fila.find('.justificacion-input').val();
                        html += '<li><strong>' + nombre + ':</strong> ';
                        html += justificacion ? justificacion : '<em>Sin especificar justificación</em>';
                        html += '</li>';
                    });
                    html += '</ul>';
                }
                
                return html;
            }

            // Validación del formulario antes del envío
            $('#form-pase-lista').on('submit', function(e) {
                var ausenciasJustificadasSinJustificacion = [];
                
                // Validar que las ausencias justificadas tengan justificación
                $('.asistencia-radio[value="AJ"]:checked').each(function() {
                    var $fila = $(this).closest('tr');
                    var nombre = $fila.find('strong').first().text();
                    var justificacion = $fila.find('.justificacion-input').val();
                    
                    if (!justificacion || justificacion.trim() === '') {
                        ausenciasJustificadasSinJustificacion.push(nombre);
                    }
                });
                
                if (ausenciasJustificadasSinJustificacion.length > 0) {
                    var mensaje = 'Los siguientes estudiantes están marcados como "Ausencia Justificada" pero no tienen justificación:\n\n';
                    mensaje += ausenciasJustificadasSinJustificacion.join('\n');
                    mensaje += '\n\nDebe proporcionar una justificación para continuar.';
                    
                    alert(mensaje);
                    e.preventDefault();
                    return false;
                }
            });

            // Inicializar contadores al cargar la página
            actualizarResumen();
            
            // Aplicar efectos visuales iniciales
            setTimeout(function() {
                $('.table tbody tr').addClass('table-success'); // Todos empiezan como presentes
            }, 300);
        });
    </script>

    <style>
        .avatar-sm {
            width: 35px;
            height: 35px;
            font-size: 0.875rem;
        }
        
        .table tbody tr {
            transition: background-color 0.3s ease;
        }
        
        .justificacion-container {
            transition: all 0.3s ease;
        }
        
        .form-check-input:checked {
            transform: scale(1.1);
            transition: transform 0.2s ease;
        }
        
        .card {
            box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
            border: 1px solid rgba(0, 0, 0, 0.125);
        }
        cñs
        .table-responsive {
            border-radius: 0;
        }
        
        .badge {
            font-size: 0.75em;
        }
        
        @@media (max-width: 768px) {
            .table-responsive {
                font-size: 0.875rem;
            }
            
            .avatar-sm {
                width: 30px;
                height: 30px;
                font-size: 0.75rem;
            }
        }
    </style>
}
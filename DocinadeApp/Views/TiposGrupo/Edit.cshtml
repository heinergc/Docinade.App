@model DocinadeApp.ViewModels.Grupos.EditTipoGrupoViewModel

@{
    ViewData["Title"] = $"Editar Tipo: {Model.Nombre}";
}

<link rel="stylesheet" href="~/css/estilos_genericos.css" />

<div class="page-header">
    <div class="row align-items-center">
        <div class="col">
            <h1 class="page-title">
                <i class="fas fa-edit text-warning me-2"></i>
                Editar Tipo de Grupo
            </h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb breadcrumb-white">
                    <li class="breadcrumb-item">
                        <a href="@Url.Action("Index", "Home")" class="text-white">
                            <i class="fas fa-home"></i> Inicio
                        </a>
                    </li>
                    <li class="breadcrumb-item">
                        <a href="@Url.Action("Index")" class="text-white">
                            <i class="fas fa-tags"></i> Tipos de Grupo
                        </a>
                    </li>
                    <li class="breadcrumb-item active text-white">Editar: @Model.Nombre</li>
                </ol>
            </nav>
        </div>
    </div>
</div>

<div class="main-container">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card card-primary">
                <div class="card-header">
                    <h5 class="card-title">
                        <i class="fas fa-edit me-2"></i>
                        Editar: @Model.Nombre
                    </h5>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post" id="editTipoForm">
                        <input asp-for="IdTipoGrupo" type="hidden" />
                        <input asp-for="FechaRegistro" type="hidden" />

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="form-group">
                            <label class="form-label">ID del Tipo</label>
                            <input value="@Model.IdTipoGrupo" class="form-control" readonly />
                            <div class="text-muted mt-1">Identificador único del tipo de grupo</div>
                        </div>

                        <div class="form-group">
                            <label asp-for="Nombre" class="form-label required">Nombre</label>
                            <input asp-for="Nombre" class="form-control" maxlength="100" />
                            <span asp-validation-for="Nombre" class="invalid-feedback"></span>
                            <div class="text-muted mt-1">Nombre descriptivo del tipo de grupo</div>
                        </div>

                        <div class="form-group">
                            <label asp-for="Estado" class="form-label required">Estado</label>
                            <select asp-for="Estado" class="form-control form-select">
                                @foreach (var estado in ViewBag.EstadosDisponibles as List<DocinadeApp.Controllers.EstadoOption>)
                                {
                                    <option value="@estado.Valor"
                                            selected="@(Model.Estado == estado.Valor)">
                                        @estado.Nombre
                                    </option>
                                }
                            </select>
                            <span asp-validation-for="Estado" class="invalid-feedback"></span>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Fecha de Registro</label>
                            <input value="@Model.FechaRegistro.ToString("dd/MM/yyyy HH:mm")" class="form-control" readonly />
                            <div class="text-muted mt-1">Fecha de creación del tipo de grupo</div>
                        </div>

                        <!-- Botones de acción -->
                        <div class="d-flex justify-content-between mt-4 pt-3 border-top">
                            <div class="btn-group-modern">
                                <a href="@Url.Action("Index")" class="btn btn-secondary">
                                    <i class="fas fa-arrow-left"></i> <span class="btn-text">Volver a Lista</span>
                                </a>
                                <a href="@Url.Action("Details", new { id = Model.IdTipoGrupo })" class="btn btn-info">
                                    <i class="fas fa-eye"></i> <span class="btn-text">Ver Detalles</span>
                                </a>
                            </div>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> <span class="btn-text">Guardar Cambios</span>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function() {
            // Validación del formulario
            $('#editTipoForm').on('submit', function(e) {
                const nombre = $('#Nombre').val().trim();

                if (!nombre) {
                    e.preventDefault();
                    Swal.fire({
                        title: 'Campo requerido',
                        text: 'Por favor, ingrese el nombre del tipo de grupo',
                        icon: 'error'
                    });
                    return false;
                }

                // Mostrar loading
                Swal.fire({
                    title: 'Guardando cambios...',
                    text: 'Por favor espere',
                    allowOutsideClick: false,
                    didOpen: () => {
                        Swal.showLoading();
                    }
                });

                return true;
            });
        });
    </script>
}

@section Styles {
    <style>
        /* Campo requerido */
        .required::after {
            content: ' *';
            color: var(--color-danger);
            font-weight: bold;
        }

        /* Estilos para breadcrumb blanco */
        .breadcrumb-white {
            background-color: rgba(255, 255, 255, 0.1);
            padding: 0.75rem 1rem;
            border-radius: var(--radius-lg);
            margin-bottom: 1rem;
        }

        .breadcrumb-white .breadcrumb-item a {
            color: white !important;
            text-decoration: none;
            transition: all var(--transition-normal);
        }

        .breadcrumb-white .breadcrumb-item a:hover {
            color: rgba(255, 255, 255, 0.8) !important;
            text-shadow: 0 0 5px rgba(255, 255, 255, 0.5);
        }

        .breadcrumb-white .breadcrumb-item.active {
            color: white !important;
        }

        .breadcrumb-white .breadcrumb-item + .breadcrumb-item::before {
            color: rgba(255, 255, 255, 0.6);
        }

        /* Personalización específica para la página de edición */
        .card-primary .card-header {
            background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-hover) 100%);
        }

        /* Mejorar formularios */
        .form-control:focus {
            border-color: var(--color-primary);
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
        }

        .form-select:focus {
            border-color: var(--color-primary);
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
        }

        /* Responsive para botones en móviles */
        @@media (max-width: 768px) {
            .btn-group-modern {
                flex-direction: column;
                gap: 0.5rem;
                width: 100%;
            }

            .btn-group-modern .btn {
                width: 100%;
                justify-content: center;
            }

            .d-flex.justify-content-between {
                flex-direction: column;
                gap: 1rem;
            }
        }
    </style>
}
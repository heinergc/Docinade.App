@model IEnumerable<RubricasApp.Web.Models.SliderItem>

@{
    ViewData["Title"] = "Gestión de Slider";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="d-flex justify-content-between align-items-center">
                <h2>
                    <i class="fas fa-images"></i> Gestión de Slider Dinámico
                </h2>
                <a asp-action="Create" class="btn btn-primary">
                    <i class="fas fa-plus"></i> Nuevo Slider
                </a>
            </div>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-triangle"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow">
        <div class="card-body">
            <div class="table-responsive">
                <table id="sliderTable" class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th style="width: 100px;">Imagen</th>
                            <th>Título</th>
                            <th>Subtítulo</th>
                            <th>Enlace</th>
                            <th style="width: 80px;">Orden</th>
                            <th style="width: 100px;">Estado</th>
                            <th style="width: 180px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr id="slider-row-@item.Id">
                                <td>
                                    @if (!string.IsNullOrEmpty(item.ImagenUrl))
                                    {
                                        <img src="@item.ImagenUrl" alt="@item.Titulo" 
                                             class="img-thumbnail" style="max-width: 80px; max-height: 60px; object-fit: cover;">
                                    }
                                    else
                                    {
                                        <div class="text-muted">
                                            <i class="fas fa-image fa-2x"></i>
                                        </div>
                                    }
                                </td>
                                <td>
                                    <strong>@item.Titulo</strong>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.Subtitulo))
                                    {
                                        <span>@item.Subtitulo</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic">Sin subtítulo</span>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.EnlaceUrl))
                                    {
                                        <a href="@item.EnlaceUrl" target="_blank" class="text-primary">
                                            <i class="fas fa-external-link-alt"></i> 
                                            @(item.TextoBoton ?? "Ver enlace")
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic">Sin enlace</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-secondary">@item.Orden</span>
                                </td>
                                <td class="text-center">
                                    <button class="btn btn-sm toggle-active-btn @(item.Activo ? "btn-success" : "btn-secondary")" 
                                            data-id="@item.Id"
                                            data-activo="@item.Activo.ToString().ToLower()"
                                            title="@(item.Activo ? "Click para desactivar" : "Click para activar")">
                                        <i class="fas @(item.Activo ? "fa-check-circle" : "fa-times-circle")"></i>
                                        @(item.Activo ? "Activo" : "Inactivo")
                                    </button>
                                </td>
                                <td>
                                    <div class="btn-group" role="group">
                                        <a asp-action="Edit" asp-route-id="@item.Id" 
                                           class="btn btn-sm btn-warning" 
                                           title="Editar">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" 
                                           class="btn btn-sm btn-danger" 
                                           title="Eliminar">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <p class="text-muted">
            <i class="fas fa-info-circle"></i> 
            Total de sliders: <strong>@Model.Count()</strong> 
            | Activos: <strong>@Model.Count(s => s.Activo)</strong>
        </p>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    
    <script>
        $(document).ready(function() {
            // Inicializar DataTable
            $('#sliderTable').DataTable({
                "language": {
                    "url": "//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json"
                },
                "order": [[4, "asc"]], // Ordenar por columna Orden
                "pageLength": 10,
                "responsive": true
            });

            // Toggle Activo/Inactivo con AJAX
            $('.toggle-active-btn').on('click', function() {
                const btn = $(this);
                const id = btn.data('id');
                const isActive = btn.data('activo') === 'true';

                if (confirm(`¿Está seguro de ${isActive ? 'desactivar' : 'activar'} este slider?`)) {
                    $.ajax({
                        url: '@Url.Action("ToggleActive", "Slider")',
                        type: 'POST',
                        data: { id: id },
                        headers: {
                            'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                        },
                        success: function(response) {
                            if (response.success) {
                                // Actualizar estado del botón
                                const newActive = !isActive;
                                btn.data('activo', newActive);
                                
                                if (newActive) {
                                    btn.removeClass('btn-secondary').addClass('btn-success');
                                    btn.html('<i class="fas fa-check-circle"></i> Activo');
                                    btn.attr('title', 'Click para desactivar');
                                } else {
                                    btn.removeClass('btn-success').addClass('btn-secondary');
                                    btn.html('<i class="fas fa-times-circle"></i> Inactivo');
                                    btn.attr('title', 'Click para activar');
                                }

                                // Mostrar mensaje de éxito
                                showAlert('success', response.message);
                            } else {
                                showAlert('danger', response.message || 'Error al cambiar estado');
                            }
                        },
                        error: function() {
                            showAlert('danger', 'Error de conexión al servidor');
                        }
                    });
                }
            });

            function showAlert(type, message) {
                const alertHtml = `
                    <div class="alert alert-${type} alert-dismissible fade show" role="alert">
                        <i class="fas fa-${type === 'success' ? 'check-circle' : 'exclamation-triangle'}"></i> ${message}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>`;
                
                $('.container-fluid .row').first().after(alertHtml);
                
                setTimeout(function() {
                    $('.alert').fadeOut('slow', function() {
                        $(this).remove();
                    });
                }, 3000);
            }
        });
    </script>
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">
    <style>
        .table-responsive {
            min-height: 400px;
        }
        .img-thumbnail {
            border-radius: 8px;
        }
        .toggle-active-btn {
            transition: all 0.3s ease;
            min-width: 90px;
        }
        .toggle-active-btn:hover {
            transform: scale(1.05);
        }
    </style>
}

@model DocinadeApp.ViewModels.VincularUsuarioProfesorViewModel

@{
    ViewData["Title"] = "Vincular Usuario al Profesor";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-lg-8 offset-lg-2">
            <!-- Encabezado -->
            <div class="card border-primary mb-4">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-person-badge"></i> Vincular Usuario al Profesor
                    </h4>
                </div>
                <div class="card-body">
                    <!-- Información del Profesor -->
                    <div class="alert alert-info">
                        <h5 class="alert-heading">
                            <i class="bi bi-person-circle"></i> Información del Profesor
                        </h5>
                        <hr>
                        <p class="mb-1"><strong>Nombre:</strong> @Model.NombreProfesor</p>
                        <p class="mb-0"><strong>Cédula:</strong> @Model.CedulaProfesor</p>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.UsuarioVinculadoId))
                    {
                        <!-- Usuario Actualmente Vinculado -->
                        <div class="alert alert-success">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="alert-heading mb-2">
                                        <i class="bi bi-check-circle"></i> Usuario Vinculado Actualmente
                                    </h6>
                                    <p class="mb-0">@Model.UsuarioVinculadoNombre</p>
                                </div>
                                <form asp-action="DesvincularUsuario" method="post" class="d-inline" 
                                      onsubmit="return confirm('¿Está seguro de desvincular este usuario del profesor?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@Model.ProfesorId" />
                                    <button type="submit" class="btn btn-sm btn-danger">
                                        <i class="bi bi-x-circle"></i> Desvincular
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning">
                            <i class="bi bi-exclamation-triangle"></i>
                            <strong>Advertencia:</strong> Este profesor no tiene ningún usuario vinculado actualmente.
                        </div>
                    }

                    <!-- Formulario para Vincular/Cambiar Usuario -->
                    <form asp-action="VincularUsuario" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="ProfesorId" />

                        <div class="card">
                            <div class="card-header bg-light">
                                <h5 class="mb-0">
                                    @if (string.IsNullOrEmpty(Model.UsuarioVinculadoId))
                                    {
                                        <i class="bi bi-plus-circle"></i> <text>Vincular Nuevo Usuario</text>
                                    }
                                    else
                                    {
                                        <i class="bi bi-arrow-left-right"></i> <text>Cambiar Usuario Vinculado</text>
                                    }
                                </h5>
                            </div>
                            <div class="card-body">
                                <div class="form-group">
                                    <label asp-for="UsuarioSeleccionadoId" class="form-label">
                                        <strong>Seleccione un Usuario:</strong>
                                    </label>
                                    <select asp-for="UsuarioSeleccionadoId" class="form-select" asp-items="Model.UsuariosDisponibles">
                                        <option value="">-- Seleccione un usuario --</option>
                                    </select>
                                    <div class="form-text">
                                        <i class="bi bi-info-circle"></i>
                                        Solo se muestran usuarios sin profesor asignado o el usuario actualmente vinculado.
                                    </div>
                                </div>

                                <div class="alert alert-info mt-3">
                                    <h6><i class="bi bi-lightbulb"></i> Información Importante:</h6>
                                    <ul class="mb-0">
                                        <li>Al vincular un usuario, se actualizar su <code>NumeroIdentificacion</code> con la cédula del profesor.</li>
                                        <li>Si el profesor ya tiene un usuario vinculado, éste será desvinculado automáticamente.</li>
                                        <li>El usuario vinculado podrá ser asignado como profesor guía en las boletas de conducta.</li>
                                    </ul>
                                </div>
                            </div>
                            <div class="card-footer">
                                <div class="d-flex justify-content-between">
                                    <a asp-action="Details" asp-route-id="@Model.ProfesorId" class="btn btn-secondary">
                                        <i class="bi bi-arrow-left"></i> Cancelar
                                    </a>
                                    <button type="submit" class="btn btn-primary">
                                        <i class="bi bi-save"></i> 
                                        @if (string.IsNullOrEmpty(Model.UsuarioVinculadoId))
                                        {
                                            <text>Vincular Usuario</text>
                                        }
                                        else
                                        {
                                            <text>Actualizar Vinculación</text>
                                        }
                                    </button>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Confirmar cambio de usuario vinculado
        $('form[asp-action="VincularUsuario"]').on('submit', function(e) {
            var usuarioActual = '@Model.UsuarioVinculadoId';
            var usuarioSeleccionado = $('#UsuarioSeleccionadoId').val();
            
            if (usuarioActual && usuarioSeleccionado && usuarioActual !== usuarioSeleccionado) {
                if (!confirm('¿Está seguro de cambiar el usuario vinculado? El usuario actual será desvinculado.')) {
                    e.preventDefault();
                    return false;
                }
            }
        });
    </script>
}

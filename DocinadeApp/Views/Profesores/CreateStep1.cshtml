@model DocinadeApp.ViewModels.ProfesorViewModel
@{
    ViewData["Title"] = "Nuevo Profesor - Información Personal";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <!-- Header con progreso -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div>
                            <h1 class="h4 mb-0 text-gray-800">
                                <i class="fas fa-user-plus"></i> Nuevo Profesor
                            </h1>
                            <p class="mb-0 text-muted">Paso 1 de 6: Información Personal</p>
                        </div>
                        <div>
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left"></i> Volver a Lista
                            </a>
                        </div>
                    </div>
                    
                    <!-- Barra de progreso -->
                    <div class="progress mb-3" style="height: 8px;">
                        <div class="progress-bar bg-primary" role="progressbar" style="width: 16.67%" aria-valuenow="16.67" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                    
                    <!-- Indicadores de pasos -->
                    <div class="row text-center small">
                        <div class="col-2">
                            <div class="text-primary font-weight-bold">
                                <i class="fas fa-user"></i><br>Personal
                            </div>
                        </div>
                        <div class="col-2 text-muted">
                            <i class="fas fa-phone"></i><br>Contacto
                        </div>
                        <div class="col-2 text-muted">
                            <i class="fas fa-map-marker-alt"></i><br>Dirección
                        </div>
                        <div class="col-2 text-muted">
                            <i class="fas fa-graduation-cap"></i><br>Académica
                        </div>
                        <div class="col-2 text-muted">
                            <i class="fas fa-briefcase"></i><br>Laboral
                        </div>
                        <div class="col-2 text-muted">
                            <i class="fas fa-check-circle"></i><br>Final
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Formulario -->
    <div class="row">
        <div class="col-12">
            <div class="card shadow">
                <div class="card-header">
                    <h6 class="m-0 font-weight-bold text-primary">
                        <i class="fas fa-user"></i> Información Personal
                    </h6>
                </div>
                <div class="card-body">
                    <form asp-action="CreateStep1" method="post" novalidate>
                        <!-- Campo de Cédula PRIMERO con consulta automática -->
                        <div class="row">
                            <div class="col-md-8">
                                <div class="form-group">
                                    <label asp-for="Cedula" class="form-label required">Número de Cédula</label>
                                    <div class="input-group">
                                        <input asp-for="Cedula" class="form-control" placeholder="112345678" id="cedulaInput" maxlength="9" />
                                        <button type="button" class="btn btn-primary btn-cedula" id="consultarCedulaBtn" title="Consultar información de la cédula">
                                            <i class="fas fa-search me-1"></i>
                                            <span class="btn-text">Consultar</span>
                                        </button>
                                    </div>
                                    <span asp-validation-for="Cedula" class="text-danger"></span>
                                    <small class="form-text text-muted">Formato costarricense sin guiones: 112345678. Presione Consultar para autocompletar los datos.</small>
                                    <div id="cedulaMessage" class="mt-2"></div>
                                </div>
                            </div>

                            <!-- Tipo de Cédula -->
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label asp-for="TipoCedula" class="form-label required"></label>
                                    <select asp-for="TipoCedula" class="form-control">
                                        <option value="Nacional" selected>Nacional</option>
                                        <option value="Residencia">Residencia</option>
                                        <option value="Dimex">Dimex</option>
                                    </select>
                                    <span asp-validation-for="TipoCedula" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <!-- Nombres -->
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="Nombres" class="form-label required"></label>
                                    <input asp-for="Nombres" class="form-control" placeholder="Ingrese los nombres completos" />
                                    <span asp-validation-for="Nombres" class="text-danger"></span>
                                </div>
                            </div>

                            <!-- Primer Apellido -->
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="PrimerApellido" class="form-label required"></label>
                                    <input asp-for="PrimerApellido" class="form-control" placeholder="Ingrese el primer apellido" />
                                    <span asp-validation-for="PrimerApellido" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <!-- Segundo Apellido -->
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="SegundoApellido" class="form-label"></label>
                                    <input asp-for="SegundoApellido" class="form-control" placeholder="Ingrese el segundo apellido (opcional)" />
                                    <span asp-validation-for="SegundoApellido" class="text-danger"></span>
                                </div>
                            </div>

                            <!-- Sexo -->
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="Sexo" class="form-label"></label>
                                    <select asp-for="Sexo" class="form-control">
                                        <option value="">-- Seleccione --</option>
                                        <option value="M">Masculino</option>
                                        <option value="F">Femenino</option>
                                    </select>
                                    <span asp-validation-for="Sexo" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <!-- Fecha de Nacimiento -->
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label asp-for="FechaNacimiento" class="form-label"></label>
                                    <input asp-for="FechaNacimiento" type="date" class="form-control" />
                                    <span asp-validation-for="FechaNacimiento" class="text-danger"></span>
                                </div>
                            </div>

                            <!-- Estado Civil -->
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label asp-for="EstadoCivil" class="form-label"></label>
                                    <select asp-for="EstadoCivil" class="form-control">
                                        <option value="">-- Seleccione --</option>
                                        <option value="Soltero">Soltero(a)</option>
                                        <option value="Casado">Casado(a)</option>
                                        <option value="Divorciado">Divorciado(a)</option>
                                        <option value="Viudo">Viudo(a)</option>
                                        <option value="Unión Libre">Unión Libre</option>
                                    </select>
                                    <span asp-validation-for="EstadoCivil" class="text-danger"></span>
                                </div>
                            </div>

                            <!-- Nacionalidad -->
                            <div class="col-md-4">
                                <div class="form-group">
                                    <label asp-for="Nacionalidad" class="form-label"></label>
                                    <input asp-for="Nacionalidad" class="form-control" placeholder="Nacionalidad" />
                                    <span asp-validation-for="Nacionalidad" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <!-- Botones de navegación -->
                        <div class="row mt-4">
                            <div class="col-12">
                                <div class="d-flex justify-content-between">
                                    <a asp-action="Index" class="btn btn-secondary">
                                        <i class="fas fa-times"></i> Cancelar
                                    </a>
                                    <button type="submit" class="btn btn-primary">
                                        Continuar <i class="fas fa-arrow-right"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.required::after {
    content: " *";
    color: red;
}

.form-label {
    font-weight: 600;
    margin-bottom: 0.5rem;
}

.progress {
    border-radius: 10px;
}

.progress-bar {
    border-radius: 10px;
}

/* Estilos para alinear correctamente el botón con el input */
.input-group {
    display: flex;
    align-items: stretch;
}

.input-group .form-control {
    border-top-right-radius: 0;
    border-bottom-right-radius: 0;
    border-right: 0;
}

.input-group .btn {
    border-top-left-radius: 0;
    border-bottom-left-radius: 0;
    border-left: 1px solid #ced4da;
    white-space: nowrap;
}

/* Estilos mejorados para el botón de consulta */
.btn-cedula {
    background: linear-gradient(135deg, #007bff 0%, #0056b3 100%);
    border: none;
    color: white;
    font-weight: 600;
    padding: 0.5rem 1rem;
    transition: all 0.3s ease;
    box-shadow: 0 2px 4px rgba(0, 123, 255, 0.2);
    position: relative;
    overflow: hidden;
}

.btn-cedula:hover {
    background: linear-gradient(135deg, #0056b3 0%, #004085 100%);
    transform: translateY(-1px);
    box-shadow: 0 4px 8px rgba(0, 123, 255, 0.3);
    color: white;
}

.btn-cedula:active {
    transform: translateY(0);
    box-shadow: 0 2px 4px rgba(0, 123, 255, 0.2);
}

.btn-cedula .fas {
    margin-right: 0.25rem;
}

.btn-cedula:disabled {
    background: #6c757d;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
}

/* Animación de carga */
.btn-cedula.loading {
    pointer-events: none;
}

.btn-cedula.loading .fa-spinner {
    animation: fa-spin 1s linear infinite;
}

/* Asegurar que el botón tenga la misma altura que el input */
.input-group .btn {
    height: auto;
    padding: 0.375rem 0.75rem;
}

#cedulaInput {
    border-right: none;
}

#consultarCedulaBtn {
    border-left: 1px solid #ced4da;
}

/* Estados adicionales del botón */
.btn-cedula.btn-success {
    background: linear-gradient(135deg, #28a745 0%, #1e7e34 100%);
    color: white;
}

.btn-cedula.btn-success:hover {
    background: linear-gradient(135deg, #1e7e34 0%, #155724 100%);
    color: white;
}

/* Keyframes para la animación de carga */
@@keyframes spin-animation {
    0% { 
        transform: rotate(0deg); 
    }
    100% { 
        transform: rotate(360deg); 
    }
}

.btn-cedula.loading .fa-spinner {
    animation: spin-animation 1s linear infinite;
}

/* Responsive para pantallas pequeñas */
.btn-cedula .btn-text {
    display: inline-block;
}

@@media (max-width: 576px) {
    .btn-cedula .btn-text {
        display: none;
    }
    
    .btn-cedula {
        padding: 0.5rem;
        min-width: 45px;
    }
}
</style>
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    
    <script>
        $(document).ready(function() {
            // Solo permitir números en el campo de cédula
            $('#cedulaInput').on('input', function() {
                let value = $(this).val().replace(/\D/g, ''); // Solo números
                $(this).val(value);
                
                // Limitar a 9 dígitos máximo
                if (value.length > 9) {
                    $(this).val(value.substring(0, 9));
                }
            });

            // Consultar cédula automáticamente cuando se complete
            $('#cedulaInput').on('blur', function() {
                var cedula = $(this).val().trim();
                if (cedula && cedula.length >= 8) { // Mínimo 8 dígitos
                    consultarCedula(cedula);
                }
            });

            // Botón para consultar cédula manualmente
            $('#consultarCedulaBtn').click(function() {
                var cedula = $('#cedulaInput').val().trim();
                if (!cedula) {
                    mostrarMensaje('Por favor ingrese un número de cédula', 'warning');
                    return;
                }
                if (cedula.length < 8) {
                    mostrarMensaje('La cédula debe tener al menos 8 dígitos', 'warning');
                    return;
                }
                consultarCedula(cedula);
            });

            // Función para consultar la cédula
            function consultarCedula(cedula) {
                // Mostrar indicador de carga con diseño mejorado
                $('#consultarCedulaBtn').addClass('loading').prop('disabled', true)
                    .html('<i class="fas fa-spinner fa-spin me-1"></i><span class="btn-text">Consultando...</span>');
                
                limpiarMensajes();

                // Hacer la consulta AJAX
                $.ajax({
                    url: '@Url.Action("ConsultarCedula", "Profesores")',
                    type: 'POST',
                    headers: {
                        'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                    },
                    contentType: 'application/json',
                    data: JSON.stringify({ cedula: cedula }),
                    success: function(response) {
                        if (response.success) {
                            // Llenar los campos automáticamente
                            if (response.nombres) {
                                $('#Nombres').val(response.nombres);
                            }
                            if (response.primerApellido) {
                                $('#PrimerApellido').val(response.primerApellido);
                            }
                            if (response.segundoApellido) {
                                $('#SegundoApellido').val(response.segundoApellido);
                            }
                            
                            mostrarMensaje('✓ ' + response.message, 'success');
                            
                            // Efecto visual de éxito
                            $('#consultarCedulaBtn').removeClass('loading').addClass('btn-success')
                                .html('<i class="fas fa-check me-1"></i><span class="btn-text">Completado</span>');
                            
                            setTimeout(function() {
                                $('#consultarCedulaBtn').removeClass('btn-success').addClass('btn-primary')
                                    .html('<i class="fas fa-search me-1"></i><span class="btn-text">Consultar</span>');
                            }, 2000);
                        } else {
                            if (response.exists) {
                                mostrarMensaje('⚠ ' + response.message, 'danger');
                            } else {
                                mostrarMensaje('ℹ ' + response.message, 'info');
                            }
                        }
                    },
                    error: function(xhr, status, error) {
                        console.error('Error al consultar cédula:', error);
                        mostrarMensaje('❌ Error al consultar la cédula. Intente nuevamente.', 'danger');
                    },
                    complete: function() {
                        // Restaurar botón si no fue exitoso
                        if (!$('#consultarCedulaBtn').hasClass('btn-success')) {
                            $('#consultarCedulaBtn').removeClass('loading').prop('disabled', false)
                                .html('<i class="fas fa-search me-1"></i><span class="btn-text">Consultar</span>');
                        }
                    }
                });
            }

            // Función para mostrar mensajes
            function mostrarMensaje(mensaje, tipo) {
                var alertClass = 'alert-info';
                switch(tipo) {
                    case 'success': alertClass = 'alert-success'; break;
                    case 'warning': alertClass = 'alert-warning'; break;
                    case 'danger': alertClass = 'alert-danger'; break;
                }
                
                $('#cedulaMessage').html(
                    '<div class="alert ' + alertClass + ' alert-dismissible fade show mt-2" role="alert">' +
                    mensaje +
                    '<button type="button" class="close" data-dismiss="alert">' +
                    '<span>&times;</span></button></div>'
                );
            }

            // Función para limpiar mensajes
            function limpiarMensajes() {
                $('#cedulaMessage').empty();
            }
        });
    </script>
}

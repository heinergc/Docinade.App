@model RubricasApp.Web.ViewModels.ProfesorViewModel
@{
    ViewData["Title"] = "Nuevo Profesor - Información de Contacto";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <!-- Header con progreso -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div>
                            <h1 class="h4 mb-0 text-gray-800">
                                <i class="fas fa-user-plus"></i> Nuevo Profesor: @Model.NombreCompleto
                            </h1>
                            <p class="mb-0 text-muted">Paso 2 de 6: Información de Contacto</p>
                        </div>
                        <div>
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left"></i> Volver a Lista
                            </a>
                        </div>
                    </div>
                    
                    <!-- Barra de progreso -->
                    <div class="progress mb-3" style="height: 8px;">
                        <div class="progress-bar bg-primary" role="progressbar" style="width: 33.33%" aria-valuenow="33.33" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                    
                    <!-- Indicadores de pasos -->
                    <div class="row text-center small">
                        <div class="col-2 text-success">
                            <i class="fas fa-check-circle"></i><br>Personal
                        </div>
                        <div class="col-2">
                            <div class="text-primary font-weight-bold">
                                <i class="fas fa-phone"></i><br>Contacto
                            </div>
                        </div>
                        <div class="col-2 text-muted">
                            <i class="fas fa-map-marker-alt"></i><br>Dirección
                        </div>
                        <div class="col-2 text-muted">
                            <i class="fas fa-graduation-cap"></i><br>Académica
                        </div>
                        <div class="col-2 text-muted">
                            <i class="fas fa-briefcase"></i><br>Laboral
                        </div>
                        <div class="col-2 text-muted">
                            <i class="fas fa-check-circle"></i><br>Final
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Formulario -->
    <div class="row">
        <div class="col-12">
            <div class="card shadow">
                <div class="card-header">
                    <h6 class="m-0 font-weight-bold text-primary">
                        <i class="fas fa-phone"></i> Información de Contacto
                    </h6>
                </div>
                <div class="card-body">
                    <form asp-action="CreateStep2" method="post" novalidate>
                        
                        <!-- Emails -->
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group mb-4">
                                    <label asp-for="EmailPersonal" class="form-label required"></label>
                                    <div class="input-group">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text icon-enhanced">
                                                <i class="fas fa-envelope"></i>
                                            </span>
                                        </div>
                                        <input asp-for="EmailPersonal" type="email" class="form-control form-control-enhanced" placeholder="ejemplo@correo.com" />
                                    </div>
                                    <span asp-validation-for="EmailPersonal" class="text-danger"></span>
                                    <small class="form-text text-muted">Este será su email principal de contacto</small>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <div class="form-group mb-4">
                                    <label asp-for="EmailInstitucional" class="form-label"></label>
                                    <div class="input-group">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text icon-enhanced">
                                                <i class="fas fa-university"></i>
                                            </span>
                                        </div>
                                        <input asp-for="EmailInstitucional" type="email" class="form-control form-control-enhanced" placeholder="profesor@institucion.ac.cr" />
                                    </div>
                                    <span asp-validation-for="EmailInstitucional" class="text-danger"></span>
                                    <small class="form-text text-muted">Email proporcionado por la institución (opcional)</small>
                                </div>
                            </div>
                        </div>

                        <!-- Teléfonos -->
                        <div class="row">
                            <div class="col-md-4">
                                <div class="form-group mb-4">
                                    <label asp-for="TelefonoCelular" class="form-label required"></label>
                                    <div class="input-group">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text icon-enhanced">
                                                <i class="fas fa-mobile-alt"></i>
                                            </span>
                                        </div>
                                        <input asp-for="TelefonoCelular" class="form-control form-control-enhanced" placeholder="8888-8888" />
                                    </div>
                                    <span asp-validation-for="TelefonoCelular" class="text-danger"></span>
                                    <small class="form-text text-muted">Número principal de contacto</small>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="form-group mb-4">
                                    <label asp-for="TelefonoFijo" class="form-label"></label>
                                    <div class="input-group">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text icon-enhanced">
                                                <i class="fas fa-phone"></i>
                                            </span>
                                        </div>
                                        <input asp-for="TelefonoFijo" class="form-control form-control-enhanced" placeholder="2222-2222" />
                                    </div>
                                    <span asp-validation-for="TelefonoFijo" class="text-danger"></span>
                                    <small class="form-text text-muted">Teléfono fijo residencial (opcional)</small>
                                </div>
                            </div>

                            <div class="col-md-4">
                                <div class="form-group mb-4">
                                    <label asp-for="TelefonoOficina" class="form-label"></label>
                                    <div class="input-group">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text icon-enhanced">
                                                <i class="fas fa-building"></i>
                                            </span>
                                        </div>
                                        <input asp-for="TelefonoOficina" class="form-control form-control-enhanced" placeholder="2222-2222" />
                                        <input asp-for="Extension" class="form-control form-control-enhanced extension-input" placeholder="Ext" />
                                    </div>
                                    <span asp-validation-for="TelefonoOficina" class="text-danger"></span>
                                    <span asp-validation-for="Extension" class="text-danger"></span>
                                    <small class="form-text text-muted">Teléfono de la oficina y extensión (opcional)</small>
                                </div>
                            </div>
                        </div>

                        <!-- Información adicional -->
                        <div class="row mt-4">
                            <div class="col-12">
                                <div class="alert alert-info">
                                    <i class="fas fa-info-circle"></i>
                                    <strong>Importante:</strong> Esta información será utilizada para comunicaciones oficiales y notificaciones del sistema. 
                                    Asegúrese de que los datos sean correctos y estén actualizados.
                                </div>
                            </div>
                        </div>

                        <!-- Botones de navegación -->
                        <div class="row mt-4">
                            <div class="col-12">
                                <div class="d-flex justify-content-between">
                                    <a asp-action="Create" class="btn btn-outline-secondary">
                                        <i class="fas fa-arrow-left"></i> Anterior
                                    </a>
                                    <button type="submit" class="btn btn-primary">
                                        Continuar <i class="fas fa-arrow-right"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.required::after {
    content: " *";
    color: red;
    font-weight: bold;
}

.form-label {
    font-weight: 600;
    margin-bottom: 0.75rem;
    font-size: 1.1rem;
    color: #374151;
}

.input-group-lg {
    margin-bottom: 0.5rem;
}

.input-group-text.icon-enhanced {
    background-color: #f8f9fa;
    border: 1px solid #ced4da;
    color: #6c757d;
    width: 50px;
    height: 50px;
    display: flex;
    justify-content: center;
    align-items: center;
    border-top-left-radius: 4px;
    border-bottom-left-radius: 4px;
}

.form-control-enhanced {
    border: 1px solid #ced4da;
    border-left: none;
    padding: 0.75rem 1rem;
    font-size: 1rem;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    color: #495057;
    background-color: #fff;
    transition: border-color 0.15s ease-in-out, box-shadow 0.15s ease-in-out;
    border-top-right-radius: 4px;
    border-bottom-right-radius: 4px;
}

.form-control-enhanced:focus {
    border-color: #80bdff;
    box-shadow: 0 0 0 0.2rem rgba(0, 123, 255, 0.25);
    outline: none;
}

.form-control-enhanced::placeholder {
    color: #6c757d;
    font-style: normal;
    opacity: 1;
}

.extension-input {
    max-width: 100px;
    border-top-left-radius: 0 !important;
    border-bottom-left-radius: 0 !important;
    border-left: 1px solid #ced4da;
}

.progress {
    border-radius: 10px;
    height: 8px;
}

.progress-bar {
    border-radius: 10px;
    background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
}

.card {
    border-radius: 12px;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
}

.card-header {
    background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
    border-bottom: 2px solid #e5e7eb;
}

.alert-info {
    background: linear-gradient(135deg, #dbeafe 0%, #bfdbfe 100%);
    border: 1px solid #93c5fd;
    border-radius: 8px;
}

.btn-primary {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border: none;
    border-radius: 8px;
    padding: 0.75rem 1.5rem;
    font-weight: 600;
    transition: all 0.3s ease;
}

.btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
}

.btn-outline-secondary {
    border: 2px solid #6b7280;
    color: #6b7280;
    border-radius: 8px;
    padding: 0.75rem 1.5rem;
    font-weight: 600;
    transition: all 0.3s ease;
}

.btn-outline-secondary:hover {
    background-color: #6b7280;
    border-color: #6b7280;
    transform: translateY(-2px);
}

/* Responsive adjustments */
@@media (max-width: 768px) {
    .form-label {
        font-size: 1rem;
    }
    
    .form-control-enhanced {
        font-size: 0.9rem;
        padding: 0.625rem 0.875rem;
    }
    
    .input-group-text.icon-enhanced {
        width: 45px;
    }
    
    .extension-input {
        max-width: 80px;
    }
}

@@media (max-width: 576px) {
    .input-group .form-control-enhanced {
        font-size: 0.9rem;
    }
    
    .btn-primary, .btn-outline-secondary {
        padding: 0.625rem 1.25rem;
        font-size: 0.95rem;
    }
}
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

@model List<DocinadeApp.ViewModels.InstitucionListViewModel>

@{
    ViewData["Title"] = "Instituciones Educativas";
}

<!-- Contenido Principal -->
<main class="main-content fade-in">
    <div class="container-fluid px-4">
        <!-- Header de Página -->
        <div class="page-header">
            <h3 class="page-title-white">
                <i class="fas fa-university"></i>
                Instituciones Educativas
            </h3>
        </div>

        <!-- Mensajes de alerta -->
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle"></i> @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <!-- Tarjeta de filtros y acciones -->
        <div class="card mb-4">
            <div class="card-body">
                <form method="get" asp-action="Index" class="row g-3">
                    <div class="col-md-5">
                        <label class="form-label">Buscar Institución</label>
                        <input type="text" name="searchTerm" value="@ViewBag.SearchTerm" 
                               class="form-control" placeholder="Nombre, Código MEP o Dirección Regional...">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Estado</label>
                        <select name="estado" class="form-select">
                            <option value="">Todos</option>
                            <option value="true" selected="@(ViewBag.EstadoSeleccionado == true)">Activos</option>
                            <option value="false" selected="@(ViewBag.EstadoSeleccionado == false)">Inactivos</option>
                        </select>
                    </div>
                    <div class="col-md-4 d-flex align-items-end gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-search"></i> Buscar
                        </button>
                        <a href="@Url.Action("Index")" class="btn btn-secondary">
                            <i class="fas fa-times"></i> Limpiar
                        </a>
                        @if (User.HasClaim("permission", DocinadeApp.Models.Permissions.ApplicationPermissions.Instituciones.CREAR))
                        {
                            <a asp-action="Create" class="btn btn-success ms-auto">
                                <i class="fas fa-plus"></i> Nueva Institución
                            </a>
                        }
                    </div>
                </form>
            </div>
        </div>

        <!-- Tarjeta de tabla -->
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="fas fa-list"></i> 
                    Lista de Instituciones (@Model.Count)
                </h5>
            </div>
            <div class="card-body">
                @if (Model.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover table-striped">
                            <thead class="table-dark">
                                <tr>
                                    <th>Nombre</th>
                                    <th>Código MEP</th>
                                    <th>Tipo</th>
                                    <th>Dirección Regional</th>
                                    <th>Circuito Escolar</th>
                                    <th>Estado</th>
                                    <th>Fecha Creación</th>
                                    <th style="width: 150px;">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td><strong>@item.Nombre</strong></td>
                                        <td>@(item.CodigoMEP ?? "-")</td>
                                        <td><span class="badge bg-info">@item.TipoInstitucion</span></td>
                                        <td>@(item.DireccionRegional ?? "-")</td>
                                        <td>@(item.CircuitoEscolar ?? "-")</td>
                                        <td>
                                            @if (item.Estado)
                                            {
                                                <span class="badge bg-success">Activa</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">Inactiva</span>
                                            }
                                        </td>
                                        <td>@item.FechaCreacion.ToString("dd/MM/yyyy")</td>
                                        <td>
                                            <div class="btn-group" role="group">
                                                @if (User.HasClaim("permission", DocinadeApp.Models.Permissions.ApplicationPermissions.Instituciones.VER_DETALLES))
                                                {
                                                    <a asp-action="Details" asp-route-id="@item.Id" 
                                                       class="btn btn-sm btn-info" title="Ver Detalles">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                }
                                                @if (User.HasClaim("permission", DocinadeApp.Models.Permissions.ApplicationPermissions.Instituciones.EDITAR))
                                                {
                                                    <a asp-action="Edit" asp-route-id="@item.Id" 
                                                       class="btn btn-sm btn-warning" title="Editar">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                }
                                                @if (User.HasClaim("permission", DocinadeApp.Models.Permissions.ApplicationPermissions.Instituciones.ELIMINAR) && item.Estado)
                                                {
                                                    <a asp-action="Delete" asp-route-id="@item.Id" 
                                                       class="btn btn-sm btn-danger" title="Eliminar">
                                                        <i class="fas fa-trash"></i>
                                                    </a>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="alert alert-info text-center" role="alert">
                        <i class="fas fa-info-circle fa-2x mb-2"></i>
                        <p class="mb-0">No se encontraron instituciones educativas.</p>
                        @if (User.HasClaim("permission", DocinadeApp.Models.Permissions.ApplicationPermissions.Instituciones.CREAR))
                        {
                            <a asp-action="Create" class="btn btn-success mt-3">
                                <i class="fas fa-plus"></i> Crear Primera Institución
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</main>

@section Scripts {
    <script>
        // Auto-cerrar alertas después de 5 segundos
        setTimeout(function() {
            $('.alert-dismissible').fadeOut('slow');
        }, 5000);
    </script>
}

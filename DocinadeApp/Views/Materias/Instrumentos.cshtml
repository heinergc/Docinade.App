@model IEnumerable<DocinadeApp.ViewModels.InstrumentoAsignadoVm>

@{
    ViewData["Title"] = "Instrumentos Asignados";
    var materia = ViewBag.Materia as DocinadeApp.ViewModels.Academic.MateriaVm;
}

<div class="row">
    <div class="col-md-12">
        <div class="card">
            <div class="card-header">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h3 class="card-title mb-0">
                            <i class="fas fa-tools"></i> Instrumentos de Evaluación
                        </h3>
                        <div class="card-subtitle mt-1">
                            <span class="badge bg-primary">@materia?.Codigo</span>
                            <span class="text-muted">@materia?.Nombre</span>
                        </div>
                    </div>
                    <div>
                        <a asp-action="AsignarInstrumentos" asp-route-id="@materia?.MateriaId" class="btn btn-success">
                            <i class="fas fa-plus"></i> Gestionar Instrumentos
                        </a>
                    </div>
                </div>
            </div>
            
            <div class="card-body">
                @if (Model.Any())
                {
                    <div class="mb-3">
                        <div class="row">
                            <div class="col-md-6">
                                <p class="mb-0">
                                    <i class="fas fa-info-circle text-info"></i>
                                    <strong>Total de instrumentos asignados:</strong> 
                                    <span class="badge bg-primary">@Model.Count()</span>
                                </p>
                            </div>
                            <div class="col-md-6 text-end">
                                <p class="mb-0">
                                    <i class="fas fa-star text-warning"></i>
                                    <strong>Obligatorios:</strong> 
                                    <span class="badge bg-warning">@Model.Count(i => i.EsObligatorio)</span>
                                    <span class="mx-2">|</span>
                                    <i class="fas fa-circle text-secondary"></i>
                                    <strong>Opcionales:</strong> 
                                    <span class="badge bg-secondary">@Model.Count(i => !i.EsObligatorio)</span>
                                </p>
                            </div>
                        </div>
                    </div>
                    
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th><i class="fas fa-sort-numeric-up"></i> Orden</th>
                                    <th><i class="fas fa-tools"></i> Instrumento</th>
                                    <th><i class="fas fa-calendar"></i> Período Académico</th>
                                    <th><i class="fas fa-clock"></i> Fecha Asignación</th>
                                    <th><i class="fas fa-star"></i> Tipo</th>
                                    <th class="text-center"><i class="fas fa-cogs"></i> Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var instrumento in Model.OrderBy(i => i.OrdenPresentacion ?? int.MaxValue).ThenBy(i => i.InstrumentoNombre))
                                {
                                    <tr>
                                        <td>
                                            @if (instrumento.OrdenPresentacion.HasValue)
                                            {
                                                <span class="badge bg-primary fs-6">@instrumento.OrdenPresentacion</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <i class="fas fa-tools text-primary me-2"></i>
                                                <div>
                                                    <strong>@instrumento.InstrumentoNombre</strong>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="badge bg-info px-3 py-2">
                                                <i class="fas fa-calendar me-1"></i>
                                                @instrumento.PeriodoAcademicoNombre
                                            </span>
                                        </td>
                                        <td>
                                            <small class="text-muted">
                                                <i class="fas fa-clock me-1"></i>
                                                @instrumento.FechaAsignacion.ToString("dd/MM/yyyy")
                                                <br>
                                                @instrumento.FechaAsignacion.ToString("HH:mm")
                                            </small>
                                        </td>
                                        <td>
                                            @if (instrumento.EsObligatorio)
                                            {
                                                <span class="badge bg-warning px-3 py-2">
                                                    <i class="fas fa-star me-1"></i> Obligatorio
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary px-3 py-2">
                                                    <i class="fas fa-circle me-1"></i> Opcional
                                                </span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            <div class="btn-group" role="group">
                                                <a href="#" class="btn btn-outline-primary btn-sm" 
                                                   data-bs-toggle="tooltip" title="Ver detalles del instrumento">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                                <a asp-controller="InstrumentoMaterias" 
                                                   asp-action="Edit" 
                                                   asp-route-instrumentoId="@instrumento.InstrumentoId" 
                                                   asp-route-materiaId="@materia?.MateriaId" 
                                                   class="btn btn-outline-warning btn-sm"
                                                   data-bs-toggle="tooltip" title="Editar relación">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <div class="mb-4">
                            <i class="fas fa-tools fa-4x text-muted"></i>
                        </div>
                        <h5 class="text-muted mb-3">Sin Instrumentos Asignados</h5>
                        <p class="text-muted mb-4">
                            Esta materia no tiene instrumentos de evaluación asignados.
                        </p>
                        <a asp-action="AsignarInstrumentos" asp-route-id="@materia?.MateriaId" class="btn btn-primary">
                            <i class="fas fa-plus-circle"></i> Asignar Primer Instrumento
                        </a>
                    </div>
                }
            </div>
            
            <div class="card-footer">
                <div class="d-flex justify-content-between">
                    <div class="btn-group" role="group">
                        <a asp-action="Details" asp-route-id="@materia?.MateriaId" class="btn btn-secondary">
                            <i class="fas fa-arrow-left"></i> Volver a Detalles
                        </a>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="fas fa-list"></i> Lista de Materias
                        </a>
                    </div>
                    
                    @if (Model.Any())
                    {
                        <div class="btn-group" role="group">
                            <a asp-action="AsignarInstrumentos" asp-route-id="@materia?.MateriaId" class="btn btn-success">
                                <i class="fas fa-plus"></i> Gestionar Instrumentos
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Inicializar tooltips
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl);
            });
        });
    </script>
}
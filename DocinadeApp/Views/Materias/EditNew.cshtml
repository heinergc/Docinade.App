@model RubricasApp.Web.ViewModels.Academic.MateriaEditVm

@{
    ViewData["Title"] = "Editar Materia";
}

<div class="main-container">
    <!-- Sección de Encabezado -->
    <div class="header-section">
        <div>
            <h2><i class="fas fa-edit"></i> Editar Materia</h2>
            <p class="text-muted mb-0">Modifica la información de la materia <strong>@Model.Codigo</strong></p>
        </div>
        <div class="header-actions">
            <a asp-action="Details" asp-route-id="@Model.MateriaId" class="btn btn-outline-info">
                <i class="fas fa-eye"></i> Ver Detalles
            </a>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="fas fa-list"></i> Volver a la Lista
            </a>
        </div>
    </div>

    <form asp-action="Edit" method="post" novalidate>
        <div class="row">
            <div class="col-md-8">
                <!-- Formulario Principal -->
                <div class="card card-primary mb-4">
                    <div class="card-header">
                        <h5 class="card-title">
                            <i class="fas fa-edit"></i> Información de la Materia
                        </h5>
                        <span class="badge bg-light text-dark">@Model.Codigo</span>
                    </div>
                    <div class="card-body">
                        <input asp-for="MateriaId" type="hidden" />
                        
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="Codigo" class="form-label">
                                        <i class="fas fa-code"></i> Código
                                    </label>
                                    <input asp-for="Codigo" class="form-control" placeholder="Ej: MAT101" />
                                    <span asp-validation-for="Codigo" class="invalid-feedback"></span>
                                </div>
                                
                                <div class="form-group">
                                    <label asp-for="Nombre" class="form-label">
                                        <i class="fas fa-book-open"></i> Nombre
                                    </label>
                                    <input asp-for="Nombre" class="form-control" placeholder="Nombre de la materia" />
                                    <span asp-validation-for="Nombre" class="invalid-feedback"></span>
                                </div>
                            </div>
                            
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="Creditos" class="form-label">
                                        <i class="fas fa-graduation-cap"></i> Créditos
                                    </label>
                                    <input asp-for="Creditos" type="number" min="0" max="10" class="form-control" />
                                    <span asp-validation-for="Creditos" class="invalid-feedback"></span>
                                </div>
                                
                                <div class="form-group">
                                    <label asp-for="Tipo" class="form-label">
                                        <i class="fas fa-tag"></i> Tipo
                                    </label>
                                    <select asp-for="Tipo" class="form-control form-select">
                                        <option value="">Seleccionar tipo</option>
                                        <option value="Teórica">Teórica</option>
                                        <option value="Práctica">Práctica</option>
                                        <option value="Virtual">Virtual</option>
                                        <option value="Híbrida">Híbrida</option>
                                    </select>
                                    <span asp-validation-for="Tipo" class="invalid-feedback"></span>
                                </div>
                                
                                <div class="form-group">
                                    <label class="form-label">
                                        <i class="fas fa-toggle-on"></i> Estado
                                    </label>
                                    <div class="d-flex align-items-center gap-2">
                                        <input asp-for="Activa" type="checkbox" class="form-check-input" id="activaCheck" />
                                        <label for="activaCheck" class="form-check-label">Materia Activa</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="form-group">
                            <label asp-for="Descripcion" class="form-label">
                                <i class="fas fa-file-text"></i> Descripción
                            </label>
                            <textarea asp-for="Descripcion" class="form-control" rows="4" 
                                      placeholder="Descripción de la materia (opcional)"></textarea>
                            <span asp-validation-for="Descripcion" class="invalid-feedback"></span>
                        </div>
                        
                        <!-- Botones de acción -->
                        <div class="card-footer">
                            <div class="d-flex justify-content-between align-items-center">
                                <div class="btn-group" role="group">
                                    <button type="submit" class="btn btn-primary">
                                        <i class="fas fa-save"></i> Guardar Cambios
                                    </button>
                                    <a asp-action="Details" asp-route-id="@Model.MateriaId" class="btn btn-outline-info">
                                        <i class="fas fa-eye"></i> Ver Detalles
                                    </a>
                                    <a asp-action="Index" class="btn btn-secondary">
                                        <i class="fas fa-times"></i> Cancelar
                                    </a>
                                </div>
                                
                                @* Ejemplo de información de modificación *@
                                <small class="text-muted">
                                    <i class="fas fa-clock"></i>
                                    Edición en curso
                                </small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Sidebar con información adicional -->
            <div class="col-md-4">
                <!-- Información Actual -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title">
                            <i class="fas fa-info-circle"></i> Información Actual
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <div class="d-flex justify-content-between">
                                <span class="text-muted">
                                    <i class="fas fa-book me-1"></i> Materia:
                                </span>
                                <strong>@Model.Nombre</strong>
                            </div>
                        </div>
                        <div class="mb-3">
                            <div class="d-flex justify-content-between">
                                <span class="text-muted">
                                    <i class="fas fa-graduation-cap me-1"></i> Créditos:
                                </span>
                                <strong>@Model.Creditos</strong>
                            </div>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.Tipo))
                        {
                            <div class="mb-3">
                                <div class="d-flex justify-content-between">
                                    <span class="text-muted">
                                        <i class="fas fa-tag me-1"></i> Tipo:
                                    </span>
                                    <strong>@Model.Tipo</strong>
                                </div>
                            </div>
                        }
                        <div class="mb-0">
                            <div class="d-flex justify-content-between">
                                <span class="text-muted">
                                    <i class="fas fa-toggle-on me-1"></i> Estado:
                                </span>
                                <strong class="@(Model.Activa ? "text-success" : "text-secondary")">
                                    @(Model.Activa ? "Activa" : "Inactiva")
                                </strong>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Acciones Adicionales -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="card-title">
                            <i class="fas fa-cogs"></i> Acciones Adicionales
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="d-grid gap-2">
                            <a asp-action="Details" asp-route-id="@Model.MateriaId" class="btn btn-outline-info">
                                <i class="fas fa-eye me-2"></i> Ver Detalles Completos
                            </a>
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="fas fa-list me-2"></i> Volver a Lista
                            </a>
                            
                            <hr class="my-2" />
                            
                            <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteModal">
                                <i class="fas fa-trash me-2"></i> Eliminar Materia
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Ayuda -->
                <div class="card">
                    <div class="card-header">
                        <h5 class="card-title">
                            <i class="fas fa-question-circle"></i> Ayuda
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <div class="d-flex align-items-start gap-2">
                                <i class="fas fa-info-circle text-primary mt-1"></i>
                                <div>
                                    <strong>Código:</strong>
                                    <small class="text-muted d-block">Identificador único de la materia (ej: MAT101)</small>
                                </div>
                            </div>
                        </div>
                        <div class="mb-3">
                            <div class="d-flex align-items-start gap-2">
                                <i class="fas fa-graduation-cap text-primary mt-1"></i>
                                <div>
                                    <strong>Créditos:</strong>
                                    <small class="text-muted d-block">Valor académico entre 0 y 10 créditos</small>
                                </div>
                            </div>
                        </div>
                        <div class="mb-0">
                            <div class="d-flex align-items-start gap-2">
                                <i class="fas fa-tag text-primary mt-1"></i>
                                <div>
                                    <strong>Tipo:</strong>
                                    <small class="text-muted d-block">Modalidad de enseñanza de la materia</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<!-- Modal de confirmación para eliminar -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteModalLabel">
                    <i class="fas fa-exclamation-triangle"></i> Confirmar Eliminación
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>¿Está seguro que desea eliminar la materia <strong>@Model.Codigo - @Model.Nombre</strong>?</p>
                <div class="alert alert-warning">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    <strong>Advertencia:</strong> Esta acción no se puede deshacer.
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times"></i> Cancelar
                </button>
                <a asp-action="Delete" asp-route-id="@Model.MateriaId" class="btn btn-danger">
                    <i class="fas fa-trash"></i> Eliminar
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Inicializar tooltips si está disponible Bootstrap
            if (typeof bootstrap !== 'undefined' && bootstrap.Tooltip) {
                var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
                var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
                    return new bootstrap.Tooltip(tooltipTriggerEl);
                });
            }
            
            // Validación en tiempo real
            const form = document.querySelector('form');
            if (form) {
                form.addEventListener('submit', function(e) {
                    const isValid = form.checkValidity();
                    if (!isValid) {
                        e.preventDefault();
                        e.stopPropagation();
                    }
                    form.classList.add('was-validated');
                });
            }
        });
    </script>
}

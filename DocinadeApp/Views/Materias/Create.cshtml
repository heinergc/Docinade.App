@model DocinadeApp.ViewModels.Academic.CrearMateriaVm

@{
    ViewData["Title"] = "Nueva Materia";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <!-- Header de Página -->
            <div class="card mb-4">
                <div class="card-header bg-success text-white">
                    <h3 class="card-title mb-0">
                        <i class="fas fa-plus-circle"></i> Nueva Materia
                    </h3>
                </div>
            </div>

            <!-- Mensajes de alerta -->
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <!-- Formulario Principal -->
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-book"></i> Información de la Nueva Materia
                    </h5>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post">
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger" role="alert">
                                <i class="fas fa-exclamation-circle"></i>
                                <strong>Por favor, corrija los siguientes errores:</strong>
                                <div asp-validation-summary="All" class="mt-2"></div>
                            </div>
                        }
                        
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Codigo" class="form-label">
                                        <i class="fas fa-code"></i> @Html.DisplayNameFor(m => m.Codigo)
                                    </label>
                                    <input asp-for="Codigo" class="form-control" placeholder="Ej: MAT101" />
                                    <span asp-validation-for="Codigo" class="text-danger"></span>
                                    <div class="form-text">Código único identificador de la materia</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Nombre" class="form-label">
                                        <i class="fas fa-book"></i> @Html.DisplayNameFor(m => m.Nombre)
                                    </label>
                                    <input asp-for="Nombre" class="form-control" placeholder="Nombre de la materia" />
                                    <span asp-validation-for="Nombre" class="text-danger"></span>
                                    <div class="form-text">Nombre completo de la materia</div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="row">
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label asp-for="Creditos" class="form-label">
                                        <i class="fas fa-star"></i> @Html.DisplayNameFor(m => m.Creditos)
                                    </label>
                                    <input asp-for="Creditos" class="form-control" type="number" min="0" max="10" />
                                    <span asp-validation-for="Creditos" class="text-danger"></span>
                                    <div class="form-text">Valor académico (0-10)</div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label asp-for="Tipo" class="form-label">
                                        <i class="fas fa-tag"></i> @Html.DisplayNameFor(m => m.Tipo)
                                    </label>
                                    <select asp-for="Tipo" class="form-select">
                                        <option value="">Seleccionar tipo</option>
                                        <option value="Teórica">Teórica</option>
                                        <option value="Práctica">Práctica</option>
                                        <option value="Virtual">Virtual</option>
                                        <option value="Híbrida">Híbrida</option>
                                    </select>
                                    <span asp-validation-for="Tipo" class="text-danger"></span>
                                    <div class="form-text">Modalidad de enseñanza</div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label class="form-label">
                                        <i class="fas fa-toggle-on"></i> Estado
                                    </label>
                                    <div class="form-check form-switch mt-2">
                                        <input asp-for="Activa" class="form-check-input" type="checkbox" checked />
                                        <label asp-for="Activa" class="form-check-label">
                                            Materia Activa
                                        </label>
                                    </div>
                                    <div class="form-text">Define si la materia está disponible</div>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Descripcion" class="form-label">
                                <i class="fas fa-align-left"></i> @Html.DisplayNameFor(m => m.Descripcion)
                            </label>
                            <textarea asp-for="Descripcion" class="form-control" rows="4" placeholder="Descripción de la materia (opcional)"></textarea>
                            <span asp-validation-for="Descripcion" class="text-danger"></span>
                            <div class="form-text">Información adicional sobre la materia (opcional)</div>
                        </div>

                        <!-- Botones de Acción -->
                        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mt-4">
                            <div class="btn-group" role="group">
                                <button type="submit" class="btn btn-success">
                                    <i class="fas fa-save"></i> Guardar Materia
                                </button>
                                <a asp-action="Index" class="btn btn-secondary">
                                    <i class="fas fa-times"></i> Cancelar
                                </a>
                            </div>
                            <small class="text-muted">
                                <i class="fas fa-info-circle"></i>
                                Los campos marcados con * son obligatorios
                            </small>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Sidebar de ayuda -->
    <div class="row mt-4">
        <div class="col-md-8 offset-md-2">
            <div class="card border-info">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-question-circle"></i> Ayuda para crear una nueva materia
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4">
                            <div class="help-item p-3 border rounded mb-3">
                                <i class="fas fa-code text-primary mb-2"></i>
                                <h6>Código</h6>
                                <small class="text-muted">
                                    Debe ser único en el sistema. Ejemplo: MAT101, FIS201, etc.
                                </small>
                            </div>
                        </div>
                        
                        <div class="col-md-4">
                            <div class="help-item p-3 border rounded mb-3">
                                <i class="fas fa-star text-warning mb-2"></i>
                                <h6>Créditos</h6>
                                <small class="text-muted">
                                    Valor académico entre 0 y 10. Determina la carga horaria de la materia.
                                </small>
                            </div>
                        </div>
                        
                        <div class="col-md-4">
                            <div class="help-item p-3 border rounded mb-3">
                                <i class="fas fa-tag text-success mb-2"></i>
                                <h6>Tipo</h6>
                                <small class="text-muted">
                                    Define la modalidad: Teórica, Práctica, Virtual o Híbrida.
                                </small>
                            </div>
                        </div>
                    </div>
                    
                    <div class="alert alert-info mt-3">
                        <i class="fas fa-lightbulb"></i>
                        <strong>Sugerencia:</strong> Asegúrese de que el código de la materia siga las convenciones de su institución educativa.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        $(document).ready(function() {
            // Auto-generar código basado en el nombre (opcional)
            $('#Nombre').on('blur', function() {
                var nombre = $(this).val();
                var codigo = $('#Codigo').val();
                
                if (!codigo && nombre) {
                    // Sugerir un código basado en las primeras letras
                    var palabras = nombre.split(' ');
                    var sugerencia = '';
                    for (var i = 0; i < Math.min(palabras.length, 2); i++) {
                        sugerencia += palabras[i].substring(0, 3).toUpperCase();
                    }
                    if (sugerencia) {
                        $('#Codigo').attr('placeholder', 'Ej: ' + sugerencia + '101');
                    }
                }
            });
            
            // Validación en tiempo real
            $('form input, form select, form textarea').on('blur', function() {
                $(this).removeClass('is-invalid is-valid');
                if ($(this).val() && $(this)[0].checkValidity()) {
                    $(this).addClass('is-valid');
                } else if ($(this).val()) {
                    $(this).addClass('is-invalid');
                }
            });
        });
    </script>
    
    <style>
        .help-item {
            text-align: center;
            background-color: #f8f9fa;
        }
        
        .help-item i {
            font-size: 2rem;
            display: block;
        }
        
        .help-item h6 {
            margin-top: 0.5rem;
            color: #495057;
        }
    </style>
}
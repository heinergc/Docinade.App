@model DocinadeApp.Models.GrupoCalificacion

@{
    ViewData["Title"] = "Detalles del Grupo";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title mb-0">
                        <i class="fas fa-layer-group me-2"></i>
                        @Model.NombreGrupo
                    </h3>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.NombreGrupo)</dt>
                        <dd class="col-sm-9">@Html.DisplayFor(model => model.NombreGrupo)</dd>

                        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Descripcion)</dt>
                        <dd class="col-sm-9">
                            @if (!string.IsNullOrEmpty(Model.Descripcion))
                            {
                                @Html.DisplayFor(model => model.Descripcion)
                            }
                            else
                            {
                                <span class="text-muted">Sin descripción</span>
                            }
                        </dd>

                        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Estado)</dt>
                        <dd class="col-sm-9">
                            @if (Model.Estado == "ACTIVO")
                            {
                                <span class="badge bg-success">@Model.Estado</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">@Model.Estado</span>
                            }
                        </dd>

                        <dt class="col-sm-3">@Html.DisplayNameFor(model => model.FechaCreacion)</dt>
                        <dd class="col-sm-9">@Model.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</dd>
                    </dl>
                    
                    <div class="mt-4">
                        <a asp-action="Edit" asp-route-id="@Model.IdGrupo" class="btn btn-warning">
                            <i class="fas fa-edit me-1"></i>
                            Editar
                        </a>
                        <a asp-action="AssignLevels" asp-route-id="@Model.IdGrupo" class="btn btn-success">
                            <i class="fas fa-users-cog me-1"></i>
                            Asignar Niveles
                        </a>
                        <a asp-action="Delete" asp-route-id="@Model.IdGrupo" class="btn btn-danger">
                            <i class="fas fa-trash me-1"></i>
                            Eliminar
                        </a>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="fas fa-arrow-left me-1"></i>
                            Volver a la Lista
                        </a>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <h5><i class="fas fa-chart-bar me-2"></i>Estadísticas</h5>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-6">
                            <div class="border rounded p-3">
                                <h4 class="text-primary">@Model.NivelesCalificacion.Count</h4>
                                <small class="text-muted">Niveles</small>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="border rounded p-3">
                                <h4 class="text-success">@Model.Rubricas.Count</h4>
                                <small class="text-muted">Rúbricas</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            @if (Model.NivelesCalificacion.Any())
            {
                <div class="card mt-3">
                    <div class="card-header">
                        <h5><i class="fas fa-star me-2"></i>Niveles de Calificación</h5>
                    </div>
                    <div class="card-body">
                        <div class="list-group">
                            @foreach (var nivel in Model.NivelesCalificacion.OrderBy(n => n.OrdenNivel ?? int.MaxValue).ThenBy(n => n.NombreNivel))
                            {
                                <div class="list-group-item">
                                    <div class="d-flex w-100 justify-content-between">
                                        <h6 class="mb-1">@nivel.NombreNivel</h6>
                                        @if (nivel.OrdenNivel.HasValue)
                                        {
                                            <small class="badge bg-info">@nivel.OrdenNivel</small>
                                        }
                                    </div>
                                    @if (!string.IsNullOrEmpty(nivel.Descripcion))
                                    {
                                        <p class="mb-1 text-muted small">@nivel.Descripcion</p>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
            
            @if (Model.Rubricas.Any())
            {
                <div class="card mt-3">
                    <div class="card-header">
                        <h5><i class="fas fa-list me-2"></i>Rúbricas Asociadas</h5>
                    </div>
                    <div class="card-body">
                        <div class="list-group">
                            @foreach (var rubrica in Model.Rubricas.OrderBy(r => r.NombreRubrica))
                            {
                                <div class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <h6 class="mb-0">@rubrica.NombreRubrica</h6>
                                        @if (!string.IsNullOrEmpty(rubrica.Descripcion))
                                        {
                                            <small class="text-muted">@rubrica.Descripcion</small>
                                        }
                                    </div>
                                    <a asp-controller="Rubricas" asp-action="Details" asp-route-id="@rubrica.IdRubrica" 
                                       class="btn btn-outline-primary btn-sm">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
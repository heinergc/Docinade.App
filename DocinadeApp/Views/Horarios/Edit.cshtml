@model DocinadeApp.Models.Leccion

@{
    ViewData["Title"] = "Editar Lección";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card">
                <div class="card-header bg-warning">
                    <h3 class="mb-0">
                        <i class="fas fa-edit me-2"></i>@ViewData["Title"]
                    </h3>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <input type="hidden" asp-for="IdLeccion" />
                        <input type="hidden" asp-for="FechaCreacion" />

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="IdGrupo" class="form-label">Grupo *</label>
                                <select asp-for="IdGrupo" class="form-select" id="grupoSelect">
                                    <option value="">-- Seleccione grupo --</option>
                                    @foreach (var item in ViewBag.Grupos as IEnumerable<SelectListItem>)
                                    {
                                        <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                                    }
                                </select>
                                <span asp-validation-for="IdGrupo" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="MateriaId" class="form-label">Materia *</label>
                                <select asp-for="MateriaId" class="form-select" id="materiaSelect">
                                    <option value="">-- Seleccione materia --</option>
                                    @foreach (var item in ViewBag.Materias as IEnumerable<SelectListItem>)
                                    {
                                        <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                                    }
                                </select>
                                <span asp-validation-for="MateriaId" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="DiaSemana" class="form-label">Día de la Semana *</label>
                                <select asp-for="DiaSemana" class="form-select" id="diaSelect">
                                    <option value="">-- Seleccione día --</option>
                                    <option value="1">Lunes</option>
                                    <option value="2">Martes</option>
                                    <option value="3">Miércoles</option>
                                    <option value="4">Jueves</option>
                                    <option value="5">Viernes</option>
                                    <option value="6">Sábado</option>
                                    <option value="0">Domingo</option>
                                </select>
                                <span asp-validation-for="DiaSemana" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="NumeroBloque" class="form-label">Número de Bloque *</label>
                                <input asp-for="NumeroBloque" type="number" class="form-control" min="1" max="12" />
                                <span asp-validation-for="NumeroBloque" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="HoraInicio" class="form-label">Hora de Inicio *</label>
                                <input asp-for="HoraInicio" type="time" class="form-control" id="horaInicio" />
                                <span asp-validation-for="HoraInicio" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="HoraFin" class="form-label">Hora de Fin *</label>
                                <input asp-for="HoraFin" type="time" class="form-control" id="horaFin" />
                                <span asp-validation-for="HoraFin" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-12">
                                <label asp-for="Observaciones" class="form-label">Observaciones</label>
                                <textarea asp-for="Observaciones" class="form-control" rows="3"></textarea>
                                <span asp-validation-for="Observaciones" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-12">
                                <div class="form-check">
                                    <input asp-for="Activa" class="form-check-input" type="checkbox" />
                                    <label asp-for="Activa" class="form-check-label">
                                        Lección Activa
                                    </label>
                                </div>
                            </div>
                        </div>

                        <!-- Alert para mostrar conflictos -->
                        <div id="alertConflictos" class="alert alert-warning" style="display: none;">
                            <h5><i class="fas fa-exclamation-triangle"></i> Conflictos Detectados</h5>
                            <ul id="listaConflictos"></ul>
                        </div>

                        <!-- Información de auditoría -->
                        <div class="card mb-3">
                            <div class="card-body bg-light">
                                <h6 class="card-title">Información de Auditoría</h6>
                                <div class="row">
                                    <div class="col-md-6">
                                        <small>
                                            <strong>Creado:</strong> @Model.FechaCreacion.ToString("dd/MM/yyyy HH:mm")
                                        </small>
                                    </div>
                                    @if (Model.FechaModificacion.HasValue)
                                    {
                                        <div class="col-md-6">
                                            <small>
                                                <strong>Última Modificación:</strong> @Model.FechaModificacion.Value.ToString("dd/MM/yyyy HH:mm")
                                            </small>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-arrow-left me-1"></i>Cancelar
                            </a>
                            <button type="submit" class="btn btn-warning">
                                <i class="fas fa-save me-1"></i>Actualizar
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        $(document).ready(function() {
            // Verificar conflictos al cargar
            verificarConflictos();

            // Configurar verificación de conflictos
            let timeoutId;
            $('#grupoSelect, #materiaSelect, #diaSelect, #horaInicio, #horaFin').on('change input', function() {
                clearTimeout(timeoutId);
                timeoutId = setTimeout(verificarConflictos, 500);
            });

            // Validación de horarios
            $('#horaFin').on('change', function() {
                const horaInicio = $('#horaInicio').val();
                const horaFin = $(this).val();
                
                if (horaInicio && horaFin && horaFin <= horaInicio) {
                    alert('La hora de fin debe ser mayor que la hora de inicio');
                    $(this).val('');
                }
            });
        });

        function verificarConflictos() {
            const grupoId = $('#grupoSelect').val();
            const materiaId = $('#materiaSelect').val();
            const diaSemana = $('#diaSelect').val();
            const horaInicio = $('#horaInicio').val();
            const horaFin = $('#horaFin').val();
            const leccionId = @Model.IdLeccion;

            if (!grupoId || !diaSemana || !horaInicio || !horaFin) {
                $('#alertConflictos').hide();
                return;
            }

            $.ajax({
                url: '@Url.Action("GetConflictos", "Horarios")',
                type: 'GET',
                data: {
                    grupoId: grupoId,
                    materiaId: materiaId,
                    diaSemana: diaSemana,
                    horaInicio: horaInicio,
                    horaFin: horaFin,
                    leccionId: leccionId
                },
                success: function(response) {
                    if (response.conflictos && response.conflictos.length > 0) {
                        mostrarConflictos(response.conflictos);
                    } else {
                        $('#alertConflictos').hide();
                    }
                }
            });
        }

        function mostrarConflictos(conflictos) {
            const lista = $('#listaConflictos');
            lista.empty();
            
            conflictos.forEach(function(conflicto) {
                lista.append(`<li>${conflicto}</li>`);
            });
            
            $('#alertConflictos').show();
        }
    </script>
}

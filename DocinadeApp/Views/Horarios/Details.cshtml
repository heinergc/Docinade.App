@model RubricasApp.Web.Models.Leccion

@{
    ViewData["Title"] = "Detalles de la Lección";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">
                        <i class="fas fa-info-circle me-2"></i>@ViewData["Title"]
                    </h3>
                </div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-3">Grupo</dt>
                        <dd class="col-sm-9">
                            <span class="badge bg-primary fs-6">@Model.Grupo?.Nombre</span>
                        </dd>

                        <dt class="col-sm-3">Materia</dt>
                        <dd class="col-sm-9">
                            <span class="badge bg-success fs-6">@Model.Materia?.Nombre</span>
                        </dd>

                        <dt class="col-sm-3">Día</dt>
                        <dd class="col-sm-9">
                            @switch (Model.DiaSemana)
                            {
                                case DayOfWeek.Monday: <strong>Lunes</strong> break;
                                case DayOfWeek.Tuesday: <strong>Martes</strong> break;
                                case DayOfWeek.Wednesday: <strong>Miércoles</strong> break;
                                case DayOfWeek.Thursday: <strong>Jueves</strong> break;
                                case DayOfWeek.Friday: <strong>Viernes</strong> break;
                                case DayOfWeek.Saturday: <strong>Sábado</strong> break;
                                case DayOfWeek.Sunday: <strong>Domingo</strong> break;
                            }
                        </dd>

                        <dt class="col-sm-3">Horario</dt>
                        <dd class="col-sm-9">
                            <span class="badge bg-dark fs-6">@Model.HorarioFormateado</span>
                        </dd>

                        <dt class="col-sm-3">Bloque</dt>
                        <dd class="col-sm-9">
                            <span class="badge bg-info fs-6">Bloque @Model.NumeroBloque</span>
                        </dd>

                        <dt class="col-sm-3">Observaciones</dt>
                        <dd class="col-sm-9">
                            @if (!string.IsNullOrEmpty(Model.Observaciones))
                            {
                                <span class="text-muted">@Model.Observaciones</span>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </dd>

                        <dt class="col-sm-3">Estado</dt>
                        <dd class="col-sm-9">
                            @if (Model.Activa)
                            {
                                <span class="badge bg-success fs-6">
                                    <i class="fas fa-check-circle me-1"></i>Activa
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary fs-6">
                                    <i class="fas fa-ban me-1"></i>Inactiva
                                </span>
                            }
                        </dd>
                    </dl>

                    <hr />

                    <h5 class="mb-3">Información de Auditoría</h5>
                    <dl class="row">
                        <dt class="col-sm-3">Creado</dt>
                        <dd class="col-sm-9">@Model.FechaCreacion.ToString("dd/MM/yyyy HH:mm")</dd>

                        @if (Model.FechaModificacion.HasValue)
                        {
                            <dt class="col-sm-3">Última Modificación</dt>
                            <dd class="col-sm-9">@Model.FechaModificacion.Value.ToString("dd/MM/yyyy HH:mm")</dd>
                        }

                        <dt class="col-sm-3">Total Asistencias</dt>
                        <dd class="col-sm-9">
                            <span class="badge bg-info fs-6">@Model.AsistenciasRegistradas registros</span>
                        </dd>
                    </dl>

                    <hr />

                    <div class="d-flex justify-content-between mt-4">
                        <div>
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-arrow-left me-1"></i>Volver
                            </a>
                            <a asp-action="Edit" asp-route-id="@Model.IdLeccion" class="btn btn-warning">
                                <i class="fas fa-edit me-1"></i>Editar
                            </a>
                        </div>
                        <div>
                            <button class="btn btn-@(Model.Activa ? "secondary" : "success")" 
                                    onclick="toggleActivo(@Model.IdLeccion, @Model.Activa.ToString().ToLower())">
                                <i class="fas fa-@(Model.Activa ? "ban" : "check")"></i>
                                @(Model.Activa ? "Desactivar" : "Activar")
                            </button>
                        </div>
                    </div>

                    <div class="card mt-4">
                        <div class="card-header">
                            <h5 class="mb-0">Acciones Relacionadas</h5>
                        </div>
                        <div class="card-body">
                            <div class="list-group">
                                <a asp-controller="AsistenciaLeccion" 
                                   asp-action="TomarAsistencia" 
                                   asp-route-idLeccion="@Model.IdLeccion"
                                   asp-route-fecha="@DateTime.Now.ToString("yyyy-MM-dd")"
                                   class="list-group-item list-group-item-action">
                                    <i class="fas fa-check-square me-2 text-success"></i>
                                    Tomar Asistencia
                                </a>
                                <a asp-controller="Horarios" 
                                   asp-action="HorarioSemanal" 
                                   asp-route-grupoId="@Model.IdGrupo"
                                   class="list-group-item list-group-item-action">
                                    <i class="fas fa-calendar-week me-2 text-primary"></i>
                                    Ver Horario Semanal del Grupo
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleActivo(id, estadoActual) {
            if (confirm(`¿Está seguro de ${estadoActual ? 'desactivar' : 'activar'} esta lección?`)) {
                $.post('@Url.Action("ToggleActivo", "Horarios")', { id: id }, function(response) {
                    if (response.success) {
                        location.reload();
                    } else {
                        alert('Error: ' + response.message);
                    }
                });
            }
        }
    </script>
}

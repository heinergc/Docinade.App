@using DocinadeApp.ViewModels.Account
@model RegisterViewModel
@{
    ViewData["Title"] = "Registrarse";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow">
            <div class="card-header bg-success text-white text-center">
                <h4>
                    <i class="fas fa-user-plus me-2"></i>
                    Crear Nueva Cuenta
                </h4>
            </div>
            <div class="card-body">
                <form asp-action="Register" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Nombre" class="form-label">
                                <i class="fas fa-user me-1"></i>
                                @Html.DisplayNameFor(m => m.Nombre)
                            </label>
                            <input asp-for="Nombre" class="form-control" placeholder="Nombre" />
                            <span asp-validation-for="Nombre" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="Apellidos" class="form-label">
                                <i class="fas fa-user me-1"></i>
                                @Html.DisplayNameFor(m => m.Apellidos)
                            </label>
                            <input asp-for="Apellidos" class="form-control" placeholder="Apellidos" />
                            <span asp-validation-for="Apellidos" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">
                            <i class="fas fa-envelope me-1"></i>
                            @Html.DisplayNameFor(m => m.Email)
                        </label>
                        <input asp-for="Email" class="form-control" autocomplete="username" placeholder="usuario@ejemplo.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Password" class="form-label">
                                <i class="fas fa-lock me-1"></i>
                                @Html.DisplayNameFor(m => m.Password)
                            </label>
                            <input asp-for="Password" class="form-control" autocomplete="new-password" placeholder="••••••••" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="ConfirmPassword" class="form-label">
                                <i class="fas fa-lock me-1"></i>
                                @Html.DisplayNameFor(m => m.ConfirmPassword)
                            </label>
                            <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" placeholder="••••••••" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Institucion" class="form-label">
                                <i class="fas fa-university me-1"></i>
                                @Html.DisplayNameFor(m => m.Institucion)
                            </label>
                            <input asp-for="Institucion" class="form-control" placeholder="Universidad o Institución" />
                            <span asp-validation-for="Institucion" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="Departamento" class="form-label">
                                <i class="fas fa-building me-1"></i>
                                @Html.DisplayNameFor(m => m.Departamento)
                            </label>
                            <input asp-for="Departamento" class="form-control" placeholder="Departamento o Facultad" />
                            <span asp-validation-for="Departamento" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Telefono" class="form-label">
                            <i class="fas fa-phone me-1"></i>
                            @Html.DisplayNameFor(m => m.Telefono)
                        </label>
                        <input asp-for="Telefono" class="form-control" placeholder="+506 1234-5678" />
                        <span asp-validation-for="Telefono" class="text-danger"></span>
                    </div>

                    <!-- Información sobre roles -->
                    <div class="alert alert-info">
                        <h6>
                            <i class="fas fa-info-circle me-1"></i>
                            Información sobre Roles
                        </h6>
                        <small>
                            Al registrarse, se le asignará el rol de <strong>Observador</strong> por defecto.
                            Un administrador podrá actualizar su rol según sea necesario.
                        </small>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-success">
                            <i class="fas fa-user-plus me-1"></i>
                            Crear Cuenta
                        </button>
                    </div>
                </form>

                <hr />
                
                <div class="text-center">
                    <p class="mb-0">
                        <a asp-action="Login" class="text-decoration-none">
                            <i class="fas fa-sign-in-alt me-1"></i>
                            ¿Ya tienes cuenta? Inicia sesión aquí
                        </a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    
    <script>
        // Validación adicional en el cliente
        $(document).ready(function() {
            // Formatear teléfono automáticamente
            $('#Telefono').on('input', function() {
                var value = $(this).val().replace(/\D/g, '');
                if (value.startsWith('506')) {
                    value = value.substring(3);
                }
                if (value.length >= 4) {
                    value = value.substring(0, 4) + '-' + value.substring(4, 8);
                }
                $(this).val('+506 ' + value);
            });

            // Mostrar/ocultar contraseña
            $('#showPassword').change(function() {
                var passwordField = $('#Password, #ConfirmPassword');
                if ($(this).is(':checked')) {
                    passwordField.attr('type', 'text');
                } else {
                    passwordField.attr('type', 'password');
                }
            });
        });
    </script>
}
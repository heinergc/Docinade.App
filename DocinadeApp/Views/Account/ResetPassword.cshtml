@model DocinadeApp.ViewModels.Account.ResetPasswordViewModel
@{
    ViewData["Title"] = "Restablecer Contraseña";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema de Rúbricas</title>
    
    <!-- Google Fonts y Font Awesome -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <!-- Estilos de la aplicación -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/login-styles.css" asp-append-version="true" />
</head>
<body class="login-page-background">

    <div class="login-container">
        <div class="login-card">
            <!-- Logo dinámico con íconos de Font Awesome -->
            <div class="dynamic-logo">
                <div class="logo-stack">
                    <i class="fas fa-lock primary-icon"></i>
                    <i class="fas fa-redo secondary-icon"></i>
                </div>
                <div class="logo-pulse"></div>
            </div>
            <h1 class="brand-name">Nueva Contraseña</h1>
            <h2>Crea una nueva contraseña segura</h2>

            <form asp-action="ResetPassword" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                
                <input asp-for="Email" type="hidden" />
                <input asp-for="Token" type="hidden" />

                <div class="alert alert-info" role="alert">
                    <i class="fas fa-info-circle me-2"></i>
                    <small>Restableciendo contraseña para: <strong>@Model.Email</strong></small>
                </div>

                <div class="form-group">
                    <label asp-for="Password">Nueva Contraseña</label>
                    <div class="input-group">
                        <span class="input-icon"><i class="fas fa-lock"></i></span>
                        <input asp-for="Password" type="password" class="form-control" placeholder="Mínimo 6 caracteres" required />
                    </div>
                    <span asp-validation-for="Password" class="text-danger"></span>
                    <small class="text-muted">
                        <i class="fas fa-shield-alt me-1"></i>
                        Usa al menos 6 caracteres con letras, números y símbolos
                    </small>
                </div>

                <div class="form-group">
                    <label asp-for="ConfirmPassword">Confirmar Contraseña</label>
                    <div class="input-group">
                        <span class="input-icon"><i class="fas fa-lock"></i></span>
                        <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Repite tu contraseña" required />
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-login">
                    <i class="fas fa-check me-2"></i>Restablecer Contraseña
                </button>

                <div class="login-divider"></div>

                <div class="text-center">
                    <a asp-action="Login" class="text-decoration-none">
                        <i class="fas fa-arrow-left me-1"></i>Volver al inicio de sesión
                    </a>
                </div>
            </form>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await Html.PartialAsync("_ValidationScriptsPartial")
</body>
</html>

@{
    ViewData["Title"] = "Correo Enviado";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema de Rúbricas</title>
    
    <!-- Google Fonts y Font Awesome -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <!-- Estilos de la aplicación -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/login-styles.css" asp-append-version="true" />
</head>
<body class="login-page-background">

    <div class="login-container">
        <div class="login-card text-center">
            <!-- Icono de éxito -->
            <div class="mb-4">
                <i class="fas fa-check-circle text-success" style="font-size: 5rem;"></i>
            </div>
            
            <h1 class="brand-name">Correo Enviado</h1>
            <h2 class="mb-4">Revisa tu bandeja de entrada</h2>
            
            <div class="alert alert-info text-start" role="alert">
                <i class="fas fa-info-circle me-2"></i>
                <strong>¿Qué hacer ahora?</strong>
                <ul class="mb-0 mt-2">
                    <li>Revisa tu correo electrónico (incluyendo la carpeta de spam)</li>
                    <li>Haz clic en el enlace que te enviamos</li>
                    <li>Sigue las instrucciones para crear una nueva contraseña</li>
                </ul>
            </div>

            <p class="text-muted" style="font-size: 14px;">
                El enlace expirará en 24 horas por razones de seguridad.
            </p>

            <div class="login-divider"></div>

            <a asp-action="Login" class="btn btn-login">
                <i class="fas fa-sign-in-alt me-2"></i>Volver al inicio de sesión
            </a>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

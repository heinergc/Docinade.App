@{
    ViewData["Title"] = "Contraseña Restablecida";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema de Rúbricas</title>
    
    <!-- Google Fonts y Font Awesome -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <!-- Estilos de la aplicación -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/login-styles.css" asp-append-version="true" />
</head>
<body class="login-page-background">

    <div class="login-container">
        <div class="login-card text-center">
            <!-- Icono de éxito -->
            <div class="mb-4">
                <i class="fas fa-check-circle text-success" style="font-size: 5rem;"></i>
            </div>
            
            <h1 class="brand-name">¡Contraseña Restablecida!</h1>
            <h2 class="mb-4">Ya puedes iniciar sesión</h2>
            
            <div class="alert alert-success text-start" role="alert">
                <i class="fas fa-check me-2"></i>
                <strong>Tu contraseña ha sido actualizada exitosamente</strong>
                <p class="mb-0 mt-2">
                    Ahora puedes iniciar sesión con tu nueva contraseña.
                </p>
            </div>

            <div class="alert alert-info text-start" role="alert">
                <i class="fas fa-lightbulb me-2"></i>
                <strong>Recomendaciones de seguridad:</strong>
                <ul class="mb-0 mt-2" style="font-size: 14px;">
                    <li>Guarda tu contraseña en un lugar seguro</li>
                    <li>No compartas tu contraseña con nadie</li>
                    <li>Cambia tu contraseña periódicamente</li>
                    <li>Usa contraseñas diferentes para cada servicio</li>
                </ul>
            </div>

            <a asp-action="Login" class="btn btn-login">
                <i class="fas fa-sign-in-alt me-2"></i>Iniciar Sesión
            </a>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

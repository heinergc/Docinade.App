@using RubricasApp.Web.ViewModels.Account
@model ChangePasswordViewModel
@{
    ViewData["Title"] = "Cambiar Contraseña";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow">
            <div class="card-header bg-warning text-dark text-center">
                <h4>
                    <i class="fas fa-key me-2"></i>
                    Cambiar Contraseña
                </h4>
            </div>
            <div class="card-body">
                <form asp-action="ChangePassword" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="CurrentPassword" class="form-label">
                            <i class="fas fa-lock me-1"></i>
                            @Html.DisplayNameFor(m => m.CurrentPassword)
                        </label>
                        <div class="input-group">
                            <input asp-for="CurrentPassword" class="form-control" autocomplete="current-password" id="currentPassword" />
                            <button class="btn btn-outline-secondary" type="button" id="toggleCurrentPassword">
                                <i class="fas fa-eye" id="currentPasswordIcon"></i>
                            </button>
                        </div>
                        <span asp-validation-for="CurrentPassword" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label">
                            <i class="fas fa-lock me-1"></i>
                            @Html.DisplayNameFor(m => m.NewPassword)
                        </label>
                        <div class="input-group">
                            <input asp-for="NewPassword" class="form-control" autocomplete="new-password" id="newPassword" />
                            <button class="btn btn-outline-secondary" type="button" id="toggleNewPassword">
                                <i class="fas fa-eye" id="newPasswordIcon"></i>
                            </button>
                        </div>
                        <span asp-validation-for="NewPassword" class="text-danger"></span>
                        
                        <!-- Indicador de fortaleza de contraseña -->
                        <div class="mt-2">
                            <div class="progress" style="height: 5px;">
                                <div class="progress-bar" id="passwordStrength" role="progressbar" style="width: 0%"></div>
                            </div>
                            <small class="text-muted" id="passwordStrengthText">Ingresa una nueva contraseña</small>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ConfirmPassword" class="form-label">
                            <i class="fas fa-lock me-1"></i>
                            @Html.DisplayNameFor(m => m.ConfirmPassword)
                        </label>
                        <div class="input-group">
                            <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" id="confirmPassword" />
                            <button class="btn btn-outline-secondary" type="button" id="toggleConfirmPassword">
                                <i class="fas fa-eye" id="confirmPasswordIcon"></i>
                            </button>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        
                        <!-- Indicador de coincidencia -->
                        <div class="mt-1">
                            <small class="text-muted" id="passwordMatch"></small>
                        </div>
                    </div>

                    <!-- Requisitos de contraseña -->
                    <div class="alert alert-info">
                        <h6>
                            <i class="fas fa-info-circle me-1"></i>
                            Requisitos de la Contraseña
                        </h6>
                        <ul class="mb-0 small">
                            <li id="length" class="text-muted">Al menos 6 caracteres</li>
                            <li id="uppercase" class="text-muted">Al menos una letra mayúscula</li>
                            <li id="lowercase" class="text-muted">Al menos una letra minúscula</li>
                            <li id="digit" class="text-muted">Al menos un número</li>
                            <li id="special" class="text-muted">Al menos un carácter especial (!#$%^&*)</li>
                        </ul>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-warning" id="submitButton" disabled>
                            <i class="fas fa-key me-1"></i>
                            Cambiar Contraseña
                        </button>
                    </div>
                </form>

                <hr />
                
                <div class="text-center">
                    <a asp-action="Profile" class="text-decoration-none">
                        <i class="fas fa-arrow-left me-1"></i>
                        Volver al Perfil
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    
    <script>
        $(document).ready(function() {
            // Toggle password visibility
            function togglePassword(inputId, iconId) {
                const input = document.getElementById(inputId);
                const icon = document.getElementById(iconId);
                
                if (input.type === 'password') {
                    input.type = 'text';
                    icon.classList.remove('fa-eye');
                    icon.classList.add('fa-eye-slash');
                } else {
                    input.type = 'password';
                    icon.classList.remove('fa-eye-slash');
                    icon.classList.add('fa-eye');
                }
            }

            $('#toggleCurrentPassword').click(function() {
                togglePassword('currentPassword', 'currentPasswordIcon');
            });

            $('#toggleNewPassword').click(function() {
                togglePassword('newPassword', 'newPasswordIcon');
            });

            $('#toggleConfirmPassword').click(function() {
                togglePassword('confirmPassword', 'confirmPasswordIcon');
            });

            // Password strength checker
            $('#newPassword').on('input', function() {
                const password = $(this).val();
                const strength = checkPasswordStrength(password);
                updatePasswordStrengthIndicator(strength);
                checkPasswordRequirements(password);
                checkPasswordMatch();
            });

            $('#confirmPassword').on('input', function() {
                checkPasswordMatch();
            });

            function checkPasswordStrength(password) {
                let strength = 0;
                
                if (password.length >= 6) strength += 20;
                if (password.length >= 10) strength += 10;
                if (/[a-z]/.test(password)) strength += 20;
                if (/[A-Z]/.test(password)) strength += 20;
                if (/[0-9]/.test(password)) strength += 15;
                if (/[^A-Za-z0-9]/.test(password)) strength += 15;
                
                return Math.min(strength, 100);
            }

            function updatePasswordStrengthIndicator(strength) {
                const progressBar = $('#passwordStrength');
                const text = $('#passwordStrengthText');
                
                progressBar.css('width', strength + '%');
                progressBar.removeClass('bg-danger bg-warning bg-success');
                
                if (strength < 30) {
                    progressBar.addClass('bg-danger');
                    text.text('Contraseña débil').removeClass('text-success text-warning').addClass('text-danger');
                } else if (strength < 70) {
                    progressBar.addClass('bg-warning');
                    text.text('Contraseña moderada').removeClass('text-success text-danger').addClass('text-warning');
                } else {
                    progressBar.addClass('bg-success');
                    text.text('Contraseña fuerte').removeClass('text-danger text-warning').addClass('text-success');
                }
            }

            function checkPasswordRequirements(password) {
                const requirements = {
                    length: password.length >= 6,
                    uppercase: /[A-Z]/.test(password),
                    lowercase: /[a-z]/.test(password),
                    digit: /[0-9]/.test(password),
                    special: /[^A-Za-z0-9]/.test(password)
                };

                Object.keys(requirements).forEach(req => {
                    const element = $("#" + req);
                    if (requirements[req]) {
                        element.removeClass('text-muted text-danger').addClass('text-success');
                        element.html('<i class="fas fa-check me-1"></i>' + element.text().replace('✓ ', ''));
                    } else {
                        element.removeClass('text-success').addClass('text-muted');
                        element.html(element.text().replace('✓ ', ''));
                    }
                });

                // Enable/disable submit button
                const allValid = Object.values(requirements).every(Boolean) && 
                                password === $('#confirmPassword').val() && 
                                $('#currentPassword').val().length > 0;
                $('#submitButton').prop('disabled', !allValid);
            }

            function checkPasswordMatch() {
                const newPassword = $('#newPassword').val();
                const confirmPassword = $('#confirmPassword').val();
                const matchElement = $('#passwordMatch');

                if (confirmPassword.length === 0) {
                    matchElement.text('').removeClass('text-success text-danger');
                } else if (newPassword === confirmPassword) {
                    matchElement.text('✓ Las contraseñas coinciden').removeClass('text-danger').addClass('text-success');
                } else {
                    matchElement.text('✗ Las contraseñas no coinciden').removeClass('text-success').addClass('text-danger');
                }

                // Recheck button state
                if (newPassword.length > 0) {
                    checkPasswordRequirements(newPassword);
                }
            }

            // Check current password field
            $('#currentPassword').on('input', function() {
                if ($('#newPassword').val().length > 0) {
                    checkPasswordRequirements($('#newPassword').val());
                }
            });
        });
    </script>
}
@using DocinadeApp.ViewModels.Account
@model LoginViewModel
@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = null; // Usar un layout vacío para la página de login
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sistema de Rúbricas</title>
    
    <!-- Google Fonts y Font Awesome -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <!-- Estilos de la aplicación -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/login-styles.css" asp-append-version="true" />
</head>
<body class="login-page-background">

    <div class="login-container">
        <div class="login-card">
            <!-- Logo dinámico con íconos de Font Awesome -->
            <div class="dynamic-logo">
                <div class="logo-stack">
                    <i class="fas fa-graduation-cap primary-icon"></i>
                    <i class="fas fa-chart-line secondary-icon"></i>
                </div>
                <div class="logo-pulse"></div>
            </div>
            <h1 class="brand-name">Evaluación Académica</h1>
            <h2>Bienvenido de vuelta</h2>

            <form asp-action="Login" asp-route-returnurl="@ViewData["ReturnUrl"]" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert" style="display: @(ViewData.ModelState.IsValid ? "none" : "block");"></div>

                <div class="form-group">
                    <label asp-for="Email">Correo electrónico</label>
                    <div class="input-group">
                        <span class="input-icon"><i class="fas fa-envelope"></i></span>
                        <input asp-for="Email" class="form-control" placeholder="tu-correo@ejemplo.com" autocomplete="username" required />
                    </div>
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Password">Contraseña</label>
                    <div class="input-group">
                        <span class="input-icon"><i class="fas fa-lock"></i></span>
                        <input asp-for="Password" type="password" class="form-control" id="passwordField" placeholder="Ingresa tu contraseña" autocomplete="current-password" required />
                        <button type="button" class="btn-toggle-password" id="togglePassword" aria-label="Mostrar contraseña">
                            <i class="fas fa-eye" id="togglePasswordIcon"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="form-check">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label">
                            Recordarme
                        </label>
                    </div>
                    <a asp-action="ForgotPassword" class="text-decoration-none" style="font-size: 14px;">¿Olvidaste tu contraseña?</a>
                </div>

                <button type="submit" class="btn btn-login">Iniciar Sesión</button>

                @if (ViewData["RegistroAbierto"] is bool registroAbierto && registroAbierto)
                {
                    <div class="login-divider"></div>

                    <p class="text-center text-muted" style="font-size: 14px;">¿No tienes una cuenta?</p>
                    <a asp-action="Register" class="btn btn-create-account">Crear una cuenta</a>
                }
            </form>
        </div>

        <!-- Usuarios de prueba en desarrollo -->
        @{
            var env = Context.RequestServices.GetRequiredService<IWebHostEnvironment>();
        }
        @if (env.IsDevelopment())
        {
            <div class="card mt-4 border-info" style="border-radius: 15px;">
                <div class="card-header bg-info text-white" style="border-top-left-radius: 15px; border-top-right-radius: 15px;">
                    <h6 class="mb-0"><i class="fas fa-info-circle me-2"></i>Usuarios de Prueba</h6>
                </div>
                <div class="card-body small">
                    <p class="mb-1"><strong>Admin:</strong> admin@rubricas.edu / Admin123!</p>
                    <p class="mb-1"><strong>Docente:</strong> docente@rubricas.edu / Docente123!</p>
                    <p class="mb-0"><strong>Evaluador:</strong> evaluador@rubricas.edu / Evaluador123!</p>
                </div>
            </div>
        }
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await Html.PartialAsync("_ValidationScriptsPartial")
    
    <script>
        // Toggle Password Visibility
        document.addEventListener('DOMContentLoaded', function() {
            const togglePassword = document.getElementById('togglePassword');
            const passwordField = document.getElementById('passwordField');
            const togglePasswordIcon = document.getElementById('togglePasswordIcon');
            
            if (togglePassword && passwordField && togglePasswordIcon) {
                togglePassword.addEventListener('click', function() {
                    // Cambiar el tipo de input
                    const type = passwordField.getAttribute('type') === 'password' ? 'text' : 'password';
                    passwordField.setAttribute('type', type);
                    
                    // Cambiar el icono
                    if (type === 'password') {
                        togglePasswordIcon.classList.remove('fa-eye-slash');
                        togglePasswordIcon.classList.add('fa-eye');
                        togglePassword.setAttribute('aria-label', 'Mostrar contraseña');
                    } else {
                        togglePasswordIcon.classList.remove('fa-eye');
                        togglePasswordIcon.classList.add('fa-eye-slash');
                        togglePassword.setAttribute('aria-label', 'Ocultar contraseña');
                    }
                });
            }
        });
    </script>
</body>
</html>

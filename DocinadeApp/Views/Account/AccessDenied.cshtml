@{
    ViewData["Title"] = "Acceso Denegado";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid d-flex justify-content-center align-items-center" style="min-height: 60vh;">
    <div class="text-center">
        <div class="mb-4">
            <i class="fas fa-shield-alt text-danger" style="font-size: 6rem;"></i>
        </div>
        
        <h1 class="display-4 text-danger mb-3">Acceso Denegado</h1>
        
        <p class="lead text-muted mb-4">
            No tienes permisos suficientes para acceder a esta página.
        </p>
        
        <div class="alert alert-warning d-inline-block">
            <i class="fas fa-info-circle me-2"></i>
            Si crees que esto es un error, contacta a tu administrador del sistema.
        </div>
        
        <div class="mt-4">
            <a href="@Url.Action("Index", "Home")" class="btn btn-primary me-2">
                <i class="fas fa-home me-1"></i>
                Ir al Inicio
            </a>
            
            @if (User.Identity.IsAuthenticated)
            {
                <a href="@Url.Action("Profile", "Account")" class="btn btn-outline-secondary">
                    <i class="fas fa-user me-1"></i>
                    Mi Perfil
                </a>
            }
            else
            {
                <a href="@Url.Action("Login", "Account")" class="btn btn-outline-secondary">
                    <i class="fas fa-sign-in-alt me-1"></i>
                    Iniciar Sesión
                </a>
            }
        </div>
        
        @if (User.Identity.IsAuthenticated)
        {
            <div class="mt-5">
                <div class="card d-inline-block text-start" style="max-width: 400px;">
                    <div class="card-header bg-light">
                        <h6 class="mb-0">
                            <i class="fas fa-user me-1"></i>
                            Información de tu Cuenta
                        </h6>
                    </div>
                    <div class="card-body">
                        <p class="mb-2">
                            <strong>Usuario:</strong> @User.Identity.Name
                        </p>
                        <p class="mb-2">
                            <strong>Roles actuales:</strong>
                        </p>
                        <div>
                            @if (User.IsInRole("SuperAdministrador"))
                            {
                                <span class="badge bg-danger me-1">Super Administrador</span>
                            }
                            @if (User.IsInRole("Administrador"))
                            {
                                <span class="badge bg-warning me-1">Administrador</span>
                            }
                            @if (User.IsInRole("Coordinador"))
                            {
                                <span class="badge bg-info me-1">Coordinador</span>
                            }
                            @if (User.IsInRole("Docente"))
                            {
                                <span class="badge bg-success me-1">Docente</span>
                            }
                            @if (User.IsInRole("Evaluador"))
                            {
                                <span class="badge bg-primary me-1">Evaluador</span>
                            }
                            @if (User.IsInRole("Observador"))
                            {
                                <span class="badge bg-secondary me-1">Observador</span>
                            }
                            
                            @{
                                var hasAnyRole = User.IsInRole("SuperAdministrador") || 
                                               User.IsInRole("Administrador") || 
                                               User.IsInRole("Coordinador") || 
                                               User.IsInRole("Docente") || 
                                               User.IsInRole("Evaluador") || 
                                               User.IsInRole("Observador");
                            }
                            
                            @if (!hasAnyRole)
                            {
                                <span class="text-muted">Sin roles asignados</span>
                            }
                        </div>
                        
                        @if (!hasAnyRole)
                        {
                            <div class="mt-3">
                                <small class="text-muted">
                                    <i class="fas fa-exclamation-triangle me-1"></i>
                                    Contacta a un administrador para que te asigne los roles apropiados.
                                </small>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>
@model RubricasApp.Web.ViewComponents.BuscadorEstudianteViewModel

<!-- Modal de Búsqueda de Estudiantes -->
<div class="modal fade" id="@Model.ModalId" tabindex="-1" aria-labelledby="@(Model.ModalId)Label" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="@(Model.ModalId)Label">
                    <i class="fas fa-search me-2"></i>
                    Búsqueda Avanzada de Estudiantes
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <!-- Campo de búsqueda con indicadores -->
                <div class="row mb-3">
                    <div class="col-12">
                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="fas fa-search text-primary"></i>
                            </span>
                            <input type="text"
                                   class="form-control form-control-lg"
                                   id="txtBusqueda@(Model.ModalId)"
                                   placeholder="Escriba nombre, apellidos o identificación para buscar..."
                                   autocomplete="off"
                                   data-bs-toggle="tooltip"
                                   title="Ingrese al menos 2 caracteres para iniciar la búsqueda">
                            <button class="btn btn-outline-secondary"
                                    type="button"
                                    id="btnLimpiar@(Model.ModalId)"
                                    title="Limpiar búsqueda">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>
                        <div class="form-text">
                            <small class="text-muted">
                                <i class="fas fa-info-circle"></i>
                                La búsqueda se activa automáticamente después de escribir 2 o más caracteres
                            </small>
                        </div>
                    </div>
                </div>

                <!-- Área de resultados -->
                <div class="row">
                    <div class="col-12">
                        <!-- Indicador de carga -->
                        <div id="loading@(Model.ModalId)" class="text-center py-4" style="display: none;">
                            <div class="spinner-border spinner-border-sm text-primary me-2" role="status">
                                <span class="visually-hidden">Cargando...</span>
                            </div>
                            <span class="text-muted">Buscando estudiantes...</span>
                        </div>

                        <!-- Mensaje inicial -->
                        <div id="mensajeInicial@(Model.ModalId)" class="text-center py-5">
                            <div class="mb-3">
                                <i class="fas fa-user-search fa-3x text-muted"></i>
                            </div>
                            <h6 class="text-muted">Utilice el campo de búsqueda para encontrar estudiantes</h6>
                            <p class="text-muted small mb-0">
                                Puede buscar por nombre, apellidos o número de identificación
                            </p>
                        </div>

                        <!-- Tabla de resultados -->
                        <div id="tablaContainer@(Model.ModalId)" class="table-responsive" style="display: none;">
                            <table class="table table-hover table-striped" id="tablaResultados@(Model.ModalId)">
                                <thead class="table-dark sticky-top">
                                    <tr>
                                        <th width="10%">
                                            <i class="fas fa-hashtag me-1"></i>ID
                                        </th>
                                        <th width="25%">
                                            <i class="fas fa-user me-1"></i>Apellidos
                                        </th>
                                        <th width="25%">
                                            <i class="fas fa-user me-1"></i>Nombre
                                        </th>
                                        <th width="20%">
                                            <i class="fas fa-id-card me-1"></i>Identificación
                                        </th>
                                        <th width="20%">
                                            <i class="fas fa-building me-1"></i>Institución
                                        </th>
                                    </tr>
                                </thead>
                                <tbody id="tbodyResultados@(Model.ModalId)">
                                    <!-- Resultados dinámicos -->
                                </tbody>
                            </table>
                        </div>

                        <!-- Mensaje sin resultados -->
                        <div id="sinResultados@(Model.ModalId)" class="text-center py-5" style="display: none;">
                            <div class="mb-3">
                                <i class="fas fa-search-minus fa-3x text-warning"></i>
                            </div>
                            <h6 class="text-muted">No se encontraron estudiantes</h6>
                            <p class="text-muted small mb-0">
                                Intente modificar los términos de búsqueda o verificar la ortografía
                            </p>
                        </div>

                        <!-- Mensaje de error -->
                        <div id="mensajeError@(Model.ModalId)" class="alert alert-danger" style="display: none;">
                            <div class="d-flex align-items-center">
                                <i class="fas fa-exclamation-triangle fa-2x me-3"></i>
                                <div>
                                    <h6 class="mb-1">Error al cargar los datos</h6>
                                    <p class="mb-0 small" id="detalleError@(Model.ModalId)">
                                        Ocurrió un error al realizar la búsqueda. Intente nuevamente.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer bg-light">
                <div class="d-flex justify-content-between w-100 align-items-center">
                    <small class="text-muted">
                        <i class="fas fa-mouse-pointer me-1"></i>
                        Haga clic en una fila para seleccionar el estudiante
                    </small>
                    <div>
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                            <i class="fas fa-times me-1"></i>
                            Cancelar
                        </button>
                        <button type="button"
                                class="btn btn-primary"
                                id="btnSeleccionar@(Model.ModalId)"
                                style="display: none;">
                            <i class="fas fa-check me-1"></i>
                            Seleccionar
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (Model.IncluirScripts)
{
    <!-- Scripts del buscador -->
    <script src="~/js/components/buscador-estudiante.js" asp-append-version="true"></script>
    <script>
        // Inicializar el buscador cuando el documento esté listo
        document.addEventListener('DOMContentLoaded', function() {
            if (typeof BuscadorEstudiante !== 'undefined') {
                new BuscadorEstudiante({
                    selectId: '@Model.SelectId',
                    modalId: '@Model.ModalId',
                    buscarUrl: '@Html.Raw(Model.BuscarUrl)',
                    debug: false // CORREGIDO: usar false en lugar de Environment.IsDevelopment()
                });
                console.log('✅ Buscador de estudiantes inicializado para modal: @Model.ModalId');
            } else {
                console.error('❌ La clase BuscadorEstudiante no está disponible');
            }
        });
    </script>
}

@{
    // Registrar estilos específicos si no están incluidos
    if (ViewContext.HttpContext.Items["BuscadorEstudianteStyles"] == null)
    {
        ViewContext.HttpContext.Items["BuscadorEstudianteStyles"] = true;
    }
}

<style>
    /* Estilos específicos para el buscador modal */
    # @Model.ModalId .estudiante-row {
        cursor: pointer;
        transition: all 0.2s ease;
    }

        # @Model.ModalId .estudiante-row:hover {
            background-color: var(--bs-primary-bg-subtle, #e3f2fd);
            transform: translateX(3px);
        }

        # @Model.ModalId .estudiante-row.selected {
            background-color: var(--bs-primary, #0d6efd);
            color: white;
        }

            # @Model.ModalId .estudiante-row.selected:hover {
                background-color: var(--bs-primary-dark, #0a58ca);
            }

    # @Model.ModalId .table-responsive {
        max-height: 400px;
        overflow-y: auto;
    }

    # @Model.ModalId .sticky-top {
        position: sticky;
        top: 0;
        z-index: 1020;
    }

    # @Model.ModalId .modal-dialog {
        max-width: 90%;
    }

    /* Responsive behavior for modal dialog */
    @@media (min-width: 992px) {
        # @Model.ModalId .modal-dialog {
            max-width: 800px;
        }
    }
</style>
@model RubricasApp.Web.ViewModels.CurriculumsMasivosViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Currículums Vitae</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            font-size: 10pt;
            line-height: 1.3;
            color: #333;
        }
        
        .curriculum-page {
            padding: 20px;
            page-break-after: always;
        }
        
        .curriculum-page:last-child {
            page-break-after: avoid;
        }
        
        .header {
            text-align: center;
            margin-bottom: 20px;
            border-bottom: 2px solid #0066cc;
            padding-bottom: 10px;
        }
        
        .header h1 {
            color: #0066cc;
            font-size: 18pt;
            margin-bottom: 3px;
        }
        
        .header .cedula {
            font-size: 10pt;
            color: #666;
            margin-top: 3px;
        }
        
        .section {
            margin-bottom: 15px;
        }
        
        .section-title {
            background-color: #0066cc;
            color: white;
            padding: 6px 10px;
            font-size: 11pt;
            font-weight: bold;
            margin-bottom: 8px;
            border-radius: 2px;
        }
        
        .section-content {
            padding: 0 5px;
        }
        
        .info-grid {
            display: table;
            width: 100%;
        }
        
        .info-row {
            display: table-row;
        }
        
        .info-label {
            display: table-cell;
            font-weight: bold;
            width: 150px;
            padding: 3px 10px 3px 0;
            vertical-align: top;
            font-size: 9pt;
        }
        
        .info-value {
            display: table-cell;
            padding: 3px 0;
            vertical-align: top;
            font-size: 9pt;
        }
        
        .experience-item {
            margin-bottom: 10px;
            padding: 8px;
            background-color: #f8f9fa;
            border-left: 2px solid #0066cc;
        }
        
        .experience-item h4 {
            color: #0066cc;
            font-size: 10pt;
            margin-bottom: 3px;
        }
        
        .experience-item .institution {
            font-weight: bold;
            color: #444;
            margin-bottom: 2px;
            font-size: 9pt;
        }
        
        .experience-item .period {
            color: #666;
            font-size: 8pt;
            margin-bottom: 3px;
        }
        
        .badge {
            display: inline-block;
            padding: 2px 6px;
            background-color: #e7f3ff;
            color: #0066cc;
            border-radius: 2px;
            font-size: 8pt;
            margin-right: 3px;
            margin-top: 2px;
        }
        
        .badge.cargo {
            background-color: #ffe7e7;
            color: #cc0000;
        }
    </style>
</head>
<body>
    @foreach (var curriculum in Model.Curriculums)
    {
        <div class="curriculum-page">
            <!-- ENCABEZADO -->
            <div class="header">
                <h1>@curriculum.NombreCompleto</h1>
                <div class="cedula">Cédula @curriculum.TipoCedula: @curriculum.Cedula</div>
            </div>

            <!-- CONTACTO -->
            <div class="section">
                <div class="section-title">CONTACTO</div>
                <div class="section-content">
                    <div class="info-grid">
                        <div class="info-row">
                            <div class="info-label">Email:</div>
                            <div class="info-value">@curriculum.EmailPersonal</div>
                        </div>
                        <div class="info-row">
                            <div class="info-label">Teléfono:</div>
                            <div class="info-value">@curriculum.TelefonoCelular</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- FORMACIÓN ACADÉMICA -->
            @if (curriculum.FormacionAcademica.Count > 0)
            {
                <div class="section">
                    <div class="section-title">FORMACIÓN ACADÉMICA</div>
                    <div class="section-content">
                        @foreach (var formacion in curriculum.FormacionAcademica)
                        {
                            <div class="experience-item">
                                <h4>@formacion.TituloObtenido</h4>
                                <div class="institution">@formacion.InstitucionEducativa</div>
                                <div class="period">
                                    @formacion.TipoFormacion | @(formacion.AnioInicio ?? 0) - @(formacion.EnCurso ? "En curso" : formacion.AnioFinalizacion?.ToString() ?? "")
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- INFORMACIÓN LABORAL -->
            <div class="section">
                <div class="section-title">INFORMACIÓN LABORAL</div>
                <div class="section-content">
                    <div class="info-grid">
                        @if (curriculum.InstitucionNombre != null)
                        {
                            <div class="info-row">
                                <div class="info-label">Institución:</div>
                                <div class="info-value">@curriculum.InstitucionNombre</div>
                            </div>
                        }
                        <div class="info-row">
                            <div class="info-label">Ingreso:</div>
                            <div class="info-value">@curriculum.FechaIngreso.ToString("dd/MM/yyyy") (@curriculum.AniosServicio años)</div>
                        </div>
                        <div class="info-row">
                            <div class="info-label">Contrato:</div>
                            <div class="info-value">@curriculum.TipoContrato - @curriculum.TipoJornada</div>
                        </div>
                    </div>
                    
                    @if (curriculum.EsDirector || curriculum.EsCoordinador || curriculum.EsDecano || curriculum.CargoAdministrativo != null)
                    {
                        <div style="margin-top: 8px;">
                            <strong style="font-size: 9pt;">Cargos:</strong>
                            @if (curriculum.EsDirector) { <span class="badge cargo">Director</span> }
                            @if (curriculum.EsCoordinador) { <span class="badge cargo">Coordinador</span> }
                            @if (curriculum.EsDecano) { <span class="badge cargo">Decano</span> }
                            @if (curriculum.CargoAdministrativo != null) { <span class="badge cargo">@curriculum.CargoAdministrativo</span> }
                        </div>
                    }
                </div>
            </div>

            <!-- EXPERIENCIA LABORAL (Resumida) -->
            @if (curriculum.ExperienciaLaboral.Count > 0)
            {
                <div class="section">
                    <div class="section-title">EXPERIENCIA LABORAL PREVIA</div>
                    <div class="section-content">
                        @foreach (var exp in curriculum.ExperienciaLaboral.Take(3))
                        {
                            <div class="experience-item">
                                <h4>@exp.CargoDesempenado</h4>
                                <div class="institution">@exp.NombreInstitucion</div>
                                <div class="period">
                                    @exp.FechaInicio.ToString("MM/yyyy") - @(exp.TrabajandoActualmente ? "Actualidad" : exp.FechaFin?.ToString("MM/yyyy") ?? "")
                                </div>
                            </div>
                        }
                        @if (curriculum.ExperienciaLaboral.Count > 3)
                        {
                            <div style="font-size: 8pt; color: #666; margin-top: 5px;">
                                ... y @(curriculum.ExperienciaLaboral.Count - 3) experiencias más
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- CAPACITACIONES (Resumida) -->
            @if (curriculum.Capacitaciones.Count > 0)
            {
                <div class="section">
                    <div class="section-title">CAPACITACIONES</div>
                    <div class="section-content">
                        @foreach (var cap in curriculum.Capacitaciones.Take(3))
                        {
                            <div style="margin-bottom: 5px; font-size: 9pt;">
                                <strong>@cap.NombreCapacitacion</strong>
                                @if (cap.InstitucionOrganizadora != null)
                                {
                                    <span> - @cap.InstitucionOrganizadora</span>
                                }
                                @if (cap.HorasCapacitacion.HasValue)
                                {
                                    <span class="badge">@cap.HorasCapacitacion hrs</span>
                                }
                            </div>
                        }
                        @if (curriculum.Capacitaciones.Count > 3)
                        {
                            <div style="font-size: 8pt; color: #666; margin-top: 5px;">
                                ... y @(curriculum.Capacitaciones.Count - 3) capacitaciones más
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- INFORMACIÓN ADICIONAL -->
            @if (curriculum.AreasEspecializacion != null || curriculum.IdiomasHabla != null || curriculum.ExperienciaDocente != null)
            {
                <div class="section">
                    <div class="section-title">INFORMACIÓN ADICIONAL</div>
                    <div class="section-content">
                        <div class="info-grid">
                            @if (curriculum.AreasEspecializacion != null)
                            {
                                <div class="info-row">
                                    <div class="info-label">Especialización:</div>
                                    <div class="info-value">@curriculum.AreasEspecializacion</div>
                                </div>
                            }
                            @if (curriculum.IdiomasHabla != null)
                            {
                                <div class="info-row">
                                    <div class="info-label">Idiomas:</div>
                                    <div class="info-value">@curriculum.IdiomasHabla</div>
                                </div>
                            }
                            @if (curriculum.ExperienciaDocente != null)
                            {
                                <div class="info-row">
                                    <div class="info-label">Exp. Docente:</div>
                                    <div class="info-value">@curriculum.ExperienciaDocente años</div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</body>
</html>

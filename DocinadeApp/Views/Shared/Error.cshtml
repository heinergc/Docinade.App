@model DocinadeApp.ViewModels.ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-exclamation-triangle-fill"></i> Error
                    </h4>
                </div>
                <div class="card-body">
                    <h5>Ha ocurrido un error inesperado</h5>
                    
                    @if (!string.IsNullOrEmpty(Model?.Message))
                    {
                        <div class="alert alert-warning mt-3">
                            <strong>Detalles:</strong> @Model.Message
                        </div>
                    }
                    
                    @if (Model?.ShowRequestId ?? false)
                    {
                        <p class="text-muted">
                            <strong>Request ID:</strong> <code>@Model.RequestId</code>
                        </p>
                    }
                    
                    <div class="mt-4">
                        <a href="@Url.Action("Index", "Home")" class="btn btn-primary">
                            <i class="bi bi-house-fill"></i> Volver al Inicio
                        </a>
                        
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <a href="javascript:history.back()" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Volver Atrás
                            </a>
                        }
                    </div>
                </div>
            </div>
            
            @if (ViewData["ErrorDetails"] != null)
            {
                <div class="card mt-3 border-secondary">
                    <div class="card-header bg-light">
                        <h6 class="mb-0">Información técnica</h6>
                    </div>
                    <div class="card-body">
                        <pre class="mb-0"><code>@ViewData["ErrorDetails"]</code></pre>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

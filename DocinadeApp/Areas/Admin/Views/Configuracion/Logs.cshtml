@model DocinadeApp.ViewModels.Admin.LogsViewModel

@{
    ViewData["Title"] = "Logs del Sistema";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "Home", new { area = "" })">
                    <i class="fas fa-home"></i> Inicio
                </a>
            </li>
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index")">
                    <i class="fas fa-cogs"></i> Configuración
                </a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">
                <i class="fas fa-file-alt"></i> Logs
            </li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="row mb-4">
        <div class="col-md-8">
            <h2 class="mb-0">
                <i class="fas fa-file-alt text-info"></i>
                Logs del Sistema
            </h2>
            <p class="text-muted mt-2">Monitoreo y análisis de logs de aplicación, errores y auditoría</p>
        </div>
        <div class="col-md-4 text-end">
            <div class="btn-group">
                <button type="button" class="btn btn-outline-success" onclick="refreshLogs()">
                    <i class="fas fa-sync-alt"></i> Actualizar
                </button>
                <button type="button" class="btn btn-outline-warning" onclick="exportLogs()">
                    <i class="fas fa-download"></i> Exportar
                </button>
                <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left"></i> Volver
                </a>
            </div>
        </div>
    </div>

    <!-- Estadísticas de Logs -->
    <div class="row mb-4">
        <div class="col-md-2">
            <div class="card text-center bg-info text-white">
                <div class="card-body">
                    <i class="fas fa-info-circle fa-2x mb-2"></i>
                    <h4>@Model.LogCounts.Information</h4>
                    <p class="mb-0">Información</p>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-center bg-warning text-white">
                <div class="card-body">
                    <i class="fas fa-exclamation-triangle fa-2x mb-2"></i>
                    <h4>@Model.LogCounts.Warning</h4>
                    <p class="mb-0">Advertencias</p>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-center bg-danger text-white">
                <div class="card-body">
                    <i class="fas fa-times-circle fa-2x mb-2"></i>
                    <h4>@Model.LogCounts.Error</h4>
                    <p class="mb-0">Errores</p>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-center bg-dark text-white">
                <div class="card-body">
                    <i class="fas fa-bug fa-2x mb-2"></i>
                    <h4>@Model.LogCounts.Critical</h4>
                    <p class="mb-0">Críticos</p>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-center bg-secondary text-white">
                <div class="card-body">
                    <i class="fas fa-search fa-2x mb-2"></i>
                    <h4>@Model.LogCounts.Audit</h4>
                    <p class="mb-0">Auditoría</p>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-center bg-success text-white">
                <div class="card-body">
                    <i class="fas fa-check-circle fa-2x mb-2"></i>
                    <h4>@Model.LogCounts.Debug</h4>
                    <p class="mb-0">Debug</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Filtros -->
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-filter"></i>
                        Filtros de Búsqueda
                    </h5>
                </div>
                <div class="card-body">
                    <form id="filterForm">
                        <div class="row">
                            <div class="col-md-2">
                                <label class="form-label">Nivel de Log</label>
                                <select asp-for="FiltroNivel" class="form-select" onchange="applyFilters()">
                                    <option value="">Todos</option>
                                    <option value="Information">Información</option>
                                    <option value="Warning">Advertencia</option>
                                    <option value="Error">Error</option>
                                    <option value="Critical">Crítico</option>
                                    <option value="Debug">Debug</option>
                                    <option value="Audit">Auditoría</option>
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">Fecha Desde</label>
                                <input asp-for="FechaDesde" type="date" class="form-control" onchange="applyFilters()" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">Fecha Hasta</label>
                                <input asp-for="FechaHasta" type="date" class="form-control" onchange="applyFilters()" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">Usuario</label>
                                <input asp-for="FiltroUsuario" type="text" class="form-control" 
                                    placeholder="Nombre de usuario" onkeyup="delayedFilter()" />
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Búsqueda en Mensaje</label>
                                <input asp-for="FiltroBusqueda" type="text" class="form-control" 
                                    placeholder="Buscar en mensaje..." onkeyup="delayedFilter()" />
                            </div>
                            <div class="col-md-1">
                                <label class="form-label">&nbsp;</label>
                                <button type="button" class="btn btn-outline-secondary d-block" onclick="clearFilters()">
                                    <i class="fas fa-eraser"></i>
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Lista de Logs -->
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="fas fa-list"></i>
                        Registros de Log
                    </h5>
                    <div>
                        <span class="badge bg-info">Total: <span id="totalLogs">@Model.LogEntries.Count</span></span>
                        <button class="btn btn-sm btn-outline-danger ms-2" onclick="clearOldLogs()">
                            <i class="fas fa-trash"></i> Limpiar Antiguos
                        </button>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive" style="max-height: 600px; overflow-y: auto;">
                        <table class="table table-hover mb-0" id="logsTable">
                            <thead class="table-dark sticky-top">
                                <tr>
                                    <th width="140">Fecha/Hora</th>
                                    <th width="80">Nivel</th>
                                    <th width="120">Usuario</th>
                                    <th width="150">Categoría</th>
                                    <th>Mensaje</th>
                                    <th width="100">Acciones</th>
                                </tr>
                            </thead>
                            <tbody id="logsTableBody">
                                @if (Model.LogEntries != null && Model.LogEntries.Any())
                                {
                                    @foreach (var log in Model.LogEntries)
                                    {
                                        <tr class="log-entry" data-level="@log.Level.ToLower()">
                                            <td>
                                                <small>
                                                    @log.Timestamp.ToString("dd/MM/yyyy")<br>
                                                    @log.Timestamp.ToString("HH:mm:ss")
                                                </small>
                                            </td>
                                            <td>
                                                <span class="badge @GetLevelBadgeClass(log.Level)">
                                                    @GetLevelIcon(log.Level) @log.Level
                                                </span>
                                            </td>
                                            <td>
                                                <small>@(log.Usuario ?? "Sistema")</small>
                                            </td>
                                            <td>
                                                <small class="text-muted">@log.Categoria</small>
                                            </td>
                                            <td>
                                                <div class="log-message">
                                                    @log.Mensaje
                                                    @if (!string.IsNullOrEmpty(log.DetalleError))
                                                    {
                                                        <button class="btn btn-sm btn-outline-info ms-1" 
                                                            onclick="showLogDetails('@log.Id')">
                                                            <i class="fas fa-info-circle"></i>
                                                        </button>
                                                    }
                                                </div>
                                            </td>
                                            <td>
                                                <div class="btn-group-vertical btn-group-sm">
                                                    @if (!string.IsNullOrEmpty(log.DetalleError))
                                                    {
                                                        <button class="btn btn-outline-info" onclick="showLogDetails('@log.Id')">
                                                            <i class="fas fa-eye"></i>
                                                        </button>
                                                    }
                                                    @if (log.Level == "Error" || log.Level == "Critical")
                                                    {
                                                        <button class="btn btn-outline-warning" onclick="reportBug('@log.Id')">
                                                            <i class="fas fa-bug"></i>
                                                        </button>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-4">
                                            <i class="fas fa-info-circle"></i>
                                            No hay logs disponibles con los filtros aplicados
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                @if (Model.LogEntries != null && Model.LogEntries.Any())
                {
                    <div class="card-footer">
                        <div class="d-flex justify-content-between align-items-center">
                            <small class="text-muted">
                                Mostrando @Model.LogEntries.Count registros
                            </small>
                            <div>
                                <button class="btn btn-sm btn-outline-primary" onclick="loadMoreLogs()">
                                    <i class="fas fa-plus"></i> Cargar Más
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Modal para detalles del log -->
<div class="modal fade" id="logDetailsModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-info-circle"></i>
                    Detalles del Log
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="logDetailsContent">
                <!-- Contenido cargado dinámicamente -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" class="btn btn-primary" onclick="copyLogDetails()">
                    <i class="fas fa-copy"></i> Copiar
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let filterTimeout;

        function delayedFilter() {
            clearTimeout(filterTimeout);
            filterTimeout = setTimeout(applyFilters, 500);
        }

        function applyFilters() {
            const filters = {
                nivel: $('#FiltroNivel').val(),
                fechaDesde: $('#FechaDesde').val(),
                fechaHasta: $('#FechaHasta').val(),
                usuario: $('#FiltroUsuario').val(),
                busqueda: $('#FiltroBusqueda').val()
            };

            $.get('@Url.Action("Logs")', filters, function(data) {
                $('#logsTableBody').html($(data).find('#logsTableBody').html());
                updateLogCounts();
            });
        }

        function clearFilters() {
            $('#filterForm')[0].reset();
            applyFilters();
        }

        function refreshLogs() {
            location.reload();
        }

        function showLogDetails(logId) {
            $.get('@Url.Action("LogDetails")', { id: logId }, function(data) {
                $('#logDetailsContent').html(data);
                $('#logDetailsModal').modal('show');
            });
        }

        function copyLogDetails() {
            const content = $('#logDetailsContent').text();
            navigator.clipboard.writeText(content).then(() => {
                toastr.success('Detalles copiados al portapapeles');
            });
        }

        function exportLogs() {
            const filters = {
                nivel: $('#FiltroNivel').val(),
                fechaDesde: $('#FechaDesde').val(),
                fechaHasta: $('#FechaHasta').val(),
                usuario: $('#FiltroUsuario').val(),
                busqueda: $('#FiltroBusqueda').val()
            };

            const params = new URLSearchParams(filters);
            window.open('@Url.Action("ExportLogs")?' + params.toString(), '_blank');
        }

        function clearOldLogs() {
            Swal.fire({
                title: '¿Limpiar logs antiguos?',
                text: 'Esta acción eliminará los logs más antiguos de 30 días. ¿Continuar?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Limpiar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('@Url.Action("ClearOldLogs")', {
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    }, function(data) {
                        if (data.success) {
                            toastr.success(data.message);
                            refreshLogs();
                        } else {
                            toastr.error(data.message);
                        }
                    });
                }
            });
        }

        function reportBug(logId) {
            Swal.fire({
                title: 'Reportar Error',
                text: 'Se enviará un reporte del error al equipo de desarrollo.',
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#28a745',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Reportar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('@Url.Action("ReportBug")', {
                        logId: logId,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    }, function(data) {
                        if (data.success) {
                            toastr.success('Reporte enviado correctamente');
                        } else {
                            toastr.error('Error al enviar el reporte');
                        }
                    });
                }
            });
        }

        function loadMoreLogs() {
            const currentCount = $('#logsTableBody tr').length;
            $.get('@Url.Action("LoadMoreLogs")', { skip: currentCount }, function(data) {
                $('#logsTableBody').append(data);
                updateLogCounts();
            });
        }

        function updateLogCounts() {
            const counts = {
                information: 0,
                warning: 0,
                error: 0,
                critical: 0,
                audit: 0,
                debug: 0
            };

            $('#logsTableBody .log-entry').each(function() {
                const level = $(this).data('level');
                if (counts.hasOwnProperty(level)) {
                    counts[level]++;
                }
            });

            $('#totalLogs').text($('#logsTableBody .log-entry').length);
        }

        // Auto-refresh logs cada 30 segundos
        setInterval(function() {
            if ($('#autoRefresh').is(':checked')) {
                refreshLogs();
            }
        }, 30000);

        $(document).ready(function() {
            // Configurar fechas por defecto
            const today = new Date();
            const yesterday = new Date(today);
            yesterday.setDate(yesterday.getDate() - 1);
            
            $('#FechaHasta').val(today.toISOString().split('T')[0]);
            $('#FechaDesde').val(yesterday.toISOString().split('T')[0]);
        });
    </script>
}

@section Styles {
    <style>
        .log-message {
            max-width: 400px;
            word-wrap: break-word;
        }
        
        .table-responsive {
            border: 1px solid #dee2e6;
        }
        
        .log-entry:hover {
            background-color: #f8f9fa;
        }
        
        .badge {
            font-size: 0.7em;
        }
        
        .sticky-top {
            position: sticky;
            top: 0;
            z-index: 10;
        }
        
        .btn-group-vertical .btn {
            margin-bottom: 2px;
        }
    </style>
}

@functions {
    string GetLevelBadgeClass(string level)
    {
        return level?.ToLower() switch
        {
            "information" => "bg-info",
            "warning" => "bg-warning",
            "error" => "bg-danger",
            "critical" => "bg-dark",
            "debug" => "bg-success",
            "audit" => "bg-secondary",
            _ => "bg-light text-dark"
        };
    }

    string GetLevelIcon(string level)
    {
        return level?.ToLower() switch
        {
            "information" => "<i class='fas fa-info-circle'></i>",
            "warning" => "<i class='fas fa-exclamation-triangle'></i>",
            "error" => "<i class='fas fa-times-circle'></i>",
            "critical" => "<i class='fas fa-bug'></i>",
            "debug" => "<i class='fas fa-check-circle'></i>",
            "audit" => "<i class='fas fa-search'></i>",
            _ => "<i class='fas fa-circle'></i>"
        };
    }
}
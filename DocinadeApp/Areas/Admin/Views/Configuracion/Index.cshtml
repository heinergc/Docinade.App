@model DocinadeApp.ViewModels.Admin.ConfiguracionIndexViewModel

@{
    ViewData["Title"] = "Configuración del Sistema";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "Home", new { area = "" })">
                    <i class="fas fa-home"></i> Inicio
                </a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">
                <i class="fas fa-cogs"></i> Configuración
            </li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="row mb-4">
        <div class="col-md-8">
            <h2 class="mb-0">
                <i class="fas fa-cogs text-primary"></i>
                Configuración del Sistema
            </h2>
            <p class="text-muted mt-2">Panel de administración y configuración del sistema de rúbricas</p>
        </div>
        <div class="col-md-4 text-end">
            <div class="btn-group">
                <button type="button" class="btn btn-outline-success" onclick="checkSystemHealth()">
                    <i class="fas fa-heartbeat"></i> Verificar Estado
                </button>
                <button type="button" class="btn btn-outline-warning" onclick="toggleMaintenanceMode()">
                    <i class="fas fa-tools"></i> Mantenimiento
                </button>
            </div>
        </div>
    </div>

    <!-- Estadísticas rápidas -->
    <div class="row mb-4">
        <div class="col-md-2">
            <div class="card text-center bg-primary text-white">
                <div class="card-body">
                    <i class="fas fa-users fa-2x mb-2"></i>
                    <h4>@Model.QuickStats.TotalUsuarios</h4>
                    <p class="mb-0">Usuarios</p>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-center bg-success text-white">
                <div class="card-body">
                    <i class="fas fa-user-check fa-2x mb-2"></i>
                    <h4>@Model.QuickStats.UsuariosActivos</h4>
                    <p class="mb-0">Activos</p>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-center bg-info text-white">
                <div class="card-body">
                    <i class="fas fa-shield-alt fa-2x mb-2"></i>
                    <h4>@Model.QuickStats.TotalRoles</h4>
                    <p class="mb-0">Roles</p>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-center bg-warning text-white">
                <div class="card-body">
                    <i class="fas fa-table fa-2x mb-2"></i>
                    <h4>@Model.QuickStats.TotalRubricas</h4>
                    <p class="mb-0">Rúbricas</p>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-center bg-secondary text-white">
                <div class="card-body">
                    <i class="fas fa-clipboard-check fa-2x mb-2"></i>
                    <h4>@Model.QuickStats.EvaluacionesHoy</h4>
                    <p class="mb-0">Eval. Hoy</p>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card text-center @(Model.SystemHealth.EstadoGeneral == "Saludable" ? "bg-success" : "bg-danger") text-white">
                <div class="card-body">
                    <i class="fas fa-heartbeat fa-2x mb-2"></i>
                    <h6>@Model.SystemHealth.EstadoGeneral</h6>
                    <p class="mb-0">Sistema</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Información del sistema -->
    <div class="row mb-4">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-info-circle"></i>
                        Información del Sistema
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <table class="table table-sm">
                                <tr>
                                    <td><strong>Aplicación:</strong></td>
                                    <td>@Model.SystemInfo.NombreAplicacion</td>
                                </tr>
                                <tr>
                                    <td><strong>Versión:</strong></td>
                                    <td>@Model.SystemInfo.Version</td>
                                </tr>
                                <tr>
                                    <td><strong>Entorno:</strong></td>
                                    <td>
                                        <span class="badge @(Model.SystemInfo.EntornoEjecucion == "Production" ? "bg-success" : "bg-warning")">
                                            @Model.SystemInfo.EntornoEjecucion
                                        </span>
                                    </td>
                                </tr>
                                <tr>
                                    <td><strong>Servidor:</strong></td>
                                    <td>@Model.SystemInfo.ServidorBase</td>
                                </tr>
                            </table>
                        </div>
                        <div class="col-md-6">
                            <table class="table table-sm">
                                <tr>
                                    <td><strong>Base de Datos:</strong></td>
                                    <td>@Model.SystemInfo.BaseDatos</td>
                                </tr>
                                <tr>
                                    <td><strong>Framework:</strong></td>
                                    <td>@Model.SystemInfo.VersionFramework</td>
                                </tr>
                                <tr>
                                    <td><strong>Inicio Sistema:</strong></td>
                                    <td>@Model.SystemInfo.FechaInicioSistema.ToString("dd/MM/yyyy HH:mm")</td>
                                </tr>
                                <tr>
                                    <td><strong>Última Actualización:</strong></td>
                                    <td>@Model.SystemInfo.UltimaActualizacion.ToString("dd/MM/yyyy HH:mm")</td>
                                </tr>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-heartbeat"></i>
                        Estado del Sistema
                    </h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <div class="d-flex justify-content-between">
                            <span>Base de Datos:</span>
                            <span class="badge @(Model.SystemHealth.BaseDatosOnline ? "bg-success" : "bg-danger")">
                                @(Model.SystemHealth.BaseDatosOnline ? "Online" : "Offline")
                            </span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="d-flex justify-content-between">
                            <span>Espacio en Disco:</span>
                            <span class="badge bg-info">@Model.SystemHealth.EspacioDiscoDisponible</span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="d-flex justify-content-between">
                            <span>Memoria:</span>
                            <span class="badge bg-info">@Model.SystemHealth.MemoriaDisponible</span>
                        </div>
                    </div>
                    @if (Model.SystemHealth.UltimBackup.HasValue)
                    {
                        <div class="mb-3">
                            <small class="text-muted">
                                Último Backup: @Model.SystemHealth.UltimBackup.Value.ToString("dd/MM/yyyy HH:mm")
                            </small>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Configuraciones de registro de usuarios -->
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-user-plus"></i>
                        Configuración de Registro de Usuarios
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="alert alert-@(Model.ModoRegistroActual == DocinadeApp.Models.ModoRegistroUsuarios.Abierto ? "success" : "warning")" role="alert">
                                <h6 class="alert-heading">
                                    <i class="fas fa-@(Model.ModoRegistroActual == DocinadeApp.Models.ModoRegistroUsuarios.Abierto ? "unlock" : "lock")"></i>
                                    Estado actual del registro
                                </h6>
                                <p class="mb-0">
                                    El registro de usuarios está actualmente 
                                    <strong>@(Model.ModoRegistroActual == DocinadeApp.Models.ModoRegistroUsuarios.Abierto ? "ABIERTO" : "CERRADO")</strong>
                                </p>
                            </div>
                            
                            <form asp-action="ActualizarModoRegistro" method="post">
                                @Html.AntiForgeryToken()
                                <div class="mb-3">
                                    <label class="form-label">Modo de Registro</label>
                                    <select name="ModoRegistro" class="form-select" required>
                                        <option value="@DocinadeApp.Models.ModoRegistroUsuarios.Abierto" 
                                                selected="@(Model.ModoRegistroActual == DocinadeApp.Models.ModoRegistroUsuarios.Abierto)">
                                            Abierto - Los usuarios pueden registrarse libremente
                                        </option>
                                        <option value="@DocinadeApp.Models.ModoRegistroUsuarios.Cerrado" 
                                                selected="@(Model.ModoRegistroActual == DocinadeApp.Models.ModoRegistroUsuarios.Cerrado)">
                                            Cerrado - Solo administradores pueden crear usuarios
                                        </option>
                                    </select>
                                </div>
                                
                                <div class="mb-3">
                                    <label class="form-label">Mensaje personalizado (cuando está cerrado)</label>
                                    <textarea name="MensajePersonalizado" class="form-control" rows="3" 
                                              placeholder="Mensaje que se mostrará cuando el registro esté cerrado...">@Model.MensajeRegistroCerrado</textarea>
                                    <div class="form-text">
                                        Este mensaje se mostrará a los usuarios cuando intenten registrarse y el registro esté cerrado.
                                    </div>
                                </div>
                                
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-save"></i> Actualizar Configuración
                                </button>
                            </form>
                        </div>
                        
                        <div class="col-md-6">
                            <h6><i class="fas fa-info-circle"></i> Información sobre los modos de registro</h6>
                            <div class="card bg-light">
                                <div class="card-body">
                                    <div class="mb-3">
                                        <h6 class="text-success">
                                            <i class="fas fa-unlock"></i> Registro Abierto
                                        </h6>
                                        <p class="small mb-0">
                                            Los usuarios pueden crear cuentas por sí mismos usando el formulario de registro. 
                                            Se recomienda para sistemas públicos o con control de acceso por invitación.
                                        </p>
                                    </div>
                                    <hr>
                                    <div>
                                        <h6 class="text-warning">
                                            <i class="fas fa-lock"></i> Registro Cerrado
                                        </h6>
                                        <p class="small mb-0">
                                            Solo los administradores pueden crear nuevas cuentas de usuario. 
                                            Se recomienda para sistemas corporativos o con control estricto de acceso.
                                        </p>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Configuración de Empadronamiento Público -->
                            <h5 class="mt-4 mb-3">
                                <i class="fas fa-users"></i> Empadronamiento Público
                            </h5>
                            
                            <div class="alert alert-@(Model.EmpadronamientoPublicoHabilitado ? "success" : "warning")">
                                <i class="fas fa-info-circle"></i> 
                                <strong>Estado actual:</strong> 
                                @if (Model.EmpadronamientoPublicoHabilitado)
                                {
                                    <span class="badge bg-success">HABILITADO</span>
                                    <p class="mb-0 mt-2 small">El formulario de empadronamiento público está disponible para estudiantes.</p>
                                }
                                else
                                {
                                    <span class="badge bg-warning">DESHABILITADO</span>
                                    <p class="mb-0 mt-2 small">El formulario de empadronamiento público no está disponible.</p>
                                }
                            </div>
                            
                            <form asp-action="ActualizarEmpadronamientoPublico" method="post" class="mb-3">
                                @Html.AntiForgeryToken()
                                
                                <div class="form-check form-switch mb-3">
                                    <input class="form-check-input" 
                                           type="checkbox" 
                                           name="habilitado" 
                                           id="habilitarEmpadronamiento" 
                                           value="true"
                                           @(Model.EmpadronamientoPublicoHabilitado ? "checked" : "")>
                                    <label class="form-check-label" for="habilitarEmpadronamiento">
                                        <strong>Habilitar empadronamiento público</strong>
                                    </label>
                                </div>
                                
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-save"></i> Actualizar Configuración
                                </button>
                            </form>
                            
                            <div class="card bg-light">
                                <div class="card-body">
                                    <h6><i class="fas fa-info-circle"></i> Información sobre el empadronamiento público</h6>
                                    <p class="small mb-0">
                                        <strong>Cuando está habilitado:</strong> Los estudiantes pueden acceder al formulario de 
                                        empadronamiento desde la página principal para registrar sus datos básicos. 
                                        El botón aparecerá en la pantalla de inicio.
                                    </p>
                                    <hr class="my-2">
                                    <p class="small mb-0">
                                        <strong>Cuando está deshabilitado:</strong> El botón de empadronamiento no será visible 
                                        en la página principal y los estudiantes no podrán acceder al formulario.
                                    </p>
                                </div>
                            </div>
                            
                            @if (Model.Configuraciones.Any())
                            {
                                <div class="mt-3">
                                    <h6><i class="fas fa-cogs"></i> Otras Configuraciones</h6>
                                    <div class="table-responsive">
                                        <table class="table table-sm">
                                            <thead>
                                                <tr>
                                                    <th>Configuración</th>
                                                    <th>Valor</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var config in Model.Configuraciones.Take(5))
                                                {
                                                    <tr>
                                                        <td><small>@config.Clave</small></td>
                                                        <td><small>@config.Valor</small></td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Menú de configuraciones -->
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-sliders-h"></i>
                        Módulos de Configuración
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <!-- Configuración General -->
                        <div class="col-md-4 mb-3">
                            <div class="card h-100 border-primary">
                                <div class="card-header bg-primary text-white">
                                    <h6 class="mb-0">
                                        <i class="fas fa-cog"></i>
                                        Configuración General
                                    </h6>
                                </div>
                                <div class="card-body">
                                    <p class="card-text">Configurar parámetros generales del sistema, información de contacto y configuraciones básicas.</p>
                                    <ul class="list-unstyled small">
                                        <li><i class="fas fa-check text-success"></i> Información del sistema</li>
                                        <li><i class="fas fa-check text-success"></i> Configuraciones de sesión</li>
                                        <li><i class="fas fa-check text-success"></i> Configuraciones de archivos</li>
                                        <li><i class="fas fa-check text-success"></i> Notificaciones</li>
                                    </ul>
                                </div>
                                <div class="card-footer">
                                    <a href="@Url.Action("General")" class="btn btn-primary">
                                        <i class="fas fa-edit"></i> Configurar
                                    </a>
                                </div>
                            </div>
                        </div>

                        <!-- Configuración de Seguridad -->
                        <div class="col-md-4 mb-3">
                            <div class="card h-100 border-danger">
                                <div class="card-header bg-danger text-white">
                                    <h6 class="mb-0">
                                        <i class="fas fa-shield-alt"></i>
                                        Seguridad
                                    </h6>
                                </div>
                                <div class="card-body">
                                    <p class="card-text">Configurar políticas de seguridad, autenticación y validaciones de contraseñas.</p>
                                    <ul class="list-unstyled small">
                                        <li><i class="fas fa-check text-success"></i> Políticas de contraseñas</li>
                                        <li><i class="fas fa-check text-success"></i> Autenticación 2FA</li>
                                        <li><i class="fas fa-check text-success"></i> Bloqueo de cuentas</li>
                                        <li><i class="fas fa-check text-success"></i> Expiración de sesiones</li>
                                    </ul>
                                </div>
                                <div class="card-footer">
                                    <a href="@Url.Action("Seguridad")" class="btn btn-danger">
                                        <i class="fas fa-shield-alt"></i> Configurar
                                    </a>
                                </div>
                            </div>
                        </div>

                        <!-- Configuración de Email -->
                        <div class="col-md-4 mb-3">
                            <div class="card h-100 border-primary">
                                <div class="card-header bg-primary text-white">
                                    <h6 class="mb-0">
                                        <i class="fas fa-envelope"></i>
                                        Configuración de Email
                                    </h6>
                                </div>
                                <div class="card-body">
                                    <p class="card-text">Configurar los parámetros SMTP para el envío de correos electrónicos del sistema.</p>
                                    <ul class="list-unstyled small">
                                        <li><i class="fas fa-check text-success"></i> Servidor SMTP</li>
                                        <li><i class="fas fa-check text-success"></i> Credenciales de acceso</li>
                                        <li><i class="fas fa-check text-success"></i> Email remitente</li>
                                        <li><i class="fas fa-check text-success"></i> Correo de prueba</li>
                                    </ul>
                                </div>
                                <div class="card-footer">
                                    <a href="@Url.Action("Email")" class="btn btn-primary">
                                        <i class="fas fa-envelope"></i> Configurar
                                    </a>
                                </div>
                            </div>
                        </div>

                        <!-- Logs del Sistema -->
                        <div class="col-md-4 mb-3">
                            <div class="card h-100 border-info">
                                <div class="card-header bg-info text-white">
                                    <h6 class="mb-0">
                                        <i class="fas fa-file-alt"></i>
                                        Logs del Sistema
                                    </h6>
                                </div>
                                <div class="card-body">
                                    <p class="card-text">Revisar logs de aplicación, errores y actividad del sistema para monitoreo y debugging.</p>
                                    <ul class="list-unstyled small">
                                        <li><i class="fas fa-check text-success"></i> Logs de aplicación</li>
                                        <li><i class="fas fa-check text-success"></i> Logs de errores</li>
                                        <li><i class="fas fa-check text-success"></i> Logs de auditoría</li>
                                        <li><i class="fas fa-check text-success"></i> Filtros y búsqueda</li>
                                    </ul>
                                </div>
                                <div class="card-footer">
                                    <a href="@Url.Action("Logs")" class="btn btn-info">
                                        <i class="fas fa-eye"></i> Ver Logs
                                    </a>
                                </div>
                            </div>
                        </div>

                        <!-- Permisos y Roles -->
                        <div class="col-md-4 mb-3">
                            <div class="card h-100 border-success">
                                <div class="card-header bg-success text-white">
                                    <h6 class="mb-0">
                                        <i class="fas fa-users-cog"></i>
                                        Permisos y Roles
                                    </h6>
                                </div>
                                <div class="card-body">
                                    <p class="card-text">Gestionar roles de usuario y asignación de permisos del sistema.</p>
                                    <ul class="list-unstyled small">
                                        <li><i class="fas fa-check text-success"></i> Gestión de roles</li>
                                        <li><i class="fas fa-check text-success"></i> Asignación de permisos</li>
                                        <li><i class="fas fa-check text-success"></i> Matriz de permisos</li>
                                        <li><i class="fas fa-check text-success"></i> Sincronización</li>
                                    </ul>
                                </div>
                                <div class="card-footer">
                                    <a href="@Url.Action("Index", "Permissions")" class="btn btn-success">
                                        <i class="fas fa-shield-alt"></i> Gestionar
                                    </a>
                                </div>
                            </div>
                        </div>

                        <!-- Auditoría -->
                        <div class="col-md-4 mb-3">
                            <div class="card h-100 border-warning">
                                <div class="card-header bg-warning text-dark">
                                    <h6 class="mb-0">
                                        <i class="fas fa-search"></i>
                                        Auditoría
                                    </h6>
                                </div>
                                <div class="card-body">
                                    <p class="card-text">Revisar registros de auditoría, accesos y cambios en el sistema.</p>
                                    <ul class="list-unstyled small">
                                        <li><i class="fas fa-check text-success"></i> Registro de accesos</li>
                                        <li><i class="fas fa-check text-success"></i> Historial de cambios</li>
                                        <li><i class="fas fa-check text-success"></i> Reportes de auditoría</li>
                                        <li><i class="fas fa-check text-success"></i> Exportación de datos</li>
                                    </ul>
                                </div>
                                <div class="card-footer">
                                    <a href="@Url.Action("Index", "Audit")" class="btn btn-warning">
                                        <i class="fas fa-search"></i> Ver Auditoría
                                    </a>
                                </div>
                            </div>
                        </div>

                        <!-- Mantenimiento -->
                        <div class="col-md-4 mb-3">
                            <div class="card h-100 border-secondary">
                                <div class="card-header bg-secondary text-white">
                                    <h6 class="mb-0">
                                        <i class="fas fa-tools"></i>
                                        Mantenimiento
                                    </h6>
                                </div>
                                <div class="card-body">
                                    <p class="card-text">Herramientas de mantenimiento, backup y limpieza del sistema.</p>
                                    <ul class="list-unstyled small">
                                        <li><i class="fas fa-check text-success"></i> Modo mantenimiento</li>
                                        <li><i class="fas fa-check text-success"></i> Backup automático</li>
                                        <li><i class="fas fa-check text-success"></i> Limpieza de logs</li>
                                        <li><i class="fas fa-check text-success"></i> Health checks</li>
                                    </ul>
                                </div>
                                <div class="card-footer">
                                    <button class="btn btn-secondary" onclick="showMaintenanceOptions()">
                                        <i class="fas fa-tools"></i> Mantenimiento
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function checkSystemHealth() {
            $.get('@Url.Action("HealthCheck")', function(data) {
                if (data.success) {
                    let healthHtml = '<div class="list-group">';
                    data.checks.forEach(check => {
                        let iconClass = check.status === 'Healthy' ? 'text-success fa-check-circle' : 
                                       check.status === 'Warning' ? 'text-warning fa-exclamation-triangle' : 
                                       'text-danger fa-times-circle';
                        healthHtml += `
                            <div class="list-group-item">
                                <div class="d-flex w-100 justify-content-between">
                                    <h6 class="mb-1">
                                        <i class="fas ${iconClass}"></i> ${check.name}
                                    </h6>
                                    <span class="badge bg-${check.status === 'Healthy' ? 'success' : check.status === 'Warning' ? 'warning' : 'danger'}">
                                        ${check.status}
                                    </span>
                                </div>
                                <p class="mb-1">${check.message}</p>
                            </div>
                        `;
                    });
                    healthHtml += '</div>';
                    
                    Swal.fire({
                        title: 'Estado del Sistema',
                        html: healthHtml,
                        icon: 'info',
                        width: '600px'
                    });
                } else {
                    toastr.error('Error al verificar el estado del sistema');
                }
            });
        }

        function toggleMaintenanceMode() {
            Swal.fire({
                title: '¿Activar Modo Mantenimiento?',
                text: 'Esto bloqueará el acceso a los usuarios regulares.',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Activar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('@Url.Action("MantenimientoMode")', { 
                        enable: true,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    }, function(data) {
                        if (data.success) {
                            toastr.success(data.message);
                        } else {
                            toastr.error(data.message);
                        }
                    });
                }
            });
        }

        function showMaintenanceOptions() {
            Swal.fire({
                title: 'Opciones de Mantenimiento',
                html: `
                    <div class="list-group">
                        <button class="list-group-item list-group-item-action" onclick="checkSystemHealth()">
                            <i class="fas fa-heartbeat text-info"></i> Verificar Estado del Sistema
                        </button>
                        <button class="list-group-item list-group-item-action" onclick="toggleMaintenanceMode()">
                            <i class="fas fa-tools text-warning"></i> Activar Modo Mantenimiento
                        </button>
                        <a href="@Url.Action("Logs")" class="list-group-item list-group-item-action">
                            <i class="fas fa-file-alt text-primary"></i> Ver Logs del Sistema
                        </a>
                    </div>
                `,
                showConfirmButton: false,
                showCancelButton: true,
                cancelButtonText: 'Cerrar'
            });
        }
    </script>
}


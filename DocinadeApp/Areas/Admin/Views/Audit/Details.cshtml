@model RubricasApp.Web.ViewModels.Admin.AuditLogViewModel

@{
    ViewData["Title"] = $"Detalle de Auditoría - {Model.Id}";
}

<div class="container-fluid">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "Home", new { area = "" })">
                    <i class="fas fa-home"></i> Inicio
                </a>
            </li>
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "Audit", new { area = "Admin" })">
                    <i class="fas fa-shield-alt"></i> Auditoría
                </a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">
                <i class="fas fa-info-circle"></i> Detalle #@Model.Id
            </li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="row mb-4">
        <div class="col-md-8">
            <h2 class="mb-0">
                <i class="fas fa-info-circle text-info"></i>
                Detalle de Auditoría #@Model.Id
            </h2>
            <p class="text-muted mt-2">Información detallada del registro de auditoría</p>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("Index", "Audit", new { area = "Admin" })" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left"></i> Volver al Listado
            </a>
        </div>
    </div>

    <!-- Información General -->
    <div class="row mb-4">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-info-circle"></i> Información General
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <table class="table table-borderless">
                                <tr>
                                    <td class="fw-bold text-muted">ID:</td>
                                    <td><span class="badge bg-primary">#@Model.Id</span></td>
                                </tr>
                                <tr>
                                    <td class="fw-bold text-muted">Fecha y Hora:</td>
                                    <td>
                                        <i class="fas fa-calendar-alt text-muted"></i>
                                        @Model.Timestamp.ToString("dd/MM/yyyy HH:mm:ss")
                                    </td>
                                </tr>
                                <tr>
                                    <td class="fw-bold text-muted">Usuario:</td>
                                    <td>
                                        <i class="fas fa-user text-muted"></i>
                                        @Model.UserName
                                    </td>
                                </tr>
                                <tr>
                                    <td class="fw-bold text-muted">Acción:</td>
                                    <td>
                                        <span class="badge bg-info">@Model.Action</span>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="fw-bold text-muted">Tipo de Entidad:</td>
                                    <td>
                                        <span class="badge bg-secondary">@Model.EntityType</span>
                                    </td>
                                </tr>
                            </table>
                        </div>
                        <div class="col-md-6">
                            <table class="table table-borderless">
                                <tr>
                                    <td class="fw-bold text-muted">Estado:</td>
                                    <td>
                                        @if (Model.Success)
                                        {
                                            <span class="badge bg-success">
                                                <i class="fas fa-check"></i> Exitoso
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">
                                                <i class="fas fa-times"></i> Error
                                            </span>
                                        }
                                    </td>
                                </tr>
                                <tr>
                                    <td class="fw-bold text-muted">Nivel de Log:</td>
                                    <td>
                                        @{
                                            var logLevelClass = Model.LogLevel switch
                                            {
                                                "Error" => "bg-danger",
                                                "Warning" => "bg-warning",
                                                "Information" => "bg-info",
                                                "Critical" => "bg-dark",
                                                _ => "bg-secondary"
                                            };
                                        }
                                        <span class="badge @logLevelClass">@Model.LogLevel</span>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="fw-bold text-muted">ID de Entidad:</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(Model.EntityId))
                                        {
                                            <code>@Model.EntityId</code>
                                        }
                                        else
                                        {
                                            <em class="text-muted">N/A</em>
                                        }
                                    </td>
                                </tr>
                                <tr>
                                    <td class="fw-bold text-muted">Nombre de Entidad:</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(Model.EntityName))
                                        {
                                            @Model.EntityName
                                        }
                                        else
                                        {
                                            <em class="text-muted">N/A</em>
                                        }
                                    </td>
                                </tr>
                                <tr>
                                    <td class="fw-bold text-muted">Dirección IP:</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(Model.IpAddress))
                                        {
                                            <code>@Model.IpAddress</code>
                                        }
                                        else
                                        {
                                            <em class="text-muted">N/A</em>
                                        }
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Información Técnica -->
        <div class="col-lg-4">
            <div class="card">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-cogs"></i> Información Técnica
                    </h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="fw-bold text-muted">User Agent:</label>
                        @if (!string.IsNullOrEmpty(Model.UserAgent))
                        {
                            <div class="mt-1">
                                <small class="text-break">@Model.UserAgent</small>
                            </div>
                        }
                        else
                        {
                            <div class="mt-1">
                                <em class="text-muted">No disponible</em>
                            </div>
                        }
                    </div>

                    @if (Model.Duration.HasValue)
                    {
                        <div class="mb-3">
                            <label class="fw-bold text-muted">Duración:</label>
                            <div class="mt-1">
                                <span class="badge bg-info">@Model.Duration.Value.TotalMilliseconds ms</span>
                            </div>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.HttpMethod))
                    {
                        <div class="mb-3">
                            <label class="fw-bold text-muted">Método HTTP:</label>
                            <div class="mt-1">
                                <span class="badge bg-primary">@Model.HttpMethod</span>
                            </div>
                        </div>
                    }

                    @if (Model.ResponseStatusCode.HasValue)
                    {
                        <div class="mb-3">
                            <label class="fw-bold text-muted">Código de Respuesta:</label>
                            <div class="mt-1">
                                @{
                                    var statusClass = Model.ResponseStatusCode.Value >= 200 && Model.ResponseStatusCode.Value < 300 ? "bg-success" :
                                                     Model.ResponseStatusCode.Value >= 400 ? "bg-danger" : "bg-warning";
                                }
                                <span class="badge @statusClass">@Model.ResponseStatusCode</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Información Adicional -->
    @if (!string.IsNullOrEmpty(Model.AdditionalInfo))
    {
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0">
                            <i class="fas fa-info"></i> Información Adicional
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="bg-light p-3 rounded">
                            <pre class="mb-0">@Model.AdditionalInfo</pre>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Mensaje de Error -->
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="row mb-4">
            <div class="col-12">
                <div class="card border-danger">
                    <div class="card-header bg-danger text-white">
                        <h5 class="mb-0">
                            <i class="fas fa-exclamation-triangle"></i> Mensaje de Error
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="alert alert-danger mb-0">
                            <pre class="mb-0">@Model.ErrorMessage</pre>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Valores Anteriores y Nuevos -->
    @if (!string.IsNullOrEmpty(Model.OldValues) || !string.IsNullOrEmpty(Model.NewValues))
    {
        <div class="row mb-4">
            @if (!string.IsNullOrEmpty(Model.OldValues))
            {
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header bg-warning text-dark">
                            <h5 class="mb-0">
                                <i class="fas fa-history"></i> Valores Anteriores
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="bg-light p-3 rounded">
                                <pre class="mb-0">@Model.OldValues</pre>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @if (!string.IsNullOrEmpty(Model.NewValues))
            {
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header bg-success text-white">
                            <h5 class="mb-0">
                                <i class="fas fa-edit"></i> Valores Nuevos
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="bg-light p-3 rounded">
                                <pre class="mb-0">@Model.NewValues</pre>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <!-- URL de Solicitud -->
    @if (!string.IsNullOrEmpty(Model.RequestUrl))
    {
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">
                            <i class="fas fa-link"></i> URL de Solicitud
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="bg-light p-3 rounded">
                            <code>@Model.RequestUrl</code>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Metadatos -->
    @if (!string.IsNullOrEmpty(Model.Metadata))
    {
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header bg-dark text-white">
                        <h5 class="mb-0">
                            <i class="fas fa-database"></i> Metadatos
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="bg-light p-3 rounded">
                            <pre class="mb-0">@Model.Metadata</pre>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Referrer -->
    @if (!string.IsNullOrEmpty(Model.Referrer))
    {
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header bg-secondary text-white">
                        <h5 class="mb-0">
                            <i class="fas fa-external-link-alt"></i> Página de Referencia
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="bg-light p-3 rounded">
                            <code>@Model.Referrer</code>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Acciones -->
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-light">
                    <h5 class="mb-0">
                        <i class="fas fa-tools"></i> Acciones
                    </h5>
                </div>
                <div class="card-body">
                    <div class="btn-group" role="group">
                        <a href="@Url.Action("Index", "Audit", new { area = "Admin" })" class="btn btn-outline-secondary">
                            <i class="fas fa-list"></i> Volver al Listado
                        </a>
                        
                        @if (!string.IsNullOrEmpty(Model.UserId))
                        {
                            <a href="@Url.Action("UserActivity", "Audit", new { area = "Admin", userId = Model.UserId })" class="btn btn-outline-info">
                                <i class="fas fa-user-clock"></i> Ver Actividad del Usuario
                            </a>
                        }
                        
                        <a href="@Url.Action("Index", "Audit", new { area = "Admin", action = Model.Action })" class="btn btn-outline-primary">
                            <i class="fas fa-filter"></i> Ver Logs Similares
                        </a>
                        
                        <button type="button" class="btn btn-outline-success" onclick="window.print()">
                            <i class="fas fa-print"></i> Imprimir
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
 
<!-- Estilos para impresión -->
<style>
    @@media print {
        .btn-group,
        .breadcrumb,
        nav {
            display: none !important;
        }
        
        .card {
            border: 1px solid #000 !important;
            break-inside: avoid;
        }
        
        .card-header {
            background-color: #f8f9fa !important;
            color: #000 !important;
        }
        
        pre {
            white-space: pre-wrap;
            word-break: break-word;
        }
    }
</style>

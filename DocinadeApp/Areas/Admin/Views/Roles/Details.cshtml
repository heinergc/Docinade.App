@model RubricasApp.Web.ViewModels.Admin.RoleViewModel

@{
    ViewData["Title"] = $"Detalles del Rol - {Model.Name}";
    var hasUsers = Model.UserCount > 0;
    var hasPermissions = Model.PermissionCount > 0;
}

<div class="container-fluid">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index", "Home", new { area = "" })">
                    <i class="fas fa-home"></i> Inicio
                </a>
            </li>
            <li class="breadcrumb-item">
                <a href="@Url.Action("Index")">
                    <i class="fas fa-users-cog"></i> Roles
                </a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="row mb-4">
        <div class="col-md-8">
            <h2 class="mb-0">
                <i class="fas fa-user-tag text-primary"></i>
                Detalles del Rol
            </h2>
            <p class="text-muted mt-2">Información completa del rol y sus asignaciones</p>
        </div>
        <div class="col-md-4 text-end">
            @if (!Model.IsSystemRole)
            {
                <a href="@Url.Action("Edit", new { id = Model.Id })" class="btn btn-warning me-2">
                    <i class="fas fa-edit"></i> Editar
                </a>
                <button type="button" class="btn btn-danger" onclick="deleteRole('@Model.Id', '@Model.Name', @Model.UserCount)">
                    <i class="fas fa-trash"></i> Eliminar
                </button>
            }
            else
            {
                <span class="badge bg-secondary fs-6">
                    <i class="fas fa-lock"></i> Rol del Sistema
                </span>
            }
        </div>
    </div>

    <!-- Información Principal -->
    <div class="row mb-4">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="card-title mb-0">
                        <i class="fas fa-info-circle"></i>
                        Información del Rol
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <dl class="row">
                                <dt class="col-sm-4">Nombre:</dt>
                                <dd class="col-sm-8">
                                    <strong>@Model.Name</strong>
                                    @if (Model.IsSystemRole)
                                    {
                                        <span class="badge bg-secondary ms-2">Sistema</span>
                                    }
                                </dd>

                                <dt class="col-sm-4">ID:</dt>
                                <dd class="col-sm-8">
                                    <code>@Model.Id</code>
                                </dd>

                                <dt class="col-sm-4">Tipo:</dt>
                                <dd class="col-sm-8">
                                    @if (Model.IsSystemRole)
                                    {
                                        <span class="badge bg-warning">
                                            <i class="fas fa-cog"></i> Rol del Sistema
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-info">
                                            <i class="fas fa-user"></i> Rol Personalizado
                                        </span>
                                    }
                                </dd>
                            </dl>
                        </div>
                        <div class="col-md-6">
                            <dl class="row">
                                <dt class="col-sm-5">Usuarios Asignados:</dt>
                                <dd class="col-sm-7">
                                    <span class="badge bg-primary fs-6">@Model.UserCount</span>
                                    @if (hasUsers)
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-primary ms-2" 
                                                onclick="showRoleUsers('@Model.Id', '@Model.Name')">
                                            <i class="fas fa-eye"></i> Ver Usuarios
                                        </button>
                                    }
                                </dd>

                                <dt class="col-sm-5">Permisos:</dt>
                                <dd class="col-sm-7">
                                    <span class="badge bg-success fs-6">@Model.PermissionCount</span>
                                    @if (hasPermissions)
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-success ms-2" 
                                                onclick="showRolePermissions('@Model.Id', '@Model.Name')">
                                            <i class="fas fa-shield-alt"></i> Ver Permisos
                                        </button>
                                    }
                                </dd>

                                <dt class="col-sm-5">Estado:</dt>
                                <dd class="col-sm-7">
                                    <span class="badge bg-success">
                                        <i class="fas fa-check-circle"></i> Activo
                                    </span>
                                </dd>
                            </dl>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <hr>
                        <div class="row">
                            <div class="col-12">
                                <h6>Descripción:</h6>
                                <p class="text-muted">@Model.Description</p>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Estadísticas Rápidas -->
        <div class="col-lg-4">
            <div class="card shadow-sm">
                <div class="card-header bg-info text-white">
                    <h5 class="card-title mb-0">
                        <i class="fas fa-chart-bar"></i>
                        Estadísticas
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-6 mb-3">
                            <div class="border rounded p-3 bg-light">
                                <i class="fas fa-users fa-2x text-primary mb-2"></i>
                                <h4 class="mb-0">@Model.UserCount</h4>
                                <small class="text-muted">Usuarios</small>
                            </div>
                        </div>
                        <div class="col-6 mb-3">
                            <div class="border rounded p-3 bg-light">
                                <i class="fas fa-shield-alt fa-2x text-success mb-2"></i>
                                <h4 class="mb-0">@Model.PermissionCount</h4>
                                <small class="text-muted">Permisos</small>
                            </div>
                        </div>
                    </div>
                    
                    @if (Model.IsSystemRole)
                    {
                        <div class="alert alert-warning mb-0">
                            <i class="fas fa-exclamation-triangle"></i>
                            <strong>Nota:</strong> Este es un rol del sistema y no puede ser modificado o eliminado.
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info mb-0">
                            <i class="fas fa-info-circle"></i>
                            <strong>Nota:</strong> Puede editar este rol para modificar sus permisos y configuración.
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Acciones Adicionales -->
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-secondary text-white">
                    <h5 class="card-title mb-0">
                        <i class="fas fa-cogs"></i>
                        Acciones
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <h6>Gestión del Rol</h6>
                            <div class="d-grid gap-2">
                                @if (!Model.IsSystemRole)
                                {
                                    <a href="@Url.Action("Edit", new { id = Model.Id })" class="btn btn-warning">
                                        <i class="fas fa-edit"></i> Editar Rol
                                    </a>
                                }
                                <button type="button" class="btn btn-info" onclick="showRolePermissions('@Model.Id', '@Model.Name')">
                                    <i class="fas fa-shield-alt"></i> Ver Permisos Detallados
                                </button>
                                @if (hasUsers)
                                {
                                    <button type="button" class="btn btn-primary" onclick="showRoleUsers('@Model.Id', '@Model.Name')">
                                        <i class="fas fa-users"></i> Gestionar Usuarios
                                    </button>
                                }
                            </div>
                        </div>
                        <div class="col-md-6">
                            <h6>Navegación</h6>
                            <div class="d-grid gap-2">
                                <a href="@Url.Action("Index")" class="btn btn-secondary">
                                    <i class="fas fa-arrow-left"></i> Volver a la Lista
                                </a>
                                <a href="@Url.Action("Create")" class="btn btn-success">
                                    <i class="fas fa-plus"></i> Crear Nuevo Rol
                                </a>
                                <a href="@Url.Action("Index", "Permissions")" class="btn btn-outline-primary">
                                    <i class="fas fa-shield-alt"></i> Gestionar Permisos
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal para mostrar usuarios del rol -->
<div class="modal fade" id="roleUsersModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-users"></i>
                    Usuarios del Rol: <span id="roleNameUsers"></span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="roleUsersContent">
                    <div class="text-center">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Cargando...</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal para mostrar permisos del rol -->
<div class="modal fade" id="rolePermissionsModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-shield-alt"></i>
                    Permisos del Rol: <span id="roleNamePermissions"></span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="rolePermissionsContent">
                    <div class="text-center">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Cargando...</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Inicializar tooltips
            $('[title]').tooltip();
        });

        // Función para eliminar rol
        function deleteRole(roleId, roleName, userCount) {
            if (userCount > 0) {
                Swal.fire({
                    icon: 'warning',
                    title: 'No se puede eliminar',
                    text: `El rol "${roleName}" tiene ${userCount} usuario(s) asignado(s). Primero debe remover todos los usuarios del rol.`,
                    confirmButtonText: 'Entendido'
                });
                return;
            }

            Swal.fire({
                title: '¿Eliminar rol?',
                text: `¿Está seguro de que desea eliminar el rol "${roleName}"? Esta acción no se puede deshacer.`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Sí, eliminar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('@Url.Action("Delete")/' + roleId, {
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    })
                    .done(function(response) {
                        if (response.success) {
                            Swal.fire({
                                icon: 'success',
                                title: '¡Eliminado!',
                                text: response.message,
                                timer: 2000
                            }).then(() => {
                                window.location.href = '@Url.Action("Index")';
                            });
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: 'Error',
                                text: response.message
                            });
                        }
                    })
                    .fail(function() {
                        Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            text: 'Error al procesar la solicitud'
                        });
                    });
                }
            });
        }

        // Función para mostrar usuarios del rol
        function showRoleUsers(roleId, roleName) {
            $('#roleNameUsers').text(roleName);
            $('#roleUsersModal').modal('show');
            $('#roleUsersContent').html('<div class="text-center"><div class="spinner-border text-primary" role="status"><span class="visually-hidden">Cargando...</span></div></div>');
            
            $.get('@Url.Action("GetRoleUsers")/' + roleId)
                .done(function(result) {
                    if (result.success && result.users && result.users.length > 0) {
                        var html = '<div class="table-responsive"><table class="table table-striped table-sm">';
                        html += '<thead class="table-dark"><tr><th>Email</th><th>Nombre Completo</th><th>Estado</th><th>Último Acceso</th></tr></thead><tbody>';
                        
                        result.users.forEach(function(user) {
                            html += '<tr>';
                            html += '<td>' + user.email + '</td>';
                            html += '<td>' + (user.nombreCompleto || '-') + '</td>';
                            html += '<td>' + (user.activo ? '<span class="badge bg-success">Activo</span>' : '<span class="badge bg-danger">Inactivo</span>') + '</td>';
                            html += '<td>' + (user.ultimoAcceso ? new Date(user.ultimoAcceso).toLocaleDateString() : '-') + '</td>';
                            html += '</tr>';
                        });
                        
                        html += '</tbody></table></div>';
                        $('#roleUsersContent').html(html);
                    } else {
                        $('#roleUsersContent').html('<div class="text-center text-muted py-4"><i class="fas fa-users fa-3x mb-3"></i><h5>No hay usuarios asignados</h5><p>Este rol no tiene usuarios asignados actualmente</p></div>');
                    }
                })
                .fail(function() {
                    $('#roleUsersContent').html('<div class="alert alert-danger"><i class="fas fa-exclamation-triangle"></i> Error al cargar los usuarios del rol</div>');
                });
        }

        // Función para mostrar permisos del rol
        function showRolePermissions(roleId, roleName) {
            $('#roleNamePermissions').text(roleName);
            $('#rolePermissionsModal').modal('show');
            $('#rolePermissionsContent').html('<div class="text-center"><div class="spinner-border text-primary" role="status"><span class="visually-hidden">Cargando...</span></div></div>');
            
            // Simular carga de permisos - en implementación real vendría del servidor
            setTimeout(function() {
                var html = '<div class="row">';
                html += '<div class="col-12"><p class="text-muted">Los permisos del rol se muestran agrupados por categoría.</p></div>';
                html += '<div class="col-md-6"><h6 class="text-primary">Usuarios</h6><ul class="list-unstyled"><li><i class="fas fa-check text-success"></i> Ver usuarios</li><li><i class="fas fa-check text-success"></i> Crear usuarios</li></ul></div>';
                html += '<div class="col-md-6"><h6 class="text-primary">Configuración</h6><ul class="list-unstyled"><li><i class="fas fa-check text-success"></i> Gestionar permisos</li><li><i class="fas fa-check text-success"></i> Gestionar roles</li></ul></div>';
                html += '</div>';
                $('#rolePermissionsContent').html(html);
            }, 1000);
        }
    </script>
    
    <!-- Token CSRF -->
    @Html.AntiForgeryToken()
}
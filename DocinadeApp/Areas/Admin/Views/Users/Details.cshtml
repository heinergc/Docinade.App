@model RubricasApp.Web.ViewModels.Admin.UserDetailsViewModel

@{
    ViewData["Title"] = "Detalles del Usuario";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a asp-area="Admin" asp-controller="Admin" asp-action="Index">
                    <i class="fas fa-home"></i> Administración
                </a>
            </li>
            <li class="breadcrumb-item">
                <a asp-area="Admin" asp-controller="Users" asp-action="Index">
                    <i class="fas fa-users"></i> Usuarios
                </a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">
                <i class="fas fa-eye"></i> Detalles del Usuario
            </li>
        </ol>
    </nav>

    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="mb-1">
                        <i class="fas fa-user-circle text-primary"></i>
                        Detalles del Usuario
                    </h2>
                    <p class="text-muted mb-0">
                        Información completa del usuario @Model.Email
                    </p>
                </div>
                <div>
                    <a asp-area="Admin" asp-controller="Users" asp-action="Edit" asp-route-id="@Model.Id" 
                       class="btn btn-primary me-2">
                        <i class="fas fa-edit"></i> Editar Usuario
                    </a>
                    <a asp-area="Admin" asp-controller="Users" asp-action="Index" 
                       class="btn btn-outline-secondary">
                        <i class="fas fa-arrow-left"></i> Volver a Lista
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Información Personal -->
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-primary text-white">
                    <h5 class="card-title mb-0">
                        <i class="fas fa-id-card"></i>
                        Información Personal
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-sm-4">
                            <strong><i class="fas fa-envelope text-muted"></i> Email:</strong>
                        </div>
                        <div class="col-sm-8">
                            <span class="badge @(Model.EmailConfirmed ? "bg-success" : "bg-warning")">
                                @Model.Email
                                @if (Model.EmailConfirmed)
                                {
                                    <i class="fas fa-check-circle ms-1"></i>
                                }
                                else
                                {
                                    <i class="fas fa-exclamation-circle ms-1"></i>
                                }
                            </span>
                        </div>
                    </div>
                    
                    <div class="row mb-3">
                        <div class="col-sm-4">
                            <strong><i class="fas fa-user text-muted"></i> Nombre:</strong>
                        </div>
                        <div class="col-sm-8">
                            @Model.Nombre
                        </div>
                    </div>
                    
                    <div class="row mb-3">
                        <div class="col-sm-4">
                            <strong><i class="fas fa-user text-muted"></i> Apellidos:</strong>
                        </div>
                        <div class="col-sm-8">
                            @Model.Apellido
                        </div>
                    </div>
                    
                    @if (!string.IsNullOrEmpty(Model.PhoneNumber))
                    {
                        <div class="row mb-3">
                            <div class="col-sm-4">
                                <strong><i class="fas fa-phone text-muted"></i> Teléfono:</strong>
                            </div>
                            <div class="col-sm-8">
                                @Model.PhoneNumber
                            </div>
                        </div>
                    }
                    
                    <div class="row mb-3">
                        <div class="col-sm-4">
                            <strong><i class="fas fa-power-off text-muted"></i> Estado:</strong>
                        </div>
                        <div class="col-sm-8">
                            <span class="badge @(Model.IsActive ? "bg-success" : "bg-danger")">
                                @(Model.IsActive ? "Activo" : "Inactivo")
                                <i class="fas @(Model.IsActive ? "fa-check" : "fa-times") ms-1"></i>
                            </span>
                        </div>
                    </div>
                    
                    <div class="row mb-3">
                        <div class="col-sm-4">
                            <strong><i class="fas fa-shield-alt text-muted"></i> 2FA:</strong>
                        </div>
                        <div class="col-sm-8">
                            <span class="badge @(Model.TwoFactorEnabled ? "bg-success" : "bg-secondary")">
                                @(Model.TwoFactorEnabled ? "Habilitado" : "Deshabilitado")
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Estado de la Cuenta -->
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-info text-white">
                    <h5 class="card-title mb-0">
                        <i class="fas fa-cog"></i>
                        Estado de la Cuenta
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-sm-4">
                            <strong><i class="fas fa-calendar-plus text-muted"></i> Creado:</strong>
                        </div>
                        <div class="col-sm-8">
                            @Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")
                        </div>
                    </div>
                    
                    @if (Model.LastLoginDate.HasValue)
                    {
                        <div class="row mb-3">
                            <div class="col-sm-4">
                                <strong><i class="fas fa-sign-in-alt text-muted"></i> Último acceso:</strong>
                            </div>
                            <div class="col-sm-8">
                                @Model.LastLoginDate.Value.ToString("dd/MM/yyyy HH:mm")
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="row mb-3">
                            <div class="col-sm-4">
                                <strong><i class="fas fa-sign-in-alt text-muted"></i> Último acceso:</strong>
                            </div>
                            <div class="col-sm-8">
                                <span class="text-muted">Nunca ha iniciado sesión</span>
                            </div>
                        </div>
                    }
                    
                    <div class="row mb-3">
                        <div class="col-sm-4">
                            <strong><i class="fas fa-exclamation-triangle text-muted"></i> Intentos fallidos:</strong>
                        </div>
                        <div class="col-sm-8">
                            <span class="badge @(Model.AccessFailedCount > 0 ? "bg-warning" : "bg-success")">
                                @Model.AccessFailedCount
                            </span>
                        </div>
                    </div>
                    
                    @if (Model.LockoutEnd.HasValue && Model.LockoutEnd > DateTimeOffset.UtcNow)
                    {
                        <div class="row mb-3">
                            <div class="col-sm-4">
                                <strong><i class="fas fa-lock text-muted"></i> Bloqueado hasta:</strong>
                            </div>
                            <div class="col-sm-8">
                                <span class="badge bg-danger">
                                    @Model.LockoutEnd.Value.ToString("dd/MM/yyyy HH:mm")
                                </span>
                            </div>
                        </div>
                    }
                    
                    <div class="row mb-3">
                        <div class="col-sm-4">
                            <strong><i class="fas fa-envelope-check text-muted"></i> Email confirmado:</strong>
                        </div>
                        <div class="col-sm-8">
                            <span class="badge @(Model.EmailConfirmed ? "bg-success" : "bg-warning")">
                                @(Model.EmailConfirmed ? "Sí" : "No")
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Roles y Permisos -->
    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white">
                    <h5 class="card-title mb-0">
                        <i class="fas fa-user-tag"></i>
                        Roles Asignados (@Model.Roles.Count)
                    </h5>
                </div>
                <div class="card-body">
                    @if (Model.Roles.Any())
                    {
                        <div class="row">
                            @foreach (var role in Model.Roles)
                            {
                                <div class="col-md-6 mb-2">
                                    <span class="badge bg-success p-2 w-100">
                                        <i class="fas fa-shield-alt"></i> @role
                                    </span>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-4">
                            <i class="fas fa-user-slash text-muted" style="font-size: 3rem;"></i>
                            <p class="text-muted mt-3 mb-0">No tiene roles asignados</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card shadow-sm">
                <div class="card-header bg-warning text-dark">
                    <h5 class="card-title mb-0">
                        <i class="fas fa-key"></i>
                        Resumen de Permisos
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-4">
                            <div class="border-end">
                                <h4 class="text-primary mb-1">@Model.AllPermissions.Count</h4>
                                <small class="text-muted">Total</small>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="border-end">
                                <h4 class="text-success mb-1">@Model.RolePermissions.Count</h4>
                                <small class="text-muted">Por Roles</small>
                            </div>
                        </div>
                        <div class="col-4">
                            <h4 class="text-info mb-1">@Model.DirectPermissions.Count</h4>
                            <small class="text-muted">Directos</small>
                        </div>
                    </div>
                    
                    @if (Model.DirectPermissions.Any())
                    {
                        <hr>
                        <h6 class="text-muted">Permisos Directos:</h6>
                        <div class="d-flex flex-wrap gap-1">
                            @foreach (var permission in Model.DirectPermissions.Take(5))
                            {
                                <span class="badge bg-info small">@permission</span>
                            }
                            @if (Model.DirectPermissions.Count > 5)
                            {
                                <span class="badge bg-secondary small">+@(Model.DirectPermissions.Count - 5) más</span>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Permisos Detallados por Categoría -->
    @if (Model.PermissionsByCategory.Any())
    {
        <div class="row">
            <div class="col-12 mb-4">
                <div class="card shadow-sm">
                    <div class="card-header bg-dark text-white">
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="card-title mb-0">
                                <i class="fas fa-list-ul"></i>
                                Permisos del Usuario Agrupados por Categoría
                            </h5>
                            <button class="btn btn-sm btn-outline-light" type="button" data-bs-toggle="collapse" data-bs-target="#permissionsDetail" aria-expanded="false">
                                <i class="fas fa-chevron-down"></i> Ver/Ocultar
                            </button>
                        </div>
                    </div>
                    <div class="collapse show" id="permissionsDetail">
                        <div class="card-body">
                            @if (Model.PermissionsByCategory.Any())
                            {
                                <div class="row">
                                    @foreach (var category in Model.PermissionsByCategory.OrderBy(c => c.Key))
                                    {
                                        <div class="col-md-6 col-lg-4 mb-4">
                                            <div class="card border-start border-4 border-primary h-100">
                                                <div class="card-header bg-light py-2">
                                                    <h6 class="mb-0 text-primary fw-bold">
                                                        <i class="fas fa-folder"></i>
                                                        @category.Key
                                                        <span class="badge bg-primary ms-2">@category.Value.Count</span>
                                                    </h6>
                                                </div>
                                                <div class="card-body py-2">
                                                    <div class="list-group list-group-flush">
                                                        @foreach (var permission in category.Value.OrderBy(p => p.DisplayName))
                                                        {
                                                            <div class="list-group-item px-0 py-1 border-0">
                                                                <div class="d-flex align-items-start">
                                                                    <i class="fas fa-key text-success me-2 mt-1" style="font-size: 0.8rem;"></i>
                                                                    <div class="flex-grow-1">
                                                                        <div class="fw-medium text-dark small">@permission.DisplayName</div>
                                                                        @if (!string.IsNullOrEmpty(permission.Description))
                                                                        {
                                                                            <div class="text-muted" style="font-size: 0.75rem;">@permission.Description</div>
                                                                        }
                                                                        <div class="text-info" style="font-size: 0.7rem;">
                                                                            <code>@permission.Name</code>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        }
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="text-center py-5">
                                    <i class="fas fa-shield-alt text-muted" style="font-size: 4rem;"></i>
                                    <h5 class="text-muted mt-3">Sin Permisos Específicos</h5>
                                    <p class="text-muted">Este usuario no tiene permisos específicos asignados directamente.</p>
                                </div>
                            }

                            <!-- Información adicional -->
                            <div class="alert alert-info mt-3">
                                <div class="row">
                                    <div class="col-md-8">
                                        <h6 class="alert-heading mb-2">
                                            <i class="fas fa-info-circle"></i>
                                            Información sobre Permisos
                                        </h6>
                                        <ul class="mb-0 small">
                                            <li><strong>Permisos por Roles:</strong> Heredados automáticamente de los roles asignados</li>
                                            <li><strong>Permisos Directos:</strong> Asignados específicamente a este usuario</li>
                                            <li><strong>Total de Permisos:</strong> Combinación de ambos tipos sin duplicados</li>
                                        </ul>
                                    </div>
                                    <div class="col-md-4 text-end">
                                        <div class="d-flex flex-column gap-1">
                                            <span class="badge bg-info">
                                                <i class="fas fa-users"></i> @Model.RolePermissions.Count por roles
                                            </span>
                                            <span class="badge bg-warning">
                                                <i class="fas fa-user"></i> @Model.DirectPermissions.Count directos
                                            </span>
                                            <span class="badge bg-primary">
                                                <i class="fas fa-shield-alt"></i> @Model.AllPermissions.Count total
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Acciones -->
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header bg-secondary text-white">
                    <h5 class="card-title mb-0">
                        <i class="fas fa-tools"></i>
                        Acciones Disponibles
                    </h5>
                </div>
                <div class="card-body">
                    <div class="d-flex flex-wrap gap-2">
                        <!-- Acción principal: Editar Usuario -->
                        <a asp-area="Admin" asp-controller="Users" asp-action="Edit" asp-route-id="@Model.Id"
                           class="btn btn-primary">
                            <i class="fas fa-edit"></i> Editar Usuario
                        </a>

                        <!-- Volver a la lista -->
                        <a asp-area="Admin" asp-controller="Users" asp-action="Index"
                           class="btn btn-outline-secondary">
                            <i class="fas fa-list"></i> Volver a Lista de Usuarios
                        </a>

                        @* Solo mostrar acciones adicionales si el usuario no es el actual *@
                        @{
                            var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                            var isCurrentUser = currentUserId == Model.Id;
                        }

                        @if (!isCurrentUser)
                        {
                            @* Acción de eliminar/desactivar solo disponible via AJAX *@
                            <button type="button" class="btn btn-outline-danger"
                                    onclick="showDeleteConfirmation('@Model.Id', '@Model.Email')">
                                <i class="fas fa-user-times"></i> Desactivar Usuario
                            </button>
                        }
                        else
                        {
                            <span class="badge bg-info fs-6 p-2">
                                <i class="fas fa-info-circle"></i> Este es tu perfil actual
                            </span>
                        }
                    </div>

                    @if (!isCurrentUser)
                    {
                        <hr class="my-3">
                        <div class="alert alert-light border">
                            <h6 class="mb-2">
                                <i class="fas fa-info-circle text-info"></i> Información sobre Acciones
                            </h6>
                            <ul class="mb-0 small">
                                <li><strong>Editar Usuario:</strong> Modifica información personal, roles y permisos</li>
                                <li><strong>Desactivar Usuario:</strong> Desactiva la cuenta sin eliminar los datos</li>
                                <li><strong>Gestión de Contraseña:</strong> Disponible desde la página de edición</li>
                                <li><strong>Gestión Avanzada:</strong> Acciones adicionales disponibles en la lista de usuarios</li>
                            </ul>
                        </div>
                    }

                    @* Tip informativo *@
                    <div class="mt-3">
                        <small class="text-muted">
                            <i class="fas fa-lightbulb"></i>
                            <strong>Tip:</strong> Para acciones avanzadas como restablecer contraseña, confirmar email, o gestión de bloqueos,
                            utiliza la <a asp-area="Admin" asp-controller="Users" asp-action="Index" class="text-decoration-none">lista de usuarios</a>
                            donde están disponibles todas las herramientas de administración.
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function showDeleteConfirmation(userId, userEmail) {
        Swal.fire({
            title: '¿Desactivar Usuario?',
            text: `¿Está seguro de que desea desactivar al usuario "${userEmail}"?`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#dc3545',
            cancelButtonColor: '#6c757d',
            confirmButtonText: 'Sí, desactivar',
            cancelButtonText: 'Cancelar'
        }).then((result) => {
            if (result.isConfirmed) {
                // Realizar llamada AJAX al método Delete del controlador
                $.ajax({
                    url: '@Url.Action("Delete", "Users", new { area = "Admin" })',
                    type: 'POST',
                    data: {
                        id: userId,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function(response) {
                        if (response.success) {
                            Swal.fire(
                                '¡Desactivado!',
                                response.message,
                                'success'
                            ).then(() => {
                                // Redirigir a la lista de usuarios
                                window.location.href = '@Url.Action("Index", "Users", new { area = "Admin" })';
                            });
                        } else {
                            Swal.fire(
                                'Error',
                                response.message || 'No se pudo desactivar el usuario',
                                'error'
                            );
                        }
                    },
                    error: function() {
                        Swal.fire(
                            'Error',
                            'Error de conexión al intentar desactivar el usuario',
                            'error'
                        );
                    }
                });
            }
        });
    }
</script>



@section Styles {
    <style>
        .card {
            border: none;
            border-radius: 10px;
        }
        
        .card-header {
            border-radius: 10px 10px 0 0 !important;
        }
        
        .badge {
            font-size: 0.85em;
        }
        
        .border-end {
            border-right: 1px solid #dee2e6 !important;
        }
        
        .breadcrumb {
            background-color: #f8f9fa;
            border-radius: 0.375rem;
            padding: 0.75rem 1rem;
        }
        
        .breadcrumb-item a {
            text-decoration: none;
            color: #6c757d;
        }
        
        .breadcrumb-item a:hover {
            color: #0d6efd;
        }
        
        .gap-1 > * {
            margin-right: 0.25rem !important;
            margin-bottom: 0.25rem !important;
        }
        
        .gap-2 > * {
            margin-right: 0.5rem !important;
            margin-bottom: 0.5rem !important;
        }

        .border-start {
            border-left-width: 4px !important;
        }

        .list-group-item {
            background-color: transparent;
        }

        .card .card-header {
            background-color: rgba(0,0,0,.03);
            border-bottom: 1px solid rgba(0,0,0,.125);
        }

        .collapse.show {
            display: block;
        }

        .btn-outline-light:hover {
            color: #000;
            background-color: #f8f9fa;
            border-color: #f8f9fa;
        }
    </style>
}
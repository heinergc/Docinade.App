@{
    ViewData["Title"] = "Ejemplo de Uso del Buscador de Estudiantes";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-user-search"></i>
                        Formulario con Buscador de Estudiantes
                    </h4>
                </div>
                <div class="card-body">
                    <form method="post">
                        <!-- Ejemplo 1: Uso básico -->
                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="estudiante1" class="form-label">Estudiante Principal:</label>
                                    <div class="input-group">
                                        <button class="btn btn-outline-primary" 
                                                type="button" 
                                                data-bs-toggle="modal" 
                                                data-bs-target="#modalBuscador1"
                                                title="Buscar Estudiante">
                                            <i class="fas fa-search"></i>
                                        </button>
                                        <select name="estudiante1" id="estudiante1" class="form-select" required>
                                            <option value="">-- Seleccione un estudiante --</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label for="estudiante2" class="form-label">Estudiante Secundario:</label>
                                    <div class="input-group">
                                        <button class="btn btn-outline-secondary" 
                                                type="button" 
                                                data-bs-toggle="modal" 
                                                data-bs-target="#modalBuscador2"
                                                title="Buscar Estudiante">
                                            <i class="fas fa-search"></i>
                                        </button>
                                        <select name="estudiante2" id="estudiante2" class="form-select">
                                            <option value="">-- Opcional --</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Otros campos del formulario -->
                        <div class="row">
                            <div class="col-md-12">
                                <div class="mb-3">
                                    <label for="observaciones" class="form-label">Observaciones:</label>
                                    <textarea name="observaciones" id="observaciones" class="form-control" rows="3"></textarea>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <button type="submit" class="btn btn-success">
                                <i class="fas fa-save"></i> Guardar
                            </button>
                            <button type="button" class="btn btn-secondary ms-2">
                                <i class="fas fa-times"></i> Cancelar
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ViewComponents de búsqueda -->
@await Component.InvokeAsync("BuscadorEstudiante", new { 
    selectId = "estudiante1", 
    modalId = "modalBuscador1",
    controllerName = "Evaluaciones",
    actionName = "BuscarEstudiantes",
    incluirScripts = true
})

@await Component.InvokeAsync("BuscadorEstudiante", new { 
    selectId = "estudiante2", 
    modalId = "modalBuscador2",
    controllerName = "Evaluaciones",
    actionName = "BuscarEstudiantes",
    incluirScripts = false  // Solo incluir scripts una vez por página
})

@section Scripts {
    <script>
        // Escuchar eventos de selección de estudiantes
        document.addEventListener('estudiante-seleccionado', function(event) {
            const { id, texto, nombre } = event.detail;
            console.log('Estudiante seleccionado:', { id, texto, nombre });
            
            // Aquí puedes agregar lógica adicional cuando se selecciona un estudiante
            // Por ejemplo, cargar datos relacionados, validar, etc.
        });

        // Ejemplo de inicialización manual si es necesario
        document.addEventListener('DOMContentLoaded', function() {
            // El ViewComponent ya inicializa automáticamente el buscador
            console.log('? Página cargada con buscadores de estudiantes');
        });
    </script>
}

@section Styles {
    <style>
        /* Estilos adicionales específicos para esta página */
        .input-group .btn {
            border-top-right-radius: 0;
            border-bottom-right-radius: 0;
        }
        
        .input-group .form-select {
            border-top-left-radius: 0;
            border-bottom-left-radius: 0;
            border-left: 0;
        }
        
        .input-group:focus-within .btn {
            border-color: #86b7fe;
            box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
        }
    </style>
}